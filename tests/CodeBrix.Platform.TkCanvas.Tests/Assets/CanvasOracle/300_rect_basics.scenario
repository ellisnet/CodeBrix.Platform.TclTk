# Rectangle coords/bbox basics: normalization, widths, no-outline, negatives.
canvas -width 400 -height 300
do create rectangle 10 20 30 40
q coords 1
q bbox 1
do create rectangle 30.5 40.5 10.2 20.2
q coords 2
q bbox 2
do create rectangle 50 50 90 90 -width 3
q bbox 3
do create rectangle 50 50 90 90 -width 4
q bbox 4
do create rectangle 100 100 140 140 -outline {}
q bbox 5
do create rectangle -30 -40 -10 -20
q coords 6
q bbox 6
do itemconfigure 3 -width 10
q bbox 3
q type 1
q type 5
