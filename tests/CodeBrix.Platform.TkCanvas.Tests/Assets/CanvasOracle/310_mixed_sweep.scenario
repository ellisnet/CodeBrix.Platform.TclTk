# Mixed-item sweep: odd widths, negative space, cross-type searches.
canvas -width 600 -height 400 -scrollregion {-100 -100 500 300}
do create line -50 -50 50 50 -width 7
q bbox 1
do create rectangle -80 -80 -20 -20 -width 2.5 -fill gray
q bbox 2
do create polygon 0 100 80 100 40 160 -outline black -width 1
q bbox 3
do create line 100 -50 150 0 200 -50 -joinstyle miter -width 11
q bbox 4
do create rectangle 300 100 420 220 -width 6
q bbox 5
q find overlapping -60 -60 0 0
q find enclosed -90 -90 60 60
q find closest 0 0
q find closest -50 -55
q find closest 40 130
q find closest 150 -10
q find closest 350 150
q find closest 350 150 0 5
do move all 10 20
q bbox 1
q bbox 3
q coords 1
do scale 5 0 0 0.5 0.5
q bbox 5
q coords 5
do yview moveto 0
q canvasy 0
do xview moveto 0
q canvasx 0
q xview
q yview
