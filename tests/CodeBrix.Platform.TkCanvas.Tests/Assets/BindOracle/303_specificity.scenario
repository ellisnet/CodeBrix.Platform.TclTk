# Within one tag only the MOST SPECIFIC matching binding fires:
# detail beats modifiers beats generic.
window .a
bind .a <ButtonPress> L-generic
bind .a <ButtonPress-1> L-detail
bind .a <Control-ButtonPress> L-control
bind .a <Control-ButtonPress-1> L-control-detail
event .a buttonpress 1 1 1
event .a buttonpress 2 2 2
event .a buttonpress 1 3 3 control
event .a buttonpress 3 4 4 control
