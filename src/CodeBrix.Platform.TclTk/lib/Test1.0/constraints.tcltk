    proc getFrameworkSetup472Value {} {
      # <help>
      # This procedure returns the minimum .NET Framework setup "Release"
      # registry value that indicates the .NET Framework 4.7.2 (or higher) is
      # installed.  It is a helper for [checkForNetFx45].  How it works: the
      # "special" value 461808 applies on either Windows Server (NT version 10.0,
      # release identifier 1803, via [isOsReleaseId]) or on a
      # client/missing-product-type Windows 10 with the "Windows 10, April 2018
      # Update" extra-update marker (via [haveTclPlatformOsExtraUpdateName]);
      # everywhere else the "normal" value 461814 applies.
      #
      # Arguments:
      #   None.
      #
      # Results:
      #   The integer Release threshold for .NET Framework 4.7.2: 461808 on
      #   Windows Server 1803 or the Windows 10 April 2018 Update, otherwise
      #   461814.
      # </help>

      #
      # NOTE: Check if we are running on Windows.
      #
      if {[isWindows]} then {
        #
        # NOTE: Check if we are running on a server (or client) operating
        #       system.
        #
        if {[isOsProductType server]} then {
          #
          # NOTE: Is this Windows Server (NT v10.0 release 1803)?
          #
          # BUGBUG: Is exact matching correct here?
          #
          if {[info exists ::tcl_platform(osVersion)] && \
              $::tcl_platform(osVersion) == 10.0 && \
              [isOsReleaseId 1803]} then {
            #
            # NOTE: Return the "special" value.
            #
            return 461808
          }
        } elseif {[isOsProductType missing] || [isOsProductType client]} then {
          #
          # NOTE: Is this Windows 10 (NT v10.0) with the
          #       "April 2018 Update" installed?
          #
          # BUGBUG: Is exact matching correct here?
          #
          if {[info exists ::tcl_platform(osVersion)] && \
              $::tcl_platform(osVersion) == 10.0 && \
              [haveTclPlatformOsExtraUpdateName \
                  "Windows 10, April 2018 Update"]} then {
            #
            # NOTE: Return the "special" value.
            #
            return 461808; # BUGBUG: April 2018 Update only?
          }
        }
      }

      #
      # NOTE: Return the "normal" value.
      #
      return 461814
    }

    proc getFrameworkSetup48Value {} {
      # <help>
      # This procedure returns the minimum .NET Framework setup "Release"
      # registry value that indicates the .NET Framework 4.8 (or higher) is
      # installed.  It is a helper for [checkForNetFx45] and has the most
      # involved logic of the family because 4.8 shipped distinct Release values
      # across many Windows 10 feature updates plus Windows 11 and Windows Server
      # 2022.  How it works: on a server (NT version 10.0, release identifier
      # 21H2 via [isOsReleaseId], i.e. Windows Server 2022) it returns 528449; on
      # a client/missing-product-type Windows 10 or 11 it returns, in order of
      # check, 528449 when [isOsWindows11] is true, otherwise 528372 for the May
      # 2020 / October 2020 / May 2021 updates, otherwise 528040 for the May 2019
      # / November 2019 updates -- each detected via
      # [haveTclPlatformOsExtraUpdateName].  When none of the special conditions
      # match, the "normal" value 528049 is returned.
      #
      # Arguments:
      #   None.
      #
      # Results:
      #   The integer Release threshold for .NET Framework 4.8, one of 528449,
      #   528372, 528040, or the fallback 528049, depending on the precise
      #   Windows edition and feature-update level.
      # </help>

      #
      # NOTE: Check if we are running on Windows.
      #
      if {[isWindows]} then {
        #
        # NOTE: Check if we are running on a server (or client) operating
        #       system.
        #
        if {[isOsProductType server]} then {
          #
          # NOTE: Is this Windows Server 2022 (NT v10.0)?
          #
          # BUGBUG: Is exact matching correct here?
          #
          if {[info exists ::tcl_platform(osVersion)] && \
              $::tcl_platform(osVersion) == 10.0 && \
              [isOsReleaseId 21H2]} then {
            #
            # NOTE: Return the "special" value.
            #
            return 528449
          }
        } elseif {[isOsProductType missing] || [isOsProductType client]} then {
          #
          # NOTE: Is this Windows 10 -OR- 11 (NT v10.0)?
          #
          # BUGBUG: Is exact matching correct here?
          #
          if {[info exists ::tcl_platform(osVersion)] && \
              $::tcl_platform(osVersion) == 10.0} then {
            #
            # NOTE: Is this Windows 11 (NT v10.0)?
            #
            if {[isOsWindows11]} then {
              #
              # NOTE: Return the "special" value.
              #
              return 528449
            } else {
              #
              # NOTE: Is the "May 2020 Update" -OR- "October 2020 Update"
              #       -OR- "May 2021 Update" installed?
              #
              if {[haveTclPlatformOsExtraUpdateName \
                      "Windows 10, May 2020 Update"] || \
                  [haveTclPlatformOsExtraUpdateName \
                      "Windows 10, October 2020 Update"] || \
                  [haveTclPlatformOsExtraUpdateName \
                      "Windows 10, May 2021 Update"]} then {
                #
                # NOTE: Return the "special" value.
                #
                return 528372; # BUGBUG: May / October 2020 Update(s) only?
              } else {
                #
                # NOTE: Is the "May 2019 Update" -OR- "November 2019 Update"
                #       installed?
                #
                if {[haveTclPlatformOsExtraUpdateName \
                        "Windows 10, May 2019 Update"] || \
                    [haveTclPlatformOsExtraUpdateName \
                        "Windows 10, November 2019 Update"]} then {
                  #
                  # NOTE: Return the "special" value.
                  #
                  return 528040; # BUGBUG: May / November 2019 Update(s) only?
                }
              }
            }
          }
        }
      }

      #
      # NOTE: Return the "normal" value.
      #
      return 528049
    }

    proc getFrameworkSetup481Value {} {
      # <help>
      # This procedure returns the minimum .NET Framework setup "Release"
      # registry value that indicates the .NET Framework 4.8.1 (or higher) is
      # installed.  It is a helper for [checkForNetFx45].  How it works: the
      # "special" value 533320 applies only on a client/missing-product-type
      # Windows 11 (NT version 10.0 with [isOsWindows11] true) that carries one
      # of the recognized Windows 11 update markers -- the September 2022,
      # October 2023, October 2024, or September 2025 updates -- each checked via
      # [haveTclPlatformOsExtraUpdateName].  Everywhere else the "normal" value
      # 533325 applies.
      #
      # Arguments:
      #   None.
      #
      # Results:
      #   The integer Release threshold for .NET Framework 4.8.1: 533320 on a
      #   qualifying Windows 11 update, otherwise 533325.
      # </help>

      #
      # NOTE: Check if we are running on Windows.
      #
      if {[isWindows]} then {
        if {[isOsProductType missing] || [isOsProductType client]} then {
          #
          # NOTE: Is this Windows 11 (NT v10.0)?
          #
          # BUGBUG: Is exact matching correct here?
          #
          if {[info exists ::tcl_platform(osVersion)] && \
              $::tcl_platform(osVersion) == 10.0} then {
            #
            # NOTE: Is this Windows 11 (NT v10.0)?
            #
            if {[isOsWindows11]} then {
              #
              # NOTE: Is the "September 2022 Update" -OR- a
              #       subsequent Windows 11 update installed?
              #
              # TODO: Verify this is correct as soon as the
              #       MSDN documentation is updated.
              #
              if {[haveTclPlatformOsExtraUpdateName \
                      "Windows 11, September 2022 Update"] || \
                  [haveTclPlatformOsExtraUpdateName \
                      "Windows 11, October 2023 Update"] || \
                  [haveTclPlatformOsExtraUpdateName \
                      "Windows 11, October 2024 Update"] || \
                  [haveTclPlatformOsExtraUpdateName \
                      "Windows 11, September 2025 Update"]} then {
                #
                # NOTE: Return the "special" value.
                #
                return 533320; # BUGBUG: September 2022 Update / later only?
              }
            }
          }
        }
      }

      #
      # NOTE: Return the "normal" value.
      #
      return 533325
    }

    proc checkForNetFx40 { channel } {
      # <help>
      # This procedure probes which point release and profile of the .NET
      # Framework 4.0 family is installed and registers the corresponding test
      # constraints.  For a non-"4.0" point release (4.0.1, 4.0.2, 4.0.3) it adds
      # "dotNetNN" and "dotNetNNOrHigher" (NN being the dotless version); for any
      # SKU with a profile (e.g. Client) it adds a "dotNetNNPROFILE" constraint.
      # It is Windows-only because detection reads the registry.
      #
      # How it works: it obtains the HKEY_LOCAL_MACHINE root key object via
      # [object invoke] (validated with [isNonNullObjectHandle]) and walks a
      # reversed list of v4.0 SKU subkey names under v4.0.30319 (full and Client
      # profiles for 4.0 through 4.0.3), opening each in turn.  For the first SKU
      # subkey that exists, it parses the version and optional profile out of the
      # subkey name with a regular expression, derives the dotless version via
      # [getDotlessVersion], registers the appropriate constraints, reports the
      # result, and returns.  Tricky detail: the plain "4.0" version is
      # deliberately NOT given "dotNet40"/"dotNet40OrHigher" constraints here (a
      # NOTE points to [checkForRuntimeVersion] for that); only the higher point
      # releases get version constraints, though a profile constraint is still
      # added for the 4.0 Client SKU.
      #
      # Arguments:
      #   channel -- The output channel for human-readable progress messages.
      #
      # Results:
      #   No meaningful return value (returns after the first matching SKU).
      #   Side effect is registration of the version and/or profile constraints
      #   described above when a .NET Framework 4.0 SKU is found.
      # </help>

      tputs $channel "---- checking for .NET Framework 4.0... "

      #
      # NOTE: Platform must be Windows for this constraint to even be
      #       checked (i.e. we require the registry).
      #
      if {[isWindows]} then {
        #
        # NOTE: Registry hive where the .NET Framework 4.0 setup and
        #       servicing information is stored.  No need to look in
        #       the WoW64 registry because the .NET Framework should
        #       be installed natively as well.
        #
        if {[catch {
          object invoke -alias Microsoft.Win32.Registry LocalMachine
        } rootKey] == 0 && [isNonNullObjectHandle $rootKey]} then {
          set key [appendArgs \
              {Software\Microsoft\.NETFramework\v4.0.30319\SKUs}]

          set subKeys [list \
              .NETFramework,Version=v4.0                  \
              .NETFramework,Version=v4.0,Profile=Client   \
              .NETFramework,Version=v4.0.1                \
              .NETFramework,Version=v4.0.1,Profile=Client \
              .NETFramework,Version=v4.0.2                \
              .NETFramework,Version=v4.0.2,Profile=Client \
              .NETFramework,Version=v4.0.3                \
              .NETFramework,Version=v4.0.3,Profile=Client]

          foreach subKey [lreverse $subKeys] {
            if {[catch {
              $rootKey OpenSubKey [appendArgs $key \\ $subKey]
            } skuKey] == 0 && [isNonNullObjectHandle $skuKey]} then {
              if {[regexp -- {=v(4\.0(?:\.\d+)*)(?:,Profile=(.*)$)?} \
                  $subKey dummy dotVersion profile]} then {
                set version [getDotlessVersion $dotVersion]

                if {$dotVersion ne "4.0"} then {; # checkForRuntimeVersion
                  addConstraint [appendArgs dotNet $version]
                  addConstraint [appendArgs dotNet $version OrHigher]
                }

                if {[string length $profile] > 0} then {
                  addConstraint [appendArgs dotNet $version $profile]

                  tputs $channel [appendArgs \
                      "yes (" $dotVersion ", " $profile " Profile)\n"]
                } else {
                  tputs $channel [appendArgs "yes (" $dotVersion ")\n"]
                }

                return
              }
            }
          }
        }
      }

      tputs $channel no\n
    }

    proc checkForNetFx45 { channel } {
      # <help>
      # This procedure determines the highest installed .NET Framework version in
      # the 4.5-through-4.8.1 family and registers a cascade of test constraints
      # describing it, such as "dotNet45OrHigher" (always added when any 4.5+ is
      # present) together with the exact-version constraints ("dotNet48",
      # "dotNet481", etc.) and the cumulative "OrHigher" constraints for every
      # version at or below the detected one ("dotNet451OrHigher",
      # "dotNet46OrHigher", and so on).  This lets tests require a minimum
      # framework version cleanly.  It is Windows-only because detection reads
      # the registry.
      #
      # How it works: it reads the "Release" DWORD from the NDP\v4\Full setup hive
      # via [object invoke] on Microsoft.Win32.Registry GetValue (inside a
      # [catch]; a missing value or error yields a non-integer that fails the
      # guard).  It then compares that Release value, from highest to lowest,
      # against the thresholds produced by the getFrameworkSetupNNNValue helper
      # procedures ([getFrameworkSetup481Value] down through
      # [getFrameworkSetup45Value]) and takes the first branch whose threshold is
      # met, registering the matching exact and "OrHigher" constraints for that
      # tier and all lower tiers.  Tricky detail: the 4.5.2/4.5.3 tier is
      # special-cased -- after meeting the 4.5.2 threshold it calls
      # [isFrameworkSetup453Installed] to decide between adding the 4.5.3 or 4.5.2
      # exact constraint, since those two cannot be distinguished by Release
      # value alone.  The thresholds themselves are OS- and update-dependent,
      # which is why the helper getters (rather than literals) are used.
      #
      # Arguments:
      #   channel -- The output channel for human-readable progress messages
      #              (which report the Release value and resolved version).
      #
      # Results:
      #   No meaningful return value (returns once a version is classified).
      #   Side effect is registration of the "dotNet45OrHigher" constraint plus
      #   the appropriate exact and cumulative "OrHigher" constraints for the
      #   detected framework version.
      # </help>

      tputs $channel "---- checking for .NET Framework 4.5 or higher... "

      #
      # NOTE: Platform must be Windows for this constraint to even be
      #       checked (i.e. we require the registry).
      #
      if {[isWindows]} then {
        #
        # NOTE: Registry hive where the .NET Framework 4.0 setup and
        #       servicing information is stored.  No need to look in
        #       the WoW64 registry because the .NET Framework should
        #       be installed natively as well.
        #
        set key [appendArgs HKEY_LOCAL_MACHINE\\ \
            {Software\Microsoft\NET Framework Setup\NDP\v4\Full}]

        #
        # NOTE: Attempt to fetch the .NET Framework 4.0 "release" value from
        #       the servicing registry hive.  If this value does not exist
        #       -OR- is less than 378389, then the .NET Framework 4.5 is not
        #       installed.  If this raises a script error, that will almost
        #       certainly cause the result to be a non-integer, thus failing
        #       the check below.
        #
        catch {
          object invoke Microsoft.Win32.Registry GetValue $key Release null
        } release

        if {[string is integer -strict $release] && \
            $release >= [getFrameworkSetup45Value]} then {
          #
          # NOTE: Yes, it appears that it is available.
          #
          addConstraint dotNet45OrHigher

          #
          # NOTE: If the "release" value is greater than or equal to 378758
          #       (or 378675 for Windows 8.1), then the .NET Framework 4.5.1
          #       is installed.  However, if the "release" value is also
          #       greater than or equal to 379893, then the .NET Framework
          #       4.5.2 is installed, which is an in-place upgrade to 4.5.1
          #       (and 4.5).  If the "release" value is also greater than or
          #       equal to 393297 (393295 on Windows 10), then the .NET
          #       Framework 4.6 is installed, which is an in-place upgrade
          #       to 4.5.x.  Similar handling is necessary for the .NET
          #       Framework 4.6.1, 4.6.2, 4.7, 4.7.1, 4.7.2, 4.8, and 4.8.1.
          #       For more information, see:
          #
          #       https://msdn.microsoft.com/en-us/library/hh925568.aspx
          #
          if {$release >= [getFrameworkSetup481Value]} then {
            addConstraint dotNet451OrHigher
            addConstraint dotNet452OrHigher
            addConstraint dotNet453OrHigher
            addConstraint dotNet46OrHigher
            addConstraint dotNet461OrHigher
            addConstraint dotNet462OrHigher
            addConstraint dotNet47OrHigher
            addConstraint dotNet471OrHigher
            addConstraint dotNet472OrHigher
            addConstraint dotNet48OrHigher
            addConstraint dotNet481
            addConstraint dotNet481OrHigher

            set version 4.8.1
          } elseif {$release >= [getFrameworkSetup48Value]} then {
            addConstraint dotNet451OrHigher
            addConstraint dotNet452OrHigher
            addConstraint dotNet453OrHigher
            addConstraint dotNet46OrHigher
            addConstraint dotNet461OrHigher
            addConstraint dotNet462OrHigher
            addConstraint dotNet47OrHigher
            addConstraint dotNet471OrHigher
            addConstraint dotNet472OrHigher
            addConstraint dotNet48
            addConstraint dotNet48OrHigher

            set version 4.8
          } elseif {$release >= [getFrameworkSetup472Value]} then {
            addConstraint dotNet451OrHigher
            addConstraint dotNet452OrHigher
            addConstraint dotNet453OrHigher
            addConstraint dotNet46OrHigher
            addConstraint dotNet461OrHigher
            addConstraint dotNet462OrHigher
            addConstraint dotNet47OrHigher
            addConstraint dotNet471OrHigher
            addConstraint dotNet472
            addConstraint dotNet472OrHigher

            set version 4.7.2
          } elseif {$release >= [getFrameworkSetup471Value]} then {
            addConstraint dotNet451OrHigher
            addConstraint dotNet452OrHigher
            addConstraint dotNet453OrHigher
            addConstraint dotNet46OrHigher
            addConstraint dotNet461OrHigher
            addConstraint dotNet462OrHigher
            addConstraint dotNet47OrHigher
            addConstraint dotNet471
            addConstraint dotNet471OrHigher

            set version 4.7.1
          } elseif {$release >= [getFrameworkSetup47Value]} then {
            addConstraint dotNet451OrHigher
            addConstraint dotNet452OrHigher
            addConstraint dotNet453OrHigher
            addConstraint dotNet46OrHigher
            addConstraint dotNet461OrHigher
            addConstraint dotNet462OrHigher
            addConstraint dotNet47
            addConstraint dotNet47OrHigher

            set version 4.7
          } elseif {$release >= [getFrameworkSetup462Value]} then {
            addConstraint dotNet451OrHigher
            addConstraint dotNet452OrHigher
            addConstraint dotNet453OrHigher
            addConstraint dotNet46OrHigher
            addConstraint dotNet461OrHigher
            addConstraint dotNet462
            addConstraint dotNet462OrHigher

            set version 4.6.2
          } elseif {$release >= [getFrameworkSetup461Value]} then {
            addConstraint dotNet451OrHigher
            addConstraint dotNet452OrHigher
            addConstraint dotNet453OrHigher
            addConstraint dotNet46OrHigher
            addConstraint dotNet461
            addConstraint dotNet461OrHigher

            set version 4.6.1
          } elseif {$release >= [getFrameworkSetup46Value]} then {
            addConstraint dotNet451OrHigher
            addConstraint dotNet452OrHigher
            addConstraint dotNet453OrHigher
            addConstraint dotNet46
            addConstraint dotNet46OrHigher

            set version 4.6
          } elseif {$release >= [getFrameworkSetup452Value]} then {
            addConstraint dotNet451OrHigher
            addConstraint dotNet452OrHigher

            if {[isFrameworkSetup453Installed]} then {
              addConstraint dotNet453
              addConstraint dotNet453OrHigher

              set version 4.5.3
            } else {
              addConstraint dotNet452

              set version 4.5.2
            }
          } elseif {$release >= [getFrameworkSetup451Value]} then {
            addConstraint dotNet451
            addConstraint dotNet451OrHigher

            set version 4.5.1
          } else {
            addConstraint dotNet45

            set version 4.5
          }

          #
          # NOTE: Show the "release" value we found in the registry.
          #
          tputs $channel [appendArgs "yes (" $release ", " $version ")\n"]

          #
          # NOTE: We are done here, return now.
          #
          return
        }
      }

      tputs $channel no\n
    }

    proc checkForVisualStudioViaRegistry { channel } {
      # <help>
      # This procedure probes for installed versions of Visual Studio using the
      # registry and registers a "visualStudioYEAR" test constraint (for example
      # "visualStudio2015") for each version found, as well as recording the
      # install directory of the last one located in the global
      # ::test_visual_studio variable (unless ::no(setVisualStudio) is set) for
      # use by the test suite.  It is Windows-only because it reads the registry.
      #
      # How it works: it queries the WoW64 (32-bit) VisualStudio registry hive --
      # Visual Studio is a 32-bit application -- and iterates a table mapping
      # internal version numbers (8.0 through 14.0) to product years (2005
      # through 2015).  For each, it reads the InstallDir value, joins it with
      # msenv.dll, normalizes the path, and if that file exists registers the
      # corresponding year constraint, appends the year to a running list, and
      # records the directory.  Tricky detail: this registry-based approach only
      # works through Visual Studio 2015; Visual Studio 2017 and later are not
      # detectable this way (a NOTE directs callers to a vswhere-based check
      # instead).
      #
      # Arguments:
      #   channel -- The output channel for human-readable progress messages
      #              (reporting the list of found years and the recorded
      #              directory).
      #
      # Results:
      #   No meaningful return value.  Side effects are registration of one
      #   "visualStudioYEAR" constraint per detected version and setting of the
      #   global ::test_visual_studio directory variable.
      # </help>

      tputs $channel "---- checking for Visual Studio using registry... "

      #
      # NOTE: Initially, no versions of Visual Studio have been found.
      #
      set visualStudioVersions [list]

      #
      # NOTE: Platform must be Windows for this constraint to even be
      #       checked (i.e. we require the registry).
      #
      if {[isWindows]} then {
        #
        # NOTE: Registry hive where Visual Studio install information is
        #       stored.  Make sure to look in the WoW64 registry because
        #       Visual Studio is currently always a 32-bit application.
        #
        set key [appendArgs HKEY_LOCAL_MACHINE\\ \
            [getSoftwareRegistryKey true] {\Microsoft\VisualStudio}]

        #
        # NOTE: The versions of Visual Studio that we support detection
        #       of using the registry.  This no longer works as of the
        #       release of Visual Studio 2017.  For Visual Studio 2017
        #       and beyond, the [checkForVisualStudioViaVsWhere] method
        #       must be used instead.
        #
        set versions [list [list 8.0 2005] [list 9.0 2008] \
            [list 10.0 2010] [list 11.0 2012] [list 12.0 2013] \
            [list 14.0 2015]]

        #
        # NOTE: Check each version and keep track of the ones we find.
        #
        foreach version $versions {
          #
          # NOTE: Attempt to fetch the Visual Studio install directory
          #       value from the registry, removing the trailing backslash,
          #       if any.
          #
          if {[catch {
            file normalize [file join [string trimright [object \
                invoke Microsoft.Win32.Registry GetValue [appendArgs \
                $key \\ [lindex $version 0]] InstallDir null] \\] \
                msenv.dll]
          } fileName] == 0} then {
            #
            # NOTE: Does the directory name look valid and does it
            #       actually exist?
            #
            if {[string length $fileName] > 0 && \
                [file isfile $fileName]} then {
              #
              # NOTE: Yes, it appears that it is available.
              #
              addConstraint [appendArgs \
                  visualStudio [lindex $version 1]]

              #
              # NOTE: Keep track of all the versions that we find.
              #
              lappend visualStudioVersions [lindex $version 1]

              #
              # NOTE: Save the directory for later usage by the test
              #       suite itself.
              #
              if {![info exists ::no(setVisualStudio)]} then {
                set ::test_visual_studio [file dirname $fileName]
              }
            }
          }
        }
      }

      if {[llength $visualStudioVersions] > 0} then {
        #
        # NOTE: Show where we found the latest version.
        #
        tputs $channel [appendArgs \
            "yes (" $visualStudioVersions ", \"" \
            [expr {[info exists ::test_visual_studio] ? \
                $::test_visual_studio : "<none>"}] "\")\n"]
      } else {
        tputs $channel no\n
      }
    }

    proc checkForNativeDebugger { channel } {
      # <help>
      # This procedure probes whether a native (operating system) debugger is
      # attached to the current process and registers the "nativeDebugger" test
      # constraint when one is present.  It lets tests adjust or skip behavior
      # that is sensitive to being run under a debugger.  How it works: it calls,
      # via [object invoke] with the "+NonPublic" flag, the IsDebuggerPresent
      # method on the internal NativeOps SafeNativeMethods class (which wraps the
      # Win32 API of the same name), inside a [catch], and adds the constraint
      # only when the result is strictly true.
      #
      # Arguments:
      #   channel -- The output channel for human-readable progress messages.
      #
      # Results:
      #   No meaningful return value.  Side effect is registration of the
      #   "nativeDebugger" constraint when a native debugger is present.
      # </help>

      tputs $channel "---- checking for native debugger... "

      #
      # NOTE: Is the native debugger present?
      #
      if {[catch {
        object invoke -flags +NonPublic \
            CodeBrix.Platform.TclTk._Components.Private.NativeOps+SafeNativeMethods \
            IsDebuggerPresent
      } present] == 0 && [string is true -strict $present]} then {
        #
        # NOTE: Yes, it appears that it is present.
        #
        addConstraint nativeDebugger

        tputs $channel yes\n
      } else {
        tputs $channel no\n
      }
    }

    proc checkForManagedDebugger { channel } {
      # <help>
      # This procedure probes whether a managed (.NET) debugger is attached to
      # the current process and registers the "managedDebugger" test constraint
      # when one is present.  It lets tests adjust or skip behavior that is
      # affected by managed debugging.  How it works: it reads the IsAttached
      # property of System.Diagnostics.Debugger via [object invoke], inside a
      # [catch], and adds the constraint only when the result is strictly true.
      #
      # Arguments:
      #   channel -- The output channel for human-readable progress messages.
      #
      # Results:
      #   No meaningful return value.  Side effect is registration of the
      #   "managedDebugger" constraint when a managed debugger is attached.
      # </help>

      tputs $channel "---- checking for managed debugger... "

      #
      # NOTE: Is the managed debugger attached?
      #
      if {[catch {
        object invoke System.Diagnostics.Debugger IsAttached
      } attached] == 0 && [string is true -strict $attached]} then {
        #
        # NOTE: Yes, it appears that it is attached.
        #
        addConstraint managedDebugger

        tputs $channel yes\n
      } else {
        tputs $channel no\n
      }
    }

    proc checkForScriptDebugger { channel } {
      # <help>
      # This procedure probes whether the active interpreter has an TclTk script
      # debugger associated with it and registers the "scriptDebugger" test
      # constraint when one is available.  It lets tests gate on the presence of
      # the script-level debugger.  How it works: it retrieves the Debugger of
      # the active interpreter via [object invoke] with the "+NonPublic" flag,
      # inside a [catch].  If a non-null object handle comes back, it marks that
      # handle "+NoDispose" (because the debugger is not owned by this code and
      # must not be disposed), then confirms the handle matches the expected
      # "Debugger#N" naming pattern before adding the constraint.
      #
      # Arguments:
      #   channel -- The output channel for human-readable progress messages.
      #
      # Results:
      #   No meaningful return value (returns once the debugger is confirmed).
      #   Side effect is registration of the "scriptDebugger" constraint when a
      #   script debugger is present.
      # </help>

      tputs $channel "---- checking for script debugger... "

      #
      # NOTE: Is the script debugger available?
      #
      if {[catch {
        object invoke -flags +NonPublic Interpreter.GetActive Debugger
      } debugger] == 0} then {
        #
        # NOTE: We do not own this, do not dispose it.
        #
        if {[isNonNullObjectHandle $debugger]} then {
          catch {object flags $debugger +NoDispose}
        }

        if {[regexp -- {^Debugger#\d+$} $debugger]} then {
          #
          # NOTE: Yes, it appears that it is available.
          #
          addConstraint scriptDebugger

          tputs $channel yes\n

          #
          # NOTE: We are done here, return now.
          #
          return
        }
      }

      tputs $channel no\n
    }

    proc checkForScriptDebuggerInterpreter { channel } {
      # <help>
      # This procedure probes whether the active interpreter's script debugger
      # has its own associated (isolated) interpreter, registering the
      # "scriptDebuggerInterpreter" test constraint when it does.  It is a
      # stronger condition than [checkForScriptDebugger]: not only must a script
      # debugger exist, but that debugger must expose a usable Interpreter
      # object.  How it works: it retrieves the active interpreter's Debugger via
      # [object invoke] with "+NonPublic" (inside a [catch]), marks any non-null
      # handle "+NoDispose" since it is not owned here, verifies the handle
      # matches the "Debugger#N" pattern, then invokes its Interpreter property.
      # The resulting interpreter handle is likewise marked "+NoDispose" and
      # validated against the "Interpreter#N" pattern before the constraint is
      # added.
      #
      # Arguments:
      #   channel -- The output channel for human-readable progress messages.
      #
      # Results:
      #   No meaningful return value (returns once the debugger interpreter is
      #   confirmed).  Side effect is registration of the
      #   "scriptDebuggerInterpreter" constraint when present.
      # </help>

      tputs $channel "---- checking for script debugger interpreter... "

      #
      # NOTE: Is the script debugger interpreter available?
      #
      if {[catch {
        object invoke -flags +NonPublic Interpreter.GetActive Debugger
      } debugger] == 0} then {
        #
        # NOTE: We do not own this, do not dispose it.
        #
        if {[isNonNullObjectHandle $debugger]} then {
          catch {object flags $debugger +NoDispose}
        }

        if {[regexp -- {^Debugger#\d+$} $debugger] && \
            [catch {object invoke $debugger Interpreter} interp] == 0} then {
          #
          # NOTE: We do not own this, do not dispose it.
          #
          if {[isNonNullObjectHandle $interp]} then {
            catch {object flags $interp +NoDispose}
          }

          if {[regexp -- {^Interpreter#\d+$} $interp]} then {
            #
            # NOTE: Yes, it appears that it is available.
            #
            addConstraint scriptDebuggerInterpreter

            tputs $channel yes\n

            #
            # NOTE: We are done here, return now.
            #
            return
          }
        }
      }

      tputs $channel no\n
    }

    ###########################################################################
    ############################# END TclTk ONLY ##############################
    ###########################################################################
  } else {
    ###########################################################################
    ############################# BEGIN Tcl ONLY ##############################
    ###########################################################################

    #
    # NOTE: We need several of our test constraint related commands in the
    #       global namespace.
    #
    exportAndImportPackageCommands [namespace current] [list \
        getKnownBuildTypes getKnownCompileOptions getKnownWindowsVersions \
        getKnownPublicKeyTokenPattern getKnownDotNetVersions \
        addKnownDotNetConstraints getKnownMonoVersions \
        addKnownMonoConstraints getKnownDotNetCoreVersions \
        addKnownDotNetCoreConstraints getKnownTclVersions filterKnownVersions \
        getDotNetCoreDirectoryNameOnly getDotNetCoreLibPathDirectoryNameOnly \
        getRuntimeVersion getDottedVersion getDotlessVersion \
        getMajorMinorVersion loadTestSettings lpermute lcombine \
        alwaysFullInterpReady canExecComSpec canExecWhoAmI canExecTclShell \
        canExecFossil canExecFsUtil canExecVsWhere canExecUlimit canExecCc \
        canExecWmic getCpuStatus isTestMono isTestDotNetCore \
        isTestAdministrator canPing cleanConstraintName cleanPackageName \
        haveTclPlatformOsExtraUpdateName appendExecArguments \
        tryDetectFossilRoot execFossilCommand checkForTestSuiteFiles \
        checkForPlatform checkForWindowsVersion checkForGetInstalledUpdates \
        checkForOperatingSystemUpdate checkForScriptLibrary \
        checkForEnvironmentVariable checkForVariable checkForTclOptions \
        checkForWindowsCommandProcessor checkForPackage checkForFossil \
        checkForVisualStudioViaVsWhere checkForTclTk checkForSymbols \
        checkForLogFile checkForGaruda checkForShell \
        checkForOfficialStableReleaseInProgress checkForDebug checkForTk \
        checkForVersion checkForCommand checkForSubCommand checkForIntIsWide \
        checkForEFormat checkForNamespaces checkForTestExec \
        checkForTestMachine checkForTestPlatform checkForTestConfiguration \
        checkForTestNamePrefix checkForTestSuffix checkForGnuScreen \
        checkForFile checkForNativeLibraryFile checkForPathFile \
        checkForNativeCode checkForAllowBigIntegers checkForTip127 \
        checkForTip182 checkForTip194 checkForTip207 checkForTip237 \
        checkForTip241 checkForTip285 checkForTip405 checkForTip421 \
        checkForTip426 checkForTip429 checkForTip440 checkForTip461 \
        checkForTip463 checkForTip471 checkForTip508 checkForTip521 \
        checkForTiming checkForPerformance checkForBigLists \
        checkForProcessorIntensive checkForFileSystemIntensive \
        checkForTimeIntensive checkForFullTest checkForMemoryIntensive \
        checkForStackIntensive ulimitStackSizeToBytes getUlimitC99 \
        compileViaC99 checkForStackSize checkForInteractive \
        checkForInteractiveFocus checkForInteractiveCommand \
        checkForUserInteraction checkForOfflineMode checkForNetwork \
        maybeDownloadFromUri checkForInternet checkForTlsOk \
        checkForCompileOption checkForBuildType checkForKnownBuildTypes \
        checkForKnownCompileOptions] false false

    ###########################################################################
    ############################## END Tcl ONLY ###############################
    ###########################################################################
  }

  #
  # NOTE: Provide the TclTk "test constraints" package to the interpreter.
  #
  package provide TclTk.Test.Constraints \
    [expr {[isTclTk] ? [info engine PatchLevel] : "1.0"}]
}
