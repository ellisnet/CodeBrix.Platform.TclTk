    proc getFrameworkSetup471Value {} {
      # <help>
      # This procedure returns the minimum .NET Framework setup "Release"
      # registry value that indicates the .NET Framework 4.7.1 (or higher) is
      # installed.  It is a helper for [checkForNetFx45].  How it works: the
      # "special" value 461308 applies on either Windows Server (NT version 10.0,
      # release identifier 1709, via [isOsReleaseId]) or on a
      # client/missing-product-type Windows 10 with the "Windows 10, Fall
      # Creators Update" extra-update marker (via
      # [haveTclPlatformOsExtraUpdateName]); everywhere else the "normal" value
      # 461310 applies.
      #
      # Arguments:
      #   None.
      #
      # Results:
      #   The integer Release threshold for .NET Framework 4.7.1: 461308 on
      #   Windows Server 1709 or the Windows 10 Fall Creators Update, otherwise
      #   461310.
      # </help>

      #
      # NOTE: Check if we are running on Windows.
      #
      if {[isWindows]} then {
        #
        # NOTE: Check if we are running on a server (or client) operating
        #       system.
        #
        if {[isOsProductType server]} then {
          #
          # NOTE: Is this Windows Server (NT v10.0 release 1709)?
          #
          # BUGBUG: Is exact matching correct here?
          #
          if {[info exists ::tcl_platform(osVersion)] && \
              $::tcl_platform(osVersion) == 10.0 && \
              [isOsReleaseId 1709]} then {
            #
            # NOTE: Return the "special" value.
            #
            return 461308
          }
        } elseif {[isOsProductType missing] || [isOsProductType client]} then {
          #
          # NOTE: Is this Windows 10 (NT v10.0) with the
          #       "Fall Creators Update" installed?
          #
          # BUGBUG: Is exact matching correct here?
          #
          if {[info exists ::tcl_platform(osVersion)] && \
              $::tcl_platform(osVersion) == 10.0 && \
              [haveTclPlatformOsExtraUpdateName \
                  "Windows 10, Fall Creators Update"]} then {
            #
            # NOTE: Return the "special" value.
            #
            return 461308; # BUGBUG: Fall Creators Update only?
          }
        }
      }

      #
      # NOTE: Return the "normal" value.
      #
      return 461310
