#
# NOTE: Use our own namespace here because even though we do not directly
#       support namespaces ourselves, we do not want to pollute the global
#       namespace if this script actually ends up being evaluated in Tcl.
#
namespace eval ::TclTk {
  proc getKnownBuildTypes {} {
    # <help>
    # This procedure returns the list of "well-known" build type names
    # recognized by the test suite infrastructure, such as NetFx20, NetFx48,
    # NetStandard20, NetStandard21, Bare, LeanAndMean, Database, MonoOnUnix,
    # and Development.  It exists so that other procedures (for example, the
    # build-type constraint checks) can validate a build type name against a
    # canonical set and so that callers can enumerate the supported names.
    #
    # How it works: if the global array element test_well_known(buildTypes)
    # exists, its value is returned verbatim, allowing a deployment to override
    # the canonical list; otherwise, a hard-coded literal list of the known
    # build type names is returned.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   A list of build type name strings.
    # </help>

    if {[info exists ::test_well_known(buildTypes)]} then {
      return $::test_well_known(buildTypes)
    }

    return [list \
        NetFx20 NetFx35 NetFx40 NetFx45 \
        NetFx451 NetFx452 NetFx46 NetFx461 \
        NetFx462 NetFx47 NetFx471 NetFx472 \
        NetFx48 NetFx481 NetStandard20 NetStandard21 \
        Bare LeanAndMean Database MonoOnUnix \
        Development]
  }

  proc getKnownCompileOptions {} {
    # <help>
    # This procedure returns the list of "well-known" compile-option names
    # understood by the test suite infrastructure (the conditional compilation
    # symbols that may have been defined when the core library was built, such
    # as DEBUG, NATIVE, TCL, NETWORK, MONO, X64, and many more).  It exists so
    # that the compile-option constraint checks have a canonical set to draw
    # from and so callers can enumerate the recognized option names.
    #
    # How it works: if the global array element
    # test_well_known(compileOptions) exists, its value is returned verbatim,
    # allowing a deployment to override the list; otherwise, a large hard-coded
    # literal list of the known option names is sorted with [lsort] and the
    # sorted result is returned.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   An alphabetically sorted list of compile-option name strings.
    # </help>

    if {[info exists ::test_well_known(compileOptions)]} then {
      return $::test_well_known(compileOptions)
    }

    return [lsort [list \
        APPDOMAINS APPROVED_VERBS ARGUMENT_CACHE ARM ARM64 ASSEMBLY_DATETIME \
        ASSEMBLY_RELEASE ASSEMBLY_STRONG_NAME_TAG ASSEMBLY_TAG ASSEMBLY_TEXT \
        ASSEMBLY_URI BREAK_ON_EXITING CACHE_ARGUMENT_TOSTRING \
        CACHE_ARGUMENTLIST_TOSTRING CACHE_DICTIONARY CACHE_RESULT_TOSTRING \
        CACHE_STATISTICS CACHE_STRINGLIST_TOSTRING CALLBACK_QUEUE CAS_POLICY \
        CERTIFICATE_PLUGIN CERTIFICATE_POLICY CERTIFICATE_RENEWAL \
        CODE_ANALYSIS COM_TYPE_CACHE COMPRESSION CONFIGURATION CONSOLE DAEMON \
        DATA DEAD_CODE DEBUG DEBUGGER DEBUGGER_ARGUMENTS DEBUGGER_BREAKPOINTS \
        DEBUGGER_ENGINE DEBUGGER_EXECUTE DEBUGGER_EXPRESSION \
        DEBUGGER_VARIABLE DEBUG_TRACE DEBUG_WRITE DEMO_EDITION DEMO_KEY_PAIRS \
        DRAWING DYNAMIC TCLTK EMBEDDED_LIBRARY EMBED_CERTIFICATES EMIT \
        ENTERPRISE_LOCKDOWN EXECUTE_CACHE EXPRESSION_FLAGS EXTRA_DIAGNOSTICS \
        FAST_DICTIONARY FAST_ERRORCODE FAST_ERRORINFO FOR_TEST_USE_ONLY \
        FORCE_TRACE HAVE_SIZEOF \
        HISTORY \
        IA64 INTERACTIVE_COMMANDS \
        INTERNALS_VISIBLE_TO ISOLATED_INTERPRETERS ISOLATED_PLUGINS LIBRARY \
        LICENSE_MANAGER LICENSING LICENSING_NOP LIMITED_EDITION LIST_CACHE \
        MAYBE_ENTERPRISE_LOCKDOWN MAYBE_TRACE MONO MONO_BUILD MONO_HACKS \
        MONO_LEGACY NATIVE NATIVE_PACKAGE NATIVE_THREAD_ID NATIVE_UTILITY \
        NATIVE_UTILITY_BSTR NETWORK NET_20 NET_20_FAST_ENUM NET_20_ONLY \
        NET_20_SP1 NET_20_SP2 NET_30 NET_35 NET_40 NET_45 NET_451 NET_452 \
        NET_46 NET_461 NET_462 NET_47 NET_471 NET_472 NET_48 NET_481 \
        NET_CORE_REFERENCES NET_CORE_20 NET_CORE_30 NET_CORE_50 \
        NET_STANDARD_20 NET_STANDARD_21 NON_WORKING_CODE \
        NOTIFY NOTIFY_OBJECT \
        NOTIFY_ACTIVE NOTIFY_ARGUMENTS NOTIFY_EXCEPTION NOTIFY_EXECUTE \
        NOTIFY_EXPRESSION NOTIFY_GLOBAL NOTIFY_TCL \
        OBSOLETE OBFUSCATION OFFICIAL OFFICIAL_BINARY OPEN_SSL PARSE_CACHE \
        PATCHLEVEL PLUGIN_COMMANDS POLICY_TRACE PREVIOUS_RESULT PROFILER \
        RANDOMIZE_ID REMOTING RESULT_LIMITS SAMPLE SCRIPT_ARGUMENTS SECURITY \
        SERIALIZATION SHARED_ID_POOL SHELL SOURCE_ID SOURCE_TIMESTAMP STATIC \
        STRICT_FEATURES TCL TCL_KITS TCL_THREADED TCL_THREADS TCL_UNICODE \
        TCL_WRAPPER TEST TEST_PLUGIN THREADING THROW_ON_DISPOSED TRACE \
        TYPE_CACHE UNIX UNSAFE USE_APPDOMAIN_FOR_ID USE_NAMESPACES VERBOSE \
        WEB WINDOWS WINFORMS WIX_30 WIX_35 WIX_36 WIX_37 WIX_38 WIX_39 \
        WIX_310 WIX_311 X64 X86 XML]]
  }

  proc getKnownWindowsVersions { {force false} } {
    # <help>
    # This procedure returns the list of "well-known" Windows operating system
    # version numbers recognized by the test suite infrastructure.  Each
    # element is itself a two-element list giving the major and minor version
    # (e.g. the list 5 1 for Windows XP, the list 6 1 for Windows 7, and the
    # list 10 0 for Windows 10 and 11).  It exists so that version-specific
    # platform constraints can be derived from a canonical set.
    #
    # How it works: if the global array element
    # test_well_known(windowsVersions) exists, its value is returned verbatim.
    # Otherwise, unless the global array element no(windowsVersions) is set (in
    # which case the empty list is returned), the hard-coded literal list of
    # major/minor version pairs is returned.  The "force" argument lets a
    # caller bypass the no(windowsVersions) opt-out.  Note that, as the inline
    # comment records, Windows 11 still reports itself as major/minor 10.0.
    #
    # Arguments:
    #   force -- Optional boolean.  When true, the no(windowsVersions) opt-out
    #            is ignored and the version list is returned anyway.  Defaults
    #            to false.
    #
    # Results:
    #   A list of two-element major/minor version pair lists, or the empty list
    #   when the feature is disabled and not forced.
    # </help>

    if {[info exists ::test_well_known(windowsVersions)]} then {
      return $::test_well_known(windowsVersions)
    }

    if {$force || ![info exists ::no(windowsVersions)]} then {
      #
      # NOTE: Apparently, "Windows 11" still identifies as "10.0".
      #
      return [list [list 3 1] [list 3 5] [list 3 51] [list 4 0] [list 5 0] \
          [list 5 1] [list 5 2] [list 6 0] [list 6 1] [list 6 2] [list 6 3] \
          [list 10 0]]
    } else {
      return [list]
    }
  }

  proc getKnownPublicKeyTokenPattern {} {
    # <help>
    # This procedure returns a regular-expression alternation pattern that
    # matches any of the "well-known" assembly public key tokens recognized by
    # the test suite, plus the literal word "null" (used when an assembly is
    # not strong-name signed).  It exists so that tests and constraint checks
    # can verify an assembly's public key token against the set of tokens the
    # test suite trusts.
    #
    # How it works: if the global array element
    # test_well_known(publicKeyTokenPattern) exists, its value is returned
    # verbatim.  Otherwise, a list is started with the element "null", the
    # tokens returned by [getKnownPublicKeyTokens] are appended to it via [eval
    # lappend], and the elements are joined with the vertical-bar character to
    # form the alternation pattern.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   A regular-expression alternation string of the form null then a bar
    #   then each known public key token, separated by bars.
    # </help>

    if {[info exists ::test_well_known(publicKeyTokenPattern)]} then {
      return $::test_well_known(publicKeyTokenPattern)
    }

    set list [list null]
    eval lappend list [getKnownPublicKeyTokens]

    return [join $list |]
  }

  proc getKnownDotNetVersions {} {
    # <help>
    # This procedure returns the list of "known" Microsoft .NET Framework
    # version numbers supported by the test suite infrastructure.  Each element
    # is a list of two or three integers giving the version (e.g. the list 2 0,
    # the list 4 5 1, the list 4 8 1).  As the inline notes explain, versions
    # prior to 2.0 (that is, 1.0 and 1.1) are deliberately excluded, and the
    # list must be updated manually as new framework versions are released.  It
    # exists so that the .NET Framework constraint registration can iterate
    # over a canonical version set.
    #
    # How it works: if the global array element
    # test_well_known(dotNetVersions) exists, its value is returned verbatim.
    # Otherwise the hard-coded literal list of version-component lists is
    # returned.  Tricky detail: the code guards the literal with a test of a
    # "force" variable and the no(dotNetVersions) opt-out, mirroring the other
    # version helpers; however, this procedure declares no parameters, so the
    # "force" reference relies on an inherited or globally set variable being
    # present.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   A list of version-component lists, or the empty list when the feature
    #   is disabled and not forced.
    # </help>

    #
    # NOTE: This job of this procedure is to return the list of "known"
    #       versions of the .NET Framework supported by the test suite
    #       infrastructure.  This means versions of the .NET Framework
    #       prior to 2.0 (i.e. 1.0 and 1.1) are purposely excluded.
    #
    #       https://en.wikipedia.org/wiki/.NET_framework
    #       https://dotnet.microsoft.com/en-us/download/dotnet-framework
    #
    # TODO: This list should be manually updated when a new version of
    #       the .NET Core runtime is released.
    #
    if {[info exists ::test_well_known(dotNetVersions)]} then {
      return $::test_well_known(dotNetVersions)
    }

    if {$force || ![info exists ::no(dotNetVersions)]} then {
      return [list [list 2 0] [list 3 5] [list 4 0] [list 4 0 1] \
          [list 4 0 2] [list 4 0 3] [list 4 5] [list 4 5 1] [list 4 5 2] \
          [list 4 6] [list 4 6 1] [list 4 6 2] [list 4 7] [list 4 7 1] \
          [list 4 7 2] [list 4 8] [list 4 8 1]]
    } else {
      return [list]
    }
  }

  proc addKnownDotNetConstraints { generic } {
    # <help>
    # This procedure registers the test constraints associated with the known
    # Microsoft .NET Framework versions.  It exists so that individual tests
    # can declare that they are expected to fail, misbehave, crash, or hang on
    # specific framework versions.  As the inline warning notes, none of these
    # constraints are actually used by the core library test suite itself; they
    # are provided for downstream/derived test suites.
    #
    # How it works: when "generic" is false, it iterates the versions returned
    # by [getKnownDotNetVersions], joins each version's components into a
    # dotless suffix, and for each one adds (via [addConstraint]) a family of
    # constraints, both plain and with an "Only" suffix: dotNetToDo, dotNetBug,
    # dotNetCrash, and dotNetHang, each followed by the version suffix.  When
    # "generic" is true, it instead adds just the un-versioned base constraints
    # dotNetToDo, dotNetBug, dotNetCrash, and dotNetHang.
    #
    # Arguments:
    #   generic -- Boolean.  When false, the per-version constraints are added;
    #              when true, only the generic un-versioned constraints are
    #              added.
    #
    # Results:
    #   Returns the result of the final [addConstraint] call; the meaningful
    #   effect is the side effect of registering the constraints.
    # </help>

    #
    # NOTE: Does the caller want to add the version-specific constraints
    #       or the generic ones?
    #
    if {!$generic} then {
      #
      # NOTE: Add the necessary constraints for each version of the .NET
      #       Framework that we know about.
      #
      # WARNING: None of these constraints are used by the core library
      #          test suite itself.
      #
      foreach dotNetVersion [getKnownDotNetVersions] {
        set constraintVersion [join $dotNetVersion ""]

        addConstraint [appendArgs dotNetToDo $constraintVersion]
        addConstraint [appendArgs dotNetToDo $constraintVersion Only]
        addConstraint [appendArgs dotNetBug $constraintVersion]
        addConstraint [appendArgs dotNetBug $constraintVersion Only]
        addConstraint [appendArgs dotNetCrash $constraintVersion]
        addConstraint [appendArgs dotNetCrash $constraintVersion Only]
        addConstraint [appendArgs dotNetHang $constraintVersion]
        addConstraint [appendArgs dotNetHang $constraintVersion Only]
      }
    } else {
      #
      # NOTE: Also add just the generic the .NET Framework constraints
      #       that do not have a trailing version.
      #
      # WARNING: None of these constraints are used by the core library
      #          test suite itself.
      #
      set constraints [list dotNetToDo dotNetBug dotNetCrash dotNetHang]

      foreach constraint $constraints {
        addConstraint $constraint
      }
    }
  }

  proc getKnownMonoVersions { {force false} } {
    # <help>
    # This procedure returns the list of "known" Mono runtime version numbers
    # supported by the test suite infrastructure.  Each element is a
    # two-element major/minor list (e.g. the list 2 0, the list 6 14).  As the
    # inline notes explain, versions prior to 2.0 are deliberately excluded,
    # some releases that were never made are skipped, and the list must be
    # updated manually as Mono releases occur.  It exists so the Mono
    # constraint registration can iterate over a canonical version set.
    #
    # How it works: if the global array element test_well_known(monoVersions)
    # exists, its value is returned verbatim.  Otherwise, unless the global
    # array element no(monoVersions) is set (in which case the empty list is
    # returned), the hard-coded literal list of major/minor version pairs is
    # returned.  The "force" argument bypasses the no(monoVersions) opt-out.
    #
    # Arguments:
    #   force -- Optional boolean.  When true, the no(monoVersions) opt-out is
    #            ignored and the version list is returned anyway.  Defaults to
    #            false.
    #
    # Results:
    #   A list of two-element major/minor version pair lists, or the empty list
    #   when the feature is disabled and not forced.
    # </help>

    #
    # NOTE: This job of this procedure is to return the list of "known"
    #       versions of Mono supported by the test suite infrastructure.
    #       This means versions of Mono prior to 2.0 (i.e. 0.* and 1.*)
    #       are purposely excluded.
    #
    # NOTE: Other than version 2.11 (which was officially announced and
    #       released), all of these releases are listed on the official
    #       release history pages:
    #
    #       https://en.wikipedia.org/wiki/Mono_%28software%29
    #       https://www.mono-project.com/docs/about-mono/releases/
    #       https://www.mono-project.com/docs/about-mono/versioning/
    #
    # TODO: This list should be manually updated when a new version of
    #       the Mono runtime is released -OR- when one is skipped (e.g.
    #       5.6 and 5.22).
    #
    # NOTE: As of 6.14, the Mono project is managed by the Wine project
    #       team.
    #
    if {[info exists ::test_well_known(monoVersions)]} then {
      return $::test_well_known(monoVersions)
    }

    if {$force || ![info exists ::no(monoVersions)]} then {
      return [list \
          [list 2 0] [list 2 2] [list 2 4] [list 2 6] [list 2 8] [list 2 10] \
          [list 2 11] [list 3 0] [list 3 1] [list 3 2] [list 3 4] [list 3 6] \
          [list 3 8] [list 3 10] [list 3 12] [list 4 0] [list 4 2] [list 4 4] \
          [list 4 6] [list 4 8] [list 5 0] [list 5 2] [list 5 4] [list 5 8] \
          [list 5 10] [list 5 12] [list 5 14] [list 5 16] [list 5 18] \
          [list 5 20] [list 6 0] [list 6 4] [list 6 6] [list 6 8] [list 6 10] \
          [list 6 12] [list 6 14]]
    } else {
      return [list]
    }
  }

  proc addKnownMonoConstraints { generic } {
    # <help>
    # This procedure registers the test constraints associated with the known
    # Mono runtime versions.  It exists so that individual tests can declare
    # that they are expected to fail, misbehave, crash, or hang on specific
    # Mono versions.
    #
    # How it works: when "generic" is false, it iterates the versions returned
    # by [getKnownMonoVersions], joins each version's components into a dotless
    # suffix, and for each one adds (via [addConstraint]) a family of
    # constraints, both plain and with an "Only" suffix: monoToDo, monoBug,
    # monoCrash, and monoHang, each followed by the version suffix.  When
    # "generic" is true, it instead adds just the un-versioned base constraints
    # monoToDo, monoBug, monoCrash, and monoHang.
    #
    # Arguments:
    #   generic -- Boolean.  When false, the per-version constraints are added;
    #              when true, only the generic un-versioned constraints are
    #              added.
    #
    # Results:
    #   Returns the result of the final [addConstraint] call; the meaningful
    #   effect is the side effect of registering the constraints.
    # </help>

    #
    # NOTE: Does the caller want to add the version-specific constraints
    #       or the generic ones?
    #
    if {!$generic} then {
      #
      # NOTE: Add the necessary constraints for each version of Mono that
      #       we know about.
      #
      foreach monoVersion [getKnownMonoVersions] {
        set constraintVersion [join $monoVersion ""]

        addConstraint [appendArgs monoToDo $constraintVersion]
        addConstraint [appendArgs monoToDo $constraintVersion Only]
        addConstraint [appendArgs monoBug $constraintVersion]
        addConstraint [appendArgs monoBug $constraintVersion Only]
        addConstraint [appendArgs monoCrash $constraintVersion]
        addConstraint [appendArgs monoCrash $constraintVersion Only]
        addConstraint [appendArgs monoHang $constraintVersion]
        addConstraint [appendArgs monoHang $constraintVersion Only]
      }
    } else {
      #
      # NOTE: Also add just the generic Mono constraints that do not have
      #       a trailing version.
      #
      set constraints [list monoToDo monoBug monoCrash monoHang]

      foreach constraint $constraints {
        addConstraint $constraint
      }
    }
  }

  proc getKnownDotNetCoreVersions { {force false} } {
    # <help>
    # This procedure returns the list of "known" .NET Core (and modern .NET)
    # version numbers explicitly supported by the test suite infrastructure.
    # Each element is a two-element major/minor list (e.g. the list 2 0, the
    # list 3 1, the list 10 0).  As the inline notes explain, versions prior to
    # 2.0 are deliberately excluded and the list must be updated manually as
    # new .NET Core runtimes are released.  It exists so the .NET Core
    # constraint registration can iterate over a canonical version set.
    #
    # How it works: if the global array element
    # test_well_known(dotNetCoreVersions) exists, its value is returned
    # verbatim.  Otherwise, unless the global array element
    # no(dotNetCoreVersions) is set (in which case the empty list is returned),
    # the hard-coded literal list of major/minor version pairs is returned.
    # The "force" argument bypasses the no(dotNetCoreVersions) opt-out.
    #
    # Arguments:
    #   force -- Optional boolean.  When true, the no(dotNetCoreVersions)
    #            opt-out is ignored and the version list is returned anyway.
    #            Defaults to false.
    #
    # Results:
    #   A list of two-element major/minor version pair lists, or the empty list
    #   when the feature is disabled and not forced.
    # </help>

    #
    # NOTE: This job of this procedure is to return the list of "known"
    #       versions of .NET Core explicitly supported by the test suite
    #       infrastructure.  This means versions of .NET Core prior to
    #       2.0 (i.e. 1.0 and 1.1) are purposely excluded.
    #
    #       https://en.wikipedia.org/wiki/.NET_Core
    #       https://github.com/dotnet/core/releases
    #
    # TODO: This list should be manually updated when a new version of
    #       the .NET Core runtime is released.
    #
    if {[info exists ::test_well_known(dotNetCoreVersions)]} then {
      return $::test_well_known(dotNetCoreVersions)
    }

    if {$force || ![info exists ::no(dotNetCoreVersions)]} then {
      return [list [list 2 0] [list 2 1] [list 2 2] [list 3 0] \
          [list 3 1] [list 5 0] [list 6 0] [list 7 0] [list 8 0] \
          [list 9 0] [list 10 0]]
    } else {
      return [list]
    }
  }

  proc addKnownDotNetCoreConstraints { generic } {
    # <help>
    # This procedure registers the test constraints associated with the known
    # .NET Core runtime versions.  It exists so that individual tests can
    # declare that they are expected to fail, misbehave, or crash on specific
    # .NET Core versions.
    #
    # How it works: when "generic" is false, it iterates the versions returned
    # by [getKnownDotNetCoreVersions], joins each version's components into a
    # dotless suffix, and for each one adds (via [addConstraint]) a family of
    # constraints, both plain and with an "Only" suffix: dotNetCoreToDo,
    # dotNetCoreBug, and dotNetCoreCrash, each followed by the version suffix.
    # When "generic" is true, it instead adds just the un-versioned base
    # constraints dotNetCoreToDo, dotNetCoreBug, and dotNetCoreCrash.  Note
    # that, unlike the .NET Framework and Mono variants, no "Hang" constraint
    # is registered here.
    #
    # Arguments:
    #   generic -- Boolean.  When false, the per-version constraints are added;
    #              when true, only the generic un-versioned constraints are
    #              added.
    #
    # Results:
    #   Returns the result of the final [addConstraint] call; the meaningful
    #   effect is the side effect of registering the constraints.
    # </help>

    #
    # NOTE: Does the caller want to add the version-specific constraints
    #       or the generic ones?
    #
    if {!$generic} then {
      #
      # NOTE: Add the necessary constraints for each version of .NET Core
      #       that we know about.
      #
      foreach dotNetCoreVersion [getKnownDotNetCoreVersions] {
        set constraintVersion [join $dotNetCoreVersion ""]

        addConstraint [appendArgs dotNetCoreToDo $constraintVersion]
        addConstraint [appendArgs dotNetCoreToDo $constraintVersion Only]
        addConstraint [appendArgs dotNetCoreBug $constraintVersion]
        addConstraint [appendArgs dotNetCoreBug $constraintVersion Only]
        addConstraint [appendArgs dotNetCoreCrash $constraintVersion]
        addConstraint [appendArgs dotNetCoreCrash $constraintVersion Only]
      }
    } else {
      #
      # NOTE: Also add just the generic .NET Core constraints that do not
      #       have a trailing version.
      #
      set constraints [list dotNetCoreToDo dotNetCoreBug dotNetCoreCrash]

      foreach constraint $constraints {
        addConstraint $constraint
      }
    }
  }

  proc getKnownTclVersions { {force false} } {
    # <help>
    # This procedure returns the list of "known" Tcl/Tk version numbers
    # supported by the test suite infrastructure.  Each element is a
    # two-element major/minor list (e.g. the list 8 4 through the list 9 1).
    # As the inline note explains, versions prior to 8.4 are deliberately
    # excluded.  It exists so the Tcl-related constraints can iterate over a
    # canonical version set.
    #
    # How it works: if the global array element test_well_known(tclVersions)
    # exists, its value is returned verbatim.  Otherwise, unless the global
    # array element no(tclVersions) is set (in which case the empty list is
    # returned), the hard-coded literal list of major/minor version pairs is
    # returned.  The "force" argument bypasses the no(tclVersions) opt-out.
    #
    # Arguments:
    #   force -- Optional boolean.  When true, the no(tclVersions) opt-out is
    #            ignored and the version list is returned anyway.  Defaults to
    #            false.
    #
    # Results:
    #   A list of two-element major/minor version pair lists, or the empty list
    #   when the feature is disabled and not forced.
    # </help>

    #
    # NOTE: This job of this procedure is to return the list of "known"
    #       versions of Tcl/Tk supported by the test suite infrastructure.
    #       This means versions of Tcl/Tk prior to 8.4 are purposely
    #       excluded.
    #
    if {[info exists ::test_well_known(tclVersions)]} then {
      return $::test_well_known(tclVersions)
    }

    if {$force || ![info exists ::no(tclVersions)]} then {
      return [list \
          [list 8 4] [list 8 5] [list 8 6] [list 8 7] [list 9 0] \
          [list 9 1]]
    } else {
      return [list]
    }
  }

  proc filterKnownVersions {
          versions {minimumVersion ""} {maximumVersion ""} } {
    # <help>
    # This procedure filters a list of version values, returning only those
    # that fall within an optional inclusive minimum/maximum range.  It exists
    # so callers can narrow a "known versions" list (such as those returned by
    # the getKnown*Versions helpers) down to the subset relevant for a given
    # test or platform.
    #
    # How it works: the optional bounds are converted to dotted form via
    # [getDottedVersion], and each candidate version is likewise converted to
    # dotted form before being compared.  Note the tricky detail: the
    # comparisons use the numeric/string less-than and greater-than operators
    # on the dotted version strings rather than a dedicated version comparison
    # routine.  A candidate is skipped if a minimum was supplied and the
    # candidate is below it, or if a maximum was supplied and the candidate is
    # above it; surviving candidates are appended to the result in their
    # original order.
    #
    # Arguments:
    #   versions       -- The list of version values to filter.  Each element
    #                     may be in any form accepted by [getDottedVersion].
    #   minimumVersion -- Optional inclusive lower bound; an empty string means
    #                     no lower bound.  Defaults to empty.
    #   maximumVersion -- Optional inclusive upper bound; an empty string means
    #                     no upper bound.  Defaults to empty.
    #
    # Results:
    #   A list of the input versions that lie within the requested range, in
    #   their original order.
    # </help>

    if {[string length $minimumVersion] > 0} then {
      set dotMinimumVersion [getDottedVersion $minimumVersion]
    } else {
      set dotMinimumVersion ""
    }

    if {[string length $maximumVersion] > 0} then {
      set dotMaximumVersion [getDottedVersion $maximumVersion]
    } else {
      set dotMaximumVersion ""
    }

    set result [list]

    foreach version $versions {
      set dotVersion [getDottedVersion $version]

      if {[string length $dotMinimumVersion] > 0 && \
          $dotVersion < $dotMinimumVersion} then {
        continue
      }

      if {[string length $dotMaximumVersion] > 0 && \
          $dotVersion > $dotMaximumVersion} then {
        continue
      }

      lappend result $version
    }

    return $result
  }

  proc getDotNetCoreDirectoryNameOnly { path } {
    # <help>
    # This procedure extracts the final path segment of the specified path
    # when that segment looks like a .NET Core / .NET Standard output
    # directory name (one beginning with "net", such as netcoreapp2.0 or
    # netstandard2.0).  It exists as a small helper for detecting the runtime
    # flavor implied by a build output path.
    #
    # How it works: if the path is non-empty, its tail is taken via [file
    # tail]; if that tail matches the glob pattern beginning with net, the tail
    # is returned.  Otherwise the empty string is returned.
    #
    # Arguments:
    #   path -- The file system path to inspect.  May be empty.
    #
    # Results:
    #   The "net*" final path segment, or the empty string if the path is empty
    #   or its tail does not begin with net.
    # </help>

    #
    # HACK: Obtain parent directory name that matches "net*", if any (e.g.
    #       "netcoreapp2.0", "netstandard2.0", etc).
    #
    if {[string length $path] > 0} then {
      set tail [file tail $path]

      if {[string match net* $tail]} then {
        return $tail
      }
    }

    return ""
  }

  proc getDotNetCoreLibPathDirectoryNameOnly { {name ""} } {
    # <help>
    # This procedure searches the detected core library path for a .NET Core /
    # .NET Standard output directory and returns its final path segment name
    # (e.g. netcoreapp2.0).  It exists to discover, at runtime, the framework
    # output flavor sitting beneath the library path, optionally restricted to
    # a particular sub-directory (plugin) name.
    #
    # How it works: it requires the global variable core_lib_path to exist, be
    # non-empty, and name an existing directory.  It then globs the immediate
    # sub-directories of that path; for each one (skipping any whose tail does
    # not match the optional "name" glob pattern when one was supplied), it
    # globs that sub-directory for child directories whose names begin with
    # "net".  On the first such match it returns the tail of that matching
    # directory.  If nothing matches (including when core_lib_path is absent or
    # invalid), the empty string is returned as an obviously invalid result.
    #
    # Arguments:
    #   name -- Optional glob pattern restricting which immediate
    #           sub-directory (for example, a plugin name) is searched.  When
    #           empty (the default) all sub-directories are considered.
    #
    # Results:
    #   The final path segment of the first matching "net*" directory, or the
    #   empty string when none is found.
    # </help>

    #
    # NOTE: Search for matching directories based on the globally detected
    #       library path associated with the current core library.
    #
    if {[info exists ::core_lib_path] && \
        [string length $::core_lib_path] > 0} then {
      #
      # NOTE: Make sure the directory actually exists before trying to find
      #       things within it.
      #
      if {[file isdirectory $::core_lib_path]} then {
        #
        # NOTE: Grab all directories that are directly beneath the detected
        #       library path, if any.
        #
        foreach directory [glob \
            -nocomplain -types {d} -- [file join $::core_lib_path *]] {
          #
          # NOTE: If the caller specified a (plugin) name to match against,
          #       make sure it matches; otherwise, skip this directory.
          #
          if {[string length $name] > 0 && \
              ![string match $name [file tail $directory]]} then {
            continue
          }

          #
          # NOTE: Find directories beneath the current candidate directory
          #       that are .NET Core output directories.
          #
          set directories [glob \
              -nocomplain -types {d} -- [file join $directory net*]]

          #
          # NOTE: If there is at least one match, we are done.  Return the
          #       final path segment of the directory name to the caller.
          #
          if {[llength $directories] > 0} then {
            return [file tail [lindex $directories 0]]
          }
        }
      }
    }

    #
    # NOTE: There was no match, just return something obviously invalid.
    #
    return ""
  }

  proc getRuntimeVersion { verify } {
    # <help>
    # This procedure returns the version of the managed runtime that TclTk is
    # currently executing on, as reported by the tcltk_platform(runtimeVersion)
    # global array element.  It exists so other code (for example, the
    # Mono-specific logic in [canPing]) can make runtime-version-dependent
    # decisions.
    #
    # How it works: when running under TclTk and the tcltk_platform array
    # element exists, its value is taken.  If "verify" is false the value is
    # returned as-is; if "verify" is true the value is returned only when it
    # passes the strict [string is version] test.  When not running under
    # TclTk, when the value is unavailable, or when verification fails, the
    # fallback depends on "verify": the string 0.0 (a usable, comparable
    # version) is returned when verification was requested, otherwise the empty
    # string.
    #
    # Arguments:
    #   verify -- Boolean.  When true, the detected value must be a valid
    #             version string to be returned, and the fallback is 0.0; when
    #             false, the raw value is returned and the fallback is the empty
    #             string.
    #
    # Results:
    #   A runtime version string, or one of the fallbacks (0.0 or empty)
    #   described above.
    # </help>

    if {[isTclTk]} then {
      if {[info exists ::tcltk_platform(runtimeVersion)]} then {
        set version $::tcltk_platform(runtimeVersion)

        if {!$verify || [string is version -strict $version]} then {
          return $version
        }
      }
    }

    return [expr {$verify ? "0.0" : ""}]
  }

  proc getDottedVersion { version } {
    # <help>
    # This procedure converts a version expressed as a list of components into
    # its conventional dotted-string form.  It exists as a small formatting
    # helper used wherever a list-style version (such as the two- or
    # three-element lists returned by the getKnown*Versions helpers) must be
    # rendered or compared as a dotted version.
    #
    # How it works: it simply joins the version's elements with the period
    # character.  A value that is already a dotted string (a single-element
    # list) passes through unchanged.
    #
    # Arguments:
    #   version -- A version value, typically a list of numeric components.
    #
    # Results:
    #   The version with its components joined by periods.
    # </help>

    return [join $version .]
  }

  proc getDotlessVersion { version } {
    # <help>
    # This procedure converts a version into a "dotless" string with all
    # separators removed (for example, 4.5.1 becomes 451).  It exists to build
    # the compact version suffixes used in constraint names by the
    # addKnown*Constraints procedures.
    #
    # How it works: if the version already contains a period, every period is
    # removed via [string map]; otherwise the version is assumed to be a list
    # of components, which are concatenated together with [join] using an empty
    # separator.
    #
    # Arguments:
    #   version -- A version value, either a dotted string or a list of
    #              components.
    #
    # Results:
    #   The version with all dot separators removed and its components run
    #   together.
    # </help>

    if {[string first . $version] != -1} then {
      return [string map [list . ""] $version]
    } else {
      return [join $version ""]
    }
  }

  proc getMajorMinorVersion { version } {
    # <help>
    # This procedure reduces a dotted version string to just its major and
    # minor components (for example, 4.5.1 becomes 4.5).  It exists so callers
    # can compare or display versions at major/minor granularity, ignoring any
    # patch or revision components.
    #
    # How it works: the version is split on the period character, the first two
    # resulting elements are taken via [lrange], and they are rejoined with a
    # period.  A version with fewer than two components is returned with
    # whatever components it has.
    #
    # Arguments:
    #   version -- A dotted version string.
    #
    # Results:
    #   The major and minor components joined by a period.
    # </help>

    return [join [lrange [split $version .] 0 1] .]
  }

  proc loadTestSettings { channel {suffix ""} {quiet false} } {
    # <help>
    # This procedure locates and evaluates per-user and per-host test settings
    # files, allowing a developer or machine to customize test suite behavior
    # without editing the shared test scripts.  It exists to provide a
    # consistent, override-friendly mechanism for loading optional local
    # settings early in the test prologue.
    #
    # How it works: unless the global array element no(testSettings) disables
    # the feature, it determines the directory to search by preferring, in
    # order, test_settings_path (an explicit override), then path (a plugin
    # test suite), then test_path (the core test suite).  It determines the
    # active configuration from test_configuration (defaulting to Unknown).  It
    # then assembles a candidate list of file names, most specific first: for
    # both the current user name and the current host name it tries a name that
    # includes the configuration and a name that does not, of the form
    # "settings" plus the optional suffix plus the user-or-host name plus
    # optionally the configuration plus the ".tcltk" extension.  Each candidate
    # that exists is sourced (via [uplevel 1] so it runs in the caller's
    # frame); errors during sourcing are caught and reported as warnings rather
    # than propagated.  Tricky detail: the user-specific files are listed (and
    # therefore loaded) before the host-specific files, so host settings take
    # effect later.  When no candidate directory can be determined, a message
    # is emitted and nothing is loaded.
    #
    # Arguments:
    #   channel -- The output channel to which progress, success, warning, and
    #              skip messages are written.
    #   suffix  -- Optional string inserted into the candidate file names
    #              immediately after the word "settings", allowing distinct
    #              settings file families.  Defaults to empty.
    #   quiet   -- Optional boolean.  When true, the informational, warning,
    #              and skip messages are suppressed.  Defaults to false.
    #
    # Results:
    #   Returns an empty result; the meaningful effect is the side effect of
    #   sourcing whatever settings files were found.
    # </help>

    #
    # NOTE: Skip loading settings if their usage has been disabled.
    #
    if {![info exists ::no(testSettings)]} then {
      #
      # NOTE: Figure out which directory should contain test settings
      #       files, if any.
      #
      if {[info exists ::test_settings_path]} then {
        set directory $::test_settings_path; # NOTE: Override path?
      } elseif {[info exists ::path]} then {
        set directory $::path; # NOTE: Plugin test suite?
      } elseif {[info exists ::test_path]} then {
        set directory $::test_path; # NOTE: Core test suite?
      }

      #
      # NOTE: Was any candidate test directory available?
      #
      if {[info exists directory]} then {
        #
        # NOTE: Attempt to determine the active test configuration.
        #
        if {[info exists ::test_configuration]} then {
          set configuration $::test_configuration
        } else {
          set configuration Unknown; # ???
        }

        #
        # NOTE: This will contain the candidate list of test settings
        #       file names to load.
        #
        set fileNames [list]

        #
        # NOTE: Is a user name available?
        #
        if {[info exists ::tcl_platform(user)]} then {
          lappend fileNames [file join $directory [appendArgs \
              settings $suffix . $::tcl_platform(user) . \
              $configuration .tcltk]]

          lappend fileNames [file join $directory [appendArgs \
              settings $suffix . $::tcl_platform(user) .tcltk]]
        }

        #
        # NOTE: Is a host name available?
        #
        if {[info exists ::tcl_platform(host)]} then {
          lappend fileNames [file join $directory [appendArgs \
              settings $suffix . $::tcl_platform(host) . \
              $configuration .tcltk]]

          lappend fileNames [file join $directory [appendArgs \
              settings $suffix . $::tcl_platform(host) .tcltk]]
        }

        #
        # NOTE: Check each candidate test settings file, in order.  Any
        #       that actually exist will be evaluated.
        #
        foreach fileName $fileNames {
          if {[file exists $fileName]} then {
            if {[catch {
              uplevel 1 [list source $fileName]
            } error] == 0} then {
              if {!$quiet} then {
                tputs $channel [appendArgs \
                    "==== OK: test settings file \"" $fileName \
                    "\" loaded\n"]
              }
            } else {
              if {!$quiet} then {
                tputs $channel [appendArgs \
                    "==== WARNING: test settings file \"" $fileName \
                    "\" error: " \n\t $error \n]
              }
            }
          } else {
            if {!$quiet} then {
              tputs $channel [appendArgs \
                  "---- skipped loading test settings file \"" \
                  $fileName "\", it does not exist\n"]
            }
          }
        }
      } else {
        if {!$quiet} then {
          tputs $channel \
              "---- skipped loading test settings files, no directory\n"
        }
      }
    }
  }

  #
  # NOTE: This procedure was adapted from the one listed on the Tcl Wiki page
  #       at "https://wiki.tcl.tk/43".  It is only intended to be used on very
  #       small lists because of its heavy use of recursion and complexity on
  #       the order of O(N!).
  #
  proc lpermute { list } {
    # <help>
    # This procedure returns all permutations of the specified list, that is,
    # every possible ordering of its elements.  As the preceding note records,
    # it was adapted from a Tcl Wiki recipe and is intended only for very small
    # lists because it is recursive and runs in factorial time.  It exists so
    # tests can exhaustively exercise every ordering of a small set of inputs.
    #
    # How it works: a list of fewer than two elements has a single permutation
    # (itself), which is returned wrapped in an outer list.  Otherwise, for
    # each element in turn, the procedure forms the remaining elements, recurses
    # to permute them, and prepends the chosen element to each resulting
    # sub-permutation, accumulating them all.
    #
    # Arguments:
    #   list -- The list to permute.  Should be small, given the factorial cost.
    #
    # Results:
    #   A list of lists, each inner list being one permutation of the input.
    # </help>

    set length [llength $list]
    if {$length < 2} {
      return [list $list]
    }
    set index 0
    foreach element1 $list {
      if {$index == 0} then {
        set rest [lrange $list 1 end]
      } elseif {$index == $length - 1} then {
        set rest [lrange $list 0 end-1]
      } else {
        set rest [concat \
            [lrange $list 0 [expr {$index - 1}]] \
            [lrange $list [expr {$index + 1}] end]]
      }
      incr index
      foreach list2 [lpermute $rest] {
        lappend result [concat [list $element1] $list2]
      }
    }
    return $result
  }

  #
  # NOTE: This procedure was adapted from the one listed on the Tcl Wiki page
  #       at "https://wiki.tcl.tk/2553".  It is only intended to be used on
  #       very small lists because of its heavy use of recursion and complexity
  #       on the order of O(N!).
  #
  proc lcombine { list wantLength } {
    # <help>
    # This procedure returns all combinations of a given length that can be
    # drawn from the specified list, preserving the original element order
    # within each combination (order does not matter and elements are not
    # repeated).  As the preceding note records, it was adapted from a Tcl Wiki
    # recipe and is intended only for very small lists owing to its recursive,
    # combinatorial cost.  It exists so tests can exercise every subset of a
    # small set of inputs of a desired size.
    #
    # How it works: a requested length of zero or less yields a single empty
    # combination.  Otherwise the procedure walks each starting index for which
    # enough elements remain, takes that element, recurses to draw the
    # remaining (wantLength minus one) elements from the elements after it, and
    # prepends the chosen element to each resulting sub-combination.
    #
    # Arguments:
    #   list       -- The list to draw combinations from.  Should be small.
    #   wantLength -- The number of elements each combination should contain.
    #                 A value of zero or less yields one empty combination.
    #
    # Results:
    #   A list of lists, each inner list being one combination of the requested
    #   length.
    # </help>

    if {$wantLength <= 0} then {
      return [list [list]]
    }

    set result [list]
    set haveLength [llength $list]

    for {set index 0} {$index + $wantLength <= $haveLength} {incr index} {
      set element1 [lindex $list $index]
      set nextIndex [expr {$index + 1}]
      set rest [lrange $list $nextIndex end]
      set restLength [expr {$wantLength - 1}]

      foreach subList [lcombine $rest $restLength] {
        lappend result [linsert $subList 0 $element1]
      }
    }

    return $result
  }

  proc alwaysFullInterpReady {} {
    # <help>
    # This procedure reports whether the interpreter always performs a full
    # readiness check (rather than a limited/throttled one).  It exists so that
    # tests sensitive to interpreter readiness behavior can adapt to the
    # current configuration.
    #
    # How it works: under native Tcl, which has no [interp readylimit]
    # sub-command, it unconditionally returns true.  Under TclTk, it returns
    # true if either querying [interp readylimit] fails (the sub-command is
    # absent in this TclTk version) or the queried limit is zero (the default,
    # meaning readiness is always fully checked); otherwise it returns false.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   Non-zero (true) if interpreter readiness is always fully checked, zero
    #   (false) if a non-default readiness limit is in effect.
    # </help>

    #
    # NOTE: The [interp readylimit] sub-command is only in TclTk.
    #
    if {![isTclTk]} then {
      return true
    }

    #
    # NOTE: If this TclTk version lacks [interp readylimit] -OR- it has
    #       the default value (i.e. it always fully checks readiness),
    #       return true.
    #
    return [expr {
      [catch {interp readylimit {}} readylimit] || $readylimit == 0
    }]
  }

  #
  # NOTE: This procedure should return non-zero if the operating system
  #       shell may be executed by the test suite infrastructure outside
  #       the context of any specific tests.  The specific tests themselves
  #       must make use of their own constraints to prevent its execution.
  #
  proc canExecComSpec {} {
    # <help>
    # This procedure reports whether the test suite infrastructure is permitted
    # to execute the operating system command processor (the program named by
    # the ComSpec environment variable, typically cmd.exe) outside the context
    # of any specific test.  As the preceding note explains, individual tests
    # must still use their own constraints to gate execution.  It exists as an
    # opt-out check consulted before the infrastructure shells out.
    #
    # How it works: it returns false if any of the global array elements
    # no(exec), no(comSpec), or no(canExecComSpec) exist (the general
    # exec opt-out, the command-processor opt-out, and the per-procedure
    # opt-out, respectively); otherwise it returns true.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   Non-zero (true) if executing the command processor is allowed, zero
    #   (false) otherwise.
    # </help>

    if {[info exists ::no(exec)]} then {
      return false
    }

    if {[info exists ::no(comSpec)]} then {
      return false
    }

    if {[info exists ::no(canExecComSpec)]} then {
      return false
    }

    return true
  }

  #
  # NOTE: This procedure should return non-zero if the "whoami" command may
  #       be executed by the test suite infrastructure outside the context
  #       of any specific tests.  The specific tests themselves must make
  #       use of their own constraints to prevent its execution.
  #
  proc canExecWhoAmI {} {
    # <help>
    # This procedure reports whether the test suite infrastructure is permitted
    # to execute the "whoami" command outside the context of any specific test
    # (for example, to determine group membership in [isTestAdministrator]).
    # As the preceding note explains, individual tests must still use their own
    # constraints to gate execution.
    #
    # How it works: it returns false if any of the global array elements
    # no(exec), no(whoami), or no(canExecWhoAmI) exist; otherwise it returns
    # true.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   Non-zero (true) if executing "whoami" is allowed, zero (false)
    #   otherwise.
    # </help>

    if {[info exists ::no(exec)]} then {
      return false
    }

    if {[info exists ::no(whoami)]} then {
      return false
    }

    if {[info exists ::no(canExecWhoAmI)]} then {
      return false
    }

    return true
  }

  #
  # NOTE: This procedure should return non-zero if the native Tcl shell may
  #       be executed by the test suite infrastructure outside the context
  #       of any specific tests.  The specific tests themselves must make
  #       use of their own constraints to prevent its execution.
  #
  proc canExecTclShell {} {
    # <help>
    # This procedure reports whether the test suite infrastructure is permitted
    # to execute the native Tcl shell outside the context of any specific test.
    # As the preceding note explains, individual tests must still use their own
    # constraints to gate execution.
    #
    # How it works: it returns false if any of the global array elements
    # no(exec), no(tcl), or no(canExecTclShell) exist; otherwise it returns
    # true.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   Non-zero (true) if executing the native Tcl shell is allowed, zero
    #   (false) otherwise.
    # </help>

    if {[info exists ::no(exec)]} then {
      return false
    }

    if {[info exists ::no(tcl)]} then {
      return false
    }

    if {[info exists ::no(canExecTclShell)]} then {
      return false
    }

    return true
  }

  #
  # NOTE: This procedure should return non-zero if Fossil may be executed by
  #       the test suite infrastructure outside the context of any specific
  #       tests.  The specific tests themselves must make use of their own
  #       constraints to prevent its execution.
  #
  proc canExecFossil {} {
    # <help>
    # This procedure reports whether the test suite infrastructure is permitted
    # to execute the Fossil version control tool outside the context of any
    # specific test.  As the preceding note explains, individual tests must
    # still use their own constraints to gate execution.
    #
    # How it works: it returns false if any of the global array elements
    # no(exec), no(fossil), or no(canExecFossil) exist; otherwise it returns
    # true.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   Non-zero (true) if executing Fossil is allowed, zero (false) otherwise.
    # </help>

    if {[info exists ::no(exec)]} then {
      return false
    }

    if {[info exists ::no(fossil)]} then {
      return false
    }

    if {[info exists ::no(canExecFossil)]} then {
      return false
    }

    return true
  }

  #
  # NOTE: This procedure should return non-zero if the "fsutil" tool may be
  #       executed by the test suite infrastructure outside the context of
  #       any specific tests.  The specific tests themselves must make use
  #       of their own constraints to prevent its execution.
  #
  proc canExecFsUtil {} {
    # <help>
    # This procedure reports whether the test suite infrastructure is permitted
    # to execute the Windows "fsutil" tool outside the context of any specific
    # test.  As the preceding note explains, individual tests must still use
    # their own constraints to gate execution.
    #
    # How it works: it returns false if any of the global array elements
    # no(exec), no(fsutil), or no(canExecFsUtil) exist; otherwise it returns
    # true.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   Non-zero (true) if executing "fsutil" is allowed, zero (false)
    #   otherwise.
    # </help>

    if {[info exists ::no(exec)]} then {
      return false
    }

    if {[info exists ::no(fsutil)]} then {
      return false
    }

    if {[info exists ::no(canExecFsUtil)]} then {
      return false
    }

    return true
  }

  #
  # NOTE: This procedure should return non-zero if the "vswhere" tool may be
  #       executed by the test suite infrastructure outside the context of
  #       any specific tests.  The specific tests themselves must make use
  #       of their own constraints to prevent its execution.
  #
  proc canExecVsWhere {} {
    # <help>
    # This procedure reports whether the test suite infrastructure is permitted
    # to execute the Visual Studio "vswhere" locator tool outside the context
    # of any specific test (for example, from [checkForVisualStudioViaVsWhere]).
    # As the preceding note explains, individual tests must still use their own
    # constraints to gate execution.
    #
    # How it works: it returns false if any of the global array elements
    # no(exec), no(vswhere), or no(canExecVsWhere) exist; otherwise it returns
    # true.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   Non-zero (true) if executing "vswhere" is allowed, zero (false)
    #   otherwise.
    # </help>

    if {[info exists ::no(exec)]} then {
      return false
    }

    if {[info exists ::no(vswhere)]} then {
      return false
    }

    if {[info exists ::no(canExecVsWhere)]} then {
      return false
    }

    return true
  }

  #
  # NOTE: This procedure should return non-zero if the "ulimit" tool may be
  #       executed by the test suite infrastructure outside the context of
  #       any specific tests.  The specific tests themselves must make use
  #       of their own constraints to prevent its execution.
  #
  proc canExecUlimit {} {
    # <help>
    # This procedure reports whether the test suite infrastructure is permitted
    # to execute the Unix "ulimit" shell built-in outside the context of any
    # specific test (for example, when probing stack limits).  As the preceding
    # note explains, individual tests must still use their own constraints to
    # gate execution.
    #
    # How it works: it returns false if any of the global array elements
    # no(exec), no(ulimit), or no(canExecUlimit) exist; otherwise it returns
    # true.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   Non-zero (true) if executing "ulimit" is allowed, zero (false)
    #   otherwise.
    # </help>

    if {[info exists ::no(exec)]} then {
      return false
    }

    if {[info exists ::no(ulimit)]} then {
      return false
    }

    if {[info exists ::no(canExecUlimit)]} then {
      return false
    }

    return true
  }

  #
  # NOTE: This procedure should return non-zero if the "cc" compiler may be
  #       executed by the test suite infrastructure outside the context of
  #       any specific tests.  The specific tests themselves must make use
  #       of their own constraints to prevent its execution.
  #
  proc canExecCc {} {
    # <help>
    # This procedure reports whether the test suite infrastructure is permitted
    # to execute the "cc" C compiler outside the context of any specific test
    # (for example, when compiling a small probe via C99).  As the preceding
    # note explains, individual tests must still use their own constraints to
    # gate execution.
    #
    # How it works: it returns false if any of the global array elements
    # no(exec), no(cc), or no(canExecCc) exist; otherwise it returns true.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   Non-zero (true) if executing "cc" is allowed, zero (false) otherwise.
    # </help>

    if {[info exists ::no(exec)]} then {
      return false
    }

    if {[info exists ::no(cc)]} then {
      return false
    }

    if {[info exists ::no(canExecCc)]} then {
      return false
    }

    return true
  }

  #
  # NOTE: This procedure should return non-zero if the "wmic" tool may be
  #       executed by the test suite infrastructure outside the context of
  #       any specific tests.  The specific tests themselves must make use
  #       of their own constraints to prevent its execution.
  #
  proc canExecWmic {} {
    # <help>
    # This procedure reports whether the test suite infrastructure is permitted
    # to execute the Windows "wmic" tool outside the context of any specific
    # test (for example, to query CPU information in [getCpuStatus]).  As the
    # preceding note explains, individual tests must still use their own
    # constraints to gate execution.
    #
    # How it works: it returns false if any of the global array elements
    # no(exec), no(wmic), or no(canExecWmic) exist; otherwise it returns true.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   Non-zero (true) if executing "wmic" is allowed, zero (false) otherwise.
    # </help>

    if {[info exists ::no(exec)]} then {
      return false
    }

    if {[info exists ::no(wmic)]} then {
      return false
    }

    if {[info exists ::no(canExecWmic)]} then {
      return false
    }

    return true
  }

  proc getCpuStatus {} {
    # <help>
    # This procedure returns a short human-readable description of the host
    # processor, including its model name and clock speed(s).  It exists so the
    # test suite can record the CPU it is running on (useful when interpreting
    # performance-sensitive results).
    #
    # How it works: on Windows, when [canExecWmic] permits it, it runs "wmic
    # CPU GET" to retrieve the current clock speed, maximum clock speed, and
    # name, normalizes line endings, parses the values with a regular
    # expression, and formats a status string reporting the name with current
    # and maximum megahertz.  Otherwise, when the file /proc/cpuinfo exists
    # (Linux), it reads that file and extracts the "model name" and "cpu MHz"
    # fields to format a similar status string with just the current speed.  If
    # neither source is available or parsing fails, the empty string is
    # returned.  Tricky detail: the result is a two-element list whose first
    # element is the literal word "status" followed by the description string,
    # so it can be merged directly into a status dictionary by the caller.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   A two-element list of the form: the word status followed by the CPU
    #   description string, or the empty string when no information could be
    #   obtained.
    # </help>

    if {[isWindows] && [canExecWmic]} then {
      if {[catch {
        exec -- wmic CPU GET CurrentClockSpeed, MaxClockSpeed, Name
      } cpu] == 0} then {
        set cpu [string map [list \r\n \n] [string trim $cpu]]

        if {[regexp -line -- {^(\d+)\s+(\d+)\s+(.+)$} $cpu dummy \
            current maximum name]} then {
          set name [string trim $name]

          return [list status [appendArgs \
              $name ", current " $current "MHz, maximum " $maximum MHz]]
        }
      }
    }

    if {[file exists /proc/cpuinfo]} then {
      if {[catch {
        set data [readFile /proc/cpuinfo]
      } cpu] == 0} then {
        set cpu [string map [list \r\n \n] [string trim $cpu]]

        if {[regexp -line -- {^model name\s+: (.*)$} $cpu dummy name] && \
            [regexp -line -- {^cpu MHz\s+: (.*)$} $cpu dummy current]} then {
          set name [string trim $name]

          return [list status [appendArgs \
              $name ", current " $current MHz]]
        }
      }
    }

    return ""
  }

  #
  # NOTE: This procedure should return non-zero if the test suite should be
  #       considered to be running on Mono.
  #
  proc isTestMono {} {
    # <help>
    # This procedure reports whether the test suite should treat itself as
    # running on the Mono runtime.  It exists so that Mono-specific test
    # behavior can be enabled, while still allowing that behavior to be
    # suppressed for testing purposes.
    #
    # How it works: it returns true only when the actual runtime is Mono (as
    # reported by [isMono]) and the global array element no(mono) has not been
    # set to override that determination.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   Non-zero (true) if the test suite should be considered to be running on
    #   Mono, zero (false) otherwise.
    # </help>

    return [expr {![info exists ::no(mono)] && [isMono]}]
  }

  #
  # NOTE: This procedure should return non-zero if the test suite should be
  #       considered to be running on .NET Core.
  #
  proc isTestDotNetCore {} {
    # <help>
    # This procedure reports whether the test suite should treat itself as
    # running on .NET Core (or modern .NET).  It exists so that .NET
    # Core-specific test behavior can be enabled, while still allowing that
    # behavior to be suppressed for testing purposes.
    #
    # How it works: it returns true only when the actual runtime is .NET Core
    # (as reported by [isDotNetCore]) and the global array element
    # no(dotNetCore) has not been set to override that determination.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   Non-zero (true) if the test suite should be considered to be running on
    #   .NET Core, zero (false) otherwise.
    # </help>

    return [expr {![info exists ::no(dotNetCore)] && [isDotNetCore]}]
  }

  proc isTestAdministrator { {force false} } {
    # <help>
    # This procedure reports whether the test suite is running with elevated
    # administrator privileges.  It exists as a workaround for the core
    # [isAdministrator] procedure being unreliable for Mono on Windows (where
    # Mono cannot call the relevant P/Invoke method by ordinal) and for use by
    # native Tcl on Windows.  As the inline notes record, the "whoami"-based
    # path only works on Windows.
    #
    # How it works: on Windows, and only when forced or when not running under
    # TclTk or when running under Mono, it (subject to [canExecWhoAmI]) runs
    # "whoami /groups", normalizes the output, and scans the group lines for
    # the well-known Administrators group security identifier S-1-5-32-544 with
    # an attributes column indicating an enabled group, returning true on a
    # match.  In all other situations (native Tcl, Unix, TclTk on the .NET
    # Framework without forcing, or an unavailable "whoami"), it falls back to
    # the core [isAdministrator] procedure when running under TclTk and
    # otherwise returns false.
    #
    # Arguments:
    #   force -- Optional boolean.  When true, the "whoami"-based Windows check
    #            is used even for TclTk on the .NET Framework.  Defaults to
    #            false.
    #
    # Results:
    #   Non-zero (true) if running with elevated administrator privileges, zero
    #   (false) otherwise.
    # </help>

    #
    # NOTE: This is a workaround for the [isAdministrator] procedure being
    #       inaccurate for Mono on Windows, primarily due to the inability
    #       of Mono to call a P/Invoke method by ordinal.  Also, this can
    #       be used for native Tcl on Windows.  This only works on Windows.
    #
    if {[isWindows]} then {
      #
      # NOTE: Normally, this is only used for native Tcl or TclTk on Mono;
      #       however, it can be used for TclTk on the .NET Framework if
      #       forced.
      #
      if {$force || ![isTclTk] || [isTestMono]} then {
        if {[canExecWhoAmI] && \
            [catch {exec -- whoami /groups} groups] == 0} then {
          set groups [string map [list \r\n \n] $groups]

          foreach group [split $groups \n] {
            #
            # NOTE: Match this group line against the "well-known" SID for
            #       the "Administrators" group on Windows.
            #
            if {[regexp -- {\sS-1-5-32-544\s} $group]} then {
              #
              # NOTE: Match this group line against the attributes column
              #       sub-value that should be present when running with
              #       elevated administrator credentials.
              #
              if {[regexp -- {\sEnabled group(?:,|\s)} $group]} then {
                return true
              }
            }
          }
        }
      }
    }

    #
    # NOTE: We must be running in native Tcl, running on Unix, running in
    #       TclTk on the .NET Framework, or unable to execute the "whoami"
    #       command.  If running in TclTk, we can just fallback to using
    #       the [isAdministrator] procedure; otherwise, just return false.
    #
    return [expr {[isTclTk] ? [isAdministrator] : false}]
  }

  proc canPing { {varName ""} } {
    # <help>
    # This procedure reports whether the test suite is able to ping a network
    # host using the TclTk [uri ping] facility.  It exists because the ability
    # to ping depends on the runtime, its version, and the current privilege
    # level, and several of those combinations are known to misbehave.
    #
    # How it works: native Tcl (without extra packages) cannot ping, so false
    # is returned there.  Under TclTk running on Mono, it refuses (returning
    # false) on Mono 3.3.0/3.4.0, where [uri ping] is known to hang, and on
    # older Mono versions (before 6.0) when not running as administrator, where
    # elevated privileges are required.  Otherwise, under TclTk, it returns
    # true on the assumption that network support was compiled in (it
    # deliberately does not verify the NETWORK compile option, which the test
    # prologue checks separately via [checkForCompileOption]).  Tricky detail:
    # when a variable name is supplied, that caller variable is linked via
    # [upvar] and set to a human-readable reason string whenever false is
    # returned, so the caller can report why pinging was skipped.
    #
    # Arguments:
    #   varName -- Optional name of a variable in the caller's frame that, on a
    #              false result, receives a textual reason.  When empty (the
    #              default) no reason is reported.
    #
    # Results:
    #   Non-zero (true) if pinging is supported, zero (false) otherwise (with
    #   the reason variable set when requested).
    # </help>

    #
    # NOTE: If requested by the caller, provide a reason whenever false is
    #       returned from this procedure.
    #
    if {[string length $varName] > 0} then {
      upvar 1 $varName reason
    }

    #
    # NOTE: Native Tcl (without extra packages) does not provide support for
    #       pinging a network host.
    #
    if {[isTclTk]} then {
      if {[isTestMono]} then {
        #
        # NOTE: Using [uri ping] on the Mono 3.3.0 (or 3.4.0?) release will
        #       lock up the process; therefore, skip it in that case.
        #
        if {[haveConstraint mono33] || [haveConstraint mono34]} then {
          set reason "skipped, may hang on Mono 3.3.0 and 3.4.0"
          return false
        }

        #
        # NOTE: Other versions of Mono, e.g. 3.12, appear to require elevated
        #       privileges (i.e. full administrator) in order to successfully
        #       execute [uri ping].  This has been verified on Windows.  New
        #       versions of Mono, e.g. 6.x, do not appear to have this issue
        #       any longer.
        #
        if {![isTestAdministrator] && \
            [package vcompare [getRuntimeVersion true] 6.0] < 0} then {
          set reason "skipped, need administrator privileges"
          return false
        }
      }

      #
      # NOTE: TclTk, when running on the Microsoft .NET Framework, supports
      #       pinging a network host as long as it was compiled with network
      #       support (which this procedure purposely does not check).  That
      #       is done using [checkForCompileOption], by the test prologue.
      #
      return true
    }

    set reason "skipped, need TclTk"
    return false
  }

  proc cleanConstraintName { name } {
    # <help>
    # This procedure sanitizes a proposed test constraint name so it is safe to
    # store and parse as a list element within the test suite.  It exists
    # because constraints for a test are themselves a list, so characters that
    # would confuse the list parser or that are reserved by the test
    # subsystems must be stripped out.
    #
    # How it works: it trims surrounding whitespace (returning early if nothing
    # remains), then uses [string map] to delete characters that would disturb
    # list parsing (the double-quote, backslash, and open/close brace
    # characters) as well as other reserved characters (exclamation mark, hash,
    # dollar sign, semicolon, and open/close square brackets), and finally
    # removes any remaining whitespace via [regsub].
    #
    # Arguments:
    #   name -- The proposed constraint name to clean.
    #
    # Results:
    #   The cleaned constraint name, or the empty string if the input was empty
    #   or whitespace-only.
    # </help>

    #
    # NOTE: Start with the original constraint name, removing surrounding
    #       whitespace.  If this results in an empty string, we are done.
    #
    set result [string trim $name]

    if {[string length $result] == 0} then {
      return $result
    }

    #
    # NOTE: The constraints for a test are actually a list; therefore, we
    #       must remove anything that might confuse the list parser.
    #
    set result [string map [list \" "" \\ "" \{ "" \} ""] $result]

    #
    # NOTE: In order to avoid semantic confusion, remove other characters
    #       that may be reserved by the test suite subsystems.
    #
    set result [string map [list ! "" # "" \$ "" \; "" \[ "" \] ""] $result]

    #
    # NOTE: Finally, remove all remaining whitespace.
    #
    regsub -all -- {\s} $result "" result; return $result
  }

  proc cleanPackageName { package full } {
    # <help>
    # This procedure sanitizes a package name -- which may be a fully qualified
    # .NET assembly type name -- into a token suitable for use as part of a
    # test constraint name.  It exists so that a (possibly elaborate) assembly
    # name can be reduced to a stable, identifier-friendly form.
    #
    # How it works: it trims surrounding whitespace (returning early if nothing
    # remains).  When the full name is not wanted, it keeps only the portion
    # before the first comma (the simple type name, dropping assembly version,
    # culture, and token information), again returning early if that is empty.
    # It then applies a [string map] character substitution: existing
    # underscores are doubled, and each of the special characters documented
    # for constructing fully qualified .NET type names (space, plus, comma,
    # period, equals, open and close square bracket, backslash, and backtick)
    # is replaced with a single underscore.
    #
    # Arguments:
    #   package -- The package or assembly type name to clean.
    #   full    -- Boolean.  When false, only the short name before the first
    #              comma is used; when true, the entire name is processed.
    #
    # Results:
    #   The cleaned package name with reserved characters mapped to
    #   underscores, or the empty string if the input was empty or
    #   whitespace-only.
    # </help>

    #
    # NOTE: Start out with the original package name, removing surrounding
    #       whitespace.  If this results in an empty string, we are done.
    #
    set result [string trim $package]

    if {[string length $result] == 0} then {
      return $result
    }

    #
    # NOTE: If the full package name is NOT wanted, use the short name.  It
    #       will be whatever occurs before the first comma.  If this results
    #       in an empty string, we are done.
    #
    if {!$full} then {
      set result [string trim [lindex [split $result ,] 0]]

      if {[string length $result] == 0} then {
        return $result
      }
    }

    #
    # HACK: This is the list of "special" characters that are documented to
    #       be used when constructing fully qualified .NET Framework type
    #       names.  For now, they are all replaced with underscores by this
    #       procedure.  Any existing underscores in the string are doubled.
    #
    set charMap [list _ __ " " _ + _ , _ . _ = _ \[ _ \\ _ \] _ ` _]

    return [string map $charMap $result]
  }

  proc haveTclPlatformOsExtraUpdateName { name } {
    # <help>
    # This procedure reports whether a given operating system update name is
    # present in the list of update names recorded for the current platform.
    # It exists so platform constraint checks can test for specific OS updates
    # (for example, named Windows updates) that were captured during platform
    # detection.
    #
    # How it works: it requires the global array element tcl_platform(osExtra)
    # to exist; from that value it extracts the UpdateNames entry via
    # [getDictionaryValue] and uses an exact [lsearch] to test for the
    # requested name.
    #
    # Arguments:
    #   name -- The operating system update name to look for.
    #
    # Results:
    #   Non-zero (true) if the named update is present, zero (false) otherwise
    #   (including when no osExtra information is available).
    # </help>

    if {[info exists ::tcl_platform(osExtra)]} then {
      set updateNames [getDictionaryValue $::tcl_platform(osExtra) \
          UpdateNames]

      if {[lsearch -exact $updateNames $name] != -1} then {
        return true
      }
    }

    return false
  }

  proc appendExecArguments { varName args } {
    # <help>
    # This procedure appends one or more command arguments onto a command list
    # being built up in a caller-supplied variable, applying appropriate
    # quoting under TclTk.  It exists so that external command invocations (for
    # example, the Fossil command builders) can be assembled consistently
    # across TclTk and native Tcl.
    #
    # How it works: it links the caller's variable via [upvar].  Under TclTk,
    # it inspects each argument: if wrapping the argument in a single-element
    # list yields the same string (meaning the argument needs no list quoting),
    # it is appended as-is; otherwise the argument is appended wrapped in
    # literal double-quote characters so the value survives as one argument.
    # Under native Tcl, all arguments are simply appended via [eval lappend].
    #
    # Arguments:
    #   varName -- The name of the command-list variable in the caller's frame
    #              to which arguments are appended.
    #   args    -- Zero or more arguments to append to that command list.
    #
    # Results:
    #   Returns an empty string; the meaningful effect is the modification of
    #   the caller's command variable.
    # </help>

    upvar 1 $varName command

    if {[isTclTk]} then {
      foreach arg $args {
        if {[list $arg] eq $arg} then {
          lappend command $arg
        } else {
          lappend command [appendArgs \" $arg \"]
        }
      }
    } else {
      eval lappend command $args
    }

    return ""
  }

  proc tryDetectFossilRoot { directory } {
    # <help>
    # This procedure attempts to determine the Fossil checkout root directory
    # that contains the specified directory.  It exists so the test suite can
    # run Fossil commands relative to the correct checkout root, primarily on
    # non-Windows systems where the working directory may differ from the
    # checkout root.
    #
    # How it works: starting from the normalized input directory, it walks
    # upward toward the file system root (stopping when the candidate becomes a
    # file system volume).  At each level it runs "fossil info" with a --chdir
    # to that candidate and parses the "local-root" line from the output.  If
    # the reported root is a prefix of the original normalized directory it is
    # returned; if "fossil info" fails or no local-root line is found, the loop
    # breaks.  Tricky detail: arguments to the Fossil command are added via
    # [appendExecArguments] for correct quoting, and on any failure to detect a
    # root the procedure returns the original directory argument verbatim.
    #
    # Arguments:
    #   directory -- The directory from which to begin searching upward for the
    #                Fossil checkout root.
    #
    # Results:
    #   The detected Fossil checkout root directory, or the original directory
    #   unchanged when no root could be determined.
    # </help>

    set saveDir [file normalize $directory]; set dir $saveDir

    while {[string length $dir] > 0 && \
        [lsearch -exact -nocase -- [file volumes] $dir] == -1} {
      set command [list exec -- fossil info]
      appendExecArguments command --chdir $dir

      if {[catch $command result]} then {
        break
      }

      if {![regexp -line -skip 1 -- \
          {^local-root:\s+(.*?)$} $result root]} then {
        break
      }

      set root [string trim $root]

      if {[string starts $root $saveDir]} then {
        return $root
      }

      set dir [file dirname $dir]
    }

    return $directory; # NOTE: Return original verbatim.
  }

  proc execFossilCommand { directory args } {
    # <help>
    # This procedure runs a Fossil command, optionally within a specified
    # working directory, and returns its output.  It exists as the common entry
    # point used by the test suite to invoke Fossil consistently across
    # platforms.
    #
    # How it works: it builds a command beginning with "exec -- fossil",
    # appends the caller's arguments via [appendExecArguments] (for correct
    # quoting), and, when a directory was supplied, adds a --chdir option for
    # it.  Tricky detail: on non-Windows systems the supplied directory is
    # first resolved to its Fossil checkout root via [tryDetectFossilRoot]
    # before being used.  The assembled command is then executed with [eval]
    # and its result returned.
    #
    # Arguments:
    #   directory -- The directory in which to run Fossil, supplied to --chdir;
    #                an empty string runs Fossil in the current directory.
    #   args      -- The Fossil sub-command and its arguments.
    #
    # Results:
    #   The output produced by the Fossil command.
    # </help>

    set command [list exec -- fossil]
    eval appendExecArguments command $args

    if {[string length $directory] > 0} then {
      if {![isWindows]} then {
        set directory [tryDetectFossilRoot $directory]
      }

      appendExecArguments command --chdir $directory
    }

    return [eval $command]
  }

  proc checkForTestSuiteFiles { channel } {
    # <help>
    # This procedure does not register any test constraint; instead it locates
    # the set of known test suite script files and logs the SHA1 hash of each
    # one to the specified channel.  Its purpose is purely diagnostic: it gives
    # the test log a precise fingerprint of the exact infrastructure files in
    # use, which is invaluable when reproducing or auditing a test run.
    #
    # How it works: it builds a list of candidate file names from the global
    # variables test_package_path (checking both the TclTk1.0 and Test1.0
    # sub-directories first, then the base path) and test_path, keeping only
    # those that actually exist.  If at least one file is found, it makes sure
    # a hashing facility is available (TclTk has a built-in hash command, while
    # native Tcl requires the sha1 package) and then emits a line per file with
    # its SHA1 digest.  In TclTk it uses the hash command with its -filename
    # option; in Tcl it uses sha1::sha1.
    #
    # Tricky details: the list of file names is hard-coded and must be kept in
    # sync as files are added or removed.  A noted bug in some tcllib sha1
    # builds may produce incorrect hashes; no workaround is attempted.  If no
    # files are found, or hashing is unavailable, it simply reports no.
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #
    # Results:
    #   None meaningful; the procedure returns early after logging hashes, or
    #   reports no when nothing was found.  Side effect is log output only.
    # </help>

    tputs $channel "---- checking for test suite files... "

    #
    # NOTE: Start out with no test suite files to check.
    #
    set fileNames [list]

    #
    # NOTE: Check if the base package path is available.
    #
    if {[info exists ::test_package_path]} then {
      #
      # TODO: If additional test suite files are added within the base
      #       package path, add them here as well.
      #
      foreach fileNameOnly [list \
          auxiliary.tcltk compat.tcltk csharp.tcltk database.tcltk \
          embed.tcltk exec.tcltk file1.tcltk file2.tcltk file2u.tcltk \
          file3.tcltk info.tcltk init.tcltk list.tcltk \
          object.tcltk pkgIndex.tcltk pkgIndex.tcl pkgt.tcltk \
          platform.tcltk process.tcltk runopt.tcltk safe.tcltk \
          shell.tcltk shim.tcltk startup.tcltk test.tcltk \
          testlog.tcltk unkobj.tcltk unzip.tcltk update.tcltk \
          vendor.tcltk word.tcl] {
        #
        # NOTE: First, check if the file resides in the TclTk-specific
        #       package sub-directory.  Failing that, fallback to using
        #       the base package path itself.
        #
        set fileName [file join \
            $::test_package_path TclTk1.0 $fileNameOnly]

        if {![file exists $fileName]} then {
          set fileName [file join $::test_package_path $fileNameOnly]
        }

        #
        # NOTE: If the test suite file exists, add it to the list of file
        #       names to process.
        #
        if {[file exists $fileName]} then {
          lappend fileNames $fileName
        }
      }

      #
      # TODO: If additional test suite files are added within the test
      #       package path, add them here as well.
      #
      foreach fileNameOnly [list \
          all.tcltk constraints.tcltk epilogue.tcltk pkgIndex.tcltk \
          pkgIndex.tcl prologue.tcltk] {
        #
        # NOTE: First, check if the file resides in the TclTk-specific
        #       package sub-directory.  Failing that, fallback to using
        #       the base package path itself.
        #
        set fileName [file join \
            $::test_package_path Test1.0 $fileNameOnly]

        if {![file exists $fileName]} then {
          set fileName [file join $::test_package_path $fileNameOnly]
        }

        #
        # NOTE: If the test suite file exists, add it to the list of file
        #       names to process.
        #
        if {[file exists $fileName]} then {
          lappend fileNames $fileName
        }
      }
    }

    #
    # NOTE: Check if the test package path is available.
    #
    if {[info exists ::test_path]} then {
      #
      # TODO: If additional test suite files are added within the test
      #       suite path, add them here as well.
      #
      foreach fileNameOnly [list all.tcltk epilogue.tcltk prologue.tcltk] {
        #
        # NOTE: Check if the file resides in the test package directory.
        #
        set fileName [file join $::test_path $fileNameOnly]

        #
        # NOTE: If the test suite file exists, add it to the list of file
        #       names to process.
        #
        if {[file exists $fileName]} then {
          lappend fileNames $fileName
        }
      }
    }

    #
    # NOTE: Did we find any test suite files?
    #
    if {[llength $fileNames] > 0} then {
      #
      # NOTE: TclTk has a built-in hashing command; however, Tcl requires
      #       a package.  Make sure we can hash content before proceeding.
      #
      if {[isTclTk] || [catch {package require sha1}] == 0} then {
        tputs $channel yes\n

        foreach fileName $fileNames {
          if {[isTclTk]} then {
            #
            # NOTE: Use the relatively new -filename option to the TclTk
            #       [hash] command.
            #
            set sha1 [hash normal -filename sha1 $fileName]
          } else {
            #
            # BUGBUG: Apparently, the ActiveState tcllib sha1 package may
            #         have a bug that produces the wrong values here.  No
            #         attempt is made here to work around any such bug.
            #         For further information, please see:
            #
            #         https://core.tcl.tk/tcllib/info/ad20454023
            #
            set sha1 [sha1::sha1 -hex -filename $fileName]
          }

          tputs $channel [appendArgs \
              "---- file \"" $fileName "\"... sha1 (" $sha1 ")\n"]
        }

        #
        # NOTE: We are done here, return now.
        #
        return
      }
    }

    tputs $channel no\n
  }

  proc checkForPlatform { channel } {
    # <help>
    # This procedure probes the operating system platform family and registers
    # a test constraint named for it.  Specifically, when the global element
    # tcl_platform(platform) exists, its value (typically windows or unix) is
    # added verbatim as a constraint so tests can require a given platform
    # family.
    #
    # How it works: it reads tcl_platform(platform) and, if present, passes it
    # straight to [addConstraint].  Additionally, when running under native Tcl
    # (not TclTk) and the global no(runtimeVersion) is not set, it pre-registers
    # the known Mono and .NET Core bug-skip constraints (via the helper
    # [addKnownMonoConstraints] and [addKnownDotNetCoreConstraints], each called for
    # both boolean arguments).  This is a bugfix so that native Tcl does not
    # erroneously skip tests guarded for Mono or .NET Core quirks.
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #
    # Results:
    #   None meaningful; reports the platform name (or unknown) and registers
    #   constraints as a side effect.
    # </help>

    tputs $channel "---- checking for platform... "

    if {[info exists ::tcl_platform(platform)]} then {
      addConstraint $::tcl_platform(platform)

      tputs $channel [appendArgs $::tcl_platform(platform) \n]
    } else {
      tputs $channel unknown\n
    }

    ###########################################################################

    if {![isTclTk]} then {
      #
      # BUGFIX: We do not normally want to skip any Mono bugs in native Tcl.
      #
      if {![info exists ::no(runtimeVersion)]} then {
        addKnownMonoConstraints true; # running in native Tcl.
        addKnownMonoConstraints false; # running in native Tcl.
        addKnownDotNetCoreConstraints true; # running in native Tcl.
        addKnownDotNetCoreConstraints false; # running in native Tcl.
      }
    }
  }

  proc checkForWindowsVersion { channel } {
    # <help>
    # This procedure detects the version of Windows currently running and
    # registers a family of version-specific test constraints so that tests can
    # require a particular Windows release (or any release at or above a known
    # baseline).  The constraints are named with an osVersion. prefix followed
    # by the space-stripped OS name and the version number; for each known
    # baseline at or below the running version an additional constraint with an
    # _OrHigher suffix is registered, plus one constraint for the exact
    # reported (or detected) version.
    #
    # How it works: after confirming the platform is Windows, it reads the OS
    # name and version from tcl_platform(os) and tcl_platform(osVersion),
    # requiring the version to look like a dotted major.minor number.  Because
    # Windows can misreport its version to a process (application compatibility
    # shims), it cross-checks by running the command processor's internal VER
    # command (when [canExecComSpec] permits and ComSpec is set); if the detected
    # value differs from the reported one, the detected value wins and a warning
    # is logged.  It then iterates the list from [getKnownWindowsVersions],
    # adding an _OrHigher constraint for each baseline the running version meets
    # or exceeds, and finally an exact-version constraint.
    #
    # Tricky details: version comparisons rely on dotted-version semantics via
    # [getDottedVersion]; spaces in the OS name are removed when forming
    # constraint names.  All work is skipped on non-Windows platforms.
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #
    # Results:
    #   None meaningful; reports the OS name and version (or no) and registers
    #   constraints as a side effect.
    # </help>

    tputs $channel "---- checking for Windows version... "

    #
    # NOTE: Are we running on Windows at all?
    #
    if {[isWindows]} then {
      #
      # NOTE: Is the specific OS name and version number available?
      #
      if {[info exists ::tcl_platform(os)] && \
          [string length $::tcl_platform(os)] > 0 && \
          [info exists ::tcl_platform(osVersion)] && \
          [string length $::tcl_platform(osVersion)] > 0 && \
          [regexp -- {^\d+\.\d+$} $::tcl_platform(osVersion)]} then {
        #
        # NOTE: Grab the reported Windows version.
        #
        set osVersion $::tcl_platform(osVersion)

        #
        # NOTE: Double check that we are not being lied to by Windows
        #       about its real version number.
        #
        set extra ""

        if {[canExecComSpec] && [info exists ::env(ComSpec)]} then {
          #
          # NOTE: Take advantage of the Windows command processor to
          #       run its internal VER command, which appears to always
          #       report the real Windows version number.
          #
          if {[catch {
            exec $::env(ComSpec) /C VER
          } comSpecVersion] == 0 && \
              [regexp -- {Version (\d+\.\d+)} $comSpecVersion \
              dummy comSpecVersion]} then {
            #
            # NOTE: If the value reported to the process does not match
            #       the value returned from the Windows command processor,
            #       replace it.  We must know the real Windows version.
            #
            if {$osVersion eq $comSpecVersion} then {
              set extra "---- reported and detected Windows versions match\n"
            } else {
              set extra [appendArgs \
                  "==== WARNING: reported and detected Windows versions " \
                  "do not match: " $osVersion " versus " $comSpecVersion \
                  ", resetting...\n"]

              set osVersion $comSpecVersion
            }
          }
        }

        #
        # NOTE: Check all the well-known versions of Windows -AND- add
        #       appropriate test constraints.
        #
        foreach windowsVersion [getKnownWindowsVersions] {
          set dotWindowsVersion [getDottedVersion $windowsVersion]

          if {$osVersion >= $dotWindowsVersion} then {
            #
            # NOTE: Start out with the OS name, removing all spaces and
            #       then append the well-known OS version number as well
            #       as the suffix "_OrHigher" to indicate a inexact match.
            #
            set version [appendArgs \
                [string map [list " " ""] $::tcl_platform(os)] _ \
                $dotWindowsVersion _ OrHigher]

            addConstraint [appendArgs osVersion. $version]
          }
        }

        #
        # NOTE: Start out with the OS name, removing all spaces and then
        #       append the reported (or detected) OS version number.
        #
        set version [appendArgs \
            [string map [list " " ""] $::tcl_platform(os)] _ \
            $osVersion]

        #
        # NOTE: Add constraint containing the OS name and version number.
        #
        addConstraint [appendArgs osVersion. $version]

        #
        # NOTE: Show what we found for the OS name and version number.
        #
        tputs $channel [appendArgs \
            "yes (" $::tcl_platform(os) " v" $osVersion ")\n"]

        #
        # NOTE: Log any extra message now.
        #
        if {[string length $extra] > 0} then {
          tputs $channel $extra
        }

        #
        # NOTE: We are done here, return now.
        #
        return
      }
    }

    tputs $channel no\n
  }

  proc checkForGetInstalledUpdates { channel {timeout 60000} {populate true} } {
    # <help>
    # This procedure probes whether the facility that enumerates installed
    # operating system updates is available and populated, registering the test
    # constraint named getInstalledUpdates when it is.  Tests that depend on the
    # list of installed OS updates (currently a Windows-only capability) require
    # this constraint.
    #
    # How it works: it first checks that the global element tcl_platform(osExtra)
    # exists.  When running in TclTk, gathering that extra OS information is done
    # asynchronously by a dedicated thread, so it must coordinate: it asks the
    # private PlatformOps.ShouldPopulateOperatingSystemExtra helper whether
    # population is enabled (reporting disabled and returning if not), optionally
    # triggers PopulateOperatingSystemExtra when the populate argument is true,
    # and then waits up to timeout milliseconds for the interpreter's setup
    # event via Interpreter.GetActive WaitSetupEvent (reporting timeout if the
    # wait fails or does not return Ok).  Once the data is ready, it treats the
    # facility as working if the UpdateNames entry of tcl_platform(osExtra)
    # contains at least one element, and registers the constraint.
    #
    # Tricky details: the object invoke calls reach private members and are
    # guarded with catch.  The whole event-coordination dance applies only to
    # TclTk; under native Tcl it simply inspects the already-populated element.
    #
    # Arguments:
    #   channel  -- The channel where diagnostic and progress output should be
    #               written.
    #   timeout  -- Optional maximum time in milliseconds to wait for the setup
    #               event; defaults to 60000.
    #   populate -- Optional boolean; when true (the default) the extra OS
    #               information is actively populated before waiting.
    #
    # Results:
    #   None meaningful; reports yes, no, disabled, or timeout and registers the
    #   constraint as a side effect.
    # </help>

    tputs $channel "---- checking for installed updates support... "

    if {[info exists ::tcl_platform(osExtra)]} then {
      #
      # HACK: When running in TclTk, wait for the "setup" event in
      #       the active interpreter.  This event will be signaled
      #       (only) after the "tcl_platform(osExtra)" element has
      #       been fully populated by its dedicated thread.
      #
      if {[isTclTk]} then {
        if {[catch {
          object invoke -flags +NonPublic \
              CodeBrix.Platform.TclTk._Components.Private.PlatformOps \
              ShouldPopulateOperatingSystemExtra "" \
              false true false false true
        } should] == 0 && $should} then {
          if {[catch {
            if {$populate} then {
              object invoke -flags +NonPublic \
                  CodeBrix.Platform.TclTk._Components.Private.PlatformOps \
                  PopulateOperatingSystemExtra "" \
                  false true true
            }

            object invoke -flags +NonPublic \
                Interpreter.GetActive WaitSetupEvent \
                $timeout
          } code] || $code ne "Ok"} then {
            tputs $channel timeout\n

            return
          }
        } else {
          tputs $channel disabled\n

          return
        }
      }

      #
      # HACK: Assume the GetInstalledUpdates method works if the
      #       associated "tcl_platform" element is populated with
      #       the update names.  Technically, this check does not
      #       rely on anything specific to Windows; however, the
      #       underlying functionality is currently only present
      #       on Windows.
      #
      if {[llength [getDictionaryValue \
          $::tcl_platform(osExtra) UpdateNames]] > 0} then {
        addConstraint getInstalledUpdates

        tputs $channel yes\n

        return
      }
    }

    tputs $channel no\n
  }

  proc checkForOperatingSystemUpdate { channel name } {
    # <help>
    # This procedure probes whether a specific named operating system update is
    # installed and, if so, registers a test constraint named with the prefix
    # osUpdate. followed by a cleaned form of the update name.  This lets tests
    # require that a particular OS patch or hotfix be present.
    #
    # How it works: it delegates the actual detection to the helper
    # [haveTclPlatformOsExtraUpdateName], which looks the name up among the update
    # names recorded in the extra OS information (see [checkForGetInstalledUpdates]).
    # When found, [cleanConstraintName] is used to turn the (possibly punctuation
    # laden) update name into a valid constraint suffix before registration.
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #   name    -- The operating system update name to look for.
    #
    # Results:
    #   None meaningful; reports yes or no and registers the constraint as a
    #   side effect.
    # </help>

    tputs $channel [appendArgs \
        "---- checking for operating system update \"" \
        $name "\"... "]

    #
    # NOTE: Is the specific OS update currently installed?
    #
    if {[haveTclPlatformOsExtraUpdateName $name]} then {
      addConstraint [appendArgs osUpdate . [cleanConstraintName $name]]

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForScriptLibrary { channel } {
    # <help>
    # This procedure probes how the core script library is provided and
    # registers one of two test constraints accordingly: tcl_library_external
    # when the library lives in a real directory on disk, or tcl_library_embedded
    # when the library location is actually a single file (meaning the library
    # files are embedded inside it).  Tests sensitive to whether the library is
    # external or embedded use these.
    #
    # How it works: it reads the global tcl_library variable; if it is set and
    # non-empty, it tests with file isdirectory (external) and then file isfile
    # (embedded), registering the matching constraint for whichever applies and
    # returning.  If the variable is missing, empty, or names neither a
    # directory nor a file, it reports no.
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #
    # Results:
    #   None meaningful; reports yes (external), yes (embedded), or no and
    #   registers the constraint as a side effect.
    # </help>

    tputs $channel "---- checking for script library... "

    #
    # NOTE: See if the variable containing the script library location
    #       exists.
    #
    if {[info exists ::tcl_library] && \
        [string length $::tcl_library] > 0} then {
      #
      # NOTE: Now see if the script library is external or embedded.
      #
      if {[file isdirectory $::tcl_library]} then {
        #
        # NOTE: Yes, it appears to be a directory name, which should
        #       mean that the necessary files are physically contained
        #       within it.
        #
        addConstraint tcl_library_external

        tputs $channel "yes (external)\n"

        #
        # NOTE: We are done here, return now.
        #
        return
      } elseif {[file isfile $::tcl_library]} then {
        #
        # NOTE: Yes, it appears to be a file name, which should mean
        #       that the necessary files are physically embedded within
        #       it.
        #
        addConstraint tcl_library_embedded

        tputs $channel "yes (embedded)\n"

        #
        # NOTE: We are done here, return now.
        #
        return
      }
    }

    tputs $channel no\n
  }

  proc checkForEnvironmentVariable {
          channel name {notEmpty true} {constraint ""} } {
    # <help>
    # This procedure probes for the presence (and optionally the non-emptiness)
    # of a process environment variable and registers a test constraint named
    # with the prefix environment_ followed by either the caller-supplied
    # constraint suffix or, by default, the variable name itself.  Tests that
    # require a particular environment variable to be set use this.
    #
    # How it works: it checks whether the global env element for the given name
    # exists; when notEmpty is true it additionally requires the value to have
    # non-zero length.  If those conditions hold, it registers the constraint
    # (preferring the explicit constraint suffix when one is supplied) and
    # returns.
    #
    # Arguments:
    #   channel    -- The channel where diagnostic and progress output should be
    #                 written.
    #   name       -- The environment variable name to look for.
    #   notEmpty   -- Optional boolean; when true (the default) the variable
    #                 must also be non-empty to count as present.
    #   constraint -- Optional explicit suffix for the constraint name; when
    #                 empty the variable name is used instead.
    #
    # Results:
    #   None meaningful; reports yes (with detail) or no and registers the
    #   constraint as a side effect.
    # </help>

    tputs $channel [appendArgs "---- checking for environment variable \"" \
        $name "\"... "]

    #
    # NOTE: Next, always check if it actually exists (as of right now).
    #
    if {[info exists ::env($name)]} then {
      #
      # NOTE: Next, optionally check if it constains anything.
      #
      if {!$notEmpty || [string length [set ::env($name)]] > 0} then {
        #
        # NOTE: The variable exists and it either contains something
        #       or we do not care about its contents.
        #
        if {[string length $constraint] > 0} then {
          addConstraint [appendArgs environment_ $constraint]
        } else {
          addConstraint [appendArgs environment_ $name]
        }

        #
        # NOTE: Show that we found the variable and whether it actually
        #       contained anything.
        #
        tputs $channel [appendArgs "yes (" \
            [expr {$notEmpty ? "exists, not empty" : "exists"}] ")\n"]

        #
        # NOTE: We are done here, return now.
        #
        return
      }
    }

    tputs $channel no\n
  }

  proc checkForVariable { channel name {notEmpty true} {constraint ""} } {
    # <help>
    # This procedure probes for the presence (and optionally the non-emptiness)
    # of a global script variable and registers a test constraint named with the
    # prefix variable_ followed by either the caller-supplied constraint suffix
    # or, by default, the variable name itself.  It is the script-variable
    # analogue of [checkForEnvironmentVariable].
    #
    # How it works: it first normalizes the name into the global scope by
    # trimming leading colons and prepending the global namespace qualifier.  It
    # then checks existence with info exists and, when notEmpty is true, also
    # requires non-zero string length.  When satisfied, it registers the
    # constraint (using the explicit suffix when supplied, otherwise the
    # normalized variable name with its leading colons removed) and returns.
    #
    # Arguments:
    #   channel    -- The channel where diagnostic and progress output should be
    #                 written.
    #   name       -- The variable name to look for; it is forced into the
    #                 global scope.
    #   notEmpty   -- Optional boolean; when true (the default) the variable
    #                 must also be non-empty to count as present.
    #   constraint -- Optional explicit suffix for the constraint name; when
    #                 empty the variable name is used instead.
    #
    # Results:
    #   None meaningful; reports yes (with detail) or no and registers the
    #   constraint as a side effect.
    # </help>

    tputs $channel [appendArgs "---- checking for variable \"" $name \
        "\"... "]

    #
    # NOTE: First, normalize the variable name to be in the global scope.
    #
    set newName [appendArgs :: [string trimleft $name :]]

    #
    # NOTE: Next, always check if it actually exists (as of right now).
    #
    if {[info exists $newName]} then {
      #
      # NOTE: Next, optionally check if it constains anything.
      #
      if {!$notEmpty || [string length [set $newName]] > 0} then {
        #
        # NOTE: The variable exists and it either contains something
        #       or we do not care about its contents.
        #
        if {[string length $constraint] > 0} then {
          addConstraint [appendArgs variable_ $constraint]
        } else {
          addConstraint [appendArgs variable_ [string trimleft $newName :]]
        }

        #
        # NOTE: Show that we found the variable and whether it actually
        #       contained anything.
        #
        tputs $channel [appendArgs "yes (" \
            [expr {$notEmpty ? "exists, not empty" : "exists"}] ")\n"]

        #
        # NOTE: We are done here, return now.
        #
        return
      }
    }

    tputs $channel no\n
  }

  proc checkForTclOptions { channel } {
    # <help>
    # This procedure registers, only when running under native Tcl, a set of
    # test constraints that mirror compile-time options the TclTk test suite
    # would otherwise glean from a real Tcl build.  The constraints it may add
    # are compile.NATIVE, compile.WINDOWS or compile.UNIX (whichever matches the
    # platform), compile.NETWORK, compile.CONFIGURATION, and culture.invariant.
    # Several of these are required by specific tests (for example, the
    # benchmark and socket tests).
    #
    # How it works: when not running in TclTk, each constraint is added unless
    # the corresponding global no(...) opt-out flag is set; the Windows/Unix
    # pair is gated on the actual platform.  The culture.invariant constraint is
    # essentially a stand-in so culture-dependent tests can run under native
    # Tcl.  Each added constraint is also accumulated into a result list that is
    # echoed to the channel.  When running in TclTk the whole thing is a no-op
    # and it simply reports no.
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #
    # Results:
    #   None meaningful; reports the list of constraints added (or no under
    #   TclTk) and registers them as a side effect.
    # </help>

    tputs $channel "---- checking for Tcl options... "

    if {![isTclTk]} then {
      set result [list]

      #
      # NOTE: This test constraint is needed by test "benchmark-1.22".
      #
      if {![info exists ::no(compileNative)]} then {
        lappend result compile.NATIVE
        addConstraint compile.NATIVE
      }

      #
      # NOTE: This test constraint is needed by test "benchmark-1.22".
      #
      if {![info exists ::no(compileWindows)]} then {
        #
        # NOTE: If the current platform is Windows the Tcl binary must have
        #       been compiled for Windows.
        #
        if {[isWindows]} then {
          lappend result compile.WINDOWS
          addConstraint compile.WINDOWS
        }
      }

      if {![info exists ::no(compileUnix)]} then {
        #
        # NOTE: If the current platform is Unix the Tcl binary must have
        #       been compiled for Unix.
        #
        if {![isWindows]} then {
          lappend result compile.UNIX
          addConstraint compile.UNIX
        }
      }

      #
      # NOTE: These test constraints are needed by tests "socket-*.*".
      #
      if {![info exists ::no(compileNetwork)]} then {
        lappend result compile.NETWORK
        addConstraint compile.NETWORK
      }

      if {![info exists ::no(compileConfiguration)]} then {
        lappend result compile.CONFIGURATION
        addConstraint compile.CONFIGURATION
      }

      #
      # NOTE: Just fake the invariant culture when running in native Tcl.
      #
      if {![info exists ::no(culture)]} then {
        lappend result culture.invariant
        addConstraint culture.invariant
      }

      tputs $channel [appendArgs "yes (" $result ")\n"]
    } else {
      tputs $channel no\n
    }
  }

  proc checkForWindowsCommandProcessor { channel pattern {constraint ""} } {
    # <help>
    # This procedure probes which Windows command processor is configured and
    # registers a test constraint named with the prefix comSpec_ when the
    # processor matches a caller-supplied file-name pattern (for example,
    # cmd.exe).  Tests that depend on a particular command interpreter use this.
    #
    # How it works: only on Windows, it reads the ComSpec environment variable,
    # takes its file tail, and tests it against pattern using a case-insensitive
    # glob match.  On a match it registers the constraint, using the explicit
    # constraint suffix when one is given; otherwise it derives the suffix from
    # the pattern by mapping the glob and special characters (asterisk, hyphen,
    # question mark, brackets, backslash) to underscores so the result is a
    # valid constraint name.
    #
    # Tricky details: the special-character mapping exists precisely because a
    # raw glob pattern would not be a legal constraint name.  Everything is
    # skipped on non-Windows platforms.
    #
    # Arguments:
    #   channel    -- The channel where diagnostic and progress output should be
    #                 written.
    #   pattern    -- A case-insensitive glob pattern matched against the tail of
    #                 the ComSpec value.
    #   constraint -- Optional explicit suffix for the constraint name; when
    #                 empty a sanitized form of the pattern is used.
    #
    # Results:
    #   None meaningful; reports yes (with the ComSpec value) or no and
    #   registers the constraint as a side effect.
    # </help>

    tputs $channel "---- checking for Windows Command Processor... "

    if {[isWindows]} then {
      #
      # NOTE: Grab the "ComSpec" from the Windows environment and make sure it
      #       matches the file pattern supplied by the caller (e.g. "cmd.exe").
      #
      if {[info exists ::env(ComSpec)] && \
          [string match -nocase $pattern [file tail $::env(ComSpec)]]} then {
        #
        # NOTE: We are running with a matching command processor.
        #
        if {[string length $constraint] > 0} then {
          addConstraint [appendArgs comSpec_ $constraint]
        } else {
          addConstraint [appendArgs comSpec_ \
              [string map [list * _ - _ ? _ \[ _ \\ _ \] _] $pattern]]
        }

        tputs $channel [appendArgs "yes (\"" $::env(ComSpec) "\")\n"]

        #
        # NOTE: We are done here, return now.
        #
        return
      }
    }

    tputs $channel no\n
  }

  proc checkForPackage { channel pattern } {
    # <help>
    # This procedure probes whether a dynamically loaded (binary) package whose
    # library file matches a regular expression is currently loaded, and
    # registers two test constraints describing it: loaded.name. followed by the
    # cleaned short package name, and loaded.fullName. followed by the cleaned
    # full package name.  Tests that require a particular loaded extension use
    # these.
    #
    # How it works: it iterates the entries returned by info loaded, applying
    # the given regular expression to the last field of each entry (the package
    # name), and stops at the first match, recording that entry's package name
    # (its second field).  When a match is found, the helper [cleanPackageName] is
    # used twice (with its boolean argument false then true) to derive valid
    # short and full constraint suffixes.
    #
    # Tricky details: the matching uses a regexp, not a glob, against the
    # package name field; the entire scan is wrapped in catch so an unexpected
    # info loaded failure simply yields a no result.
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #   pattern -- A regular expression matched against loaded package names.
    #
    # Results:
    #   None meaningful; reports yes or no and registers the two constraints as
    #   a side effect.
    # </help>

    tputs $channel [appendArgs \
        "---- checking for loaded package matching \"" \
        $pattern "\"... "]

    if {[catch {
      foreach loaded [info loaded] {
        if {[regexp -- $pattern [lindex $loaded end]]} then {
          set package [lindex $loaded 1]; break
        }
      }
    }] == 0} then {
      #
      # NOTE: Make sure that a matching package name was found.
      #
      if {[info exists package]} then {
        #
        # NOTE: Yes, it appears that it is loaded.
        #
        addConstraint [appendArgs \
            loaded.name. [cleanPackageName $package false]]

        addConstraint [appendArgs \
            loaded.fullName. [cleanPackageName $package true]]

        #
        # NOTE: Show that the sub-command was found.
        #
        tputs $channel yes\n

        #
        # NOTE: We are done here, return now.
        #
        return
      }
    }

    tputs $channel no\n
  }

  proc checkForFossil { channel } {
    # <help>
    # This procedure probes for the Fossil source-control tool and the
    # repository (if any) associated with the test tree, registering up to three
    # test constraints: fossil_version when the Fossil executable runs and
    # reports a recognizable version, fossil_repository_url when a valid remote
    # repository URL is found, and fossil_repository_file when a valid local
    # repository file is found.  Tests that interact with Fossil or the project
    # repository require these.
    #
    # How it works: it uses the test_path global as the working directory (or
    # empty) and, gated on [canExecFossil], runs Fossil sub-commands via the
    # [execFossilCommand] helper.  The version sub-command output is parsed with a
    # regular expression to extract the version and source identifier.  It then
    # runs remote-url and validates the result (TclTk can use uri isvalid; Tcl
    # only checks for non-empty text), optionally probing the URL for an HTTP
    # redirect to discover the real base URL, and saves it to the global
    # test_repository_url unless no(setRepositoryUrl) is set.  It runs info,
    # parses the repository: line, and if that file exists, normalizes it and
    # saves it to test_repository_file unless no(setRepositoryFile) is set.  A
    # human-readable summary is accumulated and logged.
    #
    # Tricky details: each external invocation is guarded by [canExecFossil] and
    # catch.  The redirect-detection step is TclTk-only and is skipped when
    # no(detectRepositoryUrlType) is set; it recognizes a TestBaseUrl HTML
    # comment or a base href tag and strips a trailing login path.  The
    # constraints are independent, so a build may have the version constraint
    # without either repository constraint.
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #
    # Results:
    #   None meaningful; reports yes (with a summary) or no and registers the
    #   constraints, and may set the repository URL and file globals, as side
    #   effects.
    # </help>

    tputs $channel "---- checking for Fossil... "

    if {[info exists ::test_path]} then {
      set directory $::test_path
    } else {
      set directory ""
    }

    if {[canExecFossil] && [catch {
      execFossilCommand $directory version
    } version] == 0} then {
      set version [string trim $version]

      set pattern {^This is fossil version (.*) \[([0-9a-f]+)\]\
          \d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2} UTC$}

      if {[regexp -- $pattern $version dummy version sourceId]} then {
        #
        # NOTE: Add a constraint to show that the Fossil executable
        #       itself is available.
        #
        addConstraint fossil_version

        #
        # NOTE: Append the version of Fossil currently in use.
        #
        append result version " " $version " \[" $sourceId \]

        if {[canExecFossil] && [catch {
          execFossilCommand $directory remote-url
        } remoteUrl] == 0} then {
          set remoteUrl [string trim $remoteUrl]; set validUrl false

          if {[isTclTk]} then {
            #
            # NOTE: With TclTk, we can actually validate the URL.
            #
            if {[uri isvalid $remoteUrl]} then {
              set validUrl true
            }
          } else {
            #
            # HACK: Currently, there is no simple way to validate
            #       an arbitrary URL with Tcl (i.e. without using
            #       some hideously complex regular expression).
            #
            if {[string length $remoteUrl] > 0} then {
              set validUrl true
            }
          }

          if {$validUrl} then {
            #
            # NOTE: Add a constraint to show that a valid Fossil
            #       repository URL appears to be available.
            #
            addConstraint fossil_repository_url

            #
            # NOTE: Unless forbidden from doing so, attempt to detect
            #       if an HTTP redirect response may have been used.
            #
            set typeOfUrl ""

            if {[isTclTk] && \
                ![info exists ::no(detectRepositoryUrlType)]} then {
              if {[catch {
                uri download -timeouttype Network -inline -- $remoteUrl
              } remoteBody] == 0} then {
                if {[regexp -- {<!--\s*?TestBaseUrl\s*?=\s*?"(.*?)"\s*?-->} \
                        $remoteBody dummy baseUrl] || \
                    [regexp -- {<base href="(.*?)" />} $remoteBody dummy \
                        baseUrl]} then {
                  set typeOfUrl " redirected"

                  if {[string range $baseUrl end-5 end] eq "/login"} then {
                    set baseUrl [string range $baseUrl 0 end-6]
                  }

                  set remoteUrl $baseUrl
                }
              }
            }

            #
            # NOTE: If we are not prevented from doing so, save
            #       the test repository URL to the repository
            #       currently in use to a suitably named global
            #       variable.
            #
            if {![info exists ::no(setRepositoryUrl)]} then {
              set ::test_repository_url $remoteUrl
            }

            #
            # NOTE: Append the repository URL currently in use.
            #
            append result ", remote" $typeOfUrl " URL \"" $remoteUrl \"
          }
        }

        if {[canExecFossil] && [catch {
          execFossilCommand $directory info
        } info] == 0} then {
          set info [string trim $info]; set validFile false

          if {[string length $info] > 0} then {
            set pattern {^repository:\s+(.*?)$}

            if {[regexp -line -- $pattern $info dummy repository]} then {
              set repository [string trim $repository]

              if {[file exists $repository]} then {
                set validFile true
              }
            }
          }

          if {$validFile} then {
            #
            # NOTE: Add a constraint to show that a valid Fossil
            #       repository file appears to be available.
            #
            addConstraint fossil_repository_file

            #
            # NOTE: Make sure the file name is fully normalized.
            #
            set repository [file normalize $repository]

            #
            # NOTE: If we are not prevented from doing so, save
            #       the test repository file for the repository
            #       currently in use to a suitably named global
            #       variable.
            #
            if {![info exists ::no(setRepositoryFile)]} then {
              set ::test_repository_file $repository
            }

            #
            # NOTE: Append the repository file currently in use.
            #
            append result ", local file \"" $repository \"
          }
        }

        #
        # NOTE: Show the result of the checking.
        #
        tputs $channel [appendArgs "yes (" $result ")\n"]

        #
        # NOTE: We are done here, return now.
        #
        return
      }
    }

    tputs $channel no\n
  }

  proc checkForVisualStudioViaVsWhere { channel } {
    # <help>
    # This procedure detects installed editions of Visual Studio using
    # Microsoft's vswhere locator tool and registers a test constraint named
    # visualStudio followed by the release year (for example, visualStudio2022)
    # for each edition found.  Tests that require a given Visual Studio version
    # use these.
    #
    # How it works: only on Windows and only when [canExecVsWhere] permits, it
    # iterates a fixed table mapping internal versions to release years (15.0
    # to 2017, 16.0 to 2019, 17.0 to 2022).  For each it runs vswhere to obtain
    # the latest installation path for that version, splits the possibly
    # multi-line output, and for each path checks for the presence of
    # Common7\IDE\msenv.dll as proof of a real install.  On the first valid
    # path for a version it registers the year constraint, records the year,
    # saves the IDE directory into the global test_visual_studio (unless
    # no(setVisualStudio) is set), and breaks to the next version.
    #
    # Tricky details: the msenv.dll probe avoids false positives from stale or
    # incomplete installs; only the first matching install per version is used.
    # Nothing happens off Windows or when vswhere use is not permitted.
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #
    # Results:
    #   None meaningful; reports the found versions and chosen directory (or no)
    #   and registers constraints, possibly setting test_visual_studio, as side
    #   effects.
    # </help>

    tputs $channel "---- checking for Visual Studio using \"vswhere\"... "

    #
    # NOTE: Initially, no versions of Visual Studio have been found.
    #
    set visualStudioVersions [list]

    #
    # NOTE: Use of the "vswhere" tool must be enabled for us to detect
    #       any instances of Visual Studio.
    #
    if {[isWindows] && [canExecVsWhere]} then {
      #
      # NOTE: The versions of Visual Studio that we support detection
      #       of using the "vswhere" tool.
      #
      set versions [list \
          [list 15.0 2017] [list 16.0 2019] [list 17.0 2022]]

      #
      # NOTE: Check each version and keep track of the ones we find.
      #
      foreach version $versions {
        #
        # NOTE: Attempt to fetch Visual Studio install directories
        #       value using the "vswhere" tool.
        #
        if {[catch {
          exec -- vswhere -products * -version [lindex $version 0] \
              -property installationPath -latest
        } installationPaths] == 0} then {
          #
          # NOTE: Check each Visual Studio install directory, in the
          #       order they were returned, after splitting them into
          #       a proper Tcl list.
          #
          set installationPaths [split [string map [list \r\n \n] \
              [string trim $installationPaths]] \n]

          foreach installationPath $installationPaths {
            #
            # NOTE: Remove the trailing backslash, if any.  Does the
            #       directory name look valid and does it actually
            #       exist?
            #
            set fileName [file join \
                [string trimright $installationPath \\] Common7 IDE \
                msenv.dll]

            if {[file isfile $fileName]} then {
              #
              # NOTE: Yes, it appears that it is available.
              #
              addConstraint [appendArgs \
                  visualStudio [lindex $version 1]]

              #
              # NOTE: Keep track of all the versions that we find.
              #
              lappend visualStudioVersions [lindex $version 1]

              #
              # NOTE: Save the directory for later usage by the test
              #       suite itself.
              #
              if {![info exists ::no(setVisualStudio)]} then {
                set ::test_visual_studio [file dirname $fileName]
              }

              #
              # HACK: Stop after we find the first instance of Visual
              #       Studio with the requested version.
              #
              break
            }
          }
        }
      }
    }

    if {[llength $visualStudioVersions] > 0} then {
      #
      # NOTE: Show where we found the latest version.
      #
      tputs $channel [appendArgs \
          "yes (" $visualStudioVersions ", \"" \
          [expr {[info exists ::test_visual_studio] ? \
              $::test_visual_studio : "<none>"}] "\")\n"]
    } else {
      tputs $channel no\n
    }
  }

  proc checkForTclTk { channel } {
    # <help>
    # This procedure determines whether the test suite is running inside TclTk
    # or native Tcl and registers the matching engine constraint (tcltk or tcl)
    # along with a family of bug/crash/hang skip constraints used to suppress
    # tests known to be problematic on the other engine or on specific Tcl
    # versions.
    #
    # How it works: when running in TclTk it adds tcltk plus tclBug, tclCrash,
    # and tclHang (both bare and suffixed with each known dotless Tcl version
    # from [getKnownTclVersions]), because those Tcl-specific problems can never
    # affect an TclTk run and so the guarded tests should not be skipped.  When
    # running under native Tcl it adds tcl, then for every known Tcl version
    # that does NOT match the running version it adds the version-suffixed
    # tclBug/tclCrash/tclHang constraints (using exact, not greater-than-or-equal
    # matching), and finally adds tcltkBug, tcltkCrash, and tcltkHang since
    # TclTk-specific problems cannot affect a Tcl run.
    #
    # Tricky details: the asymmetry is deliberate.  These constraints work by
    # presence: a test guarded with tclBugNN runs only when that constraint is
    # present, which is precisely when the current engine/version is immune to
    # the bug.  Version suffixes come from [getDotlessVersion].
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #
    # Results:
    #   None meaningful; reports yes (TclTk) or no (Tcl) and registers the
    #   constraints as a side effect.
    # </help>

    tputs $channel "---- checking for TclTk... "

    if {[isTclTk]} then {
      #
      # NOTE: We are running inside TclTk.
      #
      addConstraint tcltk

      #
      # NOTE: We do not want to skip bugs or crashing
      #       issues for Tcl since we are not running
      #       in Tcl.
      #
      addConstraint tclBug
      addConstraint tclCrash
      addConstraint tclHang

      #
      # NOTE: Add the necessary constraints for each
      #       version of Tcl we know about.
      #
      foreach tclVersion [getKnownTclVersions] {
        set version [getDotlessVersion $tclVersion]

        addConstraint [appendArgs tclBug $version]
        addConstraint [appendArgs tclCrash $version]
        addConstraint [appendArgs tclHang $version]
      }

      tputs $channel yes\n
    } else {
      #
      # NOTE: We are running inside Tcl.
      #
      addConstraint tcl

      #
      # NOTE: Each Tcl bug and crash constraint is set
      #       based on the exact Tcl version (i.e. not
      #       greater than or equal to).
      #
      if {[info exists ::tcl_version]} then {
        #
        # NOTE: For each Tcl version we know about,
        #       check it against the currently running
        #       Tcl version.  If the two are not equal,
        #       add the test constraints that prevent
        #       skipping those tests that are buggy
        #       only for the particular version of Tcl.
        #
        foreach tclVersion [getKnownTclVersions] {
          set dotVersion [getDottedVersion $tclVersion]

          if {$::tcl_version ne $dotVersion} then {
            set version [getDotlessVersion $tclVersion]

            addConstraint [appendArgs tclBug $version]
            addConstraint [appendArgs tclCrash $version]
            addConstraint [appendArgs tclHang $version]
          }
        }
      }

      #
      # NOTE: We do not want to skip bugs or crashing
      #       issues for TclTk since we are not running
      #       in TclTk.
      #
      addConstraint tcltkBug
      addConstraint tcltkCrash
      addConstraint tcltkHang

      tputs $channel no\n
    }
  }

  proc checkForSymbols { channel name {constraint ""} } {
    # <help>
    # This procedure probes whether debugging symbols exist for a given binary
    # and registers a test constraint named with the prefix symbols_ followed by
    # either the caller-supplied constraint suffix or, by default, the tail of
    # the binary file name.  Tests that need symbol information (for example,
    # stack-trace or debugging tests) use this.
    #
    # How it works: it derives the symbol file name by replacing the binary's
    # extension with .pdb (the Windows-style program database extension) and
    # normalizing the path, then checks for that file's existence with file
    # exists, registering the constraint when present.
    #
    # Arguments:
    #   channel    -- The channel where diagnostic and progress output should be
    #                 written.
    #   name       -- The binary file name whose companion .pdb symbol file is
    #                 sought.
    #   constraint -- Optional explicit suffix for the constraint name; when
    #                 empty the binary file tail is used.
    #
    # Results:
    #   None meaningful; reports yes or no and registers the constraint as a
    #   side effect.
    # </help>

    set fileName [file normalize [appendArgs [file rootname $name] .pdb]]

    tputs $channel [appendArgs "---- checking for symbols \"" $fileName \
        "\"... "]

    if {[file exists $fileName]} then {
      #
      # NOTE: The file appears to have associated symbols available.
      #
      if {[string length $constraint] > 0} then {
        addConstraint [appendArgs symbols_ $constraint]
      } else {
        addConstraint [appendArgs symbols_ [file tail $name]]
      }

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForLogFile { channel } {
    # <help>
    # This procedure probes whether a test log file is configured and present,
    # registering the test constraint named logFile when it is.  Tests that
    # inspect or write to the log file require this.
    #
    # How it works: it checks that the global test_log variable exists, is
    # non-empty, and names a file that currently exists on disk; only then is
    # the constraint added.
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #
    # Results:
    #   None meaningful; reports yes or no and registers the constraint as a
    #   side effect.
    # </help>

    tputs $channel "---- checking for log file... "

    if {[info exists ::test_log] && \
        [string length $::test_log] > 0 && \
        [file exists $::test_log]} then {
      #
      # NOTE: The log file appears to be available.
      #
      addConstraint logFile

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForGaruda { channel } {
    # <help>
    # This procedure probes whether the test suite is running with or via
    # Garuda (the TclTk package that bridges TclTk and native Tcl), registering
    # the test constraint named garuda when it is.  Tests that exercise the
    # TclTk/Tcl bridge require this.
    #
    # How it works: it delegates detection to the helper [haveGaruda], passing the
    # name of a variable (packageId) that the helper fills in with the detected
    # Garuda package identifier on success; that identifier is then echoed in
    # the diagnostic output.
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #
    # Results:
    #   None meaningful; reports yes (with the package id) or no and registers
    #   the constraint as a side effect.
    # </help>

    tputs $channel "---- checking for Garuda... "

    if {[haveGaruda packageId]} then {
      #
      # NOTE: We are running with or via Garuda.
      #
      addConstraint garuda

      tputs $channel [appendArgs "yes (" $packageId ")\n"]
    } else {
      tputs $channel no\n
    }
  }

  proc checkForShell { channel } {
    # <help>
    # This procedure probes whether the test suite is running under a recognized
    # interactive shell executable and, when so, registers the constraints shell,
    # shell. followed by the executable base name, and dotNetCoreOrShell.  Tests
    # that need a real shell environment (rather than an embedded or hosted
    # interpreter) use these.
    #
    # How it works: it takes the base name of the current shell executable (via
    # [getShellExecutableName]).  In TclTk it matches that name against a list of
    # well-known TclTk shell names (TclTk, TclTkShell, TclTkKit, and their 32/64
    # variants); if the global no(strictCheckForShell) is set it loosens this to
    # any name beginning with TclTk.  In native Tcl it matches names beginning
    # with tclsh.  On a match it registers the three constraints and returns.
    #
    # Tricky details: the dotNetCoreOrShell constraint is shared with .NET Core
    # detection elsewhere, expressing "either a shell or .NET Core"; the
    # shell.NAME constraint lets tests target one specific shell binary.
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #
    # Results:
    #   None meaningful; reports yes (TclTk), yes (Tcl), or no and registers the
    #   constraints as a side effect.
    # </help>

    tputs $channel "---- checking for shell... "

    set name [file rootname [file tail [getShellExecutableName]]]

    if {[isTclTk]} then {
      #
      # NOTE: By default, use strict matching of the shell executable
      #       name (exact); otherwise, match any executable names that
      #       start with "TclTk".
      #
      if {![info exists ::no(strictCheckForShell)]} then {
        set expr {
          $name in [list \
              TclTk TclTk32 TclTk64 TclTkShell TclTkShell32 \
              TclTkShell64 TclTkKit TclTkKit32 TclTkKit64]
        }

        set match [expr $expr]
      } else {
        set match [string match TclTk* $name]
      }

      #
      # NOTE: Does the name of the executable file appear to be a match
      #       for one of the "well-known" shells?
      #
      if {$match} then {
        #
        # NOTE: We are running in TclTk via the TclTkShell.
        #
        addConstraint shell
        addConstraint [appendArgs shell. $name]
        addConstraint dotNetCoreOrShell

        tputs $channel "yes (TclTk)\n"

        #
        # NOTE: We are done here, return now.
        #
        return
      }
    } else {
      if {[string match tclsh* $name]} then {
        #
        # NOTE: We are running in Tcl via tclsh.
        #
        addConstraint shell
        addConstraint [appendArgs shell. $name]
        addConstraint dotNetCoreOrShell

        tputs $channel "yes (Tcl)\n"

        #
        # NOTE: We are done here, return now.
        #
        return
      }
    }

    tputs $channel no\n
  }

  proc checkForOfficialStableReleaseInProgress { channel } {
    # <help>
    # This procedure probes whether the tests are running as part of TclTk's
    # official stable release process and registers the test constraint named
    # officialStableReleaseInProgress when so.  That constraint is consulted by
    # the [fixTimingConstraints] procedure so that timing-sensitive tests are not
    # counted against the overall results during an official release run (where
    # build machines may behave unpredictably).
    #
    # How it works: it simply delegates the decision to the helper
    # [isOfficialStableReleaseInProgress] and registers the constraint on a true
    # result.
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #
    # Results:
    #   None meaningful; reports yes or no and registers the constraint as a
    #   side effect.
    # </help>

    #
    # NOTE: If the tests appear to be running as part of the official stable
    #       release process for TclTk, then add the test constraint that will
    #       be checked by the [fixTimingConstraints] procedure, so that tests
    #       using it will not be counted against the overall results of the
    #       test run.
    #
    tputs $channel "---- checking for official stable release in progress... "

    if {[isOfficialStableReleaseInProgress]} then {
      addConstraint officialStableReleaseInProgress

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForDebug { channel } {
    # <help>
    # This procedure probes whether the running engine is a debug build and
    # registers the test constraint named debug when so.  Tests whose behavior
    # or output differs between debug and release builds use this.
    #
    # How it works: it checks the global element tcl_platform(debug) and adds
    # the constraint only when it exists and is true.
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #
    # Results:
    #   None meaningful; reports yes or no and registers the constraint as a
    #   side effect.
    # </help>

    tputs $channel "---- checking for debug... "

    if {[info exists ::tcl_platform(debug)] && $::tcl_platform(debug)} then {
      addConstraint debug

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForTk { channel } {
    # <help>
    # This procedure probes whether the Tk graphical toolkit should be
    # considered available for testing and registers the test constraint named
    # tk when so.  Tests that exercise Tk widgets or windowing use this.
    #
    # How it works: when not running in TclTk (that is, under native Tcl/Tk) the
    # constraint is always added.  When running in TclTk it is added only if the
    # tclLibrary86 or tclLibrary87 constraint is present; this is a deliberate
    # hack that, for the time being, disables Tk 8.4/8.5 testing through TclTk
    # while allowing Tk against Tcl 8.6/8.7 libraries.
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #
    # Results:
    #   None meaningful; reports yes or no and registers the constraint as a
    #   side effect.
    # </help>

    tputs $channel "---- checking for Tk... "

    #
    # HACK: For now, disable testing Tk 8.4/8.5 when running in TclTk.
    #
    if {![isTclTk] || [haveConstraint tclLibrary86] || \
        [haveConstraint tclLibrary87]} then {
      addConstraint tk

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForVersion { channel } {
    # <help>
    # This procedure detects the language (Tcl) version in effect and registers
    # a family of version test constraints so tests can target an exact version,
    # a feature available since a version, or a version range.  The constraints
    # it may add are tclNN (the single exact-match version), tclNNFeature,
    # tclNNOrHigher, and tclNNOrLower, where NN is a dotless version number.
    #
    # How it works: it requires the global tcl_version.  When running in TclTk
    # it first adds a tclNNFeature constraint for every known Tcl version,
    # because TclTk would not implement a feature at all unless it supports it
    # regardless of the reported language version.  It then walks the known Tcl
    # versions looking for the one that equals the running tcl_version exactly;
    # on that match it adds the exact tclNN constraint, then for every known
    # version less than or equal to it adds both tclNNFeature and tclNNOrHigher,
    # and for every known version greater than or equal to it adds tclNNOrLower,
    # using [filterKnownVersions] to produce the two ranges.  There is exactly one
    # exact match, so it breaks afterward.
    #
    # Tricky details: dotless and dotted version forms are produced by
    # [getDotlessVersion] and [getDottedVersion]; the TclTk-only blanket Feature
    # pass is what lets TclTk satisfy "since version" tests for features it
    # implements.
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #
    # Results:
    #   None meaningful; reports the language version (or no) and registers the
    #   constraints as a side effect.
    # </help>

    tputs $channel "---- checking for language version... "

    if {[info exists ::tcl_version]} then {
      #
      # NOTE: First, obtain the list of all "known" Tcl versions.
      #
      set tclVersions [getKnownTclVersions]

      #
      # NOTE: *TCLTK* We do want to include any tests that target
      #       "Tcl 8.X or higher" features because those tests
      #       would not be in the test suite if we did not support
      #       that particular feature, regardless of the language
      #       version.
      #
      if {[isTclTk]} then {
        #
        # NOTE: Process each "known" Tcl version, adding each of
        #       the "feature" constraints (i.e. since this is an
        #       TclTk test suite infrastructure package).
        #
        foreach tclVersion(1) $tclVersions {
          set version(1) [getDotlessVersion $tclVersion(1)]
          addConstraint [appendArgs tcl $version(1) Feature]
        }
      }

      #
      # NOTE: Process each "known" Tcl version, checking for an
      #       exact match with the running Tcl version.  When an
      #       exact match is found, add appropriate constraints.
      #
      foreach tclVersion(1) $tclVersions {
        #
        # NOTE: Does the running Tcl version match this "known"
        #       Tcl version exactly?
        #
        if {$::tcl_version eq [getDottedVersion $tclVersion(1)]} then {
          #
          # NOTE: Yes, it does.  First, add the "exact" match
          #       constraint.  There can be only one of these.
          #
          addConstraint [appendArgs \
              tcl [getDotlessVersion $tclVersion(1)]]

          #
          # NOTE: Next, process each of the "known" Tcl versions
          #       less than or equal to the running Tcl version,
          #       while adding both the "feature" and "or higher"
          #       constraints.  There will always be at least one
          #       of these.
          #
          foreach tclVersion(2) [filterKnownVersions \
              $tclVersions "" $tclVersion(1)] {
            set version(2) [getDotlessVersion $tclVersion(2)]
            addConstraint [appendArgs tcl $version(2) Feature]
            addConstraint [appendArgs tcl $version(2) OrHigher]
          }

          #
          # NOTE: Finally, process each of the "known" Tcl versions
          #       greater than or equal to the running Tcl version,
          #       while adding the "or lower" constraints.  There
          #       will always be at least one of these.
          #
          foreach tclVersion(3) [filterKnownVersions \
              $tclVersions $tclVersion(1) ""] {
            set version(3) [getDotlessVersion $tclVersion(3)]
            addConstraint [appendArgs tcl $version(3) OrLower]
          }

          #
          # NOTE: There can be only one exact Tcl version match;
          #       therefore, we are done.
          #
          break
        }
      }

      tputs $channel [appendArgs $::tcl_version \n]
    } else {
      tputs $channel no\n
    }
  }

  proc checkForCommand { channel name } {
    # <help>
    # This procedure probes whether a script command is defined and registers a
    # test constraint named with the prefix command. followed by the command
    # name when it is.  Tests that require a particular command use this.
    #
    # How it works: it asks info commands for the given name and treats a
    # non-empty result as the command being available, then adds the constraint.
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #   name    -- The command name to look for.
    #
    # Results:
    #   None meaningful; reports yes or no and registers the constraint as a
    #   side effect.
    # </help>

    tputs $channel [appendArgs "---- checking for command \"" $name \
        "\"... "]

    #
    # NOTE: Is the command available?
    #
    if {[llength [info commands $name]] > 0} then {
      #
      # NOTE: Yes, it appears that it is available.
      #
      addConstraint [appendArgs command. $name]

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForSubCommand { channel names } {
    # <help>
    # This procedure probes whether a particular sub-command of a command (or
    # ensemble) exists and registers a test constraint named with the prefix
    # subCommand. followed by the command name, a dot, and the sub-command name
    # when it does.  Tests that require a specific sub-command use this.
    #
    # How it works: the names argument must be a two-element list holding the
    # command name and the sub-command name.  In TclTk it uses info subcommands
    # on the command and checks for the sub-command with an exact list search.
    # Under native Tcl 8.5 and later it instead queries namespace ensemble
    # configure for the command's -map and looks for the sub-command among the
    # mapped names.  On a match it registers the constraint and returns.
    #
    # Tricky details: the Tcl branch is gated on tcl_version being at least 8.5
    # because the ensemble mechanism did not exist before then; both lookups are
    # wrapped in catch so a non-ensemble or unknown command yields a no result.
    # The dotted constraint name embeds both the command and sub-command.
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #   names   -- A two-element list: the command name followed by the
    #              sub-command name.
    #
    # Results:
    #   None meaningful; reports yes or no and registers the constraint as a
    #   side effect.
    # </help>

    tputs $channel [appendArgs "---- checking for sub-command \"" $names \
        "\"... "]

    #
    # NOTE: Is the sub-command available?  The list of names must have
    #       exactly two elements.  The first element must be the command
    #       name and the second element must be the sub-command name.
    #
    if {[llength $names] == 2} then {
      set commandName [lindex $names 0]
      set subCommandName [lindex $names 1]

      if {[isTclTk]} then {
        if {[catch {
          #
          # NOTE: For TclTk, use the [info subcommands] sub-command.
          #
          info subcommands $commandName
        } subCommands] == 0} then {
          if {[lsearch -exact -- $subCommands $subCommandName] != -1} then {
            #
            # NOTE: Yes, it appears that it is available.
            #
            addConstraint [appendArgs \
                subCommand. $commandName . $subCommandName]

            #
            # NOTE: Show that the sub-command was found.
            #
            tputs $channel yes\n

            #
            # NOTE: We are done here, return now.
            #
            return
          }
        }
      } elseif {$::tcl_version >= 8.5} then {
        if {[catch {
          #
          # NOTE: For Tcl 8.5+, use the [namespace ensemble] sub-command.
          #
          namespace ensemble configure $commandName
        } subCommands] == 0} then {
          foreach {name value} [getDictionaryValue $subCommands -map] {
            if {$name eq $subCommandName} then {
              #
              # NOTE: Yes, it appears that it is available.
              #
              addConstraint [appendArgs \
                  subCommand. $commandName . $subCommandName]

              #
              # NOTE: Show that the sub-command was found.
              #
              tputs $channel yes\n

              #
              # NOTE: We are done here, return now.
              #
              return
            }
          }
        }
      }
    }

    tputs $channel no\n
  }

  proc checkForIntIsWide { channel } {
    # <help>
    # This procedure probes whether the integer type used by the expression
    # engine is the same width as the wide-integer type and registers the test
    # constraint named intIsWide when so.  On some native Tcl builds (for
    # example, 64-bit Linux) the int type is already 64 bits; tests sensitive to
    # integer width use this constraint.
    #
    # How it works: it evaluates an expression comparing int() and wide() of the
    # maximum 64-bit signed value; if they compare equal (and the expression did
    # not error) the constraint is added.  This condition never holds for TclTk.
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #
    # Results:
    #   None meaningful; reports yes or no and registers the constraint as a
    #   side effect.
    # </help>

    tputs $channel "---- checking for \"int\" same as \"wide\"... "

    if {[catch {
      #
      # HACK: On some systems (e.g. Linux x86_64), the "int" Tcl type
      #       is the same as the "wide" Tcl type.  This never applies
      #       to TclTk.
      #
      expr {int(0x7fffffffffffffff) == wide(0x7fffffffffffffff)}
    } sameAsWide] == 0 && [string is true -strict $sameAsWide]} then {
      addConstraint intIsWide

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForEFormat { channel } {
    # <help>
    # This procedure probes whether the [format] command renders floating-point
    # values in the expected "e" notation and registers the test constraint
    # named eformat when so.  Tests that compare formatted floating-point output
    # use this to skip on platforms whose C library formats exponents
    # differently.
    #
    # How it works: it formats a small value and a zero and compares the results
    # against expected strings (for example, that an exponent appears as 5e-05
    # and that a zero formats as 0.0000).  TclTk and native Tcl use slightly
    # different format specifiers for the first check, so the test is branched
    # accordingly; the constraint is added only when both comparisons are true.
    #
    # Tricky details: this check was adapted from the tcltest package's own
    # eformat detection; the whole expression is guarded by catch and the result
    # must be strictly true.
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #
    # Results:
    #   None meaningful; reports yes or no and registers the constraint as a
    #   side effect.
    # </help>

    tputs $channel "---- checking for \"eformat\" support... "

    if {[catch {
      #
      # HACK: This test was stolen directly from the native Tcl source
      #       file "library/tcltest/tcltest.tcl", which is part of the
      #       "tcltest" package.
      #
      if {[isTclTk]} then {
        expr {
          [string equal [format %.0e 5e-5] 5e-05] && \
              [string equal [format %#.5g 0] 0.0000]
        }
      } else {
        expr {
          [string equal [format %g 5e-5] 5e-05] && \
              [string equal [format %#.5g 0] 0.0000]
        }
      }
    } eformat] == 0 && [string is true -strict $eformat]} then {
      addConstraint eformat

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForNamespaces { channel quiet } {
    # <help>
    # This procedure probes for namespace support and its runtime state,
    # registering up to three test constraints: namespaces.available when the
    # core library was built with namespace support, namespaces.unavailable when
    # it was not, and namespaces when support is both available and enabled at
    # runtime.  Tests that rely on namespaces use these.
    #
    # How it works: in TclTk it calls namespace enable to query (not change) the
    # current state; success means support is compiled in (beta 30 or later) so
    # it adds namespaces.available, while failure adds namespaces.unavailable.
    # If the queried state is true it also adds namespaces (and reports
    # enabled); if available but disabled and the quiet argument is false it
    # emits a warning to the log.  Under native Tcl, all supported versions have
    # namespaces, so it unconditionally adds both namespaces.available and
    # namespaces.
    #
    # Tricky details: the namespace enable call here is used purely as a probe
    # of the available/enabled state; the warning about being available but
    # disabled is suppressed when quiet is true.
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #   quiet   -- A boolean; when false a warning is logged if namespaces are
    #              available but disabled.
    #
    # Results:
    #   None meaningful; reports enabled or disabled and registers constraints
    #   as a side effect.
    # </help>

    tputs $channel "---- checking for namespace support... "

    if {[isTclTk]} then {
      #
      # NOTE: Check if namespace support was compiled into the core
      #       library (i.e. this is beta 30 or later).
      #
      if {[catch {namespace enable} enabled] == 0} then {
        set available true

        addConstraint namespaces.available
      } else {
        set available false

        addConstraint namespaces.unavailable
      }

      #
      # NOTE: We were able to query for namespace support (i.e. this
      #       must be beta 29 or later); however, we still need to
      #       check if it has been enabled at runtime.
      #
      if {[string is true -strict $enabled]} then {
        #
        # NOTE: Yes, it appears that it is available and enabled.
        #
        addConstraint namespaces

        tputs $channel enabled\n
      } else {
        tputs $channel disabled\n

        #
        # NOTE: Check if namespace support was compiled into the core
        #       library (i.e. is this beta 30 or later).
        #
        if {!$quiet && $available} then {
          #
          # NOTE: The tests seem to be running with namespace support
          #       available, but disabled.  Emit a warning into the
          #       test log file.
          #
          tputs $channel \
              "==== WARNING: running with namespaces available and disabled\n"
        }
      }
    } else {
      #
      # NOTE: All supported versions of native Tcl have namespaces enabled
      #       and available.
      #
      addConstraint namespaces.available
      addConstraint namespaces

      tputs $channel enabled\n
    }
  }

  proc checkForTestExec { channel quiet } {
    # <help>
    # This procedure probes whether the test suite is permitted to launch
    # external processes via the [exec] command and registers the test
    # constraint named [testExec] when so.  Tests that spawn helper processes use
    # this so they are skipped in locked-down environments.
    #
    # How it works: it requires that the global no(testExec) opt-out is not set
    # and that the helper [canTestExec] approves, passing the name of the current
    # procedure (obtained from info level) so the policy check can account for
    # the caller.  When permitted it adds the constraint; additionally, if the
    # quiet argument is false and the global no(exec) flag is set, it logs a
    # warning that the [testExec] procedure itself is disabled.
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #   quiet   -- A boolean; when false a warning is logged if exec use is
    #              otherwise disabled.
    #
    # Results:
    #   None meaningful; reports yes or no and registers the constraint as a
    #   side effect.
    # </help>

    tputs $channel "---- checking for test use of \"exec\" command... "

    set procName [lindex [info level [info level]] 0]

    if {![info exists ::no(testExec)] && [canTestExec $procName]} then {
      addConstraint testExec

      tputs $channel yes\n

      if {!$quiet && [info exists ::no(exec)]} then {
        tputs $channel \
            "==== WARNING: running with the \"testExec\" procedure disabled\n"
      }
    } else {
      tputs $channel no\n
    }
  }

  proc checkForTestMachine { channel } {
    # <help>
    # This procedure registers a test constraint identifying the machine
    # (processor architecture) the tests are running on, named with the prefix
    # machine. followed by the value of the global test_machine variable.  Tests
    # that target a specific architecture use this.
    #
    # How it works: when test_machine exists and is non-empty its value is
    # appended to the machine. prefix and registered; otherwise it reports
    # unknown.
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #
    # Results:
    #   None meaningful; reports the machine value (or unknown) and registers
    #   the constraint as a side effect.
    # </help>

    tputs $channel "---- checking for test machine... "

    if {[info exists ::test_machine] && \
        [string length $::test_machine] > 0} then {
      addConstraint [appendArgs machine. $::test_machine]

      tputs $channel [appendArgs $::test_machine \n]
    } else {
      tputs $channel unknown\n
    }
  }

  proc checkForTestPlatform { channel } {
    # <help>
    # This procedure registers a test constraint identifying the build platform
    # the tests are running against, named with the prefix platform. followed by
    # the value of the global test_platform variable (for example, a bitness or
    # toolset designation).  Tests that target a specific build platform use
    # this.
    #
    # How it works: when test_platform exists and is non-empty its value is
    # appended to the platform. prefix and registered; otherwise it reports
    # unknown.
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #
    # Results:
    #   None meaningful; reports the platform value (or unknown) and registers
    #   the constraint as a side effect.
    # </help>

    tputs $channel "---- checking for test platform... "

    if {[info exists ::test_platform] && \
        [string length $::test_platform] > 0} then {
      addConstraint [appendArgs platform. $::test_platform]

      tputs $channel [appendArgs $::test_platform \n]
    } else {
      tputs $channel unknown\n
    }
  }

  proc checkForTestConfiguration { channel } {
    # <help>
    # This procedure registers a test constraint identifying the build
    # configuration the tests are running against, named with the prefix
    # configuration. followed by the value of the global test_configuration
    # variable (for example, Debug or Release).  Tests that target a specific
    # configuration use this.
    #
    # How it works: when test_configuration exists and is non-empty its value is
    # appended to the configuration. prefix and registered; otherwise it reports
    # unknown.
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #
    # Results:
    #   None meaningful; reports the configuration value (or unknown) and
    #   registers the constraint as a side effect.
    # </help>

    tputs $channel "---- checking for test configuration... "

    if {[info exists ::test_configuration] && \
        [string length $::test_configuration] > 0} then {
      addConstraint [appendArgs configuration. $::test_configuration]

      tputs $channel [appendArgs $::test_configuration \n]
    } else {
      tputs $channel unknown\n
    }
  }

  proc checkForTestNamePrefix { channel } {
    # <help>
    # This procedure registers a test constraint identifying the prefix applied
    # to test names in the current run, named with the prefix namePrefix.
    # followed by the value of the global test_name_prefix variable.  Tests that
    # are sensitive to the naming scheme use this.
    #
    # How it works: when test_name_prefix exists and is non-empty its value is
    # appended to the namePrefix. prefix and registered; otherwise it reports
    # unknown.
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #
    # Results:
    #   None meaningful; reports the name prefix value (or unknown) and
    #   registers the constraint as a side effect.
    # </help>

    tputs $channel "---- checking for test name prefix... "

    if {[info exists ::test_name_prefix] && \
        [string length $::test_name_prefix] > 0} then {
      addConstraint [appendArgs namePrefix. $::test_name_prefix]

      tputs $channel [appendArgs $::test_name_prefix \n]
    } else {
      tputs $channel unknown\n
    }
  }

  proc checkForTestSuffix { channel } {
    # <help>
    # This procedure registers a test constraint identifying the suffix applied
    # to the current test run, named with the prefix suffix. followed by the
    # value of the global test_suffix variable.  Tests that are sensitive to the
    # run suffix use this.
    #
    # How it works: when test_suffix exists and is non-empty its value is
    # appended to the suffix. prefix and registered; otherwise it reports
    # unknown.
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #
    # Results:
    #   None meaningful; reports the suffix value (or unknown) and registers the
    #   constraint as a side effect.
    # </help>

    tputs $channel "---- checking for test suffix... "

    if {[info exists ::test_suffix] && \
        [string length $::test_suffix] > 0} then {
      addConstraint [appendArgs suffix. $::test_suffix]

      tputs $channel [appendArgs $::test_suffix \n]
    } else {
      tputs $channel unknown\n
    }
  }

  proc checkForGnuScreen { channel } {
    # <help>
    # This procedure probes whether the tests appear to be running inside a GNU
    # Screen session and registers the test constraint named gnuScreen when so.
    # Tests whose terminal behavior differs under Screen use this.
    #
    # How it works: it treats the session as Screen when the TERM environment
    # variable equals screen, or when the STY environment variable (set by
    # Screen to name the session) exists.  Either condition adds the constraint.
    #
    # Tricky details: as the accompanying note states, this heuristic is not
    # completely reliable but is considered good enough for the test suite's
    # purposes.
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #
    # Results:
    #   None meaningful; reports yes or no and registers the constraint as a
    #   side effect.
    # </help>

    #
    # HACK: This is not 100% reliable; however, it should be "good enough"
    #       for our purposes.
    #
    tputs $channel "---- checking for GNU Screen... "

    if {([info exists ::env(TERM)] && $::env(TERM) eq "screen") || \
        [info exists ::env(STY)]} then {
      addConstraint gnuScreen

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForFile { channel name {constraint ""} } {
    # <help>
    # This procedure probes whether a file exists at a given path and registers
    # a test constraint named with the prefix file_ followed by either the
    # caller-supplied constraint suffix or, by default, the tail of the file
    # name.  Tests that require a particular file be present use this; it is also
    # the primitive building block used by [checkForNativeLibraryFile] and
    # [checkForPathFile].
    #
    # How it works: it tests the path with file exists (the diagnostic message
    # shows the normalized path) and, when present, adds the constraint using
    # the explicit suffix when supplied, otherwise the file tail.
    #
    # Arguments:
    #   channel    -- The channel where diagnostic and progress output should be
    #                 written.
    #   name       -- The file name (path) to look for.
    #   constraint -- Optional explicit suffix for the constraint name; when
    #                 empty the file tail is used.
    #
    # Results:
    #   None meaningful; reports yes or no and registers the constraint as a
    #   side effect.
    # </help>

    tputs $channel [appendArgs "---- checking for file \"" \
        [file normalize $name] "\"... "]

    if {[file exists $name]} then {
      #
      # NOTE: Yes, it appears that it is available.
      #
      if {[string length $constraint] > 0} then {
        addConstraint [appendArgs file_ $constraint]
      } else {
        addConstraint [appendArgs file_ [file tail $name]]
      }

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForNativeLibraryFile {
          channel names {machine ""} {constraint ""} } {
    # <help>
    # This procedure searches a set of likely locations for a native (shared
    # library) file under any of several candidate base names and, when found,
    # leaves behind a test constraint named with the prefix file_ followed by
    # either the caller-supplied constraint suffix or the file tail.  It does not
    # register the constraint itself; it relies on [checkForFile] to do so, then
    # detects success by checking for that constraint.  Tests that require a
    # native library be locatable use this.
    #
    # How it works: it assembles a list of directories to search: the global
    # core_bin_path when set (a prologue-provided hint), otherwise the directory
    # of the shell executable, plus, in TclTk, several resolved native-library
    # search paths obtained via info path with NativeLibrary selectors (with and
    # without Local and NoProcessor qualifiers).  The platform's shared-library
    # extension comes from info sharedlibextension.  For each candidate name
    # (skipping any that already carries that extension), it computes the target
    # constraint name and, unless that constraint already exists, tries many
    # variations: with and without a lib prefix, with and without the shared
    # extension, and within per-architecture sub-directories derived from the
    # machine argument via [machineToPlatform] for both 32-bit and 64-bit.  Each
    # candidate path is delegated to [checkForFile]; as soon as the target
    # constraint appears the search stops.
    #
    # Tricky details: detection of success is indirect (it checks [haveConstraint]
    # for the computed name after each [checkForFile] call) because [checkForFile] is
    # what registers the constraint.  The lib prefix and per-architecture
    # sub-directory probing accommodate Unix/macOS naming and multi-architecture
    # layouts.  Nothing matching a name that already has the shared extension is
    # probed directly (such names are skipped).
    #
    # Arguments:
    #   channel    -- The channel where diagnostic and progress output should be
    #                 written.
    #   names      -- A list of candidate base file names to search for.
    #   machine    -- Optional machine/architecture hint used to form
    #                 architecture-specific sub-directory names; may be empty.
    #   constraint -- Optional explicit suffix for the constraint name; when
    #                 empty the file tail is used.
    #
    # Results:
    #   None meaningful; the registration is performed by checkForFile.  The net
    #   side effect is that a file_ constraint exists when a matching library was
    #   found.
    # </help>

    set directories [list]

    if {[info exists ::core_bin_path]} then {
      #
      # HACK: This relies on a global test suite variable that is
      #       setup by the prologue.
      #
      lappend directories $::core_bin_path; # HACK: Global.
    } else {
      #
      # HACK: This assumes the native library file should reside
      #       in the same directory as the managed assembly that
      #       contains the managed application entry-point, which
      #       -MAY- be different from the executable that started
      #       the process, e.g. Mono, .NET Core, etc.
      #
      lappend directories \
          [file normalize [file dirname [getShellExecutableName]]]
    }

    #
    # HACK: When running in TclTk, check several possible system
    #       native library directories, e.g. Linux, macOS, etc.
    #
    if {[isTclTk]} then {
      if {[catch {
        info path "=NativeLibrary +Local"
      } directory] == 0} then {
        lappend directories $directory
      }

      if {[catch {
        info path "=NativeLibrary -Local"
      } directory] == 0} then {
        lappend directories $directory
      }

      if {[catch {
        info path "=NativeLibrary +Local +NoProcessor"
      } directory] == 0} then {
        lappend directories $directory
      }

      if {[catch {
        info path "=NativeLibrary -Local +NoProcessor"
      } directory] == 0} then {
        lappend directories $directory
      }
    }

    set extension [info sharedlibextension]

    foreach name $names {
      if {[file extension $name] eq $extension} then {
        continue
      }

      if {[string length $constraint] > 0} then {
        set constraintName [appendArgs file_ $constraint]
      } else {
        set constraintName [appendArgs file_ [file tail $name]]
      }

      if {[haveConstraint $constraintName]} then {
        continue
      }

      set found false

      foreach directory $directories {
        foreach prefix [list "" lib] {
          checkForFile $channel [file join $directory \
              [appendArgs $prefix $name $extension]] \
              $constraint

          if {[haveConstraint $constraintName]} then {
            set found true; break
          }

          if {[string length [file extension $name]] > 0} then {
            checkForFile $channel [file join $directory \
                [appendArgs $prefix $name]] $constraint

            if {[haveConstraint $constraintName]} then {
              set found true; break
            }
          }

          foreach architecture [list true false] {
            checkForFile $channel [file join $directory \
                [machineToPlatform $machine $architecture] \
                [appendArgs $prefix $name $extension]] \
                $constraint

            if {[haveConstraint $constraintName]} then {
              set found true; break
            }

            if {[string length [file extension $name]] > 0} then {
              checkForFile $channel [file join $directory \
                  [machineToPlatform $machine $architecture] \
                  [appendArgs $prefix $name]] $constraint

              if {[haveConstraint $constraintName]} then {
                set found true; break
              }
            }
          }

          if {$found} then {
            break
          }
        }

        if {$found} then {
          break
        }
      }

      if {$found} then {
        break
      }
    }
  }

  proc checkForPathFile { channel name {constraint ""} } {
    # <help>
    # This procedure probes whether a file exists either at an exact path or in
    # any directory listed in the appropriate executable/library search path
    # environment variable, and registers a test constraint named with the
    # prefix file_ followed by either the caller-supplied constraint suffix or
    # the file tail.  Tests that require a tool or library reachable via PATH (or
    # the platform's library path) use this.
    #
    # How it works: it first tries the path exactly as given; on a hit it
    # registers the constraint and returns.  Otherwise it selects the search
    # variable by platform: PATH on Windows; for shared libraries on Unix,
    # DYLD_LIBRARY_PATH on macOS or LD_LIBRARY_PATH elsewhere; and PATH for
    # ordinary files on Unix.  It splits that variable on the platform's path
    # separator (taken from tcl_platform(pathSeparator) when available, else a
    # semicolon on Windows or a colon elsewhere), strips the caller's path down
    # to just the file tail, and checks each directory for that tail, registering
    # the constraint and returning on the first hit.
    #
    # Tricky details: the search-variable selection distinguishes shared
    # libraries from executables (using info sharedlibextension) so library
    # lookups consult the loader path rather than PATH; only the file tail is
    # searched along the path, so any directory component in name is ignored
    # during the path scan.
    #
    # Arguments:
    #   channel    -- The channel where diagnostic and progress output should be
    #                 written.
    #   name       -- The file name to look for, exactly and then by tail along
    #                 the search path.
    #   constraint -- Optional explicit suffix for the constraint name; when
    #                 empty the file tail is used.
    #
    # Results:
    #   None meaningful; reports yes or no and registers the constraint as a
    #   side effect.
    # </help>

    tputs $channel [appendArgs "---- checking for file \"" $name \
        "\" along PATH... "]

    if {[file exists $name]} then {
      #
      # NOTE: Yes, it appears that it is available [in the exact location they
      #       specified].
      #
      if {[string length $constraint] > 0} then {
        addConstraint [appendArgs file_ $constraint]
      } else {
        addConstraint [appendArgs file_ [file tail $name]]
      }

      tputs $channel yes\n

      #
      # NOTE: We are done here, return now.
      #
      return
    } else {
      #
      # NOTE: Use the appropriate environment variable for the platform.
      #
      if {[isWindows]} then {
        set pathName PATH
      } else {
        #
        # HACK: For shared libraries, use the LD_LIBRARY_PATH.
        #
        if {[file extension $name] eq [info sharedlibextension]} then {
          if {[isMacOS]} then {
            set pathName DYLD_LIBRARY_PATH
          } else {
            set pathName LD_LIBRARY_PATH
          }
        } else {
          set pathName PATH
        }
      }

      #
      # NOTE: Is the required environment variable available?
      #
      if {[info exists ::env($pathName)]} then {
        #
        # NOTE: Ok, grab it now.
        #
        set path $::env($pathName)

        #
        # NOTE: Use the appropriate path separator for the platform.
        #
        if {[info exists ::tcl_platform(pathSeparator)]} then {
          set separator $::tcl_platform(pathSeparator)
        } elseif {[isWindows]} then {
          set separator \;
        } else {
          set separator :
        }

        #
        # NOTE: Grab just the file name from the possibly fully qualified file
        #       name provided by the caller.
        #
        set tail [file tail $name]

        #
        # NOTE: Check each directory in the PATH for the file.
        #
        foreach directory [split $path $separator] {
          #
          # NOTE: Check for the file in this directory contained in the PATH.
          #       This strips the directory portion off the file name specified
          #       by the caller, if any, before joining that file name to the
          #       current directory of the PATH being searched.
          #
          if {[file exists [file join $directory $tail]]} then {
            #
            # NOTE: Yes, it appears that it is available in the PATH.
            #
            if {[string length $constraint] > 0} then {
              addConstraint [appendArgs file_ $constraint]
            } else {
              addConstraint [appendArgs file_ [file tail $name]]
            }

            tputs $channel yes\n

            #
            # NOTE: We are done here, return now.
            #
            return
          }
        }
      }
    }

    tputs $channel no\n
  }

  proc checkForNativeCode { channel } {
    # <help>
    # This procedure probes whether native (platform-specific) code can be
    # executed by the current binary and registers the test constraint named
    # native when so.  Tests that depend on native interop or platform code use
    # this.
    #
    # How it works: under native Tcl the answer is always yes (Tcl is itself
    # native code), so the constraint is added unconditionally.  In TclTk it
    # checks that the binary's compile options (tcltk_platform(compileOptions))
    # include the current platform from tcl_platform(platform), meaning the
    # managed binary was built for, and can host, native code on this platform;
    # only then is the constraint added.
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #
    # Results:
    #   None meaningful; reports yes or no and registers the constraint as a
    #   side effect.
    # </help>

    tputs $channel "---- checking for native code... "

    if {[isTclTk]} then {
      if {[info exists ::tcltk_platform(compileOptions)] && \
          [info exists ::tcl_platform(platform)] && \
          [lsearch -exact -nocase $::tcltk_platform(compileOptions) \
          $::tcl_platform(platform)] != -1} then {
        #
        # NOTE: Yes, the binary matches the current platform,
        #       native code can be used.
        #
        addConstraint native

        tputs $channel yes\n
      } else {
        tputs $channel no\n
      }
    } else {
      #
      # NOTE: Tcl is always native code and can always execute native code.
      #
      addConstraint native

      tputs $channel yes\n
    }
  }

  proc checkForAllowBigIntegers { channel } {
    # <help>
    # This procedure probes whether the interpreter is configured to allow
    # arbitrary-precision (big) integers and registers the test constraint named
    # bigIntegers when so.  Tests that rely on big-integer arithmetic use this.
    #
    # How it works: it delegates the decision to the helper [hasAllowBigIntegers]
    # and adds the constraint on a true result.
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #
    # Results:
    #   None meaningful; reports yes or no and registers the constraint as a
    #   side effect.
    # </help>

    tputs $channel "---- checking for AllowBigIntegers... "

    if {[hasAllowBigIntegers]} then {
      addConstraint bigIntegers

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForTip127 { channel } {
    # <help>
    # This procedure probes whether the interpreter implements Tcl Improvement
    # Proposal 127 (the -index option to [lsearch]) and registers the test
    # constraint named tip127 when so.  Tests that use indexed list searching
    # require this.
    #
    # How it works: it attempts a trivial lsearch -index call inside catch; if
    # that does not error the feature is present and the constraint is added.
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #
    # Results:
    #   None meaningful; reports yes or no and registers the constraint as a
    #   side effect.
    # </help>

    tputs $channel "---- checking for TIP #127... "

    #
    # NOTE: Is the interpreter TIP #127 ready?
    #
    if {[catch {lsearch -index 0 0 0}] == 0} then {
      addConstraint tip127

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForTip182 { channel } {
    # <help>
    # This procedure probes whether the interpreter implements Tcl Improvement
    # Proposal 182 (the bool() function in the expression engine) and registers
    # the test constraint named tip182 when so.  Tests that use bool() require
    # this.
    #
    # How it works: it evaluates an expression calling bool() inside catch; if
    # that does not error the feature is present and the constraint is added.
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #
    # Results:
    #   None meaningful; reports yes or no and registers the constraint as a
    #   side effect.
    # </help>

    tputs $channel "---- checking for TIP #182... "

    #
    # NOTE: Is the interpreter TIP #182 ready?
    #
    if {[catch {expr {bool(0)}}] == 0} then {
      addConstraint tip182

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForTip194 { channel } {
    # <help>
    # This procedure probes whether the interpreter implements Tcl Improvement
    # Proposal 194 (the [apply] command for anonymous procedures) and registers
    # the test constraint named tip194 when so.  Tests that use [apply] require
    # this.
    #
    # How it works: it invokes apply with no arguments inside catch and inspects
    # the error message; if the error is anything other than the "invalid
    # command name" message for apply, the command exists (the observed error is
    # merely about missing arguments) and the constraint is added.
    #
    # Tricky details: the detection is by error-message discrimination rather
    # than by success, since calling apply with no arguments necessarily errors
    # even when the command is present; only the specific unknown-command
    # message indicates absence.
    #
    # Arguments:
    #   channel -- The channel where diagnostic and progress output should be
    #              written.
    #
    # Results:
    #   None meaningful; reports yes or no and registers the constraint as a
    #   side effect.
    # </help>

    tputs $channel "---- checking for TIP #194... "

    #
    # NOTE: Is the interpreter TIP #194 ready?
    #
    catch {apply} error

    if {$error ne {invalid command name "apply"}} then {
      addConstraint tip194

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForTip207 { channel } {
    # <help>
    # This procedure probes whether the active interpreter implements Tcl
    # Improvement Proposal (TIP) #207, which added the -namespace option to
    # the [interp invokehidden] command, and registers the test constraint
    # named "tip207" when that support is present.  It exists so that tests
    # depending on namespace-aware hidden command invocation can be skipped on
    # interpreters that lack the feature.
    #
    # How it works: it attempts to invoke the (always present) hidden-or-not
    # "info" command via [interp invokehidden] using the -namespace switch,
    # capturing any error.  If the resulting error does NOT look like the
    # "bad option -namespace" complaint (matched as a glob with the option
    # name quoted), the option is understood and the constraint is added.
    # The probe deliberately does not care whether the underlying "info" call
    # succeeds, only whether the -namespace switch is recognized.
    #
    # Arguments:
    #   channel -- The output channel to which the human-readable progress
    #              line and a trailing "yes" or "no" result are written via
    #              [tputs].
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding the "tip207" constraint when the feature is detected and the
    #   progress text written to the channel.
    # </help>

    tputs $channel "---- checking for TIP #207... "

    #
    # NOTE: Is the interpreter TIP #207 ready?
    #
    catch {interp invokehidden {} -namespace -- info} error

    if {![string match {bad option "-namespace": *} $error]} then {
      addConstraint tip207

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForTip237 { channel } {
    # <help>
    # This procedure probes whether the active interpreter implements TIP #237,
    # which introduced the expression function entier() for exact integer
    # conversion of arbitrary numeric values, and registers the test constraint
    # named "tip237" when that support is present.
    #
    # How it works: it evaluates the expression entier(0) inside a [catch].  A
    # catch result of zero (success) means the function exists and the
    # constraint is added; any failure leaves the constraint unset.
    #
    # Arguments:
    #   channel -- The output channel for the progress line and "yes" or "no"
    #              result, written via [tputs].
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding the "tip237" constraint when the feature is detected.
    # </help>

    tputs $channel "---- checking for TIP #237... "

    #
    # NOTE: Does the interpreter have TIP #237 support?
    #
    if {[catch {expr {entier(0)}}] == 0} then {
      addConstraint tip237

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForTip241 { channel } {
    # <help>
    # This procedure probes whether the active interpreter implements TIP #241,
    # which added the -nocase option to the [lsearch] command, and registers the
    # test constraint named "tip241" when that support is present.
    #
    # How it works: it runs [lsearch -nocase 0 0] inside a [catch]; a catch
    # result of zero (success) means the -nocase option is accepted and the
    # constraint is added.  Any failure leaves the constraint unset.
    #
    # Arguments:
    #   channel -- The output channel for the progress line and "yes" or "no"
    #              result, written via [tputs].
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding the "tip241" constraint when the feature is detected.
    # </help>

    tputs $channel "---- checking for TIP #241... "

    #
    # NOTE: Is the interpreter TIP #241 ready?
    #
    if {[catch {lsearch -nocase 0 0}] == 0} then {
      addConstraint tip241

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForTip285 { channel } {
    # <help>
    # This procedure probes whether the active interpreter implements TIP #285,
    # which added asynchronous script cancellation via the [interp cancel]
    # command, and registers the test constraint named "tip285" when that
    # support is present.
    #
    # How it works: it first requires a fully ready interpreter (via
    # [alwaysFullInterpReady]); if so, it invokes [interp cancel] inside a
    # [catch] and inspects the captured error.  The signature of a working
    # implementation is the error message "eval canceled" -- when that exact
    # message is seen, the constraint is added and the procedure returns
    # immediately.  Tricky detail: the probe relies on matching this specific
    # error string rather than on success, because cancellation reports itself
    # as an error condition.  If the interpreter is not ready, or the message
    # does not match, the constraint is left unset and "no" is reported.
    #
    # Arguments:
    #   channel -- The output channel for the progress line and "yes" or "no"
    #              result, written via [tputs].
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding the "tip285" constraint when the feature is detected.
    # </help>

    tputs $channel "---- checking for TIP #285... "

    if {[alwaysFullInterpReady]} then {
      #
      # NOTE: Is the interpreter TIP #285 ready?
      #
      catch {interp cancel} error

      if {$error eq "eval canceled"} then {
        addConstraint tip285

        tputs $channel yes\n

        #
        # NOTE: We are done here, return now.
        #
        return
      }
    }

    tputs $channel no\n
  }

  proc checkForTip405 { channel } {
    # <help>
    # This procedure probes whether the active interpreter implements TIP #405,
    # which added the list-mapping commands [lmap] (and its companion [dict
    # map]), and registers the test constraint named "tip405" when that support
    # is present.
    #
    # How it works: it invokes [lmap] with no arguments inside a [catch] and
    # inspects the error.  If the captured error is anything OTHER than the
    # "invalid command name lmap" message, the command exists (the actual
    # error here would be a wrong-number-of-arguments complaint) and the
    # constraint is added.
    #
    # Arguments:
    #   channel -- The output channel for the progress line and "yes" or "no"
    #              result, written via [tputs].
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding the "tip405" constraint when the feature is detected.
    # </help>

    tputs $channel "---- checking for TIP #405... "

    #
    # NOTE: Does the interpreter have TIP #405 (i.e. [lmap])?
    #
    catch {lmap} error

    if {$error ne "invalid command name \"lmap\""} then {
      addConstraint tip405

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForTip421 { channel } {
    # <help>
    # This procedure probes whether the active interpreter implements TIP #421,
    # which added the [array for] command for iterating over the name/value
    # pairs of an array, and registers the test constraint named "tip421" when
    # that support is present.
    #
    # How it works: it builds a one-element array, uses [array for] (binding the
    # name and value variables) to accumulate the pairs into a list, and checks
    # both that the script ran without error and that the resulting list equals
    # the expected pair (the element 1 followed by the element "one").  Only
    # when both conditions hold is the constraint added, so it confirms the
    # command actually behaves correctly rather than merely existing.
    #
    # Arguments:
    #   channel -- The output channel for the progress line and "yes" or "no"
    #              result, written via [tputs].
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding the "tip421" constraint when the feature is detected.
    # </help>

    tputs $channel "---- checking for TIP #421... "

    #
    # NOTE: Is the interpreter TIP #421 ready?
    #
    if {[catch {
      set array(1) one; set list [list]

      array for {name value} array {
        lappend list $name $value
      }

      set list
    } result] == 0 && $result eq [list 1 one]} then {
      addConstraint tip421

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForTip426 { channel } {
    # <help>
    # This procedure probes whether the active interpreter implements TIP #426,
    # which added the [info cmdtype] subcommand for classifying a command by
    # type, and registers the test constraint named "tip426" when that support
    # is present.
    #
    # How it works: it invokes [info cmdtype] with no command-name argument
    # inside a [catch] and inspects the error.  A working implementation
    # complains about the wrong number of arguments with the exact message
    # mentioning that "info cmdtype commandName" is required; matching that
    # message confirms the subcommand exists and the constraint is added.
    #
    # Arguments:
    #   channel -- The output channel for the progress line and "yes" or "no"
    #              result, written via [tputs].
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding the "tip426" constraint when the feature is detected.
    # </help>

    tputs $channel "---- checking for TIP #426... "

    #
    # NOTE: Is the interpreter TIP #426 ready?
    #
    catch {info cmdtype} error

    if {$error eq {wrong # args: should be "info cmdtype commandName"}} then {
      addConstraint tip426

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForTip429 { channel } {
    # <help>
    # This procedure probes whether the active interpreter implements TIP #429,
    # which added the [string cat] subcommand for efficient string
    # concatenation, and registers the test constraint named "tip429" when that
    # support is present.
    #
    # How it works: it runs [string cat] with no arguments inside a [catch]; a
    # catch result of zero (success, yielding the empty string) means the
    # subcommand exists and the constraint is added.
    #
    # Arguments:
    #   channel -- The output channel for the progress line and "yes" or "no"
    #              result, written via [tputs].
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding the "tip429" constraint when the feature is detected.
    # </help>

    tputs $channel "---- checking for TIP #429... "

    #
    # NOTE: Is the interpreter TIP #429 ready?
    #
    if {[catch {string cat}] == 0} then {
      addConstraint tip429

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForTip440 { channel } {
    # <help>
    # This procedure probes whether the active interpreter implements TIP #440,
    # which added the "engine" element to the global tcl_platform array
    # (identifying the underlying script engine, e.g. Tcl or TclTk), and
    # registers the test constraint named "tip440" when that support is present.
    #
    # How it works: it reads the global variable element tcl_platform(engine)
    # inside a [catch]; a catch result of zero (success) means the element
    # exists and the constraint is added.  The detected engine name is also
    # echoed in parentheses on the progress line.
    #
    # Arguments:
    #   channel -- The output channel for the progress line and the "yes" (with
    #              the engine name) or "no" result, written via [tputs].
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding the "tip440" constraint when the feature is detected.
    # </help>

    tputs $channel "---- checking for TIP #440... "

    #
    # NOTE: Is the interpreter TIP #440 ready?
    #
    if {[catch {set ::tcl_platform(engine)} engine] == 0} then {
      addConstraint tip440

      tputs $channel [appendArgs "yes (" $engine ")\n"]
    } else {
      tputs $channel no\n
    }
  }

  proc checkForTip461 { channel } {
    # <help>
    # This procedure probes whether the active interpreter implements TIP #461,
    # which added the string-comparison expression operators eq, ne, lt, gt, le,
    # and ge, and registers the test constraint named "tip461" when that support
    # is present.
    #
    # How it works: it builds four expressions exercising the lt, gt, le, and ge
    # operators (wrapped in int() and comparing two identical strings) and
    # evaluates all four inside a [catch].  A catch result of zero (success)
    # means the operators are understood and the constraint is added.  The probe
    # checks only that evaluation succeeds, not the boolean outcomes.
    #
    # Arguments:
    #   channel -- The output channel for the progress line and "yes" or "no"
    #              result, written via [tputs].
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding the "tip461" constraint when the feature is detected.
    # </help>

    tputs $channel "---- checking for TIP #461... "

    #
    # NOTE: Is the interpreter TIP #461 ready?
    #
    if {[catch {
      set expr(ge) {int("abc" ge "abc")}
      set expr(gt) {int("abc" gt "abc")}
      set expr(le) {int("abc" le "abc")}
      set expr(lt) {int("abc" lt "abc")}

      list [expr $expr(ge)] [expr $expr(gt)] \
          [expr $expr(le)] [expr $expr(lt)]
    }] == 0} then {
      addConstraint tip461

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForTip463 { channel } {
    # <help>
    # This procedure probes whether the active interpreter implements TIP #463,
    # which added the -command option to [regsub] (allowing a command to compute
    # each replacement), and registers the test constraint named "tip463" when
    # that support is present.
    #
    # How it works: it runs [regsub -command . . list] inside a [catch]; a catch
    # result of zero (success) means the -command option is accepted and the
    # constraint is added.  The arguments are minimal placeholders chosen only
    # to make the option recognized, not to perform a meaningful substitution.
    #
    # Arguments:
    #   channel -- The output channel for the progress line and "yes" or "no"
    #              result, written via [tputs].
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding the "tip463" constraint when the feature is detected.
    # </help>

    tputs $channel "---- checking for TIP #463... "

    #
    # NOTE: Is the interpreter TIP #463 ready?
    #
    if {[catch {
      regsub -command . . list
    }] == 0} then {
      addConstraint tip463

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForTip471 { channel } {
    # <help>
    # This procedure probes whether the active interpreter implements TIP #471,
    # which added the [info linkedname] subcommand (reporting the target of a
    # linked variable), and registers the test constraint named "tip471" when
    # that support is present.
    #
    # How it works: it invokes [info linkedname] with no argument inside a
    # [catch] and inspects the error.  A working implementation complains about
    # the wrong number of arguments; matching the leading wrong-number-of-args
    # message (as a glob) confirms the subcommand exists and the constraint is
    # added.
    #
    # Arguments:
    #   channel -- The output channel for the progress line and "yes" or "no"
    #              result, written via [tputs].
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding the "tip471" constraint when the feature is detected.
    # </help>

    tputs $channel "---- checking for TIP #471... "

    #
    # NOTE: Is the interpreter TIP #471 ready?
    #
    catch {info linkedname} error

    if {[string match {wrong # args: should be "*} $error]} then {
      addConstraint tip471

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForTip508 { channel } {
    # <help>
    # This procedure probes whether the active interpreter implements TIP #508,
    # which added the [array default] subcommand (configuring a default value
    # for missing array elements), and registers the test constraint named
    # "tip508" when that support is present.
    #
    # How it works: it invokes [array default] with no further arguments inside
    # a [catch] and inspects the error.  A working implementation complains
    # about the wrong number of arguments; matching the leading
    # wrong-number-of-args message (as a glob) confirms the subcommand exists
    # and the constraint is added.
    #
    # Arguments:
    #   channel -- The output channel for the progress line and "yes" or "no"
    #              result, written via [tputs].
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding the "tip508" constraint when the feature is detected.
    # </help>

    tputs $channel "---- checking for TIP #508... "

    #
    # NOTE: Is the interpreter TIP #508 ready?
    #
    catch {array default} error

    if {[string match {wrong # args: should be "*} $error]} then {
      addConstraint tip508

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForTip521 { channel } {
    # <help>
    # This procedure probes whether the active interpreter implements TIP #521,
    # which added the fpclassify() expression function for classifying a
    # floating-point value (zero, subnormal, normal, infinite, or NaN), and
    # registers the test constraint named "tip521" when that support is present.
    #
    # How it works: it invokes [fpclassify 1.0] as a command inside a [catch];
    # a catch result of zero (success) means the function exists and the
    # constraint is added.
    #
    # Arguments:
    #   channel -- The output channel for the progress line and "yes" or "no"
    #              result, written via [tputs].
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding the "tip521" constraint when the feature is detected.
    # </help>

    tputs $channel "---- checking for TIP #521... "

    #
    # NOTE: Is the interpreter TIP #521 ready?
    #
    if {[catch {fpclassify 1.0}] == 0} then {
      addConstraint tip521

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForTiming {
          channel threshold {constraint ""} {tries 1} {delay 1000}
          {average false} {asynchronous false} } {
    # <help>
    # This procedure probes whether the host can perform reasonably precise
    # timing -- that is, whether a requested delay actually elapses within an
    # acceptable tolerance -- and registers a timing test constraint when it
    # does.  The constraint name defaults to "timing" but may be overridden by
    # the caller, allowing several differently-tuned timing constraints to
    # coexist.  This exists because some platforms, virtual machines, or loaded
    # systems cannot sleep accurately enough for tests that depend on real-time
    # behavior.
    #
    # How it works: for up to "tries" attempts, it records a start time, waits
    # for "delay" milliseconds, records a stop time, and computes the absolute
    # difference between the measured elapsed time and the requested delay.  The
    # delay can be performed either synchronously (a plain [after] followed by
    # running a stop script) or asynchronously (scheduling the stop script with
    # [after] and blocking in [vwait] on a global variable).  If the difference
    # falls within the inclusive zero-to-threshold range, the constraint is
    # added and the procedure returns immediately; otherwise it keeps retrying.
    #
    # Tricky details: clock readings are masked with a positive bitmask to keep
    # them non-negative.  The stop script must set a global variable because the
    # asynchronous [after] callback runs in the global frame; that value is then
    # copied into the local frame and the global is unset.  Retrying exists
    # because the first attempt is often abnormally slow (just-in-time warmup,
    # scheduling jitter).  When "average" is true and more than one try is
    # allowed, the running total is divided by the total "tries" value (not the
    # count of attempts completed so far) to compare an average difference
    # rather than a single sample.
    #
    # Arguments:
    #   channel      -- The output channel for the progress and result lines,
    #                   written via [tputs].
    #   threshold    -- The maximum acceptable difference, in milliseconds,
    #                   between the requested and measured delay.
    #   constraint   -- Optional name of the constraint to add on success; when
    #                   empty (the default), the name "timing" is used.
    #   tries        -- Optional maximum number of attempts before giving up;
    #                   defaults to 1.
    #   delay        -- Optional delay to wait per attempt, in milliseconds;
    #                   defaults to 1000.
    #   average      -- Optional boolean; when true (and more than one try is
    #                   allowed) the average difference across attempts so far
    #                   is compared against the threshold instead of the single
    #                   most recent difference.  Defaults to false.
    #   asynchronous -- Optional boolean selecting the asynchronous [after] plus
    #                   [vwait] delay mechanism instead of a synchronous wait.
    #                   Defaults to false.
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding the chosen timing constraint when an attempt lands within the
    #   threshold, plus the progress text written to the channel.
    # </help>

    tputs $channel [appendArgs \
        "---- checking for precision timing (threshold of " $threshold \
        " milliseconds" [expr {$average ? " average" : ""}] ", delay of " \
        $delay " milliseconds)... "]

    #
    # HACK: Sometimes the first try takes quite a bit longer than subsequent
    #       tries.  We attempt to bypass this problem by retrying a set number
    #       of times (which can be overridden by the caller) before giving up.
    #
    set total 0
    set difference unknown

    for {set try 0} {$try < $tries} {incr try} {
      #
      # NOTE: Create a script that will set the final clicks value.  This must
      #       use a global variable due to the nature of [after].
      #
      set stopScript {
        set ::stopClicks [expr {[clock clicks -milliseconds] & 0x7fffffff}]
      }

      #
      # NOTE: Set the initial clicks value and then attempt to wait for about
      #       one second, either synchronously or asynchronously, depending on
      #       the preference of the caller.
      #
      set start [expr {[clock clicks -milliseconds] & 0x7fffffff}]

      if {$asynchronous} then {
        set event [after $delay $stopScript]; vwait ::stopClicks
      } else {
        after $delay; eval $stopScript
      }

      #
      # NOTE: Move the final clicks value from the global frame to this one.
      #
      set stop $::stopClicks; unset ::stopClicks

      #
      # NOTE: Calculate the difference between the actual and expected
      #       number of milliseconds.
      #
      set difference [expr {abs($stop - $start - $delay)}]

      #
      # NOTE: Keep track of the total number of milliseconds elapsed for
      #       all iterations of this loop.
      #
      incr total $difference

      #
      # NOTE: If we are using the average difference, handle that now.
      #
      if {$average && $tries > 1} then {
        set difference [expr {$total / $tries}]
      }

      #
      # NOTE: Are we within the threshold specified by the caller?
      #
      if {$difference >= 0 && $difference <= $threshold} then {
        #
        # NOTE: We appear to be capable of fairly precise timing.
        #
        if {[string length $constraint] == 0} then {
          set constraint timing
        }

        addConstraint $constraint

        tputs $channel [appendArgs \
            "yes (0 <= " $difference " <= " $threshold " milliseconds" \
            [expr {$average ? " average" : ""}] ", tried " [expr {$try + 1}] \
            " out of " $tries " " [expr {$tries > 1 ? "times" : "time"}] \
            ", \"" $constraint "\")\n"]

        #
        # NOTE: We are done here, return now.
        #
        return
      }
    }

    tputs $channel [appendArgs \
        "no (0 <= " $difference " > " $threshold " milliseconds" \
        [expr {$average ? " average" : ""}] ", tried " $try " out of " \
        $tries " " [expr {$tries > 1 ? "times" : "time"}] ")\n"]
  }

  proc checkForPerformance { channel } {
    # <help>
    # This procedure determines whether performance-oriented tests are allowed
    # to run and registers the test constraint named "performance" when they
    # are.  It exists so that timing-sensitive or benchmark-style tests can be
    # globally suppressed (for example, on continuous-integration machines where
    # their results would be meaningless).
    #
    # How it works: it adds the constraint unless the global array element
    # no(performance) exists; the presence of that element acts as an opt-out
    # flag, typically set in a test prologue.
    #
    # Arguments:
    #   channel -- The output channel for the progress line and "yes" or "no"
    #              result, written via [tputs].
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding the "performance" constraint when permitted.
    # </help>

    tputs $channel "---- checking for performance testing... "

    #
    # NOTE: Are we allowed to do performance testing?
    #
    if {![info exists ::no(performance)]} then {
      addConstraint performance

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForBigLists { channel } {
    # <help>
    # This procedure determines whether tests that build or manipulate very
    # large lists are allowed to run and registers the test constraint named
    # "bigLists" when they are.  It exists to gate memory- and time-heavy list
    # tests, and additionally to work around a known crash.
    #
    # How it works: the constraint is skipped entirely if the global array
    # element no(bigLists) exists.  Otherwise, when running under TclTk, it adds
    # the constraint unless the dangerous combination of Mono plus the native
    # utility library is detected -- joining big lists with the native utility
    # on Mono is known to throw a stack-overflow exception, so that case is
    # refused with an explanatory message.  Under native Tcl the constraint is
    # always added.
    #
    # Arguments:
    #   channel -- The output channel for the progress line and result, written
    #              via [tputs].
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding the "bigLists" constraint when permitted and safe.
    # </help>

    tputs $channel "---- checking for big list testing... "

    #
    # NOTE: Are we allowed to do big list testing?
    #
    if {![info exists ::no(bigLists)]} then {
      if {[isTclTk]} then {
        #
        # MONO: Using the native utility library when running on Mono to
        #       join big lists seems to cause StackOverflowException to
        #       be thrown.
        #
        if {![isTestMono] || ![haveConstraint nativeUtility]} then {
          #
          # NOTE: Yes, it appears that it is available.
          #
          addConstraint bigLists

          tputs $channel yes\n
        } else {
          tputs $channel "no, broken on Mono with native utility\n"
        }
      } else {
        addConstraint bigLists

        tputs $channel yes\n
      }
    } else {
      tputs $channel no\n
    }
  }

  proc checkForProcessorIntensive { channel } {
    # <help>
    # This procedure determines whether processor (CPU) intensive tests are
    # allowed to run and registers the test constraints named
    # "maybeProcessorIntensive" and "processorIntensive" when they are.  It
    # exists so that heavy compute tests can be suppressed on slow or shared
    # machines.
    #
    # How it works: both constraints are added unless the global array element
    # no(processorIntensive) exists, which acts as an opt-out flag.  The
    # "maybe" variant is provided alongside the firm one so callers can express
    # softer dependencies on the same condition.
    #
    # Arguments:
    #   channel -- The output channel for the progress line and "yes" or "no"
    #              result, written via [tputs].
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding the two processor-intensive constraints when permitted.
    # </help>

    tputs $channel "---- checking for processor intensive testing... "

    #
    # NOTE: Are we allowed to do processor intensive testing?
    #
    if {![info exists ::no(processorIntensive)]} then {
      addConstraint maybeProcessorIntensive
      addConstraint processorIntensive

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForFileSystemIntensive { channel } {
    # <help>
    # This procedure determines whether file-system intensive tests are allowed
    # to run and registers the test constraints named "maybeFileSystemIntensive"
    # and "fileSystemIntensive" when they are.  It exists so that tests doing
    # large or numerous disk operations can be suppressed where they would be
    # too slow or undesirable.
    #
    # How it works: both constraints are added unless the global array element
    # no(fileSystemIntensive) exists, which acts as an opt-out flag.  The
    # "maybe" variant is provided alongside the firm one for softer
    # dependencies.
    #
    # Arguments:
    #   channel -- The output channel for the progress line and "yes" or "no"
    #              result, written via [tputs].
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding the two file-system-intensive constraints when permitted.
    # </help>

    tputs $channel "---- checking for file system intensive testing... "

    #
    # NOTE: Are we allowed to do file system intensive testing?
    #
    if {![info exists ::no(fileSystemIntensive)]} then {
      addConstraint maybeFileSystemIntensive
      addConstraint fileSystemIntensive

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForTimeIntensive { channel } {
    # <help>
    # This procedure determines whether time intensive (long-running) tests are
    # allowed to run and registers the test constraints named
    # "maybeTimeIntensive" and "timeIntensive" when they are.  It exists so that
    # tests that simply take a long time can be suppressed when quick turnaround
    # is needed.
    #
    # How it works: both constraints are added unless the global array element
    # no(timeIntensive) exists, which acts as an opt-out flag.  The "maybe"
    # variant is provided alongside the firm one for softer dependencies.
    #
    # Arguments:
    #   channel -- The output channel for the progress line and "yes" or "no"
    #              result, written via [tputs].
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding the two time-intensive constraints when permitted.
    # </help>

    tputs $channel "---- checking for time intensive testing... "

    #
    # NOTE: Are we allowed to do time intensive testing?
    #
    if {![info exists ::no(timeIntensive)]} then {
      addConstraint maybeTimeIntensive
      addConstraint timeIntensive

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForFullTest { channel } {
    # <help>
    # This procedure determines whether a "full" test run is requested -- one
    # that includes rarely-needed or exhaustive tests -- and registers the test
    # constraint named "fullTest" when it is.  It exists so that seldom-useful
    # tests can be omitted from routine runs and enabled only on demand.
    #
    # How it works: the constraint is added unless the global array element
    # no(fullTest) exists, which acts as an opt-out flag.
    #
    # Arguments:
    #   channel -- The output channel for the progress line and "yes" or "no"
    #              result, written via [tputs].
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding the "fullTest" constraint when permitted.
    # </help>

    tputs $channel "---- checking for full testing... "

    #
    # NOTE: Are we allowed to do full testing (i.e. to run rarely
    #       needed tests)?
    #
    if {![info exists ::no(fullTest)]} then {
      addConstraint fullTest

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForMemoryIntensive { channel {memoryThreshold 3000000000} } {
    # <help>
    # This procedure determines whether memory intensive tests are allowed to
    # run and registers the test constraints named "maybeMemoryIntensive" and
    # "memoryIntensive" when they are.  Unlike the other "intensive" probes, it
    # can additionally gate on how much physical memory the machine actually
    # has, so that tests requiring a lot of RAM are skipped on small hosts.
    #
    # How it works: the constraints are skipped entirely if the global array
    # element no(memoryIntensive) exists.  Otherwise, under TclTk with a
    # positive threshold, it queries total physical memory via [debug memory]
    # (extracting the totalPhysical value from the returned dictionary): if that
    # value is unknown it adds the constraints with a "yes (unknown)" note; if
    # it is a valid wide integer at or above the threshold it adds them; if it
    # is below the threshold it declines; and if the query itself fails it
    # reports an error.  Under native Tcl, or when the threshold is zero or
    # less (memory checking explicitly disabled), the constraints are added
    # unconditionally with a "yes (skipped)" note.
    #
    # Arguments:
    #   channel         -- The output channel for the progress line and result,
    #                      written via [tputs].
    #   memoryThreshold -- Optional minimum total physical memory, in bytes,
    #                      required to enable the constraints under TclTk;
    #                      defaults to 3000000000.  A value of zero or less
    #                      disables the memory check and always enables the
    #                      constraints.
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding the two memory-intensive constraints when permitted and when the
    #   memory threshold (if any) is satisfied.
    # </help>

    tputs $channel "---- checking for memory intensive testing... "

    #
    # NOTE: Are we allowed to do memory intensive testing?
    #
    if {![info exists ::no(memoryIntensive)]} then {
      if {[isTclTk] && $memoryThreshold > 0} then {
        if {[catch {debug memory} memory] == 0} then {
          set totalPhysical [getDictionaryValue $memory totalPhysical]

          if {[string length $totalPhysical] == 0} then {
            addConstraint maybeMemoryIntensive
            addConstraint memoryIntensive

            tputs $channel "yes (unknown)\n"
          } else {
            if {[string is wideinteger -strict $totalPhysical] && \
                $totalPhysical >= $memoryThreshold} then {
              addConstraint maybeMemoryIntensive
              addConstraint memoryIntensive

              tputs $channel yes\n
            } else {
              tputs $channel no\n
            }
          }
        } else {
          tputs $channel error\n
        }
      } else {
        #
        # HACK: This is either native Tcl -OR- memory threshold
        #       checks have been explicitly disabled.
        #
        addConstraint maybeMemoryIntensive
        addConstraint memoryIntensive

        tputs $channel "yes (skipped)\n"
      }
    } else {
      tputs $channel no\n
    }
  }

  proc checkForStackIntensive { channel } {
    # <help>
    # This procedure determines whether stack intensive tests (those involving
    # deep recursion or large native-stack usage) are allowed to run and
    # registers the test constraint named "stackIntensive" when they are.  It
    # exists to avoid stack-overflow crashes on builds that cannot monitor the
    # native stack.
    #
    # How it works: the constraint is skipped if the global array element
    # no(stackIntensive) exists.  Otherwise, under TclTk, it asks the private
    # NativeStack helper whether native stack checking IsAvailable (via [object
    # invoke] with non-public access); the constraint is added only when that
    # returns a strict true.  Under native Tcl the constraint is always added.
    #
    # Arguments:
    #   channel -- The output channel for the progress line and "yes" or "no"
    #              result, written via [tputs].
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding the "stackIntensive" constraint when permitted and supported.
    # </help>

    tputs $channel "---- checking for stack intensive testing... "

    #
    # NOTE: Are we allowed to do stack intensive testing?
    #
    if {![info exists ::no(stackIntensive)]} then {
      if {[isTclTk]} then {
        #
        # NOTE: Attempt to query for native stack checking in TclTk.
        #
        if {[catch {
          object invoke -flags +NonPublic \
              CodeBrix.Platform.TclTk._Components.Private.NativeStack IsAvailable
        } isAvailable] == 0 && \
            [string is true -strict $isAvailable]} then {
          #
          # NOTE: Yes, it appears that it is available.
          #
          addConstraint stackIntensive

          tputs $channel yes\n
        } else {
          tputs $channel no\n
        }
      } else {
        addConstraint stackIntensive

        tputs $channel yes\n
      }
    } else {
      tputs $channel no\n
    }
  }

  proc ulimitStackSizeToBytes { value } {
    # <help>
    # This procedure converts a stack size reported by the operating system's
    # "ulimit -s" command (which is expressed in kilobytes) into a count of
    # bytes.  It is a helper used by the stack-size probe to normalize ulimit
    # output into the byte units the constraint logic expects.
    #
    # How it works: it multiplies the supplied kilobyte value by 1024.  The
    # special string "unlimited" (which ulimit may report) is first replaced
    # with a fixed default of 0x4000 kilobytes, i.e. 16 mebibytes, since an
    # unlimited stack cannot be represented as a concrete byte count.
    #
    # Arguments:
    #   value -- A stack size in kilobytes, or the literal string "unlimited".
    #
    # Results:
    #   The stack size in bytes as an integer.
    # </help>

    set default 0x4000; # (0x4000 * 1KiB) ==> 0x1000000 bytes (16MiB)
    if {$value eq "unlimited"} then {set value $default}
    return [expr {1024 * $value}]
  }

  proc getUlimitC99 {} {
    # <help>
    # This procedure returns the C99 source code for a small command-line
    # program that mimics the relevant behavior of the shell "ulimit -s"
    # command, namely querying (and optionally setting) the process stack-size
    # resource limit.  It exists so that the stack-size probe can compile and
    # run this program on POSIX-compliant systems that have a C99 compiler but
    # lack a usable "ulimit" command.
    #
    # How it works: it simply returns a brace-quoted string literal containing
    # the program text.  The program uses getrlimit and setrlimit on the stack
    # resource; given the -s switch alone it prints the current soft limit in
    # kilobytes (or the word "unlimited" for an infinite limit), and given a
    # kilobyte argument it raises the limit and prints the new value.  This
    # procedure performs no compilation itself; it is the source provider for
    # [compileViaC99].
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   A string containing the complete C99 source code described above.
    # </help>

    return {
      #define _POSIX_C_SOURCE 200112L

      #include <errno.h>
      #include <inttypes.h>
      #include <stdio.h>
      #include <stdlib.h>
      #include <string.h>
      #include <sys/resource.h>

      static void usage(const char *prog) {
        fprintf(stderr, "Usage: %s -s [kilobytes]\n", prog);
        exit(EXIT_FAILURE);
      }

      static void print_limit(rlim_t lim) {
        if (lim == RLIM_INFINITY) {
          puts("unlimited");
        } else {
          printf("%" PRIuMAX "\n", (uintmax_t)(lim / 1024));
        }
      }

      int main(int argc, char *argv[]) {
        unsigned long long kb;
        rlim_t new_lim;
        char *end;
        struct rlimit have;
        struct rlimit want;

        if ((argc != 2 && argc != 3) || strcmp(argv[1], "-s") != 0)
          usage(argv[0]);

        if (getrlimit(RLIMIT_STACK, &have) != 0) {
          perror("getrlimit");
          return EXIT_FAILURE;
        }

        if (argc == 2) {
          print_limit(have.rlim_cur);
          return EXIT_SUCCESS;
        }

        errno = 0;
        kb = strtoull(argv[2], &end, 10);

        if (errno || *end) {
          fprintf(stderr, "invalid size: %s\n", argv[2]);
          return EXIT_FAILURE;
        }

        new_lim = (rlim_t)kb * 1024ULL;
        want = have;
        want.rlim_cur = new_lim;

        if (new_lim > have.rlim_max)
          want.rlim_max = new_lim;

        if (setrlimit(RLIMIT_STACK, &want) != 0) {
          perror("setrlimit");
          return EXIT_FAILURE;
        }

        if (getrlimit(RLIMIT_STACK, &have) != 0) {
          perror("getrlimit");
          return EXIT_FAILURE;
        }

        print_limit(have.rlim_cur);
        return EXIT_SUCCESS;
      }
    }
  }

  proc compileViaC99 { executableFileName text } {
    # <help>
    # This procedure compiles the supplied C99 source text into a native
    # executable using the system C compiler.  It is a helper used by the
    # stack-size probe to build the small ulimit-equivalent program returned by
    # [getUlimitC99] when no usable "ulimit" command is available.
    #
    # How it works: under TclTk it writes the source text to a temporary file
    # named by appending a ".c" suffix to the requested executable name, then
    # runs the compiler (cc with the -std=c99 switch, expecting a "Success"
    # exit) to produce the executable.  A [try]/[finally] block guarantees the
    # temporary source file is deleted afterward, whether or not compilation
    # succeeded.  Outside TclTk the operation is not supported and an error is
    # raised.
    #
    # Tricky details: the compiler invocation uses [exec -success Success], so a
    # nonzero compiler exit becomes a script error that propagates to the
    # caller; only the source file is cleaned up here, not the produced
    # executable (that is the caller's responsibility).
    #
    # Arguments:
    #   executableFileName -- The path of the executable to produce; the source
    #                         file is this path with a ".c" suffix appended.
    #   text               -- The C99 source code to compile.
    #
    # Results:
    #   The result is unspecified on success; the executable file is left in
    #   place.  An error is raised if compilation fails or if the procedure is
    #   called outside TclTk.
    # </help>

    if {[isTclTk]} then {
      try {
        set sourceFileName [appendArgs \
            $executableFileName .c]

        writeFile $sourceFileName $text

        exec -success Success -- \
            cc -std=c99 -o $executableFileName \
            $sourceFileName; # gcc (?)
      } finally {
        if {[info exists sourceFileName] && \
            [file exists $sourceFileName]} then {
          catch {file delete $sourceFileName}
        }
      }
    } else {
      error "not implemented on this platform"
    }
  }

  proc checkForStackSize { channel } {
    # <help>
    # This procedure probes the available native stack size for the current
    # process and registers a constraint whose name encodes the discovered size
    # in bytes, of the form "stackSize." followed by a hexadecimal byte count
    # (for example "stackSize.0x1000000").  When the size cannot be determined
    # it instead registers fallback constraints such as "stackSize.unknown"
    # (and, under native Tcl, "stackSize.unlimited").  It exists so that tests
    # sensitive to recursion depth can require a minimum stack.
    #
    # How it works: the whole probe is skipped if the global array element
    # no(stackSize) exists.  Under TclTk the discovery runs inside an outer
    # [catch] that, by design, treats only the "Return" completion code (2) as
    # success -- the inner script signals its computed size by [return]ing it.
    # On Windows it reads the PE header stack reserve of the running executable
    # via the private FileOps helper.  Otherwise, if a "ulimit" command can be
    # executed it parses "ulimit -s"; failing that, if a C compiler is
    # available, it compiles the ulimit-equivalent C99 program from
    # [getUlimitC99] via [compileViaC99], runs it, and parses its output.  Both
    # ulimit paths convert the reported kilobytes to bytes with
    # [ulimitStackSizeToBytes].  If none of these work the inner script raises
    # an error, so no concrete size is returned.  A returned positive integer is
    # formatted as hexadecimal and used to build the constraint name (the
    # detection method -- peFileReserve, ulimitCommand, or ulimitC99Source -- is
    # echoed on the progress line); otherwise "stackSize.unknown" is added.
    # Under native Tcl there is no portable way to query this, so both
    # "stackSize.unlimited" and "stackSize.unknown" are added.
    #
    # Tricky details: temporary files created during the C99 fallback are
    # deleted in a [finally] block.  The Windows branch deliberately uses the
    # running executable name rather than the shell executable helper, because
    # it must reflect the process that is actually running.
    #
    # Arguments:
    #   channel -- The output channel for the progress line and result, written
    #              via [tputs].
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding a "stackSize.*" constraint describing the discovered (or unknown)
    #   native stack size.
    # </help>

    tputs $channel "---- checking for stack size... "

    if {![info exists ::no(stackSize)]} then {
      if {[isTclTk]} then {
        #
        # HACK: This outer [catch] block only allows the "Return" code (2)
        #       to be considered successful.
        #
        if {[catch {
          if {[isWindows]} then {
            #
            # NOTE: Attempt to query for the executable stack size.
            #
            # HACK: This does not use the [getShellExecutableName] script
            #       library procedure because it must always refer to the
            #       name of the file that started the current process.
            #
            set reserve [object invoke -create UIntPtr Zero]
            set commit [object invoke -create UIntPtr Zero]

            object invoke -flags +NonPublic \
                CodeBrix.Platform.TclTk._Components.Private.FileOps \
                GetPeFileStackReserveAndCommit \
                [info nameofexecutable] reserve commit; # EXEMPT

            set type peFileReserve
            return $reserve; # bytes
          } elseif {[canExecUlimit]} then {
            if {[catch {
              #
              # NOTE: Attempt to use "ulimit" command provided by the
              #       operating system, if any.  If there is none, we
              #       fail attempt to compile it from appropriate C99
              #       source code.
              #
              string trim [exec -success Success -- ulimit -s]
            } maximum] == 0} then {
              set type ulimitCommand
              return [ulimitStackSizeToBytes $maximum]
            } elseif {[canExecCc]} then {
              #
              # NOTE: Attempt to compile a temporary "ulimit" command
              #       from our C99 source code, which should work on
              #       any "POSIX compliant" operating system with a
              #       suitable C99 compiler.
              #
              try {
                set fileName [file tempname]

                compileViaC99 $fileName [getUlimitC99]

                set maximum [string trim \
                    [exec -success Success -- $fileName -s]]

                set type ulimitC99Source
                return [ulimitStackSizeToBytes $maximum]
              } finally {
                if {[info exists fileName] && \
                    [file exists $fileName]} then {
                  catch {file delete $fileName}
                }
              }
            }
          }

          #
          # NOTE: Now we know the native stack size could not be (readily)
          #       determined; therefore, raise a script error, which will
          #       cause the stack size test constraint(s) to remain unmet.
          #       This should only be possible when running on non-Windows
          #       systems that do not have a "ulimit" command -AND- lack a
          #       C99 compiler that capable of compiling one based on our
          #       C99 source code.
          #
          error unavailable
        } stackSize] == 2 && \
            [string is integer -strict $stackSize] && $stackSize > 0} then {
          set stackSize [appendArgs 0x [format %x $stackSize]]
          addConstraint [appendArgs stackSize. $stackSize]

          tputs $channel [appendArgs "yes (" $stackSize " via " $type ")\n"]
        } else {
          addConstraint stackSize.unknown; # TODO: Fix me?

          tputs $channel no\n
        }
      } else {
        #
        # NOTE: Currently, no (cross-platform) way to check the (native)
        #       stack size in native Tcl.
        #
        addConstraint stackSize.unlimited; # TODO: Fix me?
        addConstraint stackSize.unknown; # TODO: Fix me?

        tputs $channel yes\n
      }
    } else {
      tputs $channel no\n
    }
  }

  proc checkForInteractive { channel } {
    # <help>
    # This procedure probes whether the interpreter is running interactively
    # (i.e. with a user present at a console) and registers the test constraint
    # named "interactive" when it is.  It exists so that tests requiring a live
    # console -- or that would block waiting for input -- run only when
    # appropriate.
    #
    # How it works: it checks that the global variable tcl_interactive both
    # exists and is true; this is the standard flag set when an interpreter is
    # in its interactive read-eval-print loop.
    #
    # Arguments:
    #   channel -- The output channel for the progress line and "yes" or "no"
    #              result, written via [tputs].
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding the "interactive" constraint when an interactive user is present.
    # </help>

    tputs $channel "---- checking for interactive user... "

    #
    # NOTE: Is there an interactive user?
    #
    if {[info exists ::tcl_interactive] && $::tcl_interactive} then {
      addConstraint interactive

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForInteractiveFocus { channel } {
    # <help>
    # This procedure probes whether the process console window currently has
    # input focus and registers the test constraint named "interactiveFocus"
    # when it does.  It exists for tests that exercise console focus behavior or
    # that should only run when the user is actually looking at the window.
    #
    # How it works: under TclTk it calls the private NativeConsole helper's
    # HasWindowFocus method (via [object invoke] with non-public access),
    # passing a null error placeholder.  If the call succeeds and reports focus,
    # the constraint is added; if it succeeds without focus it reports "no"; if
    # the call itself fails it reports "error".  Under native Tcl the focus
    # state cannot be determined, so it reports "unknown" and adds nothing.
    #
    # Arguments:
    #   channel -- The output channel for the progress line and result (one of
    #              "yes", "no", "error", or "unknown"), written via [tputs].
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding the "interactiveFocus" constraint when the console has focus.
    # </help>

    tputs $channel "---- checking for interactive focus... "

    if {[isTclTk]} then {
      if {[catch {
        set error null

        object invoke -flags +NonPublic \
            CodeBrix.Platform.TclTk._Components.Private.NativeConsole \
            HasWindowFocus null error
      } hasFocus] == 0} then {
        if {$hasFocus} then {
          addConstraint interactiveFocus

          tputs $channel yes\n
        } else {
          tputs $channel no\n
        }
      } else {
        tputs $channel error\n
      }
    } else {
      tputs $channel unknown\n
    }
  }

  proc checkForInteractiveCommand { channel name } {
    # <help>
    # This procedure probes whether a particular TclTk interactive command (one
    # of the special commands available at the interactive prompt, typically
    # introduced with a leading "#") is present, and registers the test
    # constraint named "interactiveCommand." followed by the command name when
    # it is.  It exists so that tests of specific interactive commands can be
    # skipped on builds where those commands are unavailable.
    #
    # How it works: only TclTk has interactive commands, so under native Tcl it
    # always reports "no".  Under TclTk it calls Utility GetInteractiveCommandNames
    # (via [object invoke]) filtered by the requested name; if that succeeds and
    # returns a non-empty list, the named command exists, the per-name
    # constraint is added, and the procedure returns immediately.
    #
    # Arguments:
    #   channel -- The output channel for the progress line and "yes" or "no"
    #              result, written via [tputs].
    #   name    -- The interactive command name to look for; it is also embedded
    #              in the constraint name that gets registered.
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding the per-name interactive-command constraint when the command is
    #   available.
    # </help>

    tputs $channel [appendArgs "---- checking for interactive command \"" \
        $name "\"... "]

    #
    # NOTE: Currently, only TclTk has "interactive commands".
    #
    if {[isTclTk]} then {
      #
      # NOTE: Attempt to query the interactive command names from TclTk.
      #
      if {[catch {
        object invoke Utility GetInteractiveCommandNames "" $name false
      } names] == 0 && [llength $names] > 0} then {
        #
        # NOTE: Yes, it appears that it is available.
        #
        addConstraint [appendArgs interactiveCommand. $name]

        tputs $channel yes\n

        #
        # NOTE: We are done here, return now.
        #
        return
      }
    }

    tputs $channel no\n
  }

  proc checkForUserInteraction { channel } {
    # <help>
    # This procedure probes whether tests may solicit interaction from a live
    # user and registers the test constraint named "userInteraction" when they
    # may.  It exists as a constraint distinct from "interactive" precisely so
    # that user-prompting tests can be disabled independently (for example, in
    # a test prologue) even on an otherwise interactive interpreter.
    #
    # How it works: at present it performs the same check as
    # [checkForInteractive] -- requiring that the global tcl_interactive
    # variable exist and be true -- but registers its own separate constraint
    # name.
    #
    # Arguments:
    #   channel -- The output channel for the progress line and "yes" or "no"
    #              result, written via [tputs].
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding the "userInteraction" constraint when user interaction is
    #   permitted.
    # </help>

    tputs $channel "---- checking for user interaction... "

    #
    # HACK: For now, do the exact same check as checkForInteractive; however,
    #       this is still useful as a separate constraint because it can be
    #       individually disabled in "prologue.tcltk".
    #
    if {[info exists ::tcl_interactive] && $::tcl_interactive} then {
      addConstraint userInteraction

      tputs $channel yes\n
    } else {
      tputs $channel no\n
    }
  }

  proc checkForOfflineMode { channel } {
    # <help>
    # This procedure probes whether the interpreter has been placed in network
    # "offline" mode and registers the test constraint named "offlineMode" when
    # it has.  It exists so that tests can adapt to a deliberately offline
    # configuration where outbound network access is disallowed.
    #
    # How it works: under TclTk it calls [uri offline] inside a [catch].  If the
    # call succeeds and reports true, the constraint is added ("yes"); if it
    # succeeds reporting false it reports "no"; if the call fails it reports
    # "error".  Under native Tcl there is no such mode, so it reports "no".
    #
    # Arguments:
    #   channel -- The output channel for the progress line and result, written
    #              via [tputs].
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding the "offlineMode" constraint when offline mode is in effect.
    # </help>

    tputs $channel "---- checking for offline mode... "

    if {[isTclTk]} then {
      if {[catch {uri offline} offline] == 0} then {
        if {$offline} then {
          addConstraint offlineMode

          tputs $channel yes\n
        } else {
          tputs $channel no\n
        }
      } else {
        tputs $channel error\n
      }
    } else {
      tputs $channel no\n
    }
  }

  proc checkForNetwork { channel host timeout {successOnly false} } {
    # <help>
    # This procedure probes basic network reachability of a given host (using an
    # ICMP-style ping) and registers a test constraint named "network_" followed
    # by the host name when the host appears reachable.  It exists so that tests
    # requiring connectivity to a specific host can be skipped when that host
    # cannot be reached.
    #
    # How it works: under TclTk it first tidies up the host argument, stripping
    # any URI scheme and path so that a value like an https URL is reduced to
    # the bare host name.  It then verifies that pinging is permitted on this
    # platform via [canPing] (a guard, since pinging is known to hang on certain
    # Mono releases) and, if so, builds and evaluates an expression that calls
    # [uri ping] with the timeout and inspects the response: the status must be
    # acceptable (only "Success" when successOnly is true, otherwise "Success"
    # or "TimedOut"), and the reported round-trip time must be a valid integer
    # no greater than the timeout.  When the expression holds the constraint is
    # added and the response is echoed.  Under native Tcl, which lacks the [uri]
    # command, it simply assumes connectivity and adds the constraint.
    #
    # Tricky details: the reachability test is built as an expression string and
    # then evaluated, partly to keep Tcl 8.4 from trying to byte-compile TclTk
    # only constructs that it dislikes.  Accepting "TimedOut" as reachable
    # (unless successOnly is set) reflects that a timed-out ping still proves the
    # host name resolved and the network path exists.
    #
    # Arguments:
    #   channel     -- The output channel for the progress line and result,
    #                  written via [tputs].
    #   host        -- The host to probe; may be given as a bare name or as a
    #                  full http or https URI, from which the host name is
    #                  extracted.  It is also embedded in the constraint name.
    #   timeout     -- The maximum acceptable ping round-trip time, in
    #                  milliseconds, and the timeout passed to [uri ping].
    #   successOnly -- Optional boolean; when true only a "Success" ping status
    #                  counts as reachable, otherwise "TimedOut" is also
    #                  accepted.  Defaults to false.
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding the per-host "network_" constraint when the host appears
    #   reachable.
    # </help>

    tputs $channel [appendArgs \
        "---- checking for network connectivity to host \"" $host "\"... "]

    if {[isTclTk]} then {
      #
      # HACK: Fixup the "host" argument in case it is actually a full URI,
      #       with a scheme, etc, e.g. "https://tcltk.to/" ==> "tcltk.to".
      #       This should not happen, but it does, because the prologue is
      #       maintained by a very lazy programmer.
      #
      if {[regexp -skip 1 -- \
          {^(?:http(?:s)?:\/\/)([^\/]+)(?:\/.*)?$} $host hostOnly]} then {
        set host $hostOnly
      }

      #
      # NOTE: Running this check on the Mono 3.3.0 (or 3.4.0?) release build
      #       will lock up the process; therefore, skip it in that case.
      #
      set reason unknown

      if {[canPing reason]} then {
        #
        # BUGBUG: Tcl 8.4 does not like this expression (and Tcl tries to
        #         compile it even though it will only actually ever be
        #         evaluated in TclTk).
        #
        set expr {[llength [info commands uri]] > 0 && \
            [catch {uri ping $host $timeout} response] == 0 && \
            [lindex $response 0] in ($successOnly ? [list Success] : \
            [list Success TimedOut]) && [string is integer -strict \
            [lindex $response 1]] && [lindex $response 1] <= $timeout}

        #
        # NOTE: Does it look like we are able to contact the network host?
        #
        if {[expr $expr]} then {
          #
          # NOTE: Yes, it appears that it is available.
          #
          addConstraint [appendArgs network_ $host]

          tputs $channel [appendArgs "yes (" $response ")\n"]
        } else {
          tputs $channel no\n
        }
      } else {
        tputs $channel [appendArgs $reason \n]
      }
    } else {
      #
      # HACK: Running in Tcl, just assume we have network access.
      #
      addConstraint [appendArgs network_ $host]

      tputs $channel yes\n
    }
  }

  proc maybeDownloadFromUri {
          channel uri timeout {pattern ""} {quiet false} } {
    # <help>
    # This procedure attempts to download the content at a URI and reports
    # whether the download succeeded (and optionally matched a pattern).  It is
    # a shared helper used by the Internet- and TLS-connectivity probes to make
    # an actual outbound request; it does not register any constraint itself.
    #
    # How it works: under TclTk it uses [uri download] (inline, with a network
    # timeout) to fetch the content.  Outside TclTk it falls back, only if the
    # global native_lib_path is set, to loading the TclTk.Tools.Common package
    # and fetching via its [getFileViaHttp] helper.  In either case, if the fetch
    # succeeds and either no pattern was supplied or the downloaded content
    # matches the pattern (as a regular expression), it returns true.  On a
    # failed download it optionally writes a warning to the channel unless quiet
    # mode is requested.
    #
    # Tricky details: a successful download whose content does NOT match a
    # supplied pattern falls through and ultimately returns false, so the
    # pattern is an additional content check, not merely a success check.  If
    # running outside TclTk without native_lib_path set, neither branch runs and
    # the procedure simply returns false.
    #
    # Arguments:
    #   channel -- The output channel used for any warning message; written via
    #              [tputs].
    #   uri     -- The URI to download.
    #   timeout -- The download timeout, in milliseconds.
    #   pattern -- Optional regular expression the downloaded content must match
    #              for the result to be true; when empty (the default) any
    #              successful download counts.
    #   quiet   -- Optional boolean; when true, suppresses the warning message
    #              emitted on a failed download.  Defaults to false.
    #
    # Results:
    #   Returns true (boolean) if the content was downloaded and matched the
    #   pattern (if any); otherwise returns false, including on download failure
    #   or when no download mechanism is available.
    # </help>

    if {[isTclTk]} then {
      if {[catch {
        uri download -timeouttype Network -inline -timeout $timeout -- $uri
      } response] == 0} then {
        if {[string length $pattern] == 0 || \
            [regexp -- $pattern $response]} then {
          return true
        }
      } else {
        if {!$quiet} then {
          tputs $channel [appendArgs \
              "==== WARNING: download failed \"" $uri \
              "\" error: " \n\t $response \n]
        }
      }
   } elseif {[info exists ::native_lib_path]} then {
      if {[catch {
        lappend ::auto_path $::native_lib_path
        package require TclTk.Tools.Common

        ::TclTk::Tools::Common::getFileViaHttp $uri 20 \
            $channel true -binary true -timeout $timeout
      } response] == 0} then {
        if {[string length $pattern] == 0 || \
            [regexp -- $pattern $response]} then {
          return true
        }
      } else {
        if {!$quiet} then {
          tputs $channel [appendArgs \
              "==== WARNING: download failed \"" $uri \
              "\" error: " \n\t $response \n]
        }
      }
    }

    return false
  }

  proc checkForInternet { channel uri timeout } {
    # <help>
    # This procedure probes actual Internet connectivity by attempting to
    # download a given URI, and registers a test constraint named "internet_"
    # followed by the host portion of that URI when the download succeeds.  It
    # is stronger than [checkForNetwork] (which only pings) because it confirms
    # an end-to-end HTTP-level fetch works.
    #
    # How it works: it first rewrites the special bootstrap URI "https://urn.to/r"
    # to a concrete page.  It derives the host name by stripping the scheme and
    # everything from the first colon or slash, and forms the constraint name
    # from it.  If that constraint is already present the probe is short
    # circuited ("duplicate").  Otherwise, when the URI matches the configured
    # test host, it requires the downloaded content to contain a known marker
    # phrase (via a regular expression); for other URIs any successful download
    # suffices.  The fetch is delegated to [maybeDownloadFromUri] in quiet mode,
    # and the constraint is added on success.
    #
    # Arguments:
    #   channel -- The output channel for the progress line and result, written
    #              via [tputs].
    #   uri     -- The URI to fetch; its host portion is embedded in the
    #              constraint name.
    #   timeout -- The download timeout, in milliseconds.
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding the per-host "internet_" constraint when the URI is reachable
    #   (and matches the marker phrase, if one applies).
    # </help>

    tputs $channel [appendArgs \
        "---- checking for Internet connectivity to URI \"" $uri "\"... "]

    if {$uri eq "https://urn.to/r"} then {
      set uri https://urn.to/r/home
    }

    set host [string map [list http:// "" https:// ""] $uri]
    regsub -all -- {:.*$|/.*$} $host "" host
    set constraint [appendArgs internet_ $host]

    if {[haveConstraint $constraint]} then {
      tputs $channel duplicate\n
    } else {
      if {[info exists ::test_host] && $uri eq $::test_host} then {
        set pattern {[^\w]The TclTk Project[^\w]}
      } else {
        set pattern ""
      }

      if {[maybeDownloadFromUri \
          $channel $uri $timeout $pattern true]} then {
        addConstraint $constraint

        tputs $channel yes\n
      } else {
        tputs $channel no\n
      }
    }
  }

  proc checkForTlsOk { channel hosts timeout } {
    # <help>
    # This procedure probes whether secure (HTTPS/TLS) downloads work against a
    # set of hosts and registers the single test constraint named "tlsOk" only
    # if every listed host can be fetched.  It exists to gate tests that depend
    # on a working TLS stack and reachable secure endpoints.
    #
    # How it works: for each host it strips any scheme and path to the bare host
    # name and builds an https URI; two hosts that disallow root access have a
    # specific path appended as a workaround.  It then tries to download each
    # URI via [maybeDownloadFromUri] (quiet, no content pattern).  As soon as
    # any host fails, it reports "no" with the failing URI and returns without
    # adding the constraint.  Only when all hosts succeed is the "tlsOk"
    # constraint added.
    #
    # Arguments:
    #   channel -- The output channel for the progress line and result, written
    #              via [tputs].
    #   hosts   -- A list of hosts (bare names or URIs) that must all be
    #              reachable over HTTPS for the constraint to be added.
    #   timeout -- The per-host download timeout, in milliseconds.
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding the "tlsOk" constraint, which happens only when every host is
    #   reachable over TLS.
    # </help>

    tputs $channel [appendArgs "---- checking for TLS to hosts \"" \
        $hosts "\"... "]

    set count 0

    foreach host $hosts {
      set host [string map [list http:// "" https:// ""] $host]
      regsub -all -- {:.*$|/.*$} $host "" host

      set uri [appendArgs https:// $host /]

      if {$host eq "urn.to"} then {
        append uri r/tcltk; # HACK: Cannot access root here.
      } elseif {$host eq "pkg.management"} then {
        append uri pkgr; # HACK: Cannot access root here.
      }

      if {![maybeDownloadFromUri \
          $channel $uri $timeout "" true]} then {
        tputs $channel [appendArgs "no (" $uri ")\n"]

        return
      }
    }

    addConstraint tlsOk

    tputs $channel yes\n
  }

  proc checkForCompileOption { channel name } {
    # <help>
    # This procedure probes whether a named TclTk compile-time option was
    # enabled in the build under test and registers the test constraint named
    # "compile." followed by the option name when it was.  It exists so that
    # tests depending on conditionally-compiled features run only on builds that
    # include them.
    #
    # How it works: under TclTk it consults the global array element
    # tcltk_platform(compileOptions) -- the list of enabled options -- and adds
    # the constraint if the name is found there (case-insensitively).  Under
    # native Tcl it can still answer the question if the TclTk Package for Tcl
    # is loaded: it uses the [tcltk] bridge command to read that same compile
    # options list from the embedded TclTk interpreter, and adds the constraint
    # (returning immediately) if the option is present.
    #
    # Arguments:
    #   channel -- The output channel for the progress line and "yes" or "no"
    #              result, written via [tputs].
    #   name    -- The compile option name to look for; it is also embedded in
    #              the constraint name that gets registered.
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding the per-option "compile." constraint when the option is enabled.
    # </help>

    tputs $channel [appendArgs "---- checking for compile option \"" \
        $name "\"... "]

    if {[isTclTk]} then {
      if {[info exists ::tcltk_platform(compileOptions)] && \
          [lsearch -exact -nocase $::tcltk_platform(compileOptions) \
              $name] != -1} then {
        #
        # NOTE: Yes, support for the TclTk compile option is present.
        #
        addConstraint [appendArgs compile. $name]

        tputs $channel yes\n
      } else {
        tputs $channel no\n
      }
    } else {
      #
      # NOTE: We are running inside Tcl; however, we need to check for an
      #       TclTk compile option.  This can now be accomplished via the
      #       [tcltk] command supplied by the TclTk Package for Tcl, if
      #       it is actually loaded and available.
      #
      if {[llength [info commands tcltk]] > 0} then {
        set options [tcltk [list expr {[info exists \
            ::tcltk_platform(compileOptions)] ? \
            $::tcltk_platform(compileOptions) : [list]}]]

        if {[lsearch -exact $options $name] != -1} then {
          #
          # NOTE: Yes, support for the TclTk compile option is present.
          #
          addConstraint [appendArgs compile. $name]

          tputs $channel yes\n

          #
          # NOTE: We are done here, return now.
          #
          return
        }
      }

      tputs $channel no\n
    }
  }

  proc checkForBuildType { channel name } {
    # <help>
    # This procedure probes whether the build under test matches a particular
    # build type and registers one or more build-type constraints accordingly.
    # A build type may be identified either by its descriptive "text" or by its
    # file-name "suffix"; matching by text adds "buildTypeText." plus the name,
    # matching by suffix adds "buildTypeSuffix." plus the name, and in both
    # cases the generic "buildType." plus the name is also added.  An empty name
    # is treated as a request for the default (untyped) build, which adds the
    # constraint "buildType.Default".  This lets tests target builds produced
    # with specific configurations.
    #
    # How it works: under TclTk it compares the requested name against the
    # global array elements tcltk_platform(text) and tcltk_platform(suffix),
    # adding the corresponding constraints (and reporting which match was
    # found).  For an empty name it adds the Default constraint only when both
    # the text and suffix are absent or empty.  Under native Tcl it performs the
    # same logic but obtains the text and suffix values from the embedded TclTk
    # interpreter through the [tcltk] bridge command, when that command is
    # available, returning immediately once a match is recorded.
    #
    # Arguments:
    #   channel -- The output channel for the progress line and result, written
    #              via [tputs].
    #   name    -- The build type to test for, matched against the build text or
    #              suffix; an empty string requests the default build type.  The
    #              name is embedded in the constraint names that get registered.
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding the appropriate build-type constraints when a match is found.
    # </help>

    tputs $channel [appendArgs "---- checking for build type \"" \
        $name "\"... "]

    if {[isTclTk]} then {
      if {[string length $name] > 0} then {
        if {[info exists ::tcltk_platform(text)] && \
            $name eq $::tcltk_platform(text)} then {
          addConstraint [appendArgs buildTypeText. $name]
          addConstraint [appendArgs buildType. $name]

          tputs $channel [appendArgs \
              "yes (" $name ", found via text)\n"]
        } elseif {[info exists ::tcltk_platform(suffix)] && \
            $name eq $::tcltk_platform(suffix)} then {
          addConstraint [appendArgs buildTypeSuffix. $name]
          addConstraint [appendArgs buildType. $name]

          tputs $channel [appendArgs \
              "yes (" $name ", found via suffix)\n"]
        } else {
          tputs $channel no\n
        }
      } else {
        if {(![info exists ::tcltk_platform(text)] || \
              [string length $::tcltk_platform(text)] == 0) && \
            (![info exists ::tcltk_platform(suffix)] || \
              [string length $::tcltk_platform(suffix)] == 0)} then {
          addConstraint buildType.Default

          tputs $channel yes\n
        } else {
          tputs $channel no\n
        }
      }
    } else {
      if {[llength [info commands tcltk]] > 0} then {
        if {[tcltk [list info exists ::tcltk_platform(text)]]} then {
          set text [tcltk [list set ::tcltk_platform(text)]]
        }

        if {[tcltk [list info exists ::tcltk_platform(suffix)]]} then {
          set suffix [tcltk [list set ::tcltk_platform(suffix)]]
        }

        if {[string length $name] > 0} then {
          if {[info exists text] && $name eq $text} then {
            addConstraint [appendArgs buildTypeText. $name]
            addConstraint [appendArgs buildType. $name]

            tputs $channel [appendArgs \
                "yes (" $name ", found via text)\n"]

            #
            # NOTE: We are done here, return now.
            #
            return
          } elseif {[info exists suffix] && $name eq $suffix} then {
            addConstraint [appendArgs buildTypeSuffix. $name]
            addConstraint [appendArgs buildType. $name]

            tputs $channel [appendArgs \
                "yes (" $name ", found via suffix)\n"]

            #
            # NOTE: We are done here, return now.
            #
            return
          }
        } else {
          if {(![info exists text] || \
                [string length $text] == 0) && \
              (![info exists suffix] || \
                [string length $suffix] == 0)} then {
            addConstraint buildType.Default

            tputs $channel yes\n

            #
            # NOTE: We are done here, return now.
            #
            return
          }
        }
      }

      tputs $channel no\n
    }
  }

  proc checkForKnownBuildTypes { channel } {
    # <help>
    # This procedure checks for every build type that the test harness knows
    # about, registering the appropriate "buildType.*" constraints for whichever
    # one matches the current build.  It is a convenience driver that does not
    # add a constraint of its own; instead it fans out to [checkForBuildType]
    # for each candidate.
    #
    # How it works: it obtains the list of known build types via
    # [getKnownBuildTypes] and appends an empty string to represent the default
    # build type.  For each candidate it first honors a per-type opt-out -- the
    # global array element no(buildType.NAME), or no(buildType.Default) for the
    # empty name -- skipping any build type so disabled, and otherwise calls
    # [checkForBuildType] to perform the actual detection.  The count of known
    # build types is echoed on the progress line.
    #
    # Arguments:
    #   channel -- The output channel for the progress line and the per-type
    #              results produced by [checkForBuildType], written via [tputs].
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding build-type constraints for whichever known build type matches.
    # </help>

    #
    # NOTE: Check for all "known" build types.
    #
    tputs $channel "---- checking for known build types... "

    set buildTypes [getKnownBuildTypes]
    lappend buildTypes ""; # HACK: Add default build type.

    if {[llength $buildTypes] > 0} then {
      tputs $channel [appendArgs "yes (" [llength $buildTypes] ")\n"]

      foreach buildType $buildTypes {
        if {[string length $buildType] > 0} then {
          if {[info exists [appendArgs ::no(buildType. $buildType )]]} then {
            continue
          }
        } else {
          if {[info exists ::no(buildType.Default)]} then {
            continue
          }
        }

        checkForBuildType $channel $buildType
      }
    } else {
      tputs $channel no\n
    }
  }

  proc checkForKnownCompileOptions { channel } {
    # <help>
    # This procedure checks for every compile option that the test harness knows
    # about, registering the appropriate "compile.*" constraints for each one
    # that is enabled in the current build.  It is a convenience driver that
    # does not add a constraint of its own; instead it fans out to
    # [checkForCompileOption] for each candidate.
    #
    # How it works: it obtains the list of known options via
    # [getKnownCompileOptions], echoes the count, and for each option calls
    # [checkForCompileOption] unless that option has been opted out via the
    # global array element no(compile.NAME).
    #
    # Arguments:
    #   channel -- The output channel for the progress line and the per-option
    #              results produced by [checkForCompileOption], written via
    #              [tputs].
    #
    # Results:
    #   The result is unspecified; the meaningful effect is the side effect of
    #   adding "compile." constraints for each known compile option that is
    #   enabled.
    # </help>

    #
    # NOTE: Check for all "known" compile options.
    #
    tputs $channel "---- checking for known compile options... "

    set options [getKnownCompileOptions]

    if {[llength $options] > 0} then {
      tputs $channel [appendArgs "yes (" [llength $options] ")\n"]

      foreach option $options {
        if {![info exists [appendArgs ::no(compile. $option )]]} then {
          checkForCompileOption $channel $option
        }
      }
    } else {
      tputs $channel no\n
    }
  }

  if {[isTclTk]} then {
    ###########################################################################
    ############################ BEGIN TclTk ONLY #############################
    ###########################################################################

    proc saveRuntimeOptions { varName } {
      # <help>
      # This procedure captures the current set of TclTk runtime options into a
      # caller-supplied variable so they can be examined or later restored.  It
      # is an TclTk-only helper (defined inside the TclTk-only block) used in
      # conjunction with the runtime-option clear and restore helpers, typically
      # to save and reinstate runtime option state around a test.
      #
      # How it works: it links the named caller variable with [upvar] and copies
      # the global array element tcltk_platform(runtimeOptions) into it, or sets
      # it to the empty list when that element does not exist.
      #
      # Arguments:
      #   varName -- The name of a variable in the caller's frame that will
      #              receive the list of current runtime options.
      #
      # Results:
      #   Returns the number of runtime options that were saved (the length of
      #   the captured list, which is zero when none are set).
      # </help>

      upvar 1 $varName runtimeOptions

      if {[info exists ::tcltk_platform(runtimeOptions)]} then {
        set runtimeOptions $::tcltk_platform(runtimeOptions)
      } else {
        set runtimeOptions [list]
      }

      return [llength $runtimeOptions]
    }

    proc clearRuntimeOptions { {ignoreError false} {names ""} } {
      # <help>
      # This procedure removes TclTk runtime options that are currently set,
      # optionally preserving a specified subset.  It is an TclTk-only helper
      # (defined inside the TclTk-only block) used to reset runtime option state,
      # for example before establishing a known configuration in a test.
      #
      # How it works: it first snapshots the current options via
      # [saveRuntimeOptions], then iterates over them.  An option is removed (via
      # [removeRuntimeOption]) when the "names" list is empty or does not contain
      # that option -- in other words, "names" is a keep-list of options to leave
      # untouched.  Each successful removal increments a counter.  If a removal
      # fails it raises an error unless ignoreError requests that failures be
      # silently tolerated.
      #
      # Arguments:
      #   ignoreError -- Optional boolean; when true, a failure to remove an
      #                  option is ignored rather than raising an error.
      #                  Defaults to false.
      #   names       -- Optional list of option names to preserve; options in
      #                  this list are not removed.  When empty (the default),
      #                  all current options are removed.
      #
      # Results:
      #   Returns the number of runtime options that were actually removed.
      # </help>

      set count 0

      saveRuntimeOptions runtimeOptions

      foreach name $runtimeOptions {
        if {[llength $names] == 0 || \
            [lsearch -exact -- $names $name] == -1} then {
          if {[removeRuntimeOption $name]} then {
            incr count
          } elseif {!$ignoreError} then {
            error [appendArgs \
                "failed to remove runtime option \"" $name \"]
          }
        }
      }

      return $count
    }

    proc restoreRuntimeOptions { varName {full true} {ignoreError false} } {
      # <help>
      # This procedure restores the set of interpreter runtime options that was
      # previously captured into a variable (typically by [saveRuntimeOptions]).
      # It is the counterpart used to undo temporary runtime option changes made
      # while probing for a capability, so the interpreter is left in its prior
      # state.  It does not itself register any test constraint.
      #
      # How it works: the saved list is accessed by name in the caller's frame
      # via [upvar].  When "full" is true, every currently set runtime option is
      # first cleared (by passing an empty exclusion list to [clearRuntimeOptions]),
      # giving an exact restore; when "full" is false, the saved options are
      # passed as the exclusion list so that only options not in the saved set are
      # cleared, leaving any already-present saved options untouched.  Each name in
      # the saved list is then re-added with [addRuntimeOption], skipping any that
      # are already present in the non-full case.
      #
      # Tricky details: if adding an option fails and "ignoreError" is false, an
      # error is raised naming the offending option; when "ignoreError" is true,
      # such failures are silently tolerated.  The running tally returned includes
      # both cleared and re-added options.
      #
      # Arguments:
      #   varName     -- The name, resolved in the caller's frame, of the variable
      #                  holding the previously saved list of runtime option names.
      #   full        -- Optional boolean (default true).  When true, perform a
      #                  complete restore by clearing all current options first;
      #                  when false, only reconcile against the saved set.
      #   ignoreError -- Optional boolean (default false).  When true, suppress
      #                  errors from failed option additions.
      #
      # Results:
      #   Returns the count of runtime options affected (those cleared plus those
      #   re-added).
      # </help>

      upvar 1 $varName runtimeOptions

      set count [clearRuntimeOptions \
          $ignoreError [expr {$full ? [list] : $runtimeOptions}]]

      foreach name $runtimeOptions {
        if {$full || ![hasRuntimeOption $name]} then {
          if {[addRuntimeOption $name]} then {
            incr count
          } elseif {!$ignoreError} then {
            error [appendArgs \
                "failed to add runtime option \"" $name \"]
          }
        }
      }

      return $count
    }

    proc addListStreamChannel { name list } {
      # <help>
      # This procedure registers a new I/O channel that is backed by a list of
      # lines, using the test harness helper CodeBrix.Platform.TclTk._Tests.Default's
      # TestAddListStreamChannel method.  It exists so that tests can feed a
      # predetermined sequence of input lines (or capture output) through the
      # normal channel machinery without touching a real file or device.  It does
      # not register any test constraint.
      #
      # How it works: it invokes the managed helper, passing the desired channel
      # name, a null underlying object, the supplied list, and a fixed set of flags
      # requesting buffering and read-line tracing.  The integer-like status code
      # returned by the call is examined; any value other than "Ok" is treated as
      # failure and the human-readable message extracted from the error object is
      # raised as a script error.
      #
      # Arguments:
      #   name -- The name to assign to the newly created channel.
      #   list -- The list of lines that backs the channel.
      #
      # Results:
      #   Returns the empty result on success; raises an error (with the message
      #   from the helper) if the channel could not be added.
      # </help>

      set error null

      set code [object invoke \
          CodeBrix.Platform.TclTk._Tests.Default TestAddListStreamChannel "" \
          $name null $list {NeedBuffer TraceReadLines} error]

      if {$code ne "Ok"} then {
        error [getStringFromObjectHandle $error]
      }
    }

    proc removeChannel { name {strict true} } {
      # <help>
      # This procedure removes a named I/O channel from the active interpreter,
      # complementing channel-creating helpers such as [addListStreamChannel].  It
      # is used to clean up channels created during a test so they do not leak into
      # later tests.  It does not register any test constraint.
      #
      # How it works: it calls the active interpreter's RemoveChannel method,
      # naming the channel and requesting the standard removal behavior.  The
      # status code returned is checked only when "strict" is true; in that case
      # any result other than "Ok" causes the error message from the error object
      # to be raised.  When "strict" is false, failures are ignored, which is handy
      # for best-effort cleanup where the channel may already be gone.
      #
      # Arguments:
      #   name   -- The name of the channel to remove.
      #   strict -- Optional boolean (default true).  When true, a failed removal
      #             raises an error; when false, failures are silently ignored.
      #
      # Results:
      #   Returns the empty result.  In strict mode, raises an error if removal
      #   fails.
      # </help>

      set error null

      set code [object invoke \
          Interpreter.GetActive RemoveChannel \
          $name None false true true error]

      if {$strict && $code ne "Ok"} then {
        error [getStringFromObjectHandle $error]
      }
    }

    proc getUnicodeCategoryCode { category } {
      # <help>
      # This procedure maps a fully spelled-out .NET UnicodeCategory enumeration
      # name (for example, UppercaseLetter or DecimalDigitNumber) to its two-letter
      # general category abbreviation (for example, Lu or Nd).  It exists so that
      # the related constraint probe can build short, stable constraint names from
      # the verbose category names returned by the runtime.  It does not register
      # any test constraint itself.
      #
      # How it works: it builds a lookup array associating each known category name
      # with its standard abbreviation, then looks up the requested category.  A
      # match returns the abbreviation; an unrecognized name returns the special
      # value Xx, denoting an unknown category.
      #
      # Arguments:
      #   category -- The .NET UnicodeCategory enumeration name to translate.
      #
      # Results:
      #   Returns the two-letter category abbreviation, or Xx when the name is not
      #   recognized.
      # </help>

      array set codes [list \
          UppercaseLetter            Lu \
          LowercaseLetter            Ll \
          TitlecaseLetter            Lt \
          ModifierLetter             Lm \
          OtherLetter                Lo \
          NonSpacingMark             Mn \
          SpacingCombiningMark       Mc \
          EnclosingMark              Me \
          DecimalDigitNumber         Nd \
          LetterNumber               Nl \
          OtherNumber                No \
          SpaceSeparator             Zs \
          LineSeparator              Zl \
          ParagraphSeparator         Zp \
          Control                    Cc \
          Format                     Cf \
          Surrogate                  Cs \
          PrivateUse                 Co \
          ConnectorPunctuation       Pc \
          DashPunctuation            Pd \
          OpenPunctuation            Ps \
          ClosePunctuation           Pe \
          InitialQuotePunctuation    Pi \
          FinalQuotePunctuation      Pf \
          OtherPunctuation           Po \
          MathSymbol                 Sm \
          CurrencySymbol             Sc \
          ModifierSymbol             Sk \
          OtherSymbol                So \
          OtherNotAssigned           Cn]

      if {[info exists codes($category)]} then {
        return $codes($category)
      } else {
        return Xx; # NOTE: Unknown.
      }
    }

    proc checkForUnicodeCategory { channel character wantCode } {
      # <help>
      # This procedure probes the Unicode general category that the runtime
      # assigns to a particular character and registers a test constraint recording
      # the result.  It exists to detect discrepancies between the expected and
      # actual category classification across runtimes (which can differ by Unicode
      # data version).  The constraint it registers is named by combining the
      # prefix unicodeCategory_, the character's code point formatted as U plus
      # four hexadecimal digits, an underscore, and the detected two-letter category
      # code, for example unicodeCategory_U0041_Lu.
      #
      # How it works: it determines the character's ordinal (code point), then calls
      # the .NET Char.GetUnicodeCategory method to obtain the verbose category name,
      # which is translated to its two-letter code via [getUnicodeCategoryCode].
      # The constraint is always added (encoding whatever category was found, not
      # only the expected one).  The progress message reports CORRECT when the
      # detected code equals the wanted code and INCORRECT (naming the wanted code)
      # otherwise.  If the runtime call fails outright, no constraint is added and
      # the output is simply no.
      #
      # Arguments:
      #   channel  -- The channel used for progress and diagnostic output.
      #   character -- The character whose Unicode category is to be checked.
      #   wantCode -- The two-letter category code that is expected, used only to
      #               label the result as correct or incorrect.
      #
      # Results:
      #   Returns the empty result.  Its observable effect is the registered
      #   constraint and the diagnostic output.
      # </help>

      set ordinal [string ordinal $character 0]

      tputs $channel [appendArgs \
          "---- checking for Unicode category of \"" \
          [format U+%04X $ordinal] "\"... "]

      if {[catch {
        object invoke Char GetUnicodeCategory $character 0
      } category] == 0} then {
        set haveCode [getUnicodeCategoryCode $category]

        addConstraint [appendArgs \
            unicodeCategory_ [format U%04X $ordinal] \
            _ $haveCode]

        if {$haveCode eq $wantCode} then {
          tputs $channel [appendArgs \
              "yes (" $category " ==> " $haveCode \
              ", CORRECT)\n"]
        } else {
          tputs $channel [appendArgs \
              "yes (" $category " ==> " $haveCode \
              ", INCORRECT, WANT " $wantCode ")\n"]
        }

        #
        # NOTE: We are done here, return now.
        #
        return
      }

      tputs $channel no\n
    }

    proc checkForGlobalTip285 { channel } {
      # <help>
      # This procedure probes for support of the global form of TIP #285 (the
      # ability to reset asynchronous cancellation of the entire interpreter, not
      # just a single script) and registers the test constraint globalTip285 when
      # it is available.  It exists so that tests exercising global script
      # cancellation can be skipped on runtimes lacking that capability.
      #
      # How it works: it attempts to evaluate [interp resetcancel] with the -global
      # option inside a [catch].  Successful evaluation (a zero result code) is
      # taken as proof that the global reset form is supported, the constraint is
      # added, and yes is printed; any failure prints no and adds nothing.
      #
      # Arguments:
      #   channel -- The channel used for progress output.
      #
      # Results:
      #   Returns the empty result; its effect is the possible registration of the
      #   globalTip285 constraint.
      # </help>

      tputs $channel "---- checking for global TIP #285... "

      if {[catch {interp resetcancel {} -global}] == 0} then {
        addConstraint globalTip285

        tputs $channel yes\n

        #
        # NOTE: We are done here, return now.
        #
        return
      }

      tputs $channel no\n
    }

    proc checkForIeee754r2008 { channel } {
      # <help>
      # This procedure probes for IEEE 754-2008 floating-point string formatting
      # behavior and registers the test constraint ieee754r2008 when it is present.
      # Newer runtimes (notably .NET Core 3.0 and later) changed Double.ToString to
      # produce shortest round-trippable representations, which alters the textual
      # form of many double values; this probe lets tests adjust their expected
      # output accordingly.
      #
      # How it works: it evaluates the expression pi() and inspects the resulting
      # string.  The full 17-significant-digit representation 3.141592653589793 is
      # used as a reliable sentinel: when the runtime produces exactly that string,
      # the new formatting semantics are assumed present and the constraint is
      # added (yes); a different string means the older formatting is in effect
      # (no).  If evaluating the expression fails, error is printed and no
      # constraint is added.
      #
      # Arguments:
      #   channel -- The channel used for progress output.
      #
      # Results:
      #   Returns the empty result; its effect is the possible registration of the
      #   ieee754r2008 constraint.
      # </help>

      tputs $channel "---- checking for IEEE 754-2008... "

      if {[catch {expr {pi()}} pi] == 0} then {
        #
        # HACK: This seems to be a reliable way to determine if breaking
        #       Double.ToString semantics are present, e.g. .NET Core 3.0.
        #
        if {$pi eq "3.141592653589793"} then {
          addConstraint ieee754r2008

          tputs $channel yes\n
        } else {
          tputs $channel no\n
        }
      } else {
        tputs $channel error\n
      }
    }

    proc checkForSystemDataSQLite { channel } {
      # <help>
      # This procedure probes for the availability of the System.Data.SQLite
      # managed assembly and registers the test constraint System.Data.SQLite when
      # it can be resolved.  It gates tests that depend on the SQLite database
      # provider.
      #
      # How it works: it first checks for the prerequisite constraint
      # file_System.Data.SQLite.dll (added elsewhere when the DLL file is found);
      # if that is missing it prints missing and stops.  Otherwise it temporarily
      # enables the ResolveAssemblySearch runtime option (saving and later
      # restoring the runtime options via [saveRuntimeOptions] and
      # [restoreRuntimeOptions] in a finally block) and attempts to resolve the
      # assembly by wildcard name.  Successful resolution adds the constraint and
      # reports the resolved assembly name; a resolution failure prints error.
      #
      # Arguments:
      #   channel -- The channel used for progress output.
      #
      # Results:
      #   Returns the empty result; its effect is the possible registration of the
      #   System.Data.SQLite constraint.
      # </help>

      tputs $channel "---- checking for System.Data.SQLite assembly... "

      if {[haveConstraint file_System.Data.SQLite.dll]} then {
        if {[catch {
          saveRuntimeOptions savedRuntimeOptions

          try {
            addRuntimeOption ResolveAssemblySearch
            object resolve "System.Data.SQLite, *"
          } finally {
            restoreRuntimeOptions savedRuntimeOptions
          }
        } assemblyName] == 0} then {
          addConstraint System.Data.SQLite

          tputs $channel [appendArgs "yes (" $assemblyName ")\n"]
        } else {
          tputs $channel error\n
        }
      } else {
        tputs $channel missing\n
      }
    }

    proc checkForGuru { channel enable } {
      # <help>
      # This procedure probes for the internal "Guru" facility and registers test
      # constraints describing whether it is available and currently enabled.
      # Depending on the outcome it adds guru.available together with either
      # guru.enabled or guru.disabled, or, if the facility cannot be queried at all,
      # guru.unavailable.  It lets tests that rely on this facility be skipped or
      # adjusted appropriately.
      #
      # How it works: it invokes the non-public ObjectOps.MaybeEnableGuru helper,
      # passing the caller-supplied enable flag, and converts the returned object to
      # a string.  When the call succeeds, guru.available is added; the raw result
      # is then inspected as a list and, if its last element is a true boolean, the
      # facility is considered enabled (guru.enabled, yes) and otherwise disabled
      # (guru.disabled, no).  The raw result is also echoed for diagnostics.  When
      # the call fails, guru.unavailable is added and the captured failure text is
      # logged as a "Guru Meditation" message.
      #
      # Arguments:
      #   channel -- The channel used for progress and diagnostic output.
      #   enable  -- The value passed through to the MaybeEnableGuru helper to
      #              request enabling or disabling the facility during the probe.
      #
      # Results:
      #   Returns the empty result; its effect is the registration of the
      #   appropriate guru.* constraint(s) and diagnostic output.
      # </help>

      tputs $channel [appendArgs \
          "---- checking for Guru using \"" $enable "\"... "]

      if {[catch {
        set result null

        object invoke -flags +NonPublic \
            CodeBrix.Platform.TclTk._Components.Private.ObjectOps MaybeEnableGuru \
            "" $enable result

        getStringFromObjectHandle $result
      } guru] == 0} then {
        addConstraint guru.available

        if {[string is list -strict $guru] && \
            [string is true -strict [lindex $guru end]]} then {
          addConstraint guru.enabled

          tputs $channel yes\n
        } else {
          addConstraint guru.disabled

          tputs $channel no\n
        }

        tputs $channel [appendArgs \
            "---- checking for Guru raw results: " \
            [formatList $guru <none>] \n]
      } else {
        addConstraint guru.unavailable

        tputs $channel unavailable\n
        tputs $channel [appendArgs "---- Guru Meditation: " $guru \n]
      }
    }

    proc checkForSecurity { channel } {
      # <help>
      # This procedure probes whether the interpreter's security subsystem is
      # active and registers a corresponding test constraint: security.enabled when
      # security is on, security.disabled when it is off, or security.unavailable
      # when the state cannot be determined.  It gates tests that behave
      # differently under signed-script enforcement and similar protections.
      #
      # How it works: it invokes the non-public HasSecurity member of the active
      # interpreter.  A successful query whose result is strictly true adds
      # security.enabled (yes); a successful query that is not true adds
      # security.disabled (no); a failed query adds security.unavailable
      # (unavailable).
      #
      # Arguments:
      #   channel -- The channel used for progress output.
      #
      # Results:
      #   Returns the empty result; its effect is the registration of exactly one
      #   of the security.* constraints.
      # </help>

      tputs $channel "---- checking for security... "

      if {[catch {
        object invoke -flags +NonPublic Interpreter.GetActive HasSecurity
      } security] == 0} then {
        if {[string is true -strict $security]} then {
          addConstraint security.enabled

          tputs $channel yes\n
        } else {
          addConstraint security.disabled

          tputs $channel no\n
        }
      } else {
        addConstraint security.unavailable

        tputs $channel unavailable\n
      }
    }

    proc checkForSoftwareUpdateTrust { channel } {
      # <help>
      # This procedure probes whether the user (or a script run on their behalf)
      # has opted into trusting TclTk's software update certificate, and registers
      # the test constraint softwareUpdate when that trust is in effect.  Because
      # this trust is off by default, the constraint effectively detects a
      # deliberate, non-default opt-in.
      #
      # How it works: it first verifies that the uri command exists, then runs
      # [uri softwareupdates] and checks that the result is exactly the message
      # indicating the software update certificate is trusted.  When all of those
      # conditions hold the constraint is added and trusted is printed; otherwise
      # untrusted is printed and no constraint is added.
      #
      # Arguments:
      #   channel -- The channel used for progress output.
      #
      # Results:
      #   Returns the empty result; its effect is the possible registration of the
      #   softwareUpdate constraint.
      # </help>

      tputs $channel "---- checking for software update trust... "

      if {[llength [info commands uri]] > 0 && \
          [catch {uri softwareupdates} trust] == 0 && \
          $trust eq "software update certificate is trusted"} then {
        #
        # NOTE: Yes, it appears that we trust our software updates.
        #       Since this setting is off by default, the user (or
        #       a script evaluated by the user) must have manually
        #       turned it on.
        #
        addConstraint softwareUpdate

        tputs $channel trusted\n
      } else {
        tputs $channel untrusted\n
      }
    }

    proc checkForManagedDebuggingAssistants { channel } {
      # <help>
      # This procedure probes for Managed Debugging Assistants (MDAs) that are
      # enabled for the current process via its ".mda.config" configuration file,
      # and registers test constraints for each one found.  When any assistants are
      # enabled it adds the general constraint mda plus a per-assistant constraint
      # named mda. followed by the assistant's name (for example, mda.LoaderLock).
      # This lets tests account for behavior or output that MDAs may inject.
      #
      # How it works: it derives the configuration file path by appending
      # ".mda.config" to the shell executable name and normalizing it.  If that file
      # exists, it loads the file as XML (wrapped in [catch] because the System.Xml
      # assembly may not be loaded), registers the MDA XML namespace with a
      # namespace manager, and uses an XPath query to select all assistant elements
      # beneath the mdaConfig/assistants node.  The Name of each selected node is
      # collected.  When one or more names result, the constraints are added, the
      # names are saved into the global test_mdas variable (unless suppressed by the
      # no(setMdas) flag), and yes plus the name list is printed.  Any other path
      # through the logic prints no.
      #
      # Arguments:
      #   channel -- The channel used for progress output.
      #
      # Results:
      #   Returns the empty result; its effects are the possible registration of
      #   the mda and mda.* constraints and the population of the test_mdas global.
      # </help>

      set fileName [file normalize [appendArgs [getShellExecutableName] \
          .mda.config]]

      tputs $channel [appendArgs \
          "---- checking for managed debugging assistants enabled via \"" \
          $fileName "\"... "]

      if {[file exists $fileName]} then {
        #
        # NOTE: Since the System.Xml assembly may not be loaded, wrap the
        #       detection in a [catch] block.
        #
        if {[catch {
          #
          # NOTE: Create and load an XML document based on the data from the
          #       MDA configuration file associated with the executable that
          #       started this process.
          #
          set document [object create -alias System.Xml.XmlDocument]
          $document LoadXml [readSharedFile $fileName]

          #
          # NOTE: Setup the XML namespace manager for use when using XPath
          #       to query the XML document.
          #
          set nameTable [$document NameTable]

          set namespaceManager [object create \
              -alias System.Xml.XmlNamespaceManager $nameTable]

          $namespaceManager AddNamespace mda \
              http://schemas.microsoft.com/CLR/2004/10/mda

          #
          # NOTE: Select all nodes underneath the location where they should
          #       reside in the MDA configuration XML document.
          #
          set nodes [$document SelectNodes \
              /mda:mdaConfig/mda:assistants/* $namespaceManager]

          #
          # NOTE: Populate the local result variable with the names of
          #       all the XML nodes found.
          #
          set names [object lmap -alias node $nodes {
            $node Name
          }]
        }] == 0} then {
          #
          # NOTE: Ok, the XML configuration file was loaded and parsed
          #       correctly, see if any managed debugging assistants were
          #       found enabled within it.
          #
          if {[info exists names] && [llength $names] > 0} then {
            #
            # NOTE: Add a test constraint for each managed debugging
            #       assistant that appears to be enabled.
            #
            addConstraint mda

            foreach name $names {
              addConstraint [appendArgs mda. $name]
            }

            #
            # NOTE: Save the list of managed debugging assistants for
            #       later use by the test suite.
            #
            if {![info exists ::no(setMdas)]} then {
              set ::test_mdas $names
            }

            #
            # NOTE: Yes, it appears that at least one managed debugging
            #       assistant is enabled.
            #
            tputs $channel [appendArgs "yes (" $names ")\n"]

            #
            # NOTE: We are done here, return now.
            #
            return
          }
        }
      }

      tputs $channel no\n
    }

    proc checkForStrongName { channel } {
      # <help>
      # This procedure probes whether the running TclTk core library was signed
      # with a strong name key and registers the test constraint strongName when it
      # was.  It gates tests that depend on strong-name signing being present.
      #
      # How it works: it invokes the active interpreter's GetStrongName method and
      # checks both that the call succeeded and that it returned a non-null object
      # handle (via [isNonNullObjectHandle]).  When both hold, the assembly is
      # considered strong-name signed, the constraint is added, and yes is printed;
      # otherwise no is printed.  Note this only detects the presence of a strong
      # name, not which key was used; the related [checkForStrongNameKey] handles
      # the specific key.
      #
      # Arguments:
      #   channel -- The channel used for progress output.
      #
      # Results:
      #   Returns the empty result; its effect is the possible registration of the
      #   strongName constraint.
      # </help>

      tputs $channel "---- checking for strong name... "

      if {[catch {
        object invoke Interpreter.GetActive GetStrongName
      } strongName] == 0 && [isNonNullObjectHandle $strongName]} then {
        #
        # NOTE: Yes, it appears that the core library was signed with a
        #       strong name key.
        #
        addConstraint strongName

        tputs $channel yes\n
      } else {
        tputs $channel no\n
      }
    }

    proc checkForStrongNameKey { channel } {
      # <help>
      # This procedure probes the specific strong name key (public key token) used
      # to sign the running TclTk core library and registers constraints describing
      # it.  When a token is present it adds a constraint named strongName. followed
      # by the token, and then classifies the key as either official
      # (strongName.official) or unofficial (strongName.unofficial) by comparing it
      # against the known official tokens; when no token is present it adds
      # strongName.none.  Several tests require an official key, so these
      # constraints let those tests be gated accurately.
      #
      # How it works: it reads the token via [info engine PublicKeyToken].  A
      # non-empty token yields the per-token constraint and, after evaluating the
      # membership expression against [getKnownPublicKeyTokens], either the official
      # or unofficial constraint.  An unofficial or absent signature triggers a
      # warning (logged and printed) unless the no(warningForStrongNameKey) flag is
      # set or the quiet constraint is present.
      #
      # Tricky details: the membership test is built as a string and run through
      # [expr] because the "ni" operator it uses was added in Tcl 8.5; deferring its
      # compilation avoids breaking Tcl 8.4, which would otherwise try to compile it
      # even though only TclTk ever evaluates it.
      #
      # Arguments:
      #   channel -- The channel used for progress, warning, and diagnostic output.
      #
      # Results:
      #   Returns the empty result; its effect is the registration of the
      #   appropriate strongName.* constraint(s) and any associated warning.
      # </help>

      tputs $channel "---- checking for strong name key... "

      if {[catch {info engine PublicKeyToken} publicKeyToken] == 0 && \
          [string length $publicKeyToken] > 0} then {
        #
        # NOTE: Add a test constraint for this specific strong name key.
        #
        addConstraint [appendArgs strongName. $publicKeyToken]

        #
        # NOTE: Show the strong name key that we found.
        #
        tputs $channel [appendArgs "yes (" $publicKeyToken ")\n"]

        #
        # BUGBUG: Tcl 8.4 does not seem to like this expression because it
        #         contains the "ni" operator added in Tcl 8.5 (and Tcl 8.4
        #         tries to compile it even though it will only be evaluated
        #         in TclTk).
        #
        set expr {$publicKeyToken ni [getKnownPublicKeyTokens]}

        if {[expr $expr]} then {
          #
          # NOTE: The TclTk core library is strong name signed with a key that
          #       is not official.  This is also not an error, per se; however,
          #       it may cause some tests to fail and it should be reported to
          #       the user and noted in the test suite log file.
          #
          addConstraint strongName.unofficial

          #
          # NOTE: Unless forbidden, issue and log a warning.
          #
          if {![info exists no(warningForStrongNameKey)] && \
              ![haveConstraint quiet]} then {
            tputs $channel [appendArgs \
                "==== WARNING: unofficial TclTk strong name signature " \
                "detected: " $publicKeyToken \n]
          }
        } else {
          #
          # NOTE: Several tests require one of the official strong name keys to
          #       be used in order for them to pass.
          #
          addConstraint strongName.official

          tputs $channel [appendArgs \
              "---- official TclTk strong name signature detected: " \
              $publicKeyToken \n]
        }
      } else {
        #
        # NOTE: The TclTk core library is not signed with a strong name key.
        #       This is not an error, per se; however, it may cause selected
        #       tests to fail and it should be reported to the user and noted
        #       in the test suite log file.
        #
        addConstraint strongName.none

        #
        # NOTE: Show that we did not find a strong name key.
        #
        tputs $channel no\n

        #
        # NOTE: Unless forbidden, issue and log a warning.
        #
        if {![info exists no(warningForStrongNameKey)] && \
            ![haveConstraint quiet]} then {
          tputs $channel \
              "==== WARNING: no TclTk strong name signature detected...\n"
        }
      }
    }

    proc checkForCertificate { channel } {
      # <help>
      # This procedure probes whether the running TclTk core library was signed
      # with an Authenticode code-signing certificate and registers the test
      # constraint certificate when it was.  It gates tests that depend on the
      # presence of a code-signing certificate.
      #
      # How it works: it invokes the active interpreter's GetCertificate method and
      # checks both that the call succeeded and that it returned a non-null object
      # handle.  When both hold, the constraint is added and the certificate's
      # Subject is queried for display; if the subject cannot be obtained, the
      # placeholder value unknown is shown instead.  Absence of a certificate
      # prints no and adds nothing.
      #
      # Arguments:
      #   channel -- The channel used for progress output.
      #
      # Results:
      #   Returns the empty result; its effect is the possible registration of the
      #   certificate constraint.
      # </help>

      tputs $channel "---- checking for certificate... "

      if {[catch {
        object invoke Interpreter.GetActive GetCertificate
      } certificate] == 0 && [isNonNullObjectHandle $certificate]} then {
        #
        # NOTE: Yes, it appears that the core library was signed with a
        #       code-signing certificate.
        #
        addConstraint certificate

        #
        # NOTE: Attempt to query the subject from the certificate.
        #
        if {[catch {
          object invoke $certificate Subject
        } subject] || [string length $subject] == 0} then {
          #
          # TODO: No certificate subject, better handling here?
          #
          set subject unknown
        }

        tputs $channel [appendArgs "yes (" $subject ")\n"]
      } else {
        tputs $channel no\n
      }
    }

    proc checkForCompileCSharp { channel } {
      # <help>
      # This procedure probes whether the test suite is able to compile C# source
      # code on demand and registers the test constraint [compileCSharp] when it can.
      # Many tests dynamically compile small C# snippets, so this gates those tests
      # on a working compiler.
      #
      # How it works: unless the no(compileCSharp) global suppresses the check, it
      # performs a trial compilation by calling [doesCompileCSharpWork].  To avoid
      # noise, it temporarily sets the no(csharpLog) flag for the duration of the
      # trial (remembering whether the flag was already present) and clears it again
      # in a finally block only if it set it.  A successful trial adds the
      # constraint (yes); failure, or the suppression flag being set, prints no.
      #
      # Arguments:
      #   channel -- The channel used for progress output.
      #
      # Results:
      #   Returns the empty result; its effect is the possible registration of the
      #   compileCSharp constraint.
      # </help>

      tputs $channel "---- checking for test use of C# compiler... "

      if {![info exists ::no(compileCSharp)]} then {
        if {[info exists ::no(csharpLog)]} then {
          set hadNoCsharpLog true
        } else {
          set ::no(csharpLog) 1
          set hadNoCsharpLog false
        }

        try {
          if {[doesCompileCSharpWork]} then {
            addConstraint compileCSharp

            tputs $channel yes\n
          } else {
            tputs $channel no\n
          }
        } finally {
          if {!$hadNoCsharpLog} then {
            unset ::no(csharpLog)
          }
        }
      } else {
        tputs $channel no\n
      }
    }

    proc checkForAdministrator { channel } {
      # <help>
      # This procedure probes whether the test process is running with full
      # administrator (elevated) privileges and registers the test constraint
      # administrator when it is.  It gates tests that require elevated rights, such
      # as those touching protected files, the registry, or system services.
      #
      # How it works: it delegates the actual determination to [isTestAdministrator]
      # and, when that returns true, adds the constraint and prints yes; otherwise
      # it prints no.
      #
      # Arguments:
      #   channel -- The channel used for progress output.
      #
      # Results:
      #   Returns the empty result; its effect is the possible registration of the
      #   administrator constraint.
      # </help>

      tputs $channel "---- checking for administrator... "

      if {[isTestAdministrator]} then {
        addConstraint administrator; # running as full admin.

        tputs $channel yes\n
      } else {
        tputs $channel no\n
      }
    }

    proc checkForHost { channel } {
      # <help>
      # This procedure probes the state of the interpreter host (its interactive
      # console-like interface) and registers a test constraint describing it:
      # hostIsOpen when the host is open, hostInputRedirected when the host is not
      # open but its input is redirected, or hostIsClosed otherwise.  These let
      # tests that interact with the host be gated on its availability.
      #
      # How it works: it calls [host isopen]; a strictly true result adds
      # hostIsOpen (open).  When the host is not open it calls [host redirected
      # Input]: a strictly true result adds hostInputRedirected (redirected) and a
      # false result adds hostIsClosed (closed).  Failures of either query are
      # logged via [tlog] and reported as error, adding no constraint.
      #
      # Arguments:
      #   channel -- The channel used for progress output.
      #
      # Results:
      #   Returns the empty result; its effect is the registration of at most one
      #   of the host state constraints.
      # </help>

      tputs $channel "---- checking for host... "

      if {[catch {host isopen} open] == 0} then {
        if {[string is true -strict $open]} then {
          addConstraint hostIsOpen

          tputs $channel open\n
        } else {
          if {[catch {host redirected Input} redirected] == 0} then {
            if {[string is true -strict $redirected]} then {
              addConstraint hostInputRedirected

              tputs $channel redirected\n
            } else {
              addConstraint hostIsClosed

              tputs $channel closed\n
            }
          } else {
            tlog $redirected; tputs $channel error\n
          }
        }
      } else {
        tlog $open; tputs $channel error\n
      }
    }

    proc checkForHostType { channel } {
      # <help>
      # This procedure probes the concrete .NET type of the active interpreter's
      # host and registers a test constraint encoding that type name.  The
      # constraint is named hostType. followed by the host type's full name, with
      # characters that are awkward in constraint names (commas, plus, ampersand,
      # asterisk, square brackets, periods, and backslashes) mapped to underscores.
      # This lets tests adapt to the specific host implementation in use.
      #
      # How it works: it invokes ToString on the type object of the active
      # interpreter's host.  A successful, non-empty result yields the sanitized
      # constraint and the original type name is printed.  A successful but empty
      # result prints unknown; a failed call prints error.  Both of the latter add
      # no constraint.
      #
      # Arguments:
      #   channel -- The channel used for progress output.
      #
      # Results:
      #   Returns the empty result; its effect is the possible registration of the
      #   hostType.* constraint.
      # </help>

      tputs $channel "---- checking for host type... "

      if {[set code [catch {
        object invoke Interpreter.GetActive.Host.GetType ToString
      } hostType]] == 0 && [string length $hostType] > 0} then {
        addConstraint [appendArgs hostType. [string map \
            [list , _ + _ & _ * _ \[ _ \] _ . _ \\ _] $hostType]]

        tputs $channel [appendArgs $hostType \n]
      } elseif {$code == 0} then {
        tputs $channel unknown\n
      } else {
        tputs $channel error\n
      }
    }

    proc checkForPrimaryThread { channel } {
      # <help>
      # This procedure probes whether the test code is currently executing on the
      # interpreter's primary thread and registers the test constraint primaryThread
      # when it is.  It gates tests whose behavior depends on running on the same
      # thread that created the interpreter.
      #
      # How it works: it compares the current thread id from [info tid] against the
      # primary thread id from [info ptid].  When they match, the constraint is
      # added and the thread id is shown after yes; otherwise no is shown with the
      # primary thread id.
      #
      # Arguments:
      #   channel -- The channel used for progress output.
      #
      # Results:
      #   Returns the empty result; its effect is the possible registration of the
      #   primaryThread constraint.
      # </help>

      tputs $channel "---- checking for primary thread... "

      if {[info tid] == [set threadId [info ptid]]} then {
        addConstraint primaryThread

        tputs $channel [appendArgs "yes (" $threadId ")\n"]
      } else {
        tputs $channel [appendArgs "no (" $threadId ")\n"]
      }
    }

    proc checkForDefaultAppDomain { channel } {
      # <help>
      # This procedure probes whether the test code is running in the default
      # application domain and registers the test constraint defaultAppDomain when
      # it is.  It gates tests that behave differently in isolated (non-default)
      # application domains.
      #
      # How it works: it obtains AppDomain.CurrentDomain and, when that yields a
      # non-null object handle, queries IsDefaultAppDomain and the domain Id
      # (defaulting these to false and unknown respectively if the queries fail or
      # return empty).  When the domain is the default one, the constraint is added
      # and the id is shown after yes; otherwise no is shown with the id.  A null
      # current domain prints no with a null marker.
      #
      # Arguments:
      #   channel -- The channel used for progress output.
      #
      # Results:
      #   Returns the empty result; its effect is the possible registration of the
      #   defaultAppDomain constraint.
      # </help>

      tputs $channel "---- checking for default application domain... "

      if {[catch {
        object invoke AppDomain CurrentDomain
      } appDomain] == 0 && [isNonNullObjectHandle $appDomain]} then {
        if {[catch {
          object invoke $appDomain IsDefaultAppDomain
        } default] || [string length $default] == 0} then {
          set default false
        }

        if {[catch {object invoke $appDomain Id} id] || \
            [string length $id] == 0} then {
          set id unknown
        }

        if {$default} then {
          addConstraint defaultAppDomain

          tputs $channel [appendArgs "yes (" $id ")\n"]
        } else {
          tputs $channel [appendArgs "no (" $id ")\n"]
        }
      } else {
        tputs $channel [appendArgs "no (null)\n"]
      }
    }

    proc checkForRuntime { channel } {
      # <help>
      # This procedure determines which managed runtime the tests are executing on
      # and registers the corresponding family of test constraints.  On .NET Core
      # it adds dotNetCore, dotNetOrDotNetCore, and dotNetCoreOrShell; on Mono it
      # adds mono and monoOrDotNetCore; and on the full .NET Framework it adds
      # dotNet and dotNetOrDotNetCore.  These broad constraints let tests be
      # included or skipped by runtime family.
      #
      # How it works: it classifies the runtime using [isTestDotNetCore] and
      # [isTestMono], falling through to .NET Framework otherwise.  Besides the
      # constraints above, it calls [addKnownMonoConstraints] and/or
      # [addKnownDotNetCoreConstraints] with a true argument so that bugs specific
      # to the OTHER runtimes are NOT skipped while running on the current one (for
      # example, Mono-specific bug skips are disabled when not on Mono).  The
      # displayed runtime name comes from tcltk_platform(runtime) when available,
      # otherwise a sensible default label per runtime.
      #
      # Arguments:
      #   channel -- The channel used for progress output.
      #
      # Results:
      #   Returns the empty result; its effect is the registration of the runtime
      #   family constraints and the related known-constraint adjustments.
      # </help>

      tputs $channel "---- checking for runtime... "

      #
      # NOTE: Are we running inside Mono -OR- on .NET Core (regardless
      #       of operating system)?
      #
      if {[isTestDotNetCore]} then {
        #
        # NOTE: Yes, it appears that we are running on .NET Core.
        #
        addConstraint dotNetCore; # running on .NET Core.
        addConstraint dotNetOrDotNetCore
        addConstraint dotNetCoreOrShell

        #
        # NOTE: We do not want to skip Mono bugs on .NET Core.
        #
        addKnownMonoConstraints true; # running on .NET Core.

        tputs $channel [appendArgs [expr {[info exists \
            ::tcltk_platform(runtime)] ? \
            $::tcltk_platform(runtime) : ".NET Core"}] \n]
      } elseif {[isTestMono]} then {
        #
        # NOTE: Yes, it appears that we are running inside Mono.
        #
        addConstraint mono; # running on Mono.
        addConstraint monoOrDotNetCore

        #
        # NOTE: We do not want to skip .NET Core bugs on Mono.
        #
        addKnownDotNetCoreConstraints true; # running on Mono.

        tputs $channel [appendArgs [expr {[info exists \
            ::tcltk_platform(runtime)] ? \
            $::tcltk_platform(runtime) : "Mono"}] \n]
      } else {
        #
        # NOTE: It appears that we are running on the full .NET.
        #
        addConstraint dotNet; # running on .NET.
        addConstraint dotNetOrDotNetCore

        #
        # NOTE: We do not want to skip Mono -OR- .NET Core bugs on .NET.
        #
        addKnownMonoConstraints true; # running on .NET.
        addKnownDotNetCoreConstraints true; # running on .NET.

        tputs $channel [appendArgs [expr {[info exists \
            ::tcltk_platform(runtime)] ? \
            $::tcltk_platform(runtime) : "Microsoft.NET"}] \n]
      }
    }

    proc checkForImageRuntimeVersion { channel } {
      # <help>
      # This procedure probes the image runtime version of the core library
      # assembly (the CLR version the assembly was built against) and registers a
      # version-specific test constraint.  The constraint is named imageRuntime
      # followed by the major and minor version with the periods removed, for
      # example imageRuntime40 for version 4.0.
      #
      # How it works: it reads tcltk_platform(imageRuntimeVersion); when present and
      # non-empty it reduces the value to its major.minor portion via
      # [getMajorMinorVersion], strips any leading v and the periods to form the
      # constraint suffix, adds the constraint, and prints the full version with the
      # dotted major.minor form.  An absent or empty platform value prints no.
      #
      # Arguments:
      #   channel -- The channel used for progress output.
      #
      # Results:
      #   Returns the empty result; its effect is the possible registration of the
      #   imageRuntime<version> constraint.
      # </help>

      tputs $channel "---- checking for image runtime version... "

      if {[info exists ::tcltk_platform(imageRuntimeVersion)] && \
          [string length $::tcltk_platform(imageRuntimeVersion)] > 0} then {
        #
        # NOTE: Get the major and minor portions of the version only.
        #
        set dotVersion [getMajorMinorVersion \
            $::tcltk_platform(imageRuntimeVersion)]

        #
        # NOTE: Now create a version string for use in the constraint name
        #       (remove the periods).
        #
        set version [string map [list v "" . ""] $dotVersion]

        #
        # NOTE: Keep track of the specific image runtime version for usage in
        #       test constraints.
        #
        addConstraint [appendArgs imageRuntime $version]

        tputs $channel [appendArgs \
            $::tcltk_platform(imageRuntimeVersion) " (" $dotVersion ")\n"]
      } else {
        tputs $channel no\n
      }
    }

    proc checkForFrameworkVersion { channel } {
      # <help>
      # This procedure probes the framework version reported for the current
      # runtime and registers a version-specific test constraint.  The constraint
      # is named framework followed by the dotless major and minor version, for
      # example framework40 for version 4.0.
      #
      # How it works: it reads tcltk_platform(frameworkVersion); when present and
      # non-empty it reduces the value to its major.minor portion via
      # [getMajorMinorVersion], converts it to a dotless form via
      # [getDotlessVersion], and, when that conversion yields a non-empty string,
      # adds the constraint.  The full framework version and its dotted major.minor
      # form are printed.  An absent or empty platform value prints no.
      #
      # Arguments:
      #   channel -- The channel used for progress output.
      #
      # Results:
      #   Returns the empty result; its effect is the possible registration of the
      #   framework<version> constraint.
      # </help>

      tputs $channel "---- checking for framework version... "

      if {[info exists ::tcltk_platform(frameworkVersion)] && \
          [string length $::tcltk_platform(frameworkVersion)] > 0} then {
        #
        # NOTE: Get the major and minor portions of the version only.
        #
        set dotVersion [getMajorMinorVersion \
            $::tcltk_platform(frameworkVersion)]

        #
        # NOTE: Now create a version string for use in the constraint name
        #       (remove the periods).
        #
        set version [getDotlessVersion $dotVersion]

        #
        # NOTE: If the framework version was found, add a test constraint
        #       for it now.
        #
        if {[string length $version] > 0} then {
          addConstraint [appendArgs framework $version]
        }

        tputs $channel [appendArgs \
            $::tcltk_platform(frameworkVersion) " (" $dotVersion ")\n"]
      } else {
        tputs $channel no\n
      }
    }

    proc checkForMatchingFrameworkVersion { channel } {
      # <help>
      # This procedure probes whether the framework version and the image runtime
      # version agree, and registers test constraints describing that relationship.
      # On an exact match it adds the general constraints matchFramework and
      # matchFramework<version> together with the per-runtime variants
      # dotNetMatchFramework, monoMatchFramework, and dotNetCoreMatchFramework (each
      # also in a <version>-suffixed form).  On a mismatch it adds only the
      # match-framework constraints for the runtimes OTHER than the one currently in
      # use, so that match-dependent tests are not skipped on those other runtimes.
      #
      # How it works: it reads both tcltk_platform(frameworkVersion) and
      # tcltk_platform(imageRuntimeVersion), reducing each to its major.minor form
      # via [getMajorMinorVersion] and stripping a leading v.  The dotless framework
      # version forms the constraint suffix.  Equality of the two dotted versions
      # selects the matching branch (yes); inequality selects the per-runtime
      # mismatch branch chosen by [isTestDotNetCore] and [isTestMono] (no).  If
      # either platform version is missing it prints an explanatory no message and
      # adds nothing.
      #
      # Arguments:
      #   channel -- The channel used for progress output.
      #
      # Results:
      #   Returns the empty result; its effect is the registration of the
      #   appropriate *MatchFramework constraints.
      # </help>

      tputs $channel "---- checking for matching framework version... "

      if {[info exists ::tcltk_platform(frameworkVersion)] && \
          [string length $::tcltk_platform(frameworkVersion)] > 0} then {
        if {[info exists ::tcltk_platform(imageRuntimeVersion)] && \
            [string length $::tcltk_platform(imageRuntimeVersion)] > 0} then {
          #
          # NOTE: Get the major and minor portions of the versions only.
          #
          set dotVersion(1) [getMajorMinorVersion \
              $::tcltk_platform(frameworkVersion)]

          set dotVersion(2) [getMajorMinorVersion \
              $::tcltk_platform(imageRuntimeVersion)]

          #
          # NOTE: Remove single leading "v" characters, if applicable.
          #
          if {[string index $dotVersion(1) 0] eq "v"} then {
            set dotVersion(1) [string range $dotVersion(1) 1 end]
          }

          if {[string index $dotVersion(2) 0] eq "v"} then {
            set dotVersion(2) [string range $dotVersion(2) 1 end]
          }

          #
          # NOTE: Now create a version string for use in the constraint
          #       name (remove the periods).
          #
          set version(1) [string map [list . ""] $dotVersion(1)]

          #
          # NOTE: Check for an exact match between the image runtime
          #       version and the framework version.
          #
          if {$dotVersion(1) eq $dotVersion(2)} then {
            #
            # NOTE: Yes, the image runtime version matches the framework.
            #
            addConstraint matchFramework
            addConstraint [appendArgs matchFramework $version(1)]

            addConstraint dotNetMatchFramework
            addConstraint [appendArgs dotNetMatchFramework $version(1)]

            addConstraint monoMatchFramework
            addConstraint [appendArgs monoMatchFramework $version(1)]

            addConstraint dotNetCoreMatchFramework
            addConstraint [appendArgs dotNetCoreMatchFramework $version(1)]

            tputs $channel yes\n
          } else {
            if {[isTestDotNetCore]} then {
              addConstraint dotNetMatchFramework
              addConstraint [appendArgs dotNetMatchFramework $version(1)]

              addConstraint monoMatchFramework
              addConstraint [appendArgs monoMatchFramework $version(1)]
            } elseif {[isTestMono]} then {
              addConstraint dotNetMatchFramework
              addConstraint [appendArgs dotNetMatchFramework $version(1)]

              addConstraint dotNetCoreMatchFramework
              addConstraint [appendArgs dotNetCoreMatchFramework $version(1)]
            } else {
              addConstraint monoMatchFramework
              addConstraint [appendArgs monoMatchFramework $version(1)]

              addConstraint dotNetCoreMatchFramework
              addConstraint [appendArgs dotNetCoreMatchFramework $version(1)]
            }

            tputs $channel no\n
          }
        } else {
          tputs $channel "no, missing image runtime version\n"
        }
      } else {
        tputs $channel "no, missing framework version\n"
      }
    }

    proc checkForRuntimeVersion { channel } {
      # <help>
      # This procedure probes the version of the managed runtime in use and
      # registers a large family of version-specific test constraints tailored to
      # that runtime.  It is one of the most involved probes in this file because
      # it generates not just a single version constraint but whole ranges of
      # "or higher", "to do", "bug", "crash", "hang", and "only" constraints used
      # throughout the test suite to skip or include tests by exact and relative
      # version.
      #
      # On .NET Core it adds dotNetCore<version> and dotNetCore<version>OrHigher for
      # the running version, and, for each known .NET Core version strictly below
      # the running one, dotNetCore<v>OrHigher, dotNetCoreToDo<v>, dotNetCoreBug<v>,
      # and dotNetCoreCrash<v>; in a separate pass over all known versions it adds
      # dotNetCore<v>Only for the exact running version (when present in the known
      # list) and the <v>Only forms of the to-do, bug, and crash constraints for
      # every other known version.  On Mono it adds the analogous mono<version>,
      # mono<version>OrHigher, and the monoToDo/monoBug/monoCrash/monoHang families
      # (including <v>Only variants).  On the full .NET Framework it adds only
      # dotNet<version> and dotNet<version>OrHigher.
      #
      # How it works: it reads tcltk_platform(runtimeVersion), reduces it to its
      # major.minor form via [getMajorMinorVersion], and derives a dotless version
      # string for constraint names.  After branching on [isTestDotNetCore] and
      # [isTestMono], it parses the dotted version into numeric major and minor
      # parts with a regular expression and walks the lists from
      # [getKnownDotNetCoreVersions] / [getKnownMonoVersions], comparing
      # major/minor numbers to decide which "or higher" and "only" constraints to
      # add.  In every branch it also calls [addKnownMonoConstraints] and/or
      # [addKnownDotNetCoreConstraints] with a false argument so that bug-skip
      # constraints for the other runtimes are enabled (i.e. those other runtimes'
      # bugs are not skipped while running here).  The full runtime version and its
      # dotted form are printed; an absent or empty platform value prints no.
      #
      # Arguments:
      #   channel -- The channel used for progress output.
      #
      # Results:
      #   Returns the empty result; its effect is the registration of the
      #   runtime-version-specific constraint families described above.
      # </help>

      tputs $channel "---- checking for runtime version... "

      if {[info exists ::tcltk_platform(runtimeVersion)] && \
          [string length $::tcltk_platform(runtimeVersion)] > 0} then {
        #
        # NOTE: Get the major and minor portions of the version only.
        #
        set dotVersion [getMajorMinorVersion \
            $::tcltk_platform(runtimeVersion)]

        #
        # NOTE: Now create a version string for use in the constraint name
        #       (remove the periods).
        #
        set version [string map [list . ""] $dotVersion]

        if {[isTestDotNetCore]} then {
          #
          # NOTE: If the runtime version was found, add a test constraint
          #       for it now.
          #
          if {[string length $version] > 0} then {
            #
            # NOTE: We are running on the .NET Core.  Keep track of the
            #       specific version for usage in test constraints.
            #
            addConstraint [appendArgs dotNetCore $version]
            addConstraint [appendArgs dotNetCore $version OrHigher]
          }

          #
          # NOTE: Attempt to parse the version into its major and minor
          #       components.
          #
          if {[string length $dotVersion] > 0 && [regexp -- {^(\d+)\.(\d+)$} \
              $dotVersion dummy majorVersion minorVersion]} then {
            #
            # NOTE: This is the list of .NET Core versions to add test
            #       constraints for.
            #
            set dotNetCoreVersions [list]

            #
            # NOTE: Check each .NET Core version "known" to the test
            #       suite.
            #
            foreach dotNetCoreVersion [getKnownDotNetCoreVersions] {
              #
              # NOTE: Check for any .NET Core major version X or higher.
              #
              if {$majorVersion >= [lindex $dotNetCoreVersion 0]} then {
                #
                # NOTE: Check for any .NET Core major/minor version
                #       higher than X.Y.
                #
                if {$majorVersion > [lindex $dotNetCoreVersion 0] || \
                    $minorVersion > [lindex $dotNetCoreVersion 1]} then {
                  #
                  # NOTE: Add this "known" version of .NET Core.
                  #
                  lappend dotNetCoreVersions $dotNetCoreVersion
                }
              }
            }

            #
            # NOTE: Add the necessary constraints for each version of .NET
            #       Core we should NOT skip bugs for.
            #
            foreach dotNetCoreVersion $dotNetCoreVersions {
              set constraintVersion [join $dotNetCoreVersion ""]

              addConstraint [appendArgs \
                  dotNetCore $constraintVersion OrHigher]

              addConstraint [appendArgs \
                  dotNetCoreToDo $constraintVersion]

              addConstraint [appendArgs \
                  dotNetCoreBug $constraintVersion]

              addConstraint [appendArgs \
                  dotNetCoreCrash $constraintVersion]
            }

            #
            # NOTE: Check all known versions of .NET Core for an exact match
            #       with the currently running one.
            #
            foreach dotNetCoreVersion [getKnownDotNetCoreVersions] {
              #
              # NOTE: Check if .NET Core major/minor version is exactly the
              #       one we are currently processing.
              #
              set constraintVersion [join $dotNetCoreVersion ""]

              if {[lindex $dotNetCoreVersion 0] == $majorVersion && \
                  [lindex $dotNetCoreVersion 1] == $minorVersion} then {
                #
                # NOTE: Add test constraints that only apply to this exact
                #       version of .NET Core.
                #
                addConstraint [appendArgs \
                    dotNetCore $constraintVersion Only]
              } else {
                #
                # NOTE: Add test constraints that apply to all versions of
                #       .NET Core except this exact version.
                #
                addConstraint [appendArgs \
                    dotNetCoreToDo $constraintVersion Only]

                addConstraint [appendArgs \
                    dotNetCoreBug $constraintVersion Only]

                addConstraint [appendArgs \
                    dotNetCoreCrash $constraintVersion Only]
              }
            }
          }

          #
          # NOTE: We do not want to skip any Mono bugs on .NET Core.  Add
          #       the necessary constraints for each version of Mono we
          #       know about.
          #
          addKnownMonoConstraints false; # running on .NET.
        } elseif {[isTestMono]} then {
          #
          # NOTE: If the runtime version was found, add a test constraint
          #       for it now.
          #
          if {[string length $version] > 0} then {
              #
              # NOTE: We are running on Mono.  Keep track of the specific
              #       version for usage in test constraints.
              #
              addConstraint [appendArgs mono $version]
              addConstraint [appendArgs mono $version OrHigher]
          }

          #
          # NOTE: Attempt to parse the version into its major and minor
          #       components.
          #
          if {[string length $dotVersion] > 0 && [regexp -- {^(\d+)\.(\d+)$} \
              $dotVersion dummy majorVersion minorVersion]} then {
            #
            # NOTE: This is the list of Mono versions to add test
            #       constraints for.
            #
            set monoVersions [list]

            #
            # NOTE: Check each Mono version "known" to the test suite.
            #
            foreach monoVersion [getKnownMonoVersions] {
              #
              # NOTE: Check for any Mono major version X or higher.
              #
              if {$majorVersion >= [lindex $monoVersion 0]} then {
                #
                # NOTE: Check for any Mono major/minor version higher
                #       than X.Y.
                #
                if {$majorVersion > [lindex $monoVersion 0] || \
                    $minorVersion > [lindex $monoVersion 1]} then {
                  #
                  # NOTE: Add this "known" version of Mono.
                  #
                  lappend monoVersions $monoVersion
                }
              }
            }

            #
            # NOTE: Add the necessary constraints for each version of Mono
            #       we should NOT skip bugs for.
            #
            foreach monoVersion $monoVersions {
              set constraintVersion [join $monoVersion ""]

              addConstraint [appendArgs mono $constraintVersion OrHigher]
              addConstraint [appendArgs monoToDo $constraintVersion]
              addConstraint [appendArgs monoBug $constraintVersion]
              addConstraint [appendArgs monoCrash $constraintVersion]
              addConstraint [appendArgs monoHang $constraintVersion]
            }

            #
            # NOTE: Check all known versions of Mono for an exact match with
            #       the currently running one.
            #
            foreach monoVersion [getKnownMonoVersions] {
              #
              # NOTE: Check if Mono major/minor version is exactly the one
              #       we are currently processing.
              #
              set constraintVersion [join $monoVersion ""]

              if {[lindex $monoVersion 0] == $majorVersion && \
                  [lindex $monoVersion 1] == $minorVersion} then {
                #
                # NOTE: Add test constraints that only apply to this exact
                #       version of Mono.
                #
                addConstraint [appendArgs mono $constraintVersion Only]
              } else {
                #
                # NOTE: Add test constraints that apply to all versions of
                #       Mono except this exact version.
                #
                addConstraint [appendArgs monoToDo $constraintVersion Only]
                addConstraint [appendArgs monoBug $constraintVersion Only]
                addConstraint [appendArgs monoCrash $constraintVersion Only]
                addConstraint [appendArgs monoHang $constraintVersion Only]
              }
            }
          }

          #
          # NOTE: We do not want to skip any .NET Core bugs on Mono.  Add
          #       the necessary constraints for each version of Mono we
          #       know about.
          #
          addKnownDotNetCoreConstraints false; # running on Mono.
        } else {
          #
          # NOTE: If the runtime version was found, add a test constraint
          #       for it now.
          #
          if {[string length $version] > 0} then {
            #
            # NOTE: We are running on the .NET Framework.  Keep track of the
            #       specific version for usage in test constraints.
            #
            addConstraint [appendArgs dotNet $version]
            addConstraint [appendArgs dotNet $version OrHigher]
          }

          #
          # NOTE: We do not want to skip any Mono bugs on .NET.  Add the
          #       necessary constraints for each version of Mono we know
          #       about.
          #
          addKnownMonoConstraints false; # running on .NET.
          addKnownDotNetCoreConstraints false; # running on .NET.
        }

        tputs $channel [appendArgs \
            $::tcltk_platform(runtimeVersion) " (" $dotVersion ")\n"]
      } else {
        tputs $channel no\n
      }
    }

    proc checkForRuntimeBuild { channel } {
      # <help>
      # This procedure probes the detailed runtime build identifier and registers a
      # build-specific test constraint.  The constraint is named runtimeBuild.
      # followed by the dotted build number, for example runtimeBuild.4.0.30319.
      #
      # How it works: it reads tcltk_platform(runtimeBuild); when present and
      # non-empty it extracts the leading dotted-numeric build (a sequence of
      # period-separated integers) from the front of the string with a regular
      # expression and, on a match, adds the constraint.  If no build number can be
      # parsed, the placeholder unknown is used for display only.  The full build
      # string and the parsed build are printed.  An absent or empty platform value
      # prints no.
      #
      # Arguments:
      #   channel -- The channel used for progress output.
      #
      # Results:
      #   Returns the empty result; its effect is the possible registration of the
      #   runtimeBuild.<build> constraint.
      # </help>

      tputs $channel "---- checking for runtime build... "

      if {[info exists ::tcltk_platform(runtimeBuild)] && \
          [string length $::tcltk_platform(runtimeBuild)] > 0} then {
        if {[regexp -- {^(\d+\.\d+(?:\.\d+)*) } \
            $::tcltk_platform(runtimeBuild) dummy build]} then {
          addConstraint [appendArgs runtimeBuild. $build]
        } else {
          set build unknown
        }

        tputs $channel [appendArgs \
            $::tcltk_platform(runtimeBuild) " (" $build ")\n"]
      } else {
        tputs $channel no\n
      }
    }

    proc checkForProcessBits { channel } {
      # <help>
      # This procedure probes the bitness (pointer width) of the running process
      # and registers a corresponding test constraint.  The constraint is named by
      # the bit count followed by bit, for example 64bit or 32bit, letting tests be
      # gated on a particular process architecture width.
      #
      # How it works: it reads tcl_platform(processBits); when that exists and is a
      # strict integer it adds the <bits>bit constraint and prints the value with a
      # -bit suffix.  When the value is absent or not an integer it prints unknown
      # and adds nothing.
      #
      # Arguments:
      #   channel -- The channel used for progress output.
      #
      # Results:
      #   Returns the empty result; its effect is the possible registration of the
      #   <bits>bit constraint.
      # </help>

      tputs $channel "---- checking for process bits... "

      if {[info exists ::tcl_platform(processBits)] && \
          [string is integer -strict $::tcl_platform(processBits)]} then {
        addConstraint [appendArgs $::tcl_platform(processBits) bit]

        tputs $channel [appendArgs $::tcl_platform(processBits) -bit\n]
      } else {
        tputs $channel unknown\n
      }
    }

    proc checkForMachine { channel bits machine } {
      # <help>
      # This procedure probes whether the current process matches a specific
      # combination of machine architecture and bitness and registers a test
      # constraint when it does.  The constraint is named by the architecture, a
      # period, the bit count, and bit, for example AMD64.64bit or x86.32bit.  It is
      # typically called several times with different architecture/bitness pairs so
      # that the matching one registers its constraint.
      #
      # How it works: it reads tcl_platform(machine) and tcl_platform(processBits)
      # and, when both exist, compares them to the caller-supplied machine and bits.
      # An exact match on both adds the constraint and prints yes; any mismatch
      # prints no.  Missing platform values print a "no, unknown" message and add
      # nothing.
      #
      # Arguments:
      #   channel -- The channel used for progress output.
      #   bits    -- The process bitness to match (for example 32 or 64).
      #   machine -- The machine architecture name to match (for example x86,
      #              AMD64).
      #
      # Results:
      #   Returns the empty result; its effect is the possible registration of the
      #   <machine>.<bits>bit constraint.
      # </help>

      tputs $channel [appendArgs "---- checking for machine \"" $bits \
          "-bit " $machine "\"... "]

      #
      # NOTE: What are the machine architecture and the
      #       number of bits for this operating system?
      #
      if {[info exists ::tcl_platform(machine)] && \
          [info exists ::tcl_platform(processBits)]} then {
        #
        # NOTE: Does the machine and number of bits match
        #       what the caller specified?
        #
        if {$::tcl_platform(machine) eq $machine && \
            $::tcl_platform(processBits) eq $bits} then {
          #
          # NOTE: Yes, it matches.
          #
          addConstraint [appendArgs $machine . $bits bit]

          tputs $channel yes\n
        } else {
          tputs $channel no\n
        }
      } else {
        tputs $channel "no, unknown\n"
      }
    }

    proc checkForTestCallStack { channel } {
      # <help>
      # This procedure probes whether the test suite is being driven from one of
      # the expected entry-point commands, in a way that does not perturb tests
      # sensitive to absolute call frame positions, and registers the test
      # constraint testCallStack when so.  It guards tests that rely on a known
      # call stack shape.
      #
      # How it works: it searches outward through the call frames for the nearest
      # frame that has associated arguments, by repeatedly evaluating [info level
      # [info level]] at increasing absolute levels (## prefix) inside a [catch]
      # until one succeeds; this loop always terminates because at least the current
      # frame qualifies.  The command name is taken from the first element of those
      # arguments.  When that command is [runTestPrologue] or [checkForTestCallStack]
      # (both deemed safe because they will not be on the stack when the tests
      # actually run), the constraint is added and yes plus the command name is
      # printed; otherwise no plus the command name is printed.
      #
      # Arguments:
      #   channel -- The channel used for progress output.
      #
      # Results:
      #   Returns the empty result; its effect is the possible registration of the
      #   testCallStack constraint.
      # </help>

      tputs $channel "---- checking for test call stack... "

      #
      # NOTE: Search for a call frame with associated arguments.
      #       At this point, there must be at least one such call
      #       frame (this one).  Therefore, this loop will always
      #       terminate.
      #
      set index 0; set arguments [list]
      set script {info level [info level]}

      while {1} {
        set level [appendArgs ## $index]

        if {[catch {uplevel $level $script} arguments] == 0} then {
          break
        }

        incr index
      }

      #
      # NOTE: Grab the command name from the arguments, if any.
      #
      set command [expr {
        [llength $arguments] > 0 ? [lindex $arguments 0] : ""
      }]

      #
      # HACK: Make sure the call stack does not end up confusing
      #       the tests that rely on absolute call frames.  The
      #       [runTestPrologue] is allowed here because it will
      #       not be active on the call stack at the point the
      #       tests are actually run.  Actually, the same thing
      #       goes for [checkForTestCallStack] as well.
      #
      if {$command in \
          [list runTestPrologue checkForTestCallStack]} then {
        addConstraint testCallStack

        tputs $channel [appendArgs "yes (\"" $command "\")\n"]

        #
        # NOTE: We are done here, return now.
        #
        return
      }

      tputs $channel [appendArgs "no (\"" $command "\")\n"]
    }

    proc checkForGarudaDll { channel } {
      # <help>
      # This procedure probes for the Garuda DLL (the native package that lets a
      # native Tcl shell load TclTk) and registers the test constraint garudaLibrary
      # when a build of it compatible with the current process architecture is
      # present.  As a side effect it also drives [checkForFile] for the located
      # DLL, which registers the usual file_<name> constraint.
      #
      # How it works: it first decides which machine architecture to target.  If
      # external command execution is permitted ([canExecTclShell] is true) it
      # leaves the machine empty so [getGarudaDll] auto-detects it from the native
      # Tcl shell; otherwise it uses [getTestMachine], substituting unknown if that
      # is empty so the auto-detect meaning of an empty value is not triggered.  It
      # then asks [getGarudaDll] for the DLL file name; when a name is returned it
      # checks the file's presence and then calls [library matcharchitecture]
      # (wrapped in [catch] since the command may be missing) to confirm the DLL
      # matches the current process architecture, adding garudaLibrary and printing
      # yes on a match and no otherwise.
      #
      # Arguments:
      #   channel -- The channel used for progress output.
      #
      # Results:
      #   Returns the empty result; its effects are the possible registration of the
      #   garudaLibrary constraint and the file constraint side effect from
      #   [checkForFile].
      # </help>

      #
      # NOTE: Skip automatic Tcl shell machine detection if we are not
      #       allowed to execute external commands.
      #
      if {[canExecTclShell]} then {
        #
        # NOTE: Have the [getGarudaDll] procedure automatically detect the
        #       machine.
        #
        set machine ""
      } else {
        #
        # NOTE: Use the machine for this test run.
        #
        set machine [getTestMachine]

        #
        # NOTE: Since an empty string means "automatically detect" to the
        #       [getGarudaDll] procedure, we must make sure the value is
        #       something else.
        #
        if {[string length $machine] == 0} then {
          set machine unknown
        }
      }

      #
      # NOTE: First, figure out what the file name for the Garuda DLL is,
      #       if anything.
      #
      set fileName [getGarudaDll $machine]

      if {[string length $fileName] > 0} then {
        #
        # NOTE: Next, check if the Garuda DLL is the same platform (i.e.
        #       machine type) as the native Tcl shell.
        #
        checkForFile $channel $fileName

        #
        # NOTE: Next, check if the Garuda DLL appears to be compatible
        #       with this platform.
        #
        tputs $channel [appendArgs \
            "---- checking if file \"" $fileName \
            "\" matches architecture for current process... "]

        if {[catch {
          library matcharchitecture $fileName; # maybe missing command?
        } match] == 0 && $match} then {
          addConstraint garudaLibrary

          tputs $channel yes\n
        } else {
          tputs $channel no\n
        }
      }
    }

    proc checkForCulture { channel } {
      # <help>
      # This procedure probes the interpreter's current culture and registers a
      # culture-specific test constraint.  The constraint is named culture. followed
      # by the culture name with hyphens replaced by underscores, for example
      # culture.en_US.  It gates tests whose expected results depend on the active
      # culture (such as number or date formatting).
      #
      # How it works: it reads the culture via [info culture]; a non-empty value
      # yields the constraint (after the hyphen-to-underscore substitution) and is
      # printed, while an empty value prints unknown and adds nothing.
      #
      # Arguments:
      #   channel -- The channel used for progress output.
      #
      # Results:
      #   Returns the empty result; its effect is the possible registration of the
      #   culture.<name> constraint.
      # </help>

      tputs $channel "---- checking for culture... "

      #
      # NOTE: Grab the current culture.
      #
      set culture [info culture]

      if {[string length $culture] > 0} then {
        #
        # NOTE: The culture information is present, use it and show it.
        #
        addConstraint [appendArgs culture. [string map [list - _] $culture]]

        tputs $channel [appendArgs $culture \n]
      } else {
        tputs $channel unknown\n
      }
    }

    proc checkForThreadCulture { channel } {
      # <help>
      # This procedure probes the culture associated with the current managed
      # thread (which may differ from the interpreter culture probed by
      # [checkForCulture]) and registers a thread-culture-specific test constraint.
      # The constraint is named threadCulture. followed by the culture name with
      # hyphens replaced by underscores, for example threadCulture.en_US.
      #
      # How it works: it obtains Thread.CurrentThread.CurrentCulture, then converts
      # it to a culture name string via the non-public FormatOps.CultureName helper.
      # When both calls succeed and yield a non-empty name, it adds the constraint
      # (after the hyphen-to-underscore substitution) and prints the name; any
      # failure or empty name prints unknown and adds nothing.
      #
      # Arguments:
      #   channel -- The channel used for progress output.
      #
      # Results:
      #   Returns the empty result; its effect is the possible registration of the
      #   threadCulture.<name> constraint.
      # </help>

      tputs $channel "---- checking for thread culture... "

      #
      # NOTE: Grab the current thread culture.
      #
      if {[catch {
        object invoke System.Threading.Thread.CurrentThread CurrentCulture
      } culture] == 0 && [catch {
        object invoke CodeBrix.Platform.TclTk._Components.Private.FormatOps CultureName \
            $culture false
      } culture] == 0 && [string length $culture] > 0} then {
        #
        # NOTE: The culture information is present, use it and show it.
        #
        addConstraint [appendArgs threadCulture. [string map [list - _] \
            $culture]]

        tputs $channel [appendArgs $culture \n]
      } else {
        tputs $channel unknown\n
      }
    }

    proc checkForQuiet { channel quiet } {
      # <help>
      # This procedure probes whether the interpreter is running in quiet mode and
      # registers the test constraint quiet when it is.  Several other probes
      # suppress warnings when this constraint is present, so detecting quiet mode
      # controls the verbosity of the test run.
      #
      # How it works: it invokes the active interpreter's Quiet property; a
      # successful, strictly true result adds the constraint.  The "quiet" argument
      # controls only this procedure's own output: when it is true the usual
      # checking/yes/no progress lines are suppressed (so that probing for quiet
      # mode does not itself produce noise), while the constraint registration still
      # happens either way.
      #
      # Arguments:
      #   channel -- The channel used for progress output.
      #   quiet   -- A boolean controlling this procedure's own output; when true,
      #              its progress messages are suppressed.
      #
      # Results:
      #   Returns the empty result; its effect is the possible registration of the
      #   quiet constraint.
      # </help>

      if {!$quiet} then {
        tputs $channel "---- checking for quiet... "
      }

      if {[catch {
        object invoke Interpreter.GetActive Quiet
      } isQuiet] == 0 && [string is true -strict $isQuiet]} then {
        #
        # NOTE: Yes, quiet mode is enabled.
        #
        addConstraint quiet

        if {!$quiet} then {
          tputs $channel yes\n
        }
      } else {
        if {!$quiet} then {
          tputs $channel no\n
        }
      }
    }

    proc checkForReferenceCountTracking { channel } {
      # <help>
      # This procedure probes whether the core library was built with support for
      # object reference count tracking and registers the test constraint
      # referenceCounts when it was.  It gates tests that inspect or depend on
      # object reference counting.
      #
      # How it works: it examines tcltk_platform(compileOptions) and, when present,
      # checks (case-insensitively) for either the NOTIFY or NOTIFY_OBJECT compile
      # option, since the notification machinery is what enables reference count
      # tracking.  Presence of either option adds the constraint and prints yes;
      # otherwise it prints no.
      #
      # Arguments:
      #   channel -- The channel used for progress output.
      #
      # Results:
      #   Returns the empty result; its effect is the possible registration of the
      #   referenceCounts constraint.
      # </help>

      tputs $channel "---- checking for object reference count tracking... "

      if {[info exists ::tcltk_platform(compileOptions)] && \
          ([lsearch -exact -nocase $::tcltk_platform(compileOptions) \
              NOTIFY] != -1 || \
           [lsearch -exact -nocase $::tcltk_platform(compileOptions) \
              NOTIFY_OBJECT] != -1)} then {
        #
        # NOTE: Yes, support for object reference count tracking is present.
        #
        addConstraint referenceCounts

        tputs $channel yes\n
      } else {
        tputs $channel no\n
      }
    }

    proc checkForRuntimeOption { channel option } {
      # <help>
      # This procedure probes whether a particular interpreter runtime option is
      # currently in effect and registers a corresponding test constraint.  The
      # constraint is named runtime. followed by the option name, for example
      # runtime.NoComplain.  It gates tests that depend on a specific runtime option
      # being set.
      #
      # How it works: it examines tcltk_platform(runtimeOptions) and, when present,
      # searches it case-insensitively for the requested option.  A match adds the
      # constraint and prints yes; absence prints no.
      #
      # Arguments:
      #   channel -- The channel used for progress output.
      #   option  -- The name of the runtime option to look for.
      #
      # Results:
      #   Returns the empty result; its effect is the possible registration of the
      #   runtime.<option> constraint.
      # </help>

      tputs $channel [appendArgs "---- checking for runtime option \"" \
          $option "\"... "]

      if {[info exists ::tcltk_platform(runtimeOptions)] && \
          [lsearch -exact -nocase $::tcltk_platform(runtimeOptions) \
              $option] != -1} then {
        #
        # NOTE: Yes, support for the runtime option is present.
        #
        addConstraint [appendArgs runtime. $option]

        tputs $channel yes\n
      } else {
        tputs $channel no\n
      }
    }

    proc testForDynamicLoading { {fileName ""} {errorVarName ""} } {
      # <help>
      # This procedure actually attempts to load a native library in order to
      # determine whether dynamic loading works on the current platform.  It is the
      # worker behind [checkForDynamicLoading] and does not itself register any test
      # constraint; it simply reports success or failure.
      #
      # How it works: unless disabled by the no(testForDynamicLoading) global or the
      # matching environment variable, it builds a list of candidate native library
      # files to try.  An explicit file name argument is used as the sole candidate;
      # otherwise it uses tcltk_debugger(dynamicLoadingTestFiles) when set, or a
      # platform default: kernel32 on Windows (assumed already loaded); on macOS
      # (Darwin) a freshly compiled canary dynamic library via [compileCanaryDyLib]
      # which is scheduled for deletion; and on other Unix systems libdl.so and
      # libdl.so.2.  Each candidate is passed to the non-public NativeOps.TestLoad-
      # Library helper inside a [catch]; the first one returning an "Ok" code makes
      # the procedure return true.  A finally block deletes any temporary canary
      # file (and its directory) that was created.
      #
      # Tricky details: the optional error variable name, when supplied, is linked
      # into the caller's frame via [upvar] so a failure message can be surfaced.
      # The check is short-circuited entirely (returning false) when the suppression
      # flag or environment variable is present.
      #
      # Arguments:
      #   fileName     -- Optional native library file name to test; when empty, a
      #                   platform-appropriate default set is used.
      #   errorVarName -- Optional name of a variable in the caller's frame that
      #                   receives a failure message; when empty, no error is
      #                   surfaced.
      #
      # Results:
      #   Returns true if any candidate library loaded successfully; otherwise
      #   returns false (including when the check is suppressed).
      # </help>

      if {![info exists ::no(testForDynamicLoading)] && \
          ![info exists ::env(testForDynamicLoading)]} then {
        if {[string length $errorVarName] > 0} then {
          upvar 1 $errorVarName error
        }

        try {
          if {[string length $fileName] > 0} then {
            set fileNames [list $fileName]
          } else {
            if {[info exists \
                ::tcltk_debugger(dynamicLoadingTestFiles)]} then {
              set fileNames $::tcltk_debugger(dynamicLoadingTestFiles)
            } else {
              set fileNames [list]

              if {[isWindows]} then {
                lappend fileNames kernel32; # HACK: Always pre-loaded?
              } elseif {[info exists ::tcl_platform(os)] && \
                  $::tcl_platform(os) eq "Darwin"} then {
                set fileName [compileCanaryDyLib error]

                if {[string length $fileName] > 0} then {
                  set delete($fileName) 1; # finally delete
                  lappend fileNames $fileName
                }
              } else {
                lappend fileNames libdl.so
                lappend fileNames libdl.so.2
              }
            }
          }

          foreach fileName $fileNames {
            if {[catch {
              set error null

              object invoke -flags +NonPublic \
                  CodeBrix.Platform.TclTk._Components.Private.NativeOps \
                  TestLoadLibrary $fileName error
            } code] == 0 && $code eq "Ok"} then {
              return true
            }
          }
        } finally {
          foreach fileName [array names delete] {
            if {[file exists $fileName]} then {
              catch {file delete $fileName}
            }

            set directory [file dirname $fileName]

            if {[file exists $directory] || \
                [file isdirectory $directory]} then {
              catch {file rmdir $directory}
            }
          }
        }
      }

      return false
    }

    proc checkForDynamicLoading { channel } {
      # <help>
      # This procedure probes whether dynamic loading of native libraries works on
      # the current platform and registers the test constraint dynamic when it
      # does.  It gates tests that load native code.
      #
      # How it works: if the no(checkForDynamicLoading) global or its matching
      # environment variable is set, the probe is skipped entirely (printing
      # disabled) -- a deliberate escape hatch because on some macOS releases
      # loading or unloading a native library has been observed to cause kernel
      # hangs later in the run.  Otherwise, on Windows dynamic loading is assumed to
      # work; on other platforms it defers to [testForDynamicLoading] (capturing any
      # error message).  A positive result adds the constraint and prints yes; a
      # negative result prints no and, if an error message was captured, logs it.
      #
      # Arguments:
      #   channel -- The channel used for progress and diagnostic output.
      #
      # Results:
      #   Returns the empty result; its effect is the possible registration of the
      #   dynamic constraint.
      # </help>

      tputs $channel "---- checking for dynamic loading... "

      #
      # NOTE: As far as we know, dynamic loading always works on Windows.
      #       On some (Unix) systems, dlopen does not work (e.g. because
      #       Mono is statically linked, etc).
      #
      if {[info exists ::no(checkForDynamicLoading)] || \
          [info exists ::env(checkForDynamicLoading)]} then {
        #
        # NOTE: On (some releases of) macOS, it seems that loading and/or
        #       unloading a dynamic native library can cause kernel hangs
        #       (deadlocks?) later in the testing process.
        #
        tputs $channel disabled\n
      } elseif {[isWindows] || [testForDynamicLoading "" error]} then {
        #
        # NOTE: Yes, it appears that it is available.
        #
        addConstraint dynamic

        tputs $channel yes\n
      } else {
        tputs $channel no\n

        if {[info exists error] && [string length $error] > 0} then {
          tputs $channel [appendArgs \
              "---- error while testing dynamic loading: " $error \n]
        }
      }
    }

    proc checkForWindowsForms { channel } {
      # <help>
      # This procedure probes whether the Windows Forms assembly is available (and
      # usable) and registers the test constraint winForms when it is.  It gates
      # tests that create GUI windows or controls.
      #
      # How it works: on Windows it proceeds directly; on Unix-like systems it first
      # requires the DISPLAY environment variable to be set as a basic indication
      # that an X server is reachable -- this guard is important because Mono has
      # been observed to crash after repeated failed attempts to create a form when
      # no X server is available.  When the platform precondition holds it attempts
      # to resolve the System.Windows.Forms assembly; success adds the constraint
      # and prints yes, while any failure (or a missing DISPLAY off Windows) prints
      # no.
      #
      # Arguments:
      #   channel -- The channel used for progress output.
      #
      # Results:
      #   Returns the empty result; its effect is the possible registration of the
      #   winForms constraint.
      # </help>

      tputs $channel "---- checking for Windows Forms... "

      #
      # HACK: When running on Windows, we do not need to do any other
      #       special checks here; however, on Unix (and Mac OS X?),
      #       we should check for the DISPLAY environment variable as
      #       some basic indication that the X server is available.
      #       This appears to be very necessary on Mono because it
      #       crashes after repeated failed attempts to create a
      #       Windows Form when the X server is unavailable (e.g. on
      #       OpenBSD).
      #
      if {[isWindows] || [info exists ::env(DISPLAY)]} then {
        #
        # NOTE: Is the Windows Forms assembly available?
        #
        if {[catch {
          object resolve System.Windows.Forms
        } assembly] == 0} then {
          #
          # NOTE: Yes, it appears that it is available.
          #
          addConstraint winForms

          tputs $channel yes\n

          #
          # NOTE: We are done here, return now.
          #
          return
        }
      }

      tputs $channel no\n
    }

    proc checkForWindowsTerminal { channel } {
      # <help>
      # This procedure probes whether the process is running inside the Windows
      # Terminal (Cascadia) console host and registers the test constraint
      # windowsTerminal when it is.  It gates tests whose console behavior or
      # appearance differs under Windows Terminal.
      #
      # How it works: rather than reading the associated environment variable
      # directly, it invokes the non-public WindowOps.IsWindowsTerminal helper so
      # that the determination matches the core library's own logic.  A successful,
      # strictly true result adds the constraint and prints yes; otherwise no is
      # printed.
      #
      # Arguments:
      #   channel -- The channel used for progress output.
      #
      # Results:
      #   Returns the empty result; its effect is the possible registration of the
      #   windowsTerminal constraint.
      # </help>

      tputs $channel "---- checking for Windows Terminal (Cascadia)... "

      if {[catch {
        #
        # HACK: Rather than simply checking the associated environment
        #       variable directly, make sure the core library actually
        #       knows how to deal with Windows Terminal.
        #
        object invoke -flags +NonPublic \
            CodeBrix.Platform.TclTk._Components.Private.WindowOps IsWindowsTerminal
      } windowsTerminal] == 0 && \
          [string is true -strict $windowsTerminal]} then {
        #
        # NOTE: Yes, it appears that it is available.
        #
        addConstraint windowsTerminal

        tputs $channel yes\n

        #
        # NOTE: We are done here, return now.
        #
        return
      }

      tputs $channel no\n
    }

    proc checkForWoW64 { channel } {
      # <help>
      # This procedure probes whether the process is running under WoW64 (a 32-bit
      # process on 64-bit Windows) and registers the test constraint wow64 when it
      # is.  It gates tests sensitive to the WoW64 file-system and registry
      # redirection layer.
      #
      # How it works: it reads tcltk_platform(wow64) and, when that value exists, is
      # a strict boolean, and is true, adds the constraint and prints yes; any other
      # case prints no.
      #
      # Arguments:
      #   channel -- The channel used for progress output.
      #
      # Results:
      #   Returns the empty result; its effect is the possible registration of the
      #   wow64 constraint.
      # </help>

      tputs $channel "---- checking for WoW64... "

      if {[info exists ::tcltk_platform(wow64)] && \
          [string is boolean -strict $::tcltk_platform(wow64)] && \
          $::tcltk_platform(wow64)} then {
        #
        # NOTE: Yes, we are running in a WoW64 process.
        #
        addConstraint wow64

        tputs $channel yes\n
      } else {
        tputs $channel no\n
      }
    }

    proc checkForStaThread { channel } {
      # <help>
      # This procedure probes whether the current managed thread is running in a
      # single-threaded apartment (STA) and registers the test constraint staThread
      # when it is.  It gates tests that require STA semantics, such as those
      # involving certain COM or UI components.
      #
      # How it works: it invokes GetApartmentState on Thread.CurrentThread and, when
      # the call succeeds and returns exactly STA, adds the constraint and prints
      # yes; any other apartment state or a failed call prints no.
      #
      # Arguments:
      #   channel -- The channel used for progress output.
      #
      # Results:
      #   Returns the empty result; its effect is the possible registration of the
      #   staThread constraint.
      # </help>

      tputs $channel "---- checking for STA thread... "

      if {[catch {
        object invoke System.Threading.Thread.CurrentThread GetApartmentState
      } apartmentState] == 0 && $apartmentState eq "STA"} then {
        #
        # NOTE: Yes, we are running in an STA thread.
        #
        addConstraint staThread

        tputs $channel yes\n
      } else {
        tputs $channel no\n
      }
    }

    proc checkForWindowsPresentationFoundation { channel } {
      # <help>
      # This procedure probes for the availability of the Windows Presentation
      # Foundation (WPF) and, if found, registers the "wpf" test constraint so
      # that tests requiring WPF can be skipped on systems where it is missing.
      # It works by attempting to resolve the PresentationFramework assembly via
      # the [object resolve] sub-command, wrapped in a [catch].  If resolution
      # succeeds the assembly is present and the constraint is added; otherwise
      # the constraint is omitted.  Progress is written to the supplied channel
      # in the standard "checking... yes/no" form.  This is mainly relevant on
      # the .NET Framework on Windows, where WPF assemblies may or may not be
      # installed.
      #
      # Arguments:
      #   channel -- The output channel (e.g. stdout or a log channel) to which
      #              the human-readable progress messages are written.
      #
      # Results:
      #   No meaningful return value.  The side effect is registration of the
      #   "wpf" constraint when WPF is available.
      # </help>

      tputs $channel "---- checking for Windows Presentation Foundation... "

      #
      # NOTE: Is the Windows Presentation Foundation available?
      #
      if {[catch {
        object resolve PresentationFramework
      } assembly] == 0} then {
        #
        # NOTE: Yes, it appears that it is available.
        #
        addConstraint wpf

        tputs $channel yes\n
      } else {
        tputs $channel no\n
      }
    }

    proc checkForDatabase { channel type string } {
      # <help>
      # This procedure probes whether the test suite can open a connection to a
      # local database and, if so, registers the "database" test constraint plus
      # a type-specific "database.TYPE" constraint (where TYPE is the lower-cased
      # database type).  It exists so database-dependent tests can be skipped
      # when no usable local database is present.  How it works: it calls [sql
      # open] with the given type and connection string inside a [catch]; on
      # success the constraints are added and the connection is immediately
      # closed via [sql close] to avoid leaking it.  Tricky detail: on Mono the
      # entire check is skipped (reported as "disabled") because the database
      # connectivity layer there can hang instead of timing out; this is gated
      # on [isTestMono] unless the user has disabled the Mono-specific test
      # suite hacks.
      #
      # Arguments:
      #   channel -- The output channel for human-readable progress messages.
      #   type    -- The database provider/type passed to [sql open] (for
      #              example, a provider name); it is also lower-cased to form
      #              the "database.TYPE" constraint name.  May be empty, in which
      #              case only the generic "database" constraint is added.
      #   string  -- The connection string passed to [sql open].
      #
      # Results:
      #   No meaningful return value.  Side effect is registration of the
      #   "database" and "database.TYPE" constraints when a connection succeeds.
      # </help>

      tputs $channel "---- checking for database... "

      #
      # HACK: Disable database connectivity testing on Mono because
      #       it fails to timeout (unless special test suite hacks
      #       for Mono have been disabled by the user).
      #
      if {![isTestMono]} then {
        #
        # NOTE: Can we access the local database?
        #
        if {[catch {sql open -type $type $string} connection] == 0} then {
          #
          # NOTE: Yes, it appears that we can connect to the local database.
          #
          addConstraint database

          #
          # NOTE: Also record the test database connection type used as a
          #       test constraint.
          #
          if {[string length $type] > 0} then {
            addConstraint [appendArgs database. [string tolower $type]]
          }

          #
          # NOTE: Cleanup the database connection we just opened.
          #
          sql close $connection

          tputs $channel yes\n
        } else {
          tputs $channel no\n
        }
      } else {
        tputs $channel disabled\n
      }
    }

    proc checkForLibraryAssemblyName { channel } {
      # <help>
      # This procedure determines the simple name of the core library assembly
      # and registers it as a "libraryAssemblyName.NAME" test constraint.
      # Normally the name is "TclTk", but custom or rebranded builds may use a
      # different assembly name, so tests that depend on the assembly name can
      # gate on the appropriate constraint.  It works by calling
      # [getTestAssemblyName] inside a [catch]; on success it appends the
      # returned name to the "libraryAssemblyName." prefix and registers that
      # constraint, also echoing the name in the progress message.  On failure
      # no constraint is added and "no" is reported.
      #
      # Arguments:
      #   channel -- The output channel for human-readable progress messages.
      #
      # Results:
      #   No meaningful return value.  Side effect is registration of the
      #   "libraryAssemblyName.NAME" constraint when the name is determined.
      # </help>

      tputs $channel "---- checking for library assembly name... "

      #
      # NOTE: What is the name of the core library assembly?  Normally,
      #       this will be "TclTk"; however, it could be something else.
      #
      if {[catch {getTestAssemblyName} assemblyName] == 0} then {
        addConstraint [appendArgs libraryAssemblyName. $assemblyName]

        tputs $channel [appendArgs "yes (" $assemblyName ")\n"]
      } else {
        tputs $channel no\n
      }
    }

    proc checkForAssembly { channel name } {
      # <help>
      # This procedure is a generic probe for whether a named managed assembly
      # can be loaded, registering a test constraint named exactly after the
      # assembly when it is available.  It exists so callers can detect optional
      # dependencies (by display name or simple name) without writing the
      # boilerplate each time.  It works by calling [object resolve] on the
      # supplied name inside a [catch]; if resolution succeeds the assembly is
      # present and a constraint with the same name is added.  Note that the
      # constraint name is the raw assembly name passed in (no prefix is
      # applied), so callers should choose names that make sense as constraint
      # identifiers.
      #
      # Arguments:
      #   channel -- The output channel for human-readable progress messages.
      #   name    -- The assembly name to resolve; this exact string is also
      #              used as the constraint name registered on success.
      #
      # Results:
      #   No meaningful return value.  Side effect is registration of a
      #   constraint named after the assembly when it can be resolved.
      # </help>

      tputs $channel [appendArgs "---- checking for assembly \"" $name \
          "\"... "]

      #
      # NOTE: Can the assembly be loaded?
      #
      if {[catch {object resolve $name} assembly] == 0} then {
        #
        # NOTE: Yes, it appears that it is available.
        #
        addConstraint $name

        tputs $channel yes\n
      } else {
        tputs $channel no\n
      }
    }

    proc checkForObjectMember { channel object member {constraint ""} } {
      # <help>
      # This procedure probes whether a managed type or object exposes a member
      # (method, property, field, etc.) matching a pattern, and registers a test
      # constraint when at least one matching member exists.  It is used to gate
      # tests on the presence of a specific API member that may differ across
      # framework or library versions.  It works by calling [object members]
      # with the "+NonPublic" flag and the supplied "-pattern", inside a [catch],
      # then checking that the resulting member list is non-empty.  The
      # registered constraint name depends on the optional argument: if a
      # "constraint" suffix is supplied, the constraint is "member_SUFFIX";
      # otherwise it is the object name, a dot, and the member pattern with any
      # leading/trailing glob characters (asterisk and question mark) trimmed
      # off.
      #
      # Arguments:
      #   channel    -- The output channel for human-readable progress messages.
      #   object     -- The type name or object handle whose members are
      #                 inspected; it also forms part of the default constraint
      #                 name.
      #   member     -- The member name or glob pattern passed to [object
      #                 members] via "-pattern".
      #   constraint -- Optional.  When non-empty, selects the alternate
      #                 constraint name "member_" followed by this value; when
      #                 empty (the default) the object-and-member based name is
      #                 used instead.
      #
      # Results:
      #   No meaningful return value.  Side effect is registration of the chosen
      #   constraint when a matching member is found.
      # </help>

      tputs $channel [appendArgs "---- checking for object member \"" \
          $object . $member "\"... "]

      if {[catch {
        object members -flags +NonPublic -pattern $member $object
      } members] == 0 && [llength $members] > 0} then {
        #
        # NOTE: Yes, it appears that it is available.
        #
        if {[string length $constraint] > 0} then {
          addConstraint [appendArgs member_ $constraint]
        } else {
          addConstraint [appendArgs $object . [string trim $member *?]]
        }

        tputs $channel yes\n
      } else {
        tputs $channel no\n
      }
    }

    proc checkForExcelUsable { channel {milliseconds 5000} } {
      # <help>
      # This procedure performs an end-to-end test of whether a usable instance
      # of Microsoft Excel can actually be automated on this machine, and
      # registers one of several mutually exclusive test constraints describing
      # the outcome: "excel.usable" when Excel can be driven successfully,
      # "excel.timeout" when starting Excel takes too long, "excel.trial" when
      # the installed Excel appears to be an expired trial edition, or
      # "excel.unusable" when it is present but otherwise broken.  It exists
      # because merely having the Excel interop assembly does not guarantee that
      # Excel can be launched and controlled, so tests that automate Excel need
      # a real liveness probe.
      #
      # Why it is elaborate: launching Excel can hang, leak processes, or pop up
      # modal dialogs, so the actual automation is run inside an isolated child
      # interpreter (created with "interp create -isolated") to keep the primary
      # interpreter and AppDomain clean.  A watchdog and an [interp timeout] of
      # twice the milliseconds value are configured so a hung Excel is forcibly
      # interrupted rather than blocking forever.  The child loads the interop
      # assembly, creates an ApplicationClass, captures the Excel process ID via
      # [info hwnd] (relayed to the parent through a "pset" alias bound to the
      # parent's [set]), hides the application, suppresses alerts, adds and
      # saves a workbook to a temporary .xls file, then quits Excel.
      #
      # How outcomes are classified: if the child script completes without error
      # the instance is usable.  Otherwise the error text is matched against
      # patterns -- "runaway script", thread-interrupted, or HRESULT 0x80080005
      # indicate a timeout; a set of HRESULT and "application has expired"
      # patterns indicate a trial edition; anything else is treated as broken.
      # A try/finally block guarantees cleanup: the isolated interpreter is
      # deleted, the Excel process is force-killed if still listed by
      # [getProcesses excel], and the temporary spreadsheet and placeholder
      # files are removed.
      #
      # Preconditions: the check only runs on Windows ([isWindows]); the
      # "Microsoft.Office.Interop.Excel" constraint must already be present; and
      # the build must support isolated interpreters, native code, and Windows
      # (the "compile.ISOLATED_INTERPRETERS", "compile.NATIVE", and
      # "compile.WINDOWS" constraints).  When any precondition is unmet the
      # check reports an "unknown" status and adds no constraint.
      #
      # Arguments:
      #   channel      -- The output channel for human-readable progress and
      #                   outcome messages.
      #   milliseconds -- Optional timing budget (default 5000).  It is used as
      #                   the post-startup settling delay and, doubled, as the
      #                   child interpreter's overall script timeout.
      #
      # Results:
      #   No meaningful return value (the procedure may [return] early after
      #   classifying a timeout or trial edition).  Side effect is registration
      #   of exactly one of the excel.usable, excel.timeout, excel.trial, or
      #   excel.unusable constraints, or none when a precondition is unmet.
      # </help>

      tputs $channel "---- checking for usable instance of Excel... "

      #
      # NOTE: As of this writing, this check is only supported on Windows.
      #
      if {[isWindows]} then {
        #
        # NOTE: This constraint check must run after the interop assembly for
        #       Excel has been detected, because this check makes use of it.
        #
        if {[haveConstraint Microsoft.Office.Interop.Excel]} then {
          #
          # NOTE: This constraint check requires the (optional) interpreter
          #       isolation feature of TclTk in order to keep the primary
          #       interpreter and AppDomain tidy.  It also requires access
          #       to native Windows support in order to use the [info hwnd]
          #       sub-command.
          #
          if {[haveConstraint compile.ISOLATED_INTERPRETERS] && \
              [haveConstraint compile.NATIVE] && \
              [haveConstraint compile.WINDOWS]} then {
            #
            # NOTE: Allocate a temporary file name that can be used to save
            #       the Excel spreadsheet.  This name will be provided to a
            #       child interpreter for its use -AND- cleaned up by this
            #       interpreter before exiting this procedure.
            #
            set tempName(1) [getTemporaryFileName]

            #
            # NOTE: Use a try/finally block to cleanup temporary files.
            #
            try {
              if {[catch {
                #
                # NOTE: In an attempt to limit the assemblies loaded into the
                #       primary AppDomain, create an isolated interpreter.
                #
                set interp [interp create -isolated]

                #
                # NOTE: Give the newly created (isolated) interpreter a means
                #       to set variables in the parent (this) interpreter.
                #
                interp alias $interp pset {} set; # parent set

                #
                # NOTE: Give the newly created (isolated) interpreter a base
                #       name for a temporary file and our milliseconds value.
                #
                interp set $interp milliseconds $milliseconds
                interp set $interp tempName(1) $tempName(1)

                #
                # NOTE: Setup reasonable script timeout for the newly created
                #       (isolated) interpreter so that Excel detection cannot
                #       simply hang forever.
                #
                catch {interp watchdog $interp false}; # NOTE: Superfluous?
                interp timeout $interp [expr {$milliseconds * 2}]
                interp watchdog $interp true +Interrupt

                #
                # NOTE: Evaluate all the Excel interop assembly related code
                #       in the other AppDomain.
                #
                interp eval $interp {
                  #
                  # NOTE: First, attempt to load the Excel interop assembly.
                  #       If this fails, we cannot continue and Excel is not
                  #       considered usable.
                  #
                  set assembly [object load -import -declare \
                      Microsoft.Office.Interop.Excel]

                  #
                  # NOTE: Next, attempt to run the Excel application using
                  #       its automation object model.  If this fails, we
                  #       cannot continue and Excel is not considered usable.
                  #
                  set application [object create -alias \
                      Microsoft.Office.Interop.Excel.ApplicationClass]; # run

                  #
                  # NOTE: Next, attempt to extract the process ID associated
                  #       with the Excel application window.  This is used to
                  #       help make sure the running Excel instance is closed
                  #       after our testing is complete.  Generally, this will
                  #       not fail because we know the [info hwnd] sub-command
                  #       should be available, due to define constant checks.
                  #
                  pset pid [getDictionaryValue \
                      [info hwnd [$application Hwnd]] processId]

                  #
                  # NOTE: Next, attempt to make sure that the Excel instance
                  #       is not visible and will not display alerts/prompts.
                  #       If this fails, Excel is not considered usable.
                  #
                  $application Visible false
                  $application DisplayAlerts false

                  #
                  # NOTE: Wait for a bit to make sure that the Excel process
                  #       is actually running (?).
                  #
                  after $milliseconds

                  #
                  # NOTE: Next, create a value of an enumerated type exposed
                  #       by the Excel automation object model so that we can
                  #       add a new workbook.  Generally, this does not fail.
                  #       If this fails, Excel is not considered usable.
                  #
                  set enumValue [object invoke -create \
                      Enum Parse XlWBATemplate xlWBATWorksheet]

                  #
                  # NOTE: Next, attempt to add a new workbook.  If this fails,
                  #       Excel is not considered usable.
                  #
                  set workbook [object invoke -alias \
                      $application.Workbooks Add $enumValue]

                  #
                  # NOTE: Setup a temporary file name that can be used to save
                  #       the Excel spreadsheet.
                  #
                  pset fileName [set fileName [file nativename [appendArgs \
                      $tempName(1) .xls]]]

                  #
                  # NOTE: Next, attempt to save a new workbook.  If this fails,
                  #       Excel is not considered usable.
                  #
                  $workbook SaveAs $fileName

                  #
                  # NOTE: Next, attempt to close Excel.  If this fails, Excel
                  #       is not considered usable.
                  #
                  $application Quit; # close

                  #
                  # NOTE: Finally, cleanup our local state just to be tidy.
                  #
                  unset workbook enumValue application assembly; # dispose
                }
              } result] == 0} then {
                #
                # NOTE: It appears the Excel instance is usable.
                #
                addConstraint excel.usable

                #
                # NOTE: Show that a usable Excel instance was found.
                #
                tputs $channel yes\n
              } else {
                #
                # NOTE: Check for runaway script error message.  Matching
                #       this would mean the watchdog thread canceled the
                #       detection script (i.e. after the blocking creation
                #       call).
                #
                if {[string match "runaway script *" $result] || \
                    [string match "*ThreadInterruptedException*" $result] || \
                    [string match "* 0x80080005*" $result]} then {
                  #
                  # NOTE: It appears that Excel is taking too long to
                  #       startup.
                  #
                  addConstraint excel.timeout

                  #
                  # NOTE: Show that Excel took too long starting up.
                  #
                  tputs $channel "no, timeout\n"

                  #
                  # NOTE: We are done here, return now.
                  #
                  return
                }

                #
                # NOTE: This is the list of error message patterns that may
                #       indicate a trial version of Excel is being used.
                #
                set patterns [list \
                    "* 0x80010001*" "* 0x800AC472*" "* 0x800A03EC*" \
                    "* application has expired.*"]

                #
                # NOTE: Check each error message pattern.  Upon finding any
                #       match, mark Excel as unusable due to being a trial
                #       edition and then stop.
                #
                foreach pattern $patterns {
                  #
                  # TODO: For now, just use [string match] here; eventually,
                  #       regular expressions may be needed.
                  #
                  if {[string match $pattern $result]} then {
                    #
                    # NOTE: It appears that Excel is a trial edition.
                    #
                    addConstraint excel.trial

                    #
                    # NOTE: Show that the Excel trial edition was found.
                    #
                    tputs $channel "no, trial\n"

                    #
                    # NOTE: We are done here, return now.
                    #
                    return
                  }
                }

                #
                # NOTE: It appears the Excel instance is not usable.
                #
                addConstraint excel.unusable

                #
                # NOTE: Show that a unusable Excel instance was found.
                #
                tputs $channel "no, broken\n"
              }
            } finally {
              #
              # NOTE: Make sure the isolated interpreter is deleted if it was
              #       actually created.
              #
              if {[info exists interp] && [interp exists $interp]} then {
                catch {interp delete $interp}
              }

              #
              # NOTE: Make sure the Excel process is (forcibly) closed if it
              #       is still running at this point.
              #
              if {[info exists pid] && $pid in [getProcesses excel]} then {
                catch {kill -force $pid}
              }

              #
              # NOTE: Make sure the temporary spreadsheet file is deleted if
              #       it was actually created.
              #
              if {[info exists fileName] && [file exists $fileName]} then {
                catch {file delete $fileName}
              }

              #
              # NOTE: Make sure the dummy temporary files are cleaned up.
              #
              if {[array exists tempName]} then {
                foreach tempFileName [array values tempName] {
                  if {[file exists $tempFileName]} then {
                    catch {file delete $tempFileName}
                  }
                }
              }
            }
          } else {
            tputs $channel "unknown, missing optional feature\n"
          }
        } else {
          tputs $channel "unknown, no Excel interop assembly\n"
        }
      } else {
        tputs $channel "unknown, not running on Windows\n"
      }
    }

    proc checkForTclInstalls { channel } {
      # <help>
      # This procedure probes for a dynamically loadable native Tcl library
      # suitable for this architecture and, when one is found, registers the
      # "tclLibrary" test constraint plus a version-specific "tclLibraryNN"
      # constraint (where NN is the dotless version, e.g. 86 for 8.6).  It exists
      # so that tests exercising the native Tcl integration layer can be skipped
      # when no compatible Tcl shared library is present.  How it works: it calls
      # [tcl select -architecture] inside a [catch] to discover a candidate
      # library, locates the "version" field in the returned list (treated like
      # a key/value pairing), and validates it against the dotted MAJOR.MINOR
      # pattern.  It then walks the known Tcl versions (from [getKnownTclVersions],
      # reversed so the highest matches first) and adds the single best-matching
      # version constraint, stopping after the first match.  Tricky detail: only
      # one version-specific constraint is registered even if several known
      # versions are at or below the detected version.
      #
      # Arguments:
      #   channel -- The output channel for human-readable progress messages.
      #
      # Results:
      #   No meaningful return value (returns early once a library is detected).
      #   Side effect is registration of "tclLibrary" and one "tclLibraryNN"
      #   constraint when a loadable Tcl library is found.
      # </help>

      tputs $channel "---- checking for Tcl installs... "

      #
      # NOTE: Check for dynamically loadable Tcl libraries (for this
      #       architecture only).
      #
      if {[catch {tcl select -architecture} tcl] == 0} then {
        #
        # NOTE: Found one?  Ok, attempt to grab the index of the version
        #       field from the list.
        #
        set index [lsearch -exact $tcl version]

        if {$index != -1} then {
          #
          # NOTE: The very next list index contains the value (i.e. like
          #       a Tcl 8.5+ dict).
          #
          set dotVersion [lindex $tcl [incr index]]

          #
          # NOTE: Do we know the version?
          #
          if {[string length $dotVersion] > 0 && \
              [regexp -- {^\d+\.\d+$} $dotVersion]} then {
            #
            # NOTE: Yes, some version of Tcl is available.
            #
            addConstraint tclLibrary

            #
            # NOTE: Is the version 8.x or higher?
            #
            foreach tclVersion [lreverse [getKnownTclVersions]] {
              if {$dotVersion >= [getDottedVersion $tclVersion]} then {
                addConstraint [appendArgs \
                    tclLibrary [getDotlessVersion $tclVersion]]

                #
                # NOTE: For now, there can be only one Tcl library match;
                #       therefore, we are done.
                #
                break
              }
            }

            tputs $channel [appendArgs $dotVersion \n]

            #
            # NOTE: We are done here, return now.
            #
            return
          }
        }
      }

      tputs $channel no\n
    }

    proc checkForTclReady { channel } {
      # <help>
      # This procedure probes whether a native Tcl library is currently loaded
      # and ready for use (as opposed to merely loadable), and registers several
      # related test constraints.  When Tcl reports ready it adds "tclReady" and
      # the umbrella "tclReadyOrLibrary" constraint; if it can determine the
      # loaded Tcl version it also adds the version-specific "tclReadyNN" and,
      # provided the matching "tclLibraryNN" constraint already exists, a
      # version-specific "tclReadyOrLibraryNN" constraint.  These let tests gate
      # on "Tcl is actually running now" versus the weaker "Tcl is either running
      # or at least available" condition.
      #
      # How it works: it calls [tcl ready] inside a [catch] and checks for a true
      # result.  If ready, it evaluates "info tclversion" in the primary native
      # Tcl interpreter (via [tcl eval] on [tcl primary]) to learn the version,
      # validates it against the dotted MAJOR.MINOR pattern, and walks the known
      # versions (reversed, highest first) to add the best single combined
      # constraint.  Tricky detail: even when Tcl is NOT ready -- and even when
      # it is ready but the version cannot be determined -- the procedure still
      # walks the known versions to register the appropriate
      # "tclReadyOrLibraryNN" constraint based purely on the existing
      # "tclLibraryNN" constraints, so the "ready or available" family is kept
      # accurate regardless of readiness.  Only one version match is registered.
      #
      # Arguments:
      #   channel -- The output channel for human-readable progress messages.
      #
      # Results:
      #   No meaningful return value.  Side effect is registration of the
      #   "tclReady"/"tclReadyNN" and "tclReadyOrLibrary"/"tclReadyOrLibraryNN"
      #   constraints as described above.
      # </help>

      tputs $channel "---- checking for Tcl readiness... "

      if {[catch {tcl ready} ready] == 0 && \
          [string is true -strict $ready]} then {
        #
        # NOTE: Yes, native Tcl is loaded and ready.
        #
        addConstraint tclReady

        #
        # NOTE: Yes, native Tcl is ready -OR- available.
        #
        addConstraint tclReadyOrLibrary

        #
        # NOTE: Ok, attempt to determine the loaded Tcl version.
        #
        if {[catch {
          tcl eval [tcl primary] {info tclversion}
        } dotVersion] == 0 && [regexp -- {^\d+\.\d+$} $dotVersion]} then {
          addConstraint [appendArgs \
              tclReady [getDotlessVersion $dotVersion]]

          #
          # NOTE: The Tcl library is ready; however, we need to add the
          #       appropriate test constraint to indicate that a specific
          #       version of Tcl is "either ready or available".
          #
          foreach tclVersion [lreverse [getKnownTclVersions]] {
            set version [getDotlessVersion $tclVersion]

            if {[haveConstraint [appendArgs tclLibrary $version]] && \
                $dotVersion >= [getDottedVersion $tclVersion]} then {
              addConstraint [appendArgs tclReadyOrLibrary $version]

              #
              # NOTE: For now, there can be only one Tcl library match;
              #       therefore, we are done.
              #
              break
            }
          }

          tputs $channel [appendArgs "yes (" $dotVersion ")\n"]
        } else {
          #
          # NOTE: The Tcl library is ready; however, we have no idea what
          #       version it actually is; therefore, skip adding the test
          #       constraint to indicate that a specific version of Tcl
          #       is "either ready or available".
          #
          tputs $channel yes\n
        }
      } else {
        #
        # NOTE: The Tcl library is not ready; however, we still need to add
        #       the appropriate test constraint to indicate that a specific
        #       version of Tcl is "either ready or available".
        #
        foreach tclVersion [lreverse [getKnownTclVersions]] {
          set version [getDotlessVersion $tclVersion]

          if {[haveConstraint [appendArgs tclLibrary $version]]} then {
            addConstraint [appendArgs tclReadyOrLibrary $version]

            #
            # NOTE: For now, there can be only one Tcl library match;
            #       therefore, we are done.
            #
            break
          }
        }

        tputs $channel no\n
      }
    }

    proc checkForTclSelect { channel } {
      # <help>
      # This procedure probes whether a native Tcl library can be selected (and
      # is therefore "probably loadable") for this architecture, registering the
      # "tclSelect" test constraint and, when the version is known, a
      # version-specific "tclSelectNN" constraint (NN being the dotless version).
      # It differs from [checkForTclInstalls] mainly in the constraint family it
      # registers and in recording only the single selected library's version.
      # How it works: it calls [tcl select -architecture] inside a [catch]; on
      # success it adds "tclSelect", then extracts the "version" value from the
      # selection result via [getDictionaryValue], validates it against the
      # dotted MAJOR.MINOR pattern, and (if valid) appends the dotless version --
      # produced by mapping the dot away with [string map] -- to form the
      # version-specific constraint.  If the version cannot be determined the
      # generic constraint is still added.
      #
      # Arguments:
      #   channel -- The output channel for human-readable progress messages.
      #
      # Results:
      #   No meaningful return value.  Side effect is registration of
      #   "tclSelect" and, when known, one "tclSelectNN" constraint.
      # </help>

      tputs $channel "---- checking for Tcl library selection... "

      if {[catch {tcl select -architecture} select] == 0} then {
        #
        # NOTE: Yes, native Tcl is "probably loadable".
        #
        addConstraint tclSelect

        #
        # NOTE: Ok, attempt to determine the selected Tcl version.
        #
        if {[catch {
          getDictionaryValue $select version
        } version] == 0 && [regexp -- {^\d+\.\d+$} $version]} then {
          addConstraint [appendArgs \
              tclSelect [string map [list . ""] $version]]

          tputs $channel [appendArgs "yes (" $select ")\n"]
        } else {
          #
          # NOTE: The Tcl library is "probably loadable"; however, we have
          #       no idea what version it actually is.
          #
          tputs $channel yes\n
        }
      } else {
        tputs $channel no\n
      }
    }

    proc checkForTclShell { channel } {
      # <help>
      # This procedure probes for the presence of a working native Tcl shell
      # (tclsh) executable and registers the "tclShell" test constraint along
      # with a version-specific "tclShellNN" constraint (NN being the dotless
      # version) when one is found.  It is used to gate tests that shell out to a
      # real Tcl interpreter.  How it works: it first confirms shelling out is
      # permitted via [canExecTclShell] and that neither the
      # ::no(getTclVersionForTclShell) nor the
      # ::env(getTclVersionForTclShell) opt-out has been set, then calls
      # [getTclVersionForTclShell] (with the configured shell verbosity) inside a
      # [catch] to actually run the shell and obtain its version.  Tricky detail:
      # because the version is obtained by executing the shell, a failed [exec]
      # surfaces as the literal value "error" or a message beginning with
      # "error: "; both are explicitly rejected so that an execution failure does
      # not masquerade as a real version.
      #
      # Arguments:
      #   channel -- The output channel for human-readable progress messages.
      #
      # Results:
      #   No meaningful return value.  Side effect is registration of "tclShell"
      #   and one "tclShellNN" constraint when a usable Tcl shell is detected.
      # </help>

      #
      # HACK: If this returns "error" that normally indicates an error was
      #       caught during [exec] (i.e. the native Tcl shell could not be
      #       executed).
      #
      set prefix "---- checking for Tcl shell version... "

      if {[canExecTclShell] && \
          ![info exists ::no(getTclVersionForTclShell)] && \
          ![info exists ::env(getTclVersionForTclShell)] && [catch {
        getTclVersionForTclShell "" [getTclShellVerbosity]
      } version] == 0 && $version ne "error" && \
          ![string match "error: *" $version]} then {
        #
        # NOTE: Yes, a native Tcl shell appears to be available.
        #
        addConstraint tclShell

        #
        # NOTE: Now, add the version specific test constraint.
        #
        addConstraint [appendArgs \
            tclShell [string map [list . ""] $version]]

        tputs $channel [appendArgs $prefix "yes (" $version ")\n"]
      } else {
        tputs $channel [appendArgs $prefix no\n]
      }
    }

    proc checkForTkPackage { channel } {
      # <help>
      # This procedure probes whether the Tk package is available to the native
      # Tcl shell and, if so, registers the "tkPackage" test constraint.  It is
      # used to gate tests that need Tk (the graphical toolkit) by way of a real
      # tclsh.  How it works: after confirming shelling out is permitted via
      # [canExecTclShell] and that neither the ::no(getTkVersionForTclShell) nor
      # the ::env(getTkVersionForTclShell) opt-out is set, it calls
      # [getTkVersionForTclShell] (with the configured shell verbosity) inside a
      # [catch].  Tricky detail: the actual Tk version is not recorded -- only
      # whether the call succeeded -- so an [exec] failure, surfaced as the
      # literal "error" or a message beginning with "error: ", is detected and
      # treated as Tk being unavailable.  Unlike the Tcl-shell check, no
      # version-specific constraint is added here.
      #
      # Arguments:
      #   channel -- The output channel for human-readable progress messages.
      #
      # Results:
      #   No meaningful return value.  Side effect is registration of the
      #   "tkPackage" constraint when Tk is available.
      # </help>

      #
      # HACK: We do not care about the Tk version returned from this
      #       procedure, we only care if it returns "error" because that
      #       would indicate an error was caught during [exec] (i.e. the
      #       native Tcl shell could not be executed).
      #
      set prefix "---- checking for Tk package version... "

      if {[canExecTclShell] && \
          ![info exists ::no(getTkVersionForTclShell)] && \
          ![info exists ::env(getTkVersionForTclShell)] && [catch {
        getTkVersionForTclShell "" [getTclShellVerbosity]
      } version] == 0 && $version ne "error" && \
          ![string match "error: *" $version]} then {
        #
        # NOTE: Yes, a native Tk package appears to be available.
        #
        addConstraint tkPackage

        tputs $channel [appendArgs $prefix "yes (" $version ")\n"]
      } else {
        tputs $channel [appendArgs $prefix no\n]
      }
    }

    proc checkForPowerShell { channel } {
      # <help>
      # This procedure probes for the availability of Windows PowerShell by
      # attempting to load its managed automation assembly, and registers the
      # "powerShell" test constraint when present.  It is used to gate tests that
      # host or invoke PowerShell.  How it works: it calls [object resolve] on
      # the System.Management.Automation assembly inside a [catch]; if resolution
      # succeeds the assembly is available and the constraint is added.
      #
      # Arguments:
      #   channel -- The output channel for human-readable progress messages.
      #
      # Results:
      #   No meaningful return value.  Side effect is registration of the
      #   "powerShell" constraint when PowerShell is available.
      # </help>

      tputs $channel "---- checking for PowerShell... "

      #
      # NOTE: Can the PowerShell assembly be loaded?
      #
      if {[catch {
        object resolve System.Management.Automation
      } assembly] == 0} then {
        #
        # NOTE: Yes, it appears that it is available.
        #
        addConstraint powerShell

        tputs $channel yes\n
      } else {
        tputs $channel no\n
      }
    }

    proc checkForWix { channel } {
      # <help>
      # This procedure probes for an installation of the WiX (Windows Installer
      # XML) toolset and, when found, registers the "wix" test constraint and
      # records the discovered toolset directory in the global ::test_wix
      # variable (unless ::no(setWix) is set) for later use by tests.  It is
      # Windows-only because detection relies on environment and registry
      # lookups; on non-Windows platforms it reports "no" immediately.
      #
      # How it probes: it looks in two places, in order.  First, if the WIX
      # environment variable is set, it normalizes that path, appends the "bin"
      # subdirectory, and verifies that directory exists and that wix.dll there
      # carries a valid file version (via [file version]); success here records
      # the source as "environment".  If the environment variable does not yield
      # a usable directory, it then queries the WoW64 (32-bit) registry hive --
      # WiX is installed as a 32-bit application -- under the Windows Installer
      # XML key, trying a descending list of supported versions (3.11 down to
      # 3.0) and reading each version's InstallRoot value; the first whose
      # wix.dll has a valid file version wins, with the source recorded as
      # "registry".  Tricky detail: the loop variable "version" is reused to hold
      # the wix.dll file version once a candidate directory is found, so the
      # progress message reports the binary's version rather than the registry
      # key name.
      #
      # Arguments:
      #   channel -- The output channel for human-readable progress messages
      #              (which include the found version, the source, and the
      #              directory).
      #
      # Results:
      #   No meaningful return value (returns early once WiX is found).  Side
      #   effects are registration of the "wix" constraint and setting of the
      #   global ::test_wix directory variable when WiX is located.
      # </help>

      tputs $channel "---- checking for WiX... "

      #
      # NOTE: Platform must be Windows for this constraint to
      #       even be checked (i.e. we require the registry).
      #
      if {[isWindows]} then {
        #
        # NOTE: Indicate that we have not found it yet.
        #
        set directory ""

        #
        # NOTE: Have we not found the directory yet?
        #
        #       Yes, this is somewhat redundant because we just set
        #       the directory to an empty string (above); however,
        #       maintaining a uniform pattern is more important.
        #
        if {[string length $directory] == 0} then {
          #
          # NOTE: Check for the WIX environment variable.
          #
          if {[info exists ::env(WIX)]} then {
            set directory [file normalize [string trimright $::env(WIX)]]

            if {[string length $directory] > 0} then {
              #
              # NOTE: We need the directory containing the binaries.
              #
              set directory [file join $directory bin]

              #
              # NOTE: Does the directory actually exist?
              #
              if {[file isdirectory $directory]} then {
                #
                # NOTE: The file name of the primary WiX assembly.
                #
                set fileName [file join $directory wix.dll]

                #
                # NOTE: We do not know the file version yet.
                #
                set version ""

                #
                # NOTE: Attempt to query the version of the file.
                #
                if {[catch {file version $fileName} version] == 0 && \
                    [string length $version] > 0} then {
                  #
                  # NOTE: Indicate where we found the file.
                  #
                  set where environment
                } else {
                  #
                  # NOTE: The file does not exist or is not properly
                  #       versioned.
                  #
                  set directory ""
                }
              } else {
                #
                # NOTE: The directory does not exist.
                #
                set directory ""
              }
            }
          }
        }

        #
        # NOTE: Have we not found the directory yet?
        #
        if {[string length $directory] == 0} then {
          #
          # NOTE: Registry hive where WiX install information is stored.  Make
          #       sure to look in the WoW64 registry because WiX is currently
          #       always installed as a 32-bit application.
          #
          set key [appendArgs HKEY_LOCAL_MACHINE\\ \
              [getSoftwareRegistryKey true] {\Microsoft\Windows Installer XML}]

          #
          # NOTE: The versions of WiX that we support.
          #
          set versions [list 3.11 3.10 3.9 3.8 3.7 3.6 3.5 3.0]

          #
          # NOTE: Check each version, stopping when one is found.
          #
          foreach version $versions {
            #
            # NOTE: Attempt to fetch the WiX install directory value from the
            #       registry, removing the trailing backslash, if any.  Does
            #       the directory name look valid and does it actually exist?
            #
            if {[catch {file normalize [string trimright [object invoke \
                    Microsoft.Win32.Registry GetValue [appendArgs $key \\ \
                    $version] InstallRoot null] \\]} directory] == 0 && \
                    [string length $directory] > 0 && \
                [file isdirectory $directory]} then {
              #
              # NOTE: The file name of the primary WiX assembly.
              #
              set fileName [file join $directory wix.dll]

              #
              # NOTE: We do not know the file version yet.
              #
              set version ""

              #
              # NOTE: Attempt to query the version of the file.
              #
              if {[catch {file version $fileName} version] == 0 && \
                  [string length $version] > 0} then {
                #
                # NOTE: Indicate where we found the file.
                #
                set where registry

                #
                # NOTE: We found it, bail out now.
                #
                break
              } else {
                #
                # NOTE: The file does not exist or is not properly
                #       versioned.
                #
                set directory ""
              }
            }
          }
        }

        #
        # NOTE: Did we find the directory?
        #
        if {[string length $directory] > 0 && \
            [file isdirectory $directory]} then {
          #
          # NOTE: Yes, it appears that it is available.
          #
          addConstraint wix

          #
          # NOTE: Save the directory for later usage by
          #       the test itself.
          #
          if {![info exists ::no(setWix)]} then {
            set ::test_wix $directory
          }

          #
          # NOTE: Show where we found it.
          #
          tputs $channel [appendArgs \
              "yes (" $version ", via " $where ", \"" \
              $directory "\")\n"]

          #
          # NOTE: We are done here, return now.
          #
          return
        }
      }

      tputs $channel no\n
    }

    proc checkForTargetFramework { channel } {
      # <help>
      # This procedure records the build's managed target framework as a test
      # constraint named "targetFramework.NAME", allowing tests to gate on the
      # specific framework moniker the assembly was built against.  How it works:
      # it reads ::tcltk_platform(targetFramework) and, if non-empty, sanitizes
      # the moniker into a valid constraint name by mapping the comma and equals
      # characters to dots and trimming any leading dot -- for example, the
      # raw moniker for .NET Framework version v2.0 becomes "NETFramework.Version.v2.0".
      # The sanitized value is appended to the "targetFramework." prefix to form
      # the constraint name.  When the platform value is absent or empty, "no"
      # is reported and no constraint is added.
      #
      # Arguments:
      #   channel -- The output channel for human-readable progress messages.
      #
      # Results:
      #   No meaningful return value.  Side effect is registration of the
      #   "targetFramework.NAME" constraint when the target framework is known.
      # </help>

      tputs $channel "---- checking for target framework... "

      if {[info exists ::tcltk_platform(targetFramework)] && \
          [string length $::tcltk_platform(targetFramework)] > 0} then {
        #
        # NOTE: Now create a string for use in the constraint name (remove
        #       the invalid characters).  For example:
        #
        #       ".NETFramework,Version=v2.0" --> "NETFramework.Version.v2.0"
        #
        set targetFramework [string trimleft [string map [list , . = .] \
            $::tcltk_platform(targetFramework)] .]

        #
        # NOTE: Keep track of the specific target framework for usage in test
        #       constraints.
        #
        addConstraint [appendArgs targetFramework. $targetFramework]

        tputs $channel [appendArgs "yes (" $targetFramework ")\n"]
      } else {
        tputs $channel no\n
      }
    }

    proc checkForNativeUtility { channel } {
      # <help>
      # This procedure records information about the native utility library
      # (TclTk's optional native helper) as test constraints.  When a usable
      # native utility is present it registers the generic "nativeUtility"
      # constraint and always registers a more specific
      # "nativeUtility.IDENTIFIER" constraint.  It lets tests gate on whether the
      # native utility is available and, optionally, on its name and version.
      #
      # How it works: it reads ::tcltk_platform(nativeUtility), whose first list
      # element is the utility name and whose second element (if present) is its
      # version.  When a version is present, the identifier is the name, a dot,
      # and the major.minor portion of the version (from [getMajorMinorVersion]);
      # otherwise the identifier is just the name.  Tricky detail: the generic
      # "nativeUtility" constraint is added only when the identifier is neither
      # the literal "disabled" nor "unavailable", but the specific
      # "nativeUtility.IDENTIFIER" constraint is added in all cases (including
      # those two sentinel states), so tests can detect the disabled/unavailable
      # conditions explicitly.
      #
      # Arguments:
      #   channel -- The output channel for human-readable progress messages.
      #
      # Results:
      #   No meaningful return value.  Side effect is registration of the
      #   "nativeUtility" and/or "nativeUtility.IDENTIFIER" constraints as
      #   described above.
      # </help>

      tputs $channel "---- checking for native utility... "

      if {[info exists ::tcltk_platform(nativeUtility)] && \
          [string length $::tcltk_platform(nativeUtility)] > 0} then {
        set name [lindex $::tcltk_platform(nativeUtility) 0]

        if {[string length $name] > 0} then {
          set version [lindex $::tcltk_platform(nativeUtility) 1]

          if {[string length $version] > 0} then {
            set nativeUtility [appendArgs \
                $name . [getMajorMinorVersion $version]]
          } else {
            set nativeUtility $name
          }

          if {$nativeUtility ni "disabled unavailable"} then {
            addConstraint nativeUtility
          }

          addConstraint [appendArgs nativeUtility. $nativeUtility]

          tputs $channel [appendArgs \
              $::tcltk_platform(nativeUtility) " (" $nativeUtility ")\n"]
        } else {
          tputs $channel unknown\n
        }
      } else {
        tputs $channel no\n
      }
    }

    proc checkForNetFx20ServicePack { channel } {
      # <help>
      # This procedure determines which service pack level of the .NET Framework
      # 2.0 is installed and registers cumulative "dotNet20SpNOrHigher"
      # constraints (for N from 0 up to the installed level) plus an exact
      # "dotNet20SpN" constraint for the installed level.  Because service packs
      # are cumulative, the "OrHigher" family lets tests require at least a given
      # SP while the exact constraint exists for the rare case a precise level is
      # needed.  It is Windows-only since detection reads the registry.
      #
      # How it works: it reads the "SP" value from the .NET Framework setup hive
      # under v2.0.50727 via [object invoke] on Microsoft.Win32.Registry
      # GetValue (inside a [catch]).  A missing value or a registry error yields
      # a non-integer, which fails the [string is integer -strict] guard and
      # results in "no".  When the value is a valid integer, a [for] loop adds
      # the "OrHigher" constraint for every level from 0 through the installed
      # value, then the exact-level constraint is added.
      #
      # Arguments:
      #   channel -- The output channel for human-readable progress messages.
      #
      # Results:
      #   No meaningful return value (returns early after registering the
      #   constraints).  Side effect is registration of the cumulative
      #   "dotNet20SpNOrHigher" constraints and the exact "dotNet20SpN"
      #   constraint when a .NET Framework 2.0 service pack is detected.
      # </help>

      tputs $channel "---- checking for .NET Framework 2.0 Service Pack... "

      #
      # NOTE: Platform must be Windows for this constraint to even be
      #       checked (i.e. we require the registry).
      #
      if {[isWindows]} then {
        #
        # NOTE: Registry hive where the .NET Framework 2.0 setup and
        #       servicing information is stored.  No need to look in
        #       the WoW64 registry because the .NET Framework should
        #       be installed natively as well.
        #
        set key [appendArgs HKEY_LOCAL_MACHINE\\ \
            {Software\Microsoft\NET Framework Setup\NDP\v2.0.50727}]

        #
        # NOTE: Attempt to fetch the .NET Framework 2.0 "SP" value from the
        #       servicing registry hive.  If this value does not exist -OR-
        #       is less than 1, then no .NET Framework 2.0 service pack is
        #       installed.  If this raises a script error, that will almost
        #       certainly cause the result to be a non-integer, thus failing
        #       the check below.
        #
        catch {
          object invoke Microsoft.Win32.Registry GetValue $key SP null
        } servicePack

        if {[string is integer -strict $servicePack]} then {
          #
          # NOTE: Service packs are always cumulative; therefore, add test
          #       constraints for all service pack levels up to the one that
          #       is actually installed.
          #
          for {set level 0} {$level <= $servicePack} {incr level} {
            addConstraint [appendArgs dotNet20Sp $level OrHigher]
          }

          #
          # NOTE: Also add the "exact" service pack test constraint even
          #       though it should almost never be used.
          #
          addConstraint [appendArgs dotNet20Sp $servicePack]

          #
          # NOTE: Show the "servicePack" value we found in the registry.
          #
          tputs $channel [appendArgs "yes (" $servicePack ")\n"]

          #
          # NOTE: We are done here, return now.
          #
          return
        }
      }

      tputs $channel no\n
    }

    proc getOsBuild {} {
      # <help>
      # This procedure returns the operating system build number as an integer,
      # extracted from the platform's OS patch level string.  It is a helper used
      # by the various OS-version detection routines (for example, distinguishing
      # Windows 11 from Windows 10).  How it works: if
      # ::tcl_platform(osPatchLevel) exists, it splits that value on dots and
      # returns the third component (index 2), which by convention holds the
      # build number.  When the patch level is unavailable it returns -1 as a
      # sentinel.
      #
      # Arguments:
      #   None.
      #
      # Results:
      #   The OS build number (the third dot-separated component of the patch
      #   level), or -1 if the patch level information is not available.
      # </help>

      if {[info exists ::tcl_platform(osPatchLevel)]} then {
        return [lindex [split $::tcl_platform(osPatchLevel) .] 2]
      }

      return -1
    }

    proc isOsWindows11 {} {
      # <help>
      # This procedure returns whether the current operating system appears to be
      # Windows 11.  It is a helper used when computing the correct .NET
      # Framework release values, since Windows 11 and Windows 10 share the same
      # NT major version (10.0) and must be distinguished by build number.  How
      # it works: it compares the OS build number from [getOsBuild] against the
      # threshold 22000, the first Windows 11 build.
      #
      # Arguments:
      #   None.
      #
      # Results:
      #   Boolean true if the OS build number is 22000 or greater (Windows 11),
      #   false otherwise.
      # </help>

      return [expr {[getOsBuild] >= 22000}]
    }

    proc isOsReleaseId { releaseId } {
      # <help>
      # This procedure returns whether the operating system's release identifier
      # exactly matches the supplied value.  It is a helper used by the .NET
      # Framework release-value routines to pin down specific Windows 10 and
      # Windows Server feature releases (for example, "1607", "1709", "21H2").
      # How it works: it checks that ::tcl_platform(osReleaseId) exists and is
      # string-equal to the given release identifier.
      #
      # Arguments:
      #   releaseId -- The release identifier to compare against, such as a
      #                feature-update designation; comparison is exact string
      #                equality.
      #
      # Results:
      #   Boolean true if the platform release identifier is present and equals
      #   the argument, false otherwise.
      # </help>

      return [expr {[info exists ::tcl_platform(osReleaseId)] && \
          $::tcl_platform(osReleaseId) eq $releaseId}]
    }

    proc isOsProductType { type } {
      # <help>
      # This procedure returns whether the operating system's product type
      # matches a requested category.  It is a helper used throughout the .NET
      # Framework release-value routines to decide whether the machine is a
      # client/workstation or a server, since the framework "release" thresholds
      # differ between them.  How it works: it lower-cases the requested type and
      # uses a [switch] to map it to the set of acceptable underlying
      # ::tcl_platform(osProductType) values -- "client" maps to "workstation",
      # "server" maps to both "server domain controller" and "server", and
      # "unknown"/"none" map to themselves.  The special "missing" type is
      # provided for backward compatibility with TclTk betas and returns true
      # only when ::tcl_platform(osProductType) does NOT exist at all.  Any other
      # requested type returns false outright.  For the non-missing cases, it
      # returns true only when the platform product type exists and is a member
      # of the mapped set.
      #
      # Arguments:
      #   type -- The product-type category to test (case-insensitive): one of
      #           "missing", "unknown", "none", "client", or "server"; anything
      #           else yields false.
      #
      # Results:
      #   Boolean true if the OS product type satisfies the requested category
      #   (or, for "missing", if no product type is reported), false otherwise.
      # </help>

      set type [string tolower $type]

      switch -exact -- $type {
        missing {
          #
          # NOTE: Used for backward compatibility with TclTk beta.
          #
          return [expr {![info exists ::tcl_platform(osProductType)]}]
        }
        unknown -
        none {
          set productTypes [list $type]
        }
        client {
          set productTypes [list workstation]
        }
        server {
          set productTypes [list "server domain controller" server]
        }
        default {
          return false; # NOTE: Unknown, so not it.
        }
      }

      return [expr {[info exists ::tcl_platform(osProductType)] && \
          $::tcl_platform(osProductType) in $productTypes}]
    }

    proc getFrameworkSetup45Value {} {
      # <help>
      # This procedure returns the minimum .NET Framework setup "Release"
      # registry value that indicates the .NET Framework 4.5 (or higher) is
      # installed.  It is a helper for [checkForNetFx45], which compares the
      # actual registry Release value against these thresholds to classify the
      # installed framework version.  Unlike the later getters, 4.5 has a single
      # universal threshold, so this simply returns the constant 378389.
      #
      # Arguments:
      #   None.
      #
      # Results:
      #   The integer Release threshold (378389) for .NET Framework 4.5.
      # </help>

      #
      # NOTE: Return the "normal" value.
      #
      return 378389
    }

    proc getFrameworkSetup451Value {} {
      # <help>
      # This procedure returns the minimum .NET Framework setup "Release"
      # registry value that indicates the .NET Framework 4.5.1 (or higher) is
      # installed.  It is a helper for [checkForNetFx45].  How it works: the 4.5.1
      # threshold differs depending on the operating system -- on Windows 8.1 and
      # Windows Server 2012 R2 (both NT version 6.3) the "special" value 378675
      # applies, while everywhere else the "normal" value 378758 applies.  It
      # uses [isWindows], [isOsProductType] (server versus client/missing), and
      # an exact match on ::tcl_platform(osVersion) equal to 6.3 to decide which
      # value to return.
      #
      # Arguments:
      #   None.
      #
      # Results:
      #   The integer Release threshold for .NET Framework 4.5.1: 378675 on
      #   Windows 8.1 / Server 2012 R2, otherwise 378758.
      # </help>

      #
      # NOTE: Check if we are running on Windows.
      #
      if {[isWindows]} then {
        #
        # NOTE: Check if we are running on a server (or client) operating
        #       system.
        #
        if {[isOsProductType server]} then {
          #
          # NOTE: Is this Windows Server 2012 R2 (NT v6.3)?
          #
          # BUGBUG: Is exact matching correct here?
          #
          if {[info exists ::tcl_platform(osVersion)] && \
              $::tcl_platform(osVersion) == 6.3} then {
            #
            # NOTE: Return the "special" value.
            #
            return 378675
          }
        } elseif {[isOsProductType missing] || [isOsProductType client]} then {
          #
          # NOTE: Is this Windows 8.1 (NT v6.3)?
          #
          # BUGBUG: Is exact matching correct here?
          #
          if {[info exists ::tcl_platform(osVersion)] && \
              $::tcl_platform(osVersion) == 6.3} then {
            #
            # NOTE: Return the "special" value.
            #
            return 378675
          }
        }
      }

      #
      # NOTE: Return the "normal" value.
      #
      return 378758
    }

    proc getFrameworkSetup452Value {} {
      # <help>
      # This procedure returns the minimum .NET Framework setup "Release"
      # registry value that indicates the .NET Framework 4.5.2 (or higher) is
      # installed.  It is a helper for [checkForNetFx45].  Version 4.5.2 has a
      # single universal threshold, so this simply returns the constant 379893.
      #
      # Arguments:
      #   None.
      #
      # Results:
      #   The integer Release threshold (379893) for .NET Framework 4.5.2.
      # </help>

      #
      # NOTE: Return the "normal" value.
      #
      return 379893
    }

    proc isFrameworkSetup453Installed {} {
      # <help>
      # This procedure returns whether the .NET Framework 4.5.3 SKU is installed.
      # It is a helper for [checkForNetFx45], which uses it to distinguish 4.5.3
      # from 4.5.2 (both of which share the same Release threshold range).
      # Because 4.5.3 cannot be told apart by a numeric Release value, detection
      # is done by probing for the existence of a specific registry SKU subkey.
      # It is Windows-only since it reads the registry.  How it works: it obtains
      # the HKEY_LOCAL_MACHINE root key object via [object invoke] (validating it
      # with [isNonNullObjectHandle]), then attempts to open the SKUs subkey for
      # the .NETFramework version v4.5.3 entry under v4.0.30319; a non-null
      # subkey handle means it is installed.  The native registry hive is used
      # (no WoW64 redirection) because the framework is installed natively.
      #
      # Arguments:
      #   None.
      #
      # Results:
      #   Boolean true if the .NET Framework 4.5.3 SKU subkey exists, false
      #   otherwise (including on non-Windows platforms).
      # </help>

      #
      # NOTE: Platform must be Windows for this constraint to even be
      #       checked (i.e. we require the registry).
      #
      if {[isWindows]} then {
        #
        # NOTE: Registry hive where the .NET Framework 4.0 setup and
        #       servicing information is stored.  No need to look in
        #       the WoW64 registry because the .NET Framework should
        #       be installed natively as well.
        #
        if {[catch {
          object invoke -alias Microsoft.Win32.Registry LocalMachine
        } rootKey] == 0 && [isNonNullObjectHandle $rootKey]} then {
          set key [appendArgs \
              {Software\Microsoft\.NETFramework\v4.0.30319\SKUs} \\ \
              .NETFramework,Version=v4.5.3]

          if {[catch {
            $rootKey OpenSubKey $key
          } skuKey] == 0 && [isNonNullObjectHandle $skuKey]} then {
            return true
          }
        }
      }

      return false
    }

    proc getFrameworkSetup46Value {} {
      # <help>
      # This procedure returns the minimum .NET Framework setup "Release"
      # registry value that indicates the .NET Framework 4.6 (or higher) is
      # installed.  It is a helper for [checkForNetFx45].  How it works: on a
      # client/missing-product-type Windows 10 machine (NT version 10.0) that is
      # NOT Windows 11, the "special" value 393295 applies; everywhere else the
      # "normal" value 393297 applies.  It distinguishes Windows 10 from Windows
      # 11 via [isOsWindows11] because they share NT version 10.0.
      #
      # Arguments:
      #   None.
      #
      # Results:
      #   The integer Release threshold for .NET Framework 4.6: 393295 on the
      #   original Windows 10 client, otherwise 393297.
      # </help>

      #
      # NOTE: Check if we are running on Windows.
      #
      if {[isWindows]} then {
        #
        # NOTE: Check if we are running on a client operating system.
        #
        if {[isOsProductType missing] || [isOsProductType client]} then {
          #
          # NOTE: Is this Windows 10 (NT v10.0)?
          #
          # BUGBUG: Is exact matching correct here?
          #
          # BUGBUG: Treats Windows 11 differently than Windows 10.
          #
          if {[info exists ::tcl_platform(osVersion)] && \
              $::tcl_platform(osVersion) == 10.0 && \
              ![isOsWindows11]} then {
            #
            # NOTE: Return the "special" value.
            #
            return 393295
          }
        }
      }

      #
      # NOTE: Return the "normal" value.
      #
      return 393297
    }

    proc getFrameworkSetup461Value {} {
      # <help>
      # This procedure returns the minimum .NET Framework setup "Release"
      # registry value that indicates the .NET Framework 4.6.1 (or higher) is
      # installed.  It is a helper for [checkForNetFx45].  How it works: on a
      # client/missing-product-type Windows 10 machine (NT version 10.0) that has
      # the "Windows 10, November Update" extra-update marker present (checked via
      # [haveTclPlatformOsExtraUpdateName]), the "special" value 394254 applies;
      # everywhere else the "normal" value 394271 applies.
      #
      # Arguments:
      #   None.
      #
      # Results:
      #   The integer Release threshold for .NET Framework 4.6.1: 394254 on
      #   Windows 10 with the November Update, otherwise 394271.
      # </help>

      #
      # NOTE: Check if we are running on Windows.
      #
      if {[isWindows]} then {
        #
        # NOTE: Check if we are running on a client operating system.
        #
        if {[isOsProductType missing] || [isOsProductType client]} then {
          #
          # NOTE: Is this Windows 10 (NT v10.0) with the
          #       "November Update" installed?
          #
          # BUGBUG: Is exact matching correct here?
          #
          if {[info exists ::tcl_platform(osVersion)] && \
              $::tcl_platform(osVersion) == 10.0 && \
              [haveTclPlatformOsExtraUpdateName \
                  "Windows 10, November Update"]} then {
            #
            # NOTE: Return the "special" value.
            #
            return 394254; # BUGBUG: November Update only?
          }
        }
      }

      #
      # NOTE: Return the "normal" value.
      #
      return 394271
    }

    proc getFrameworkSetup462Value {} {
      # <help>
      # This procedure returns the minimum .NET Framework setup "Release"
      # registry value that indicates the .NET Framework 4.6.2 (or higher) is
      # installed.  It is a helper for [checkForNetFx45].  How it works: the
      # "special" value 394802 applies on either Windows Server 2016 (NT version
      # 10.0, release identifier 1607, detected via [isOsReleaseId]) or on a
      # client/missing-product-type Windows 10 with the "Windows 10, Anniversary
      # Update" extra-update marker (detected via
      # [haveTclPlatformOsExtraUpdateName]); everywhere else the "normal" value
      # 394806 applies.
      #
      # Arguments:
      #   None.
      #
      # Results:
      #   The integer Release threshold for .NET Framework 4.6.2: 394802 on
      #   Windows Server 2016 or the Windows 10 Anniversary Update, otherwise
      #   394806.
      # </help>

      #
      # NOTE: Check if we are running on Windows.
      #
      if {[isWindows]} then {
        #
        # NOTE: Check if we are running on a server (or client) operating
        #       system.
        #
        if {[isOsProductType server]} then {
          #
          # NOTE: Is this Windows Server 2016 (NT v10.0 release 1607)?
          #
          # BUGBUG: Is exact matching correct here?
          #
          if {[info exists ::tcl_platform(osVersion)] && \
              $::tcl_platform(osVersion) == 10.0 && \
              [isOsReleaseId 1607]} then {
            #
            # NOTE: Return the "special" value.
            #
            return 394802
          }
        } elseif {[isOsProductType missing] || [isOsProductType client]} then {
          #
          # NOTE: Is this Windows 10 (NT v10.0) with the
          #       "Anniversary Update" installed?
          #
          # BUGBUG: Is exact matching correct here?
          #
          if {[info exists ::tcl_platform(osVersion)] && \
              $::tcl_platform(osVersion) == 10.0 && \
              [haveTclPlatformOsExtraUpdateName \
                  "Windows 10, Anniversary Update"]} then {
            #
            # NOTE: Return the "special" value.
            #
            return 394802; # BUGBUG: Anniversary Update only?
          }
        }
      }

      #
      # NOTE: Return the "normal" value.
      #
      return 394806
    }

    proc getFrameworkSetup47Value {} {
      # <help>
      # This procedure returns the minimum .NET Framework setup "Release"
      # registry value that indicates the .NET Framework 4.7 (or higher) is
