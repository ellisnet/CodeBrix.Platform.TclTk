#
# NOTE: Use our own namespace here because even though we do not directly
#       support namespaces ourselves, we do not want to pollute the global
#       namespace if this script actually ends up being evaluated in Tcl.
#
namespace eval ::TclTk {
  #
  # NOTE: This procedure returns non-zero if the specified runtime option
  #       is currently set.
  #
  proc hasRuntimeOption { name {default false} } {
    # <help>
    # This procedure reports whether a named runtime option is currently set.
    # Runtime options are interpreter-level flags used to enable or disable
    # various behaviors; this procedure provides a uniform way to query them
    # that works across TclTk, the Garuda native Tcl extension, and plain
    # native Tcl.
    #
    # How it works: under TclTk it tries the most direct mechanism first --
    # the [debug runtimeoption has] sub-command (when that command and
    # sub-command are available) -- and, failing that, falls back to invoking
    # the HasRuntimeOption method on the active interpreter via the [object]
    # command.  Under native Tcl, if the [tcltk] command is present (meaning
    # the Garuda extension is loaded) the query is forwarded into TclTk;
    # otherwise it consults a simulated set of options stored in the global
    # tcltk_platform(runtimeOptions) list, but only when the feature has been
    # explicitly enabled via the tclHasRuntimeOption environment variable and
    # not disabled via the matching "no" array element.  When the native Tcl
    # path is reached but not enabled, it either raises an error (when
    # configured to do so) or silently does nothing.
    #
    # Tricky details: every internal attempt is wrapped so that, if it cannot
    # produce a definitive answer, control falls through to the default value
    # rather than failing; the procedure only returns a real answer when one
    # of the mechanisms actually succeeds.
    #
    # Arguments:
    #   name    -- The name of the runtime option to query.
    #   default -- The value to return when the option's state cannot be
    #              determined by any available mechanism.  Defaults to false.
    #
    # Results:
    #   Non-zero (true) if the option is set, zero (false) if it is not, or
    #   the default value when the state cannot be determined.
    # </help>

    if {[isTclTk]} then {
      if {[llength [info commands debug]] > 0} then {
        if {[llength [info subcommands debug runtimeoption]] > 0} then {
          if {[catch {debug runtimeoption has $name} result] == 0} then {
            return $result
          }
        }
      }

      if {[llength [info commands object]] > 0} then {
        if {[catch {
          object invoke Interpreter.GetActive HasRuntimeOption $name
        } result] == 0} then {
          return $result
        }
      }
    } else {
      if {[llength [info commands tcltk]] > 0} then {; # Garuda?
        return [tcltk [list hasRuntimeOption $name $default]]
      } else {
        if {![info exists ::no(tclHasRuntimeOption)] && \
            [info exists ::env(tclHasRuntimeOption)]} then {
          if {[info exists ::tcltk_platform(runtimeOptions)] && [set \
              index [lsearch -exact $::tcltk_platform(runtimeOptions) \
              $name]] != -1} then {
            return true
          }
        } else {
          if {[info exists ::no(silentTclHasRuntimeOption)] || \
              [info exists ::env(errorOnTclHasRuntimeOption)]} then {
            error [appendArgs \
                "procedure \[" [lindex [info level [info level]] 0] \
                "\] is not enabled for native Tcl"]
          }
        }
      }
    }

    return $default
  }

  #
  # NOTE: This procedure returns the list of runtime options that are
  #       currently set.
  #
  proc listRuntimeOptions { {default ""} } {
    # <help>
    # This procedure returns the list of runtime options that are currently
    # set.  It is the enumeration counterpart to [hasRuntimeOption] and uses
    # the same multi-engine strategy so that callers obtain a consistent view
    # of the active options under TclTk, Garuda, or plain native Tcl.
    #
    # How it works: under TclTk it first tries [debug runtimeoption get]
    # (when that command and sub-command are available) and otherwise falls
    # back to the active interpreter's RuntimeOptions.ToString member via the
    # [object] command.  Under native Tcl, if the [tcltk] command is present
    # the request is forwarded into TclTk; otherwise it returns the simulated
    # tcltk_platform(runtimeOptions) list, but only when enabled via the
    # tclListRuntimeOptions environment variable and not disabled via the
    # matching "no" array element.  When the native Tcl path is reached but
    # not enabled, it either raises an error (when configured) or does
    # nothing.  Any attempt that cannot produce a result falls through to the
    # default value.
    #
    # Arguments:
    #   default -- The value to return when the set of options cannot be
    #              determined by any available mechanism.  Defaults to an
    #              empty string.
    #
    # Results:
    #   The list (or string representation) of currently set runtime options,
    #   or the default value when it cannot be determined.
    # </help>

    if {[isTclTk]} then {
      if {[llength [info commands debug]] > 0} then {
        if {[llength [info subcommands debug runtimeoption]] > 0} then {
          if {[catch {debug runtimeoption get} result] == 0} then {
            return $result
          }
        }
      }

      if {[llength [info commands object]] > 0} then {
        if {[catch {
          object invoke Interpreter.GetActive RuntimeOptions.ToString
        } result] == 0} then {
          return $result
        }
      }
    } else {
      if {[llength [info commands tcltk]] > 0} then {; # Garuda?
        return [tcltk [list listRuntimeOptions $default]]
      } else {
        if {![info exists ::no(tclListRuntimeOptions)] && \
            [info exists ::env(tclListRuntimeOptions)]} then {
          if {[info exists ::tcltk_platform(runtimeOptions)]} then {
            return $::tcltk_platform(runtimeOptions)
          }
        } else {
          if {[info exists ::no(silentTclListRuntimeOptions)] || \
              [info exists ::env(errorOnTclListRuntimeOptions)]} then {
            error [appendArgs \
                "procedure \[" [lindex [info level [info level]] 0] \
                "\] is not enabled for native Tcl"]
          }
        }
      }
    }

    return $default
  }

  #
  # NOTE: This procedure attempts to add the specified runtime option and
  #       returns non-zero if it was actually added.
  #
  proc addRuntimeOption { name } {
    # <help>
    # This procedure attempts to add (set) a named runtime option, returning
    # an indication of whether it was actually added.  It mirrors the
    # multi-engine strategy of the other runtime option procedures so that
    # options can be enabled uniformly under TclTk, Garuda, or plain native
    # Tcl.
    #
    # How it works: under TclTk it first tries [debug runtimeoption add]
    # (when available) and otherwise calls the active interpreter's
    # AddRuntimeOption method via the [object] command.  Under native Tcl, if
    # the [tcltk] command is present the request is forwarded into TclTk;
    # otherwise, when enabled via the tclAddRuntimeOption environment variable
    # and not disabled via the matching "no" array element, it appends the
    # option to the simulated tcltk_platform(runtimeOptions) list provided the
    # option is not already present, returning true only when it actually
    # added it.  When the native Tcl path is reached but not enabled, it
    # either raises an error (when configured) or does nothing.
    #
    # Arguments:
    #   name -- The name of the runtime option to add.
    #
    # Results:
    #   Non-zero (true) if the option was actually added by the succeeding
    #   mechanism; otherwise false, including when the option was already set
    #   or when no mechanism could perform the addition.
    # </help>

    if {[isTclTk]} then {
      if {[llength [info commands debug]] > 0} then {
        if {[llength [info subcommands debug runtimeoption]] > 0} then {
          if {[catch {debug runtimeoption add $name} result] == 0} then {
            return $result
          }
        }
      }

      if {[llength [info commands object]] > 0} then {
        if {[catch {
          object invoke Interpreter.GetActive AddRuntimeOption $name
        } result] == 0} then {
          return $result
        }
      }
    } else {
      if {[llength [info commands tcltk]] > 0} then {; # Garuda?
        return [tcltk [list addRuntimeOption $name]]
      } else {
        if {![info exists ::no(tclAddRuntimeOption)] && \
            [info exists ::env(tclAddRuntimeOption)]} then {
          if {![info exists ::tcltk_platform(runtimeOptions)] || [set \
              index [lsearch -exact $::tcltk_platform(runtimeOptions) \
              $name]] == -1} then {
            lappend ::tcltk_platform(runtimeOptions) $name
            return true
          }
        } else {
          if {[info exists ::no(silentTclAddRuntimeOption)] || \
              [info exists ::env(errorOnTclAddRuntimeOption)]} then {
            error [appendArgs \
                "procedure \[" [lindex [info level [info level]] 0] \
                "\] is not enabled for native Tcl"]
          }
        }
      }
    }

    return false
  }

  #
  # NOTE: This procedure attempts to remove the specified runtime option
  #       and returns non-zero if it was actually removed.
  #
  proc removeRuntimeOption { name } {
    # <help>
    # This procedure attempts to remove (clear) a named runtime option,
    # returning an indication of whether it was actually removed.  It is the
    # inverse of [addRuntimeOption] and uses the same multi-engine strategy.
    #
    # How it works: under TclTk it first tries [debug runtimeoption remove]
    # (when available) and otherwise calls the active interpreter's
    # RemoveRuntimeOption method via the [object] command.  Under native Tcl,
    # if the [tcltk] command is present the request is forwarded into TclTk;
    # otherwise, when enabled via the tclRemoveRuntimeOption environment
    # variable and not disabled via the matching "no" array element, it
    # locates the option in the simulated tcltk_platform(runtimeOptions) list
    # and, if present, removes it with [lreplace], returning true only when it
    # actually removed it.  When the native Tcl path is reached but not
    # enabled, it either raises an error (when configured) or does nothing.
    #
    # Arguments:
    #   name -- The name of the runtime option to remove.
    #
    # Results:
    #   Non-zero (true) if the option was actually removed by the succeeding
    #   mechanism; otherwise false, including when the option was not set or
    #   when no mechanism could perform the removal.
    # </help>

    if {[isTclTk]} then {
      if {[llength [info commands debug]] > 0} then {
        if {[llength [info subcommands debug runtimeoption]] > 0} then {
          if {[catch {debug runtimeoption remove $name} result] == 0} then {
            return $result
          }
        }
      }

      if {[llength [info commands object]] > 0} then {
        if {[catch {
          object invoke Interpreter.GetActive RemoveRuntimeOption $name
        } result] == 0} then {
          return $result
        }
      }
    } else {
      if {[llength [info commands tcltk]] > 0} then {; # Garuda?
        return [tcltk [list removeRuntimeOption $name]]
      } else {
        if {![info exists ::no(tclRemoveRuntimeOption)] && \
            [info exists ::env(tclRemoveRuntimeOption)]} then {
          if {[info exists ::tcltk_platform(runtimeOptions)] && [set \
              index [lsearch -exact $::tcltk_platform(runtimeOptions) \
              $name]] != -1} then {
            set ::tcltk_platform(runtimeOptions) [lreplace \
                $::tcltk_platform(runtimeOptions) $index $index]

            return true
          }
        } else {
          if {[info exists ::no(silentTclRemoveRuntimeOption)] || \
              [info exists ::env(errorOnTclRemoveRuntimeOption)]} then {
            error [appendArgs \
                "procedure \[" [lindex [info level [info level]] 0] \
                "\] is not enabled for native Tcl"]
          }
        }
      }
    }

    return false
  }

  proc toggleRuntimeOption { name {value ""} } {
    # <help>
    # This procedure sets a named runtime option to a desired on/off state,
    # or toggles it when no explicit state is given.  It is a convenience
    # built on top of [hasRuntimeOption], [addRuntimeOption], and
    # [removeRuntimeOption], saving callers from having to query the current
    # state and choose the appropriate add/remove call themselves.
    #
    # How it works: if no value argument is supplied (it is an empty string),
    # the desired state is computed as the logical negation of the option's
    # current state, as reported by [hasRuntimeOption] -- i.e. it flips the
    # option.  Then, if the desired state is true the option is added via
    # [addRuntimeOption]; otherwise it is removed via [removeRuntimeOption].
    #
    # Arguments:
    #   name  -- The name of the runtime option to set or toggle.
    #   value -- The desired state: a true value sets the option and a false
    #            value clears it.  When omitted (an empty string), the option's
    #            current state is inverted.
    #
    # Results:
    #   The result of the underlying [addRuntimeOption] or
    #   [removeRuntimeOption] call: non-zero (true) if that call actually
    #   changed the option, otherwise false.
    # </help>

    if {[string length $value] == 0} then {
      set value [expr {![hasRuntimeOption $name]}]
    }

    if {$value} then {
      return [addRuntimeOption $name]
    } else {
      return [removeRuntimeOption $name]
    }
  }

  #
  # NOTE: Provide the TclTk "runtime option" package to the interpreter.
  #
  package provide TclTk.Runtime.Option \
    [expr {[isTclTk] ? [info engine PatchLevel] : "1.0"}]
}
