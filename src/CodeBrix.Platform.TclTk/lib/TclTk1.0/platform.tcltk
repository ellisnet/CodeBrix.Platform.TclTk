#
# NOTE: Use our own namespace here because even though we do not directly
#       support namespaces ourselves, we do not want to pollute the global
#       namespace if this script actually ends up being evaluated in Tcl.
#
namespace eval ::TclTk {
  #
  # NOTE: This is the procedure that detects whether or not we are running
  #       in TclTk (otherwise, it is assumed that we are running in vanilla
  #       Tcl).  This procedure must work correctly in both Tcl and TclTk
  #       and must return non-zero only when running in TclTk.  The same
  #       procedure is also defined in the "init.tcltk" file.
  #
  proc isTclTk {} {
    # <help>
    # This procedure detects whether the script is currently running inside
    # the TclTk script engine (as opposed to vanilla Tcl).  It exists because
    # this same script library is shared between TclTk and Tcl, and large
    # portions of the library must behave differently, or take entirely
    # different code paths, depending on which engine is hosting them.  As
    # such, it is one of the most heavily used predicates in the entire
    # library, and an identical copy is also defined in the "init.tcltk" file
    # so that it is available before this package is loaded.
    #
    # How it works: it checks for the presence of the global
    # ::tcl_platform(engine) array element and compares it, case-insensitively,
    # against the literal string "tcltk".  TclTk populates this element with
    # its engine name; Tcl reports a different engine name (or, in older
    # versions, omits the element entirely), so the comparison is false there.
    # The detection is deliberately cheap because it is invoked so frequently.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   Non-zero if and only if the current script engine is TclTk; otherwise
    #   zero (including when running under Tcl).
    # </help>

    #
    # NOTE: Nothing too fancy or expensive should be done here.  In theory,
    #       use of this procedure should be rare; however, in practice, this
    #       procedure is actually used quite a bit (e.g. by the test suite).
    #
    return [expr {[info exists ::tcl_platform(engine)] && \
        [string compare -nocase tcltk $::tcl_platform(engine)] == 0}]
  }

  #
  # NOTE: This is the procedure that detects whether or not we are running
  #       in TclTk on Mono (i.e. otherwise, we are running in Tcl or in TclTk
  #       on the .NET Framework or .NET Core).  This procedure must function
  #       correctly in both Tcl and TclTk and must return non-zero only when
  #       running in TclTk on Mono.
  #
  proc isMono {} {
    # <help>
    # This procedure detects whether the script is currently running inside
    # TclTk hosted on the Mono runtime, as opposed to Tcl, or TclTk hosted on
    # the .NET Framework or .NET Core.  It exists so that the library can work
    # around behavioral differences and known limitations that are specific to
    # the Mono common language runtime.  Like the other engine and runtime
    # predicates here, it must work correctly under both Tcl and TclTk.
    #
    # How it works: it checks for the presence of the TclTk-specific global
    # ::tcltk_platform(runtime) array element and compares it, case-insensitively,
    # against the literal string "mono".  Under Tcl that array element does not
    # exist, so the result is zero; under TclTk the element reflects the actual
    # hosting runtime.  The detection is deliberately cheap because it may be
    # invoked frequently.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   Non-zero if and only if the current runtime is Mono (and the engine is
    #   TclTk); otherwise zero.
    # </help>

    #
    # NOTE: Nothing too fancy or expensive should be done here.  In theory,
    #       use of this procedure should be rare; however, in practice, this
    #       procedure is actually used quite a bit (e.g. by the test suite).
    #
    return [expr {[info exists ::tcltk_platform(runtime)] && \
        [string compare -nocase mono $::tcltk_platform(runtime)] == 0}]
  }

  #
  # NOTE: This is the procedure that detects whether or not we are running
  #       in TclTk on .NET Core (i.e. otherwise, we are running in Tcl or in
  #       TclTk on the .NET Framework or Mono).  This procedure must function
  #       correctly in both Tcl and TclTk and must return non-zero only when
  #       running in TclTk on .NET Core.  For the purposes of this procedure,
  #       the ".NET 5" and later runtimes are still treated as .NET Core.
  #
  proc isDotNetCore {} {
    # <help>
    # This procedure detects whether the script is currently running inside
    # TclTk hosted on .NET Core, as opposed to Tcl, or TclTk hosted on the
    # .NET Framework or Mono.  For the purposes of this detection, the ".NET 5"
    # and later runtimes (which dropped the "Core" branding) are still treated
    # as .NET Core.  It exists so that the library can adapt to differences
    # between the cross-platform .NET Core or .NET runtimes and the original
    # Windows-only .NET Framework.  It must work correctly under both Tcl and
    # TclTk.
    #
    # How it works: it checks for the presence of the TclTk-specific global
    # ::tcltk_platform(runtime) array element and compares it,
    # case-insensitively, against either of the literal strings ".net core" or
    # ".net".  The latter accounts for the renamed runtime; matching either one
    # yields a true result.  Under Tcl the array element does not exist, so the
    # result is zero.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   Non-zero if and only if the current runtime is .NET Core or later (and
    #   the engine is TclTk); otherwise zero.
    # </help>

    #
    # NOTE: Nothing too fancy or expensive should be done here.  In theory,
    #       use of this procedure should be rare; however, in practice, this
    #       procedure is actually used quite a bit (e.g. by the test suite).
    #
    return [expr {[info exists ::tcltk_platform(runtime)] && \
        ([string compare -nocase ".net core" $::tcltk_platform(runtime)] == 0 \
      || [string compare -nocase ".net" $::tcltk_platform(runtime)] == 0)}]
  }

  #
  # NOTE: This procedure returns non-zero if the logged on user has full
  #       administrator rights on this machine.  Currently, this only works
  #       in TclTk; however, it may work from native Tcl in the future.
  #
  proc isAdministrator {} {
    # <help>
    # This procedure detects whether the user account hosting the current
    # process has full administrative rights on this machine (e.g. membership
    # in the Administrators group on Windows, with an elevated token, or an
    # equivalent privileged identity such as root on Unix).  It exists so that
    # scripts can decide whether privileged operations are likely to succeed,
    # or warn the user before attempting them.  Currently this detection is
    # only meaningful under TclTk; native Tcl support may be added in the
    # future.
    #
    # How it works: it checks for the presence of the TclTk-specific global
    # ::tcltk_platform(administrator) array element and tests it with [string
    # is true -strict].  That element is populated by the engine based on the
    # privilege level of the current identity at startup.  Because the
    # detection relies solely on that cached element, it does not re-query the
    # operating system each time it is called, and under Tcl (where the element
    # is absent) it always returns zero.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   Non-zero if and only if the current user has full administrator rights;
    #   otherwise zero (including when the information is unavailable, such as
    #   under Tcl).
    # </help>

    return [expr {[info exists ::tcltk_platform(administrator)] && \
        [string is true -strict $::tcltk_platform(administrator)]}]
  }

  #
  # NOTE: This is the procedure that detects whether or not we are running
  #       on Windows (otherwise, it is assumed that we are running on some
  #       flavor of Unix).  This procedure must function correctly in both
  #       Tcl and TclTk and must return non-zero only when on Windows.
  #
  proc isWindows {} {
    # <help>
    # This procedure detects whether the script is currently running on a
    # Microsoft Windows operating system, as opposed to some flavor of Unix.
    # It exists because a great deal of platform-dependent behavior throughout
    # the library (path separators, environment variable names, command
    # invocation, and so on) hinges on whether the host is Windows.  It must
    # work correctly under both Tcl and TclTk, and is among the most frequently
    # used predicates in the library.
    #
    # How it works: it checks for the presence of the global
    # ::tcl_platform(platform) array element and compares it for exact equality
    # against the literal string "windows".  Both Tcl and TclTk populate this
    # element; any value other than "windows" (typically "unix") is treated as
    # not Windows.  The detection is deliberately cheap because it is invoked
    # so frequently.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   Non-zero if and only if the host operating system is Windows; otherwise
    #   zero (which is assumed to mean some flavor of Unix).
    # </help>

    #
    # NOTE: Nothing too fancy or expensive should be done here.  In theory,
    #       use of this procedure should be rare; however, in practice, this
    #       procedure is actually used quite a bit (e.g. by the test suite).
    #
    return [expr {[info exists ::tcl_platform(platform)] && \
        $::tcl_platform(platform) eq "windows"}]
  }

  proc isMacOS {} {
    # <help>
    # This procedure detects whether the script is currently running on Apple
    # macOS (formerly OS X).  It exists because macOS, while a flavor of Unix,
    # requires special handling in a few places that differ from other Unix
    # systems -- most notably the name of the dynamic loader search path
    # environment variable (see [addToPath], which uses DYLD_LIBRARY_PATH on
    # macOS rather than LD_LIBRARY_PATH).  It must work correctly under both
    # Tcl and TclTk.
    #
    # How it works: it checks for the presence of the global ::tcl_platform(os)
    # array element and compares it for exact equality against the literal
    # string "Darwin", which is the kernel and operating system name reported
    # for macOS.  Note that this is a more specific test than [isWindows]: a
    # macOS host will report a "platform" of "unix" but an "os" of "Darwin", so
    # [isWindows] returns zero and [isMacOS] returns non-zero for the same
    # machine.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   Non-zero if and only if the host operating system is macOS (reported as
    #   "Darwin"); otherwise zero.
    # </help>

    return [expr {[info exists ::tcl_platform(os)] && \
        $::tcl_platform(os) eq "Darwin"}]
  }

  #
  # NOTE: This procedure should return non-zero if and only if only there
  #       is currently an interactive user that can respond to prompts and
  #       other requests for input.
  #
  proc isInteractive {} {
    # <help>
    # This procedure detects whether there is currently an interactive user
    # who can respond to prompts and other requests for input.  It exists so
    # that scripts can decide whether it is safe to block waiting for input,
    # or whether they must instead proceed non-interactively (for example, when
    # running as part of an automated build or test run with no console
    # attached).  It must work correctly under both Tcl and TclTk.
    #
    # How it works: it checks for the presence of the global ::tcl_interactive
    # variable and tests it with [string is true -strict].  Both Tcl and TclTk
    # set this variable to reflect whether the shell was started in interactive
    # mode.  Note the accompanying "TODO" comment in the body, which questions
    # whether a more sophisticated test is warranted; for now the simple
    # variable check is considered sufficient.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   Non-zero if and only if an interactive user is believed to be present;
    #   otherwise zero.
    # </help>

    #
    # TODO: Is something more complex required here?
    #
    return [expr {[info exists ::tcl_interactive] && \
        [string is true -strict $::tcl_interactive]}]
  }

  proc foundInPath { dirs dir } {
    # <help>
    # This procedure tests whether a given directory is present in a list of
    # directories, applying platform-appropriate case sensitivity.  It exists
    # as a helper for the path-manipulation procedures in this file (e.g.
    # [addToPath]), which need to avoid adding a directory that is already
    # present in a loader search path.
    #
    # How it works: when running on Windows, where file system paths are
    # case-insensitive, both the list and the target directory are first folded
    # to lower case via [string tolower] before comparison; on other platforms
    # the values are compared as-is.  The lookup itself is an exact (not glob)
    # [lsearch] for the target directory within the list.
    #
    # Tricky details: as the in-body comments note, folding the list to lower
    # case forces a shimmer of its internal list representation, and
    # [string tolower] is used (rather than the -nocase option of [lsearch])
    # because Tcl 8.4 lacks that option (see TIP #241).  The directories are
    # compared literally, so the caller is responsible for normalizing path
    # spelling (for example via [file nativename]) beforehand if needed.
    #
    # Arguments:
    #   dirs -- The list of directories to search.
    #   dir  -- The single directory to look for within that list.
    #
    # Results:
    #   The literal string "true" if the directory is found in the list;
    #   otherwise the literal string "false".
    # </help>

    if {[isWindows]} then {
      #
      # HACK: Causes shimmering of "$dirs" list representation.  Must use
      #       [string tolower] here anyhow because Tcl 8.4 lacks -nocase
      #       option for [lsearch] (please see TIP #241).
      #
      set dirs [string tolower $dirs]
      set dir [string tolower $dir]
    }

    if {[lsearch -exact $dirs $dir] != -1} then {
      return true
    } else {
      return false
    }
  }

  #
  # NOTE: This procedure adds the specified directory to the PATH.  It is
  #       designed to work on the various flavors of Windows and Unix.
  #
  proc addToPath { dir } {
    # <help>
    # This procedure appends a directory to the operating system's dynamic
    # loader search path environment variable, if it is not already present.
    # It exists so that subsequently loaded native libraries (DLLs or shared
    # objects) can implicitly find their dependent libraries when those
    # dependencies live in the given directory rather than in the application
    # directory.  It is designed to work across the various flavors of Windows
    # and Unix and functions in both Tcl and TclTk.
    #
    # How it works: the directory is first normalized to an operating system
    # native path via [file nativename].  The relevant environment variable is
    # then chosen by platform: PATH on Windows, DYLD_LIBRARY_PATH on macOS, and
    # LD_LIBRARY_PATH on other Unix systems.  The path separator is taken from
    # ::tcl_platform(pathSeparator) when available, falling back to a semicolon
    # on Windows or a colon elsewhere.  If the variable already exists, its
    # current value is split on the separator and checked with [foundInPath];
    # the directory is appended only when it is not already present.  If the
    # variable does not exist, it is created containing just the directory.
    #
    # Tricky details: because the comparison goes through [foundInPath], the
    # already-present check is case-insensitive on Windows and case-sensitive
    # elsewhere.  The procedure mutates the global "env" array, which affects
    # the current process environment.  Note that the variable selection here
    # distinguishes macOS from other Unix systems, whereas the companion
    # [removeFromPath] does not.
    #
    # Arguments:
    #   dir -- The directory to add to the loader search path.  It is
    #          normalized to a native path before use.
    #
    # Results:
    #   The literal string "true" if the search path was created or modified
    #   (i.e. the directory was added); otherwise the literal string "false"
    #   if the directory was already present and nothing was changed.
    # </help>

    global env
    global tcl_platform

    #
    # NOTE: This should work properly in both Tcl and TclTk.
    #       Normalize to an operating system native path.
    #
    set dir [file nativename $dir]

    #
    # NOTE: On Windows, use PATH; otherwise (i.e. Unix), use
    #       LD_LIBRARY_PATH.
    #
    if {[isWindows]} then {
      set name PATH
    } elseif {[isMacOS]} then {
      set name DYLD_LIBRARY_PATH
    } else {
      set name LD_LIBRARY_PATH
    }

    #
    # NOTE: Make sure the directory is not already in the
    #       loader search path.
    #
    if {[info exists tcl_platform(pathSeparator)]} then {
      set separator $tcl_platform(pathSeparator)
    } elseif {[isWindows]} then {
      set separator \;
    } else {
      set separator :
    }

    #
    # NOTE: Does the necessary environment variable exist?
    #
    if {[info exists env($name)]} then {
      #
      # NOTE: Grab the value of the environment variable.
      #
      set value $env($name)

      #
      # NOTE: Check if the directory is already present in the
      #       list from the environment.
      #
      if {![foundInPath [split $value $separator] $dir]} then {
        #
        # NOTE: Append the directory to the loader search path.
        #       This allows us to subsequently load DLLs that
        #       implicitly attempt to load other DLLs that are
        #       not in the application directory.
        #
        set env($name) [join [list $value $dir] $separator]

        #
        # NOTE: Yes, we altered the search path.
        #
        return true
      }
    } else {
      #
      # NOTE: Create the loader search path with the directory.
      #
      set env($name) $dir

      #
      # NOTE: Yes, we created the search path.
      #
      return true
    }

    #
    # NOTE: No, we did not alter the search path.
    #
    return false
  }

  #
  # NOTE: This procedure removes the specified directory from the PATH.
  #       It is designed to work on the various flavors of Windows and
  #       Unix.
  #
  proc removeFromPath { dir } {
    # <help>
    # This procedure removes a directory from the operating system's dynamic
    # loader search path environment variable, if it is present.  It is the
    # inverse of [addToPath] and exists to undo such an addition, for example
    # during cleanup after native libraries are no longer needed.  It is
    # designed to work across the various flavors of Windows and Unix and
    # functions in both Tcl and TclTk.
    #
    # How it works: the directory is first normalized to an operating system
    # native path via [file nativename].  The relevant environment variable is
    # chosen by platform: PATH on Windows and LD_LIBRARY_PATH otherwise.  The
    # path separator is taken from ::tcl_platform(pathSeparator) when available,
    # falling back to a semicolon on Windows or a colon elsewhere.  If the
    # variable exists, its value is split on the separator and an exact
    # [lsearch] locates the directory; when found, that one element is removed
    # via [lreplace] and the joined result is written back to the environment.
    #
    # Tricky details: as the in-body "BUGBUG" comment notes, the match is exact
    # and case-sensitive even on Windows, so a directory whose spelling or case
    # differs from the stored entry will not be removed.  Unlike [addToPath],
    # this procedure does not special-case macOS (DYLD_LIBRARY_PATH); it treats
    # all non-Windows platforms as using LD_LIBRARY_PATH.  The procedure mutates
    # the global "env" array, affecting the current process environment.
    #
    # Arguments:
    #   dir -- The directory to remove from the loader search path.  It is
    #          normalized to a native path before use.
    #
    # Results:
    #   The literal string "true" if the search path was modified (i.e. the
    #   directory was found and removed); otherwise the literal string "false"
    #   if the directory was not present and nothing was changed.
    # </help>

    global env
    global tcl_platform

    #
    # NOTE: This should work properly in both Tcl and TclTk.
    #       Normalize to an operating system native path.
    #
    set dir [file nativename $dir]

    #
    # NOTE: On Windows, use PATH; otherwise (i.e. Unix), use
    #       LD_LIBRARY_PATH.
    #
    if {[isWindows]} then {
      set name PATH
    } else {
      set name LD_LIBRARY_PATH
    }

    #
    # NOTE: Make sure the directory is in the loader search
    #       path.
    #
    if {[info exists tcl_platform(pathSeparator)]} then {
      set separator $tcl_platform(pathSeparator)
    } elseif {[isWindows]} then {
      set separator \;
    } else {
      set separator :
    }

    #
    # NOTE: Does the necessary environment variable exist?
    #
    if {[info exists env($name)]} then {
      #
      # NOTE: We need to separate the directories in the path
      #       so that we can selectively remove the one we are
      #       looking for.
      #
      set dirs [split $env($name) $separator]

      #
      # BUGBUG: Consider exact case only for now.
      #
      set index [lsearch -exact $dirs $dir]

      #
      # NOTE: Is the directory in the loader search path?
      #
      if {$index != -1} then {
        #
        # NOTE: Remove the directory from the loader search path.
        #
        set dirs [lreplace $dirs $index $index]

        #
        # NOTE: Replace the original loader search path with
        #       our modified one.
        #
        set env($name) [join $dirs $separator]

        #
        # NOTE: Yes, we altered the search path.
        #
        return true
      }
    }

    #
    # NOTE: No, we did not alter the search path.
    #
    return false
  }

  #
  # NOTE: This procedure returns non-zero if the specified file names refer
  #       to the same file, using the most robust method available for the
  #       script engine and platform.
  #
  proc isSameFileName { fileName1 fileName2 } {
    # <help>
    # This procedure determines whether two file names refer to the same file,
    # using the most robust method available for the current script engine and
    # platform.  It exists because comparing file names correctly is subtle:
    # the file system may be case-insensitive, and two different names (for
    # example via links or differing spellings) can resolve to the same
    # underlying file.
    #
    # How it works: under TclTk, it delegates to the native [file same]
    # sub-command, which can compare the actual underlying files rather than
    # just their textual names.  Under Tcl, where that sub-command is not
    # available, it falls back to a textual comparison: case-insensitive
    # ([string equal -nocase]) on Windows, where the file system is typically
    # case-insensitive, and case-sensitive ([string equal]) elsewhere.
    #
    # Tricky details: the Tcl fallback is purely textual, so it does not detect
    # two distinct names that resolve to the same file, and it does not
    # normalize the names beforehand; callers needing that behavior under Tcl
    # should normalize the names themselves first.  The TclTk path is the more
    # accurate of the two.
    #
    # Arguments:
    #   fileName1 -- The first file name to compare.
    #   fileName2 -- The second file name to compare.
    #
    # Results:
    #   Non-zero if the two file names are considered to refer to the same
    #   file; otherwise zero.
    # </help>

    if {[isTclTk]} then {
      return [file same $fileName1 $fileName2]
    } else {
      if {[isWindows]} then {
        return [string equal -nocase $fileName1 $fileName2]
      } else {
        return [string equal $fileName1 $fileName2]
      }
    }
  }

  #
  # NOTE: Provide the TclTk "platform" package to the interpreter.
  #
  package provide TclTk.Platform \
    [expr {[isTclTk] ? [info engine PatchLevel] : "1.0"}]
}
