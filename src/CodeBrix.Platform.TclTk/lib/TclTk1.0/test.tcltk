  proc whereAmI {} {
    # <help>
    # This procedure returns a textual snapshot of the current managed call
    # stack, i.e. the chain of .NET methods currently executing beneath this
    # point.  It is a diagnostic aid for understanding how a particular spot in
    # a script was reached at the native level, complementing the script-level
    # [info level] view.
    #
    # How it works: it creates a System.Diagnostics.StackTrace object, passing
    # true so that source file and line information is captured where available,
    # and then returns that object's string rendering.
    #
    # Tricky details: the captured stack reflects the managed (.NET) frames, not
    # the script call frames, and the amount of file/line detail depends on the
    # availability of debugging symbols for the running build.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   A multi-line string describing the current managed call stack.
    # </help>

    set stackTrace [object create \
        -alias System.Diagnostics.StackTrace true]

    return [$stackTrace ToString]
  }

  proc dumpWhereAmI {} {
    # <help>
    # This procedure writes the current managed call stack (as produced by
    # [whereAmI]) to a uniquely named text file in the binary directory.  It is
    # a diagnostic helper for capturing "how did I get here?" snapshots to disk,
    # for example from deep within event or callback machinery where interactive
    # inspection is impractical.
    #
    # How it works: it determines its own procedure name (via the interpreter
    # call stack) and maintains a per-session counter in the debugger state
    # array, incrementing it on each call.  It composes a file name from that
    # name and the counter, placed in the [info binary] directory, and, if a
    # file with that name does not already exist, writes the stack trace there
    # via [writeFile].
    #
    # Tricky details: because the file name includes a monotonically increasing
    # counter, repeated calls produce distinct files; an existing file with the
    # computed name is never overwritten.  The counter is stored globally so it
    # persists across calls within the session.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   The empty string; the meaningful effect is the stack-trace file written
    #   to disk.
    # </help>

    set level [lindex [info level [info level]] 0]

    if {[info exists ::tcltk_debugger(whereAmICount)]} then {
      set count [incr ::tcltk_debugger(whereAmICount)]
    } else {
      set count [set ::tcltk_debugger(whereAmICount) 1]
    }

    set fileName [file join \
        [info binary] [appendArgs $level - $count .txt]]

    if {![file exists $fileName]} then {
      writeFile $fileName [whereAmI]
    }

    return ""
  }

  proc enableTracing {
          {stateTypes "=CoreEnableMask +ForceListeners"} {message true} } {
    # <help>
    # This procedure forcibly turns on the engine's diagnostic tracing at
    # essentially its maximum extent.  It is used to make troublesome behavior
    # observable by enabling the full set of trace categories and ensuring that
    # trace listeners are active, regardless of the current configuration.
    #
    # How it works: it issues a [debug trace] command with the highest priority
    # and no limits, under the META_TRACING category, asking it to reset the
    # system and listener configuration, force tracing enabled, apply the given
    # state types, set the default, and log the action.  When the message flag
    # is true a human-readable note is supplied; otherwise the message is empty.
    #
    # Tricky details: the default state types combine a core enable mask with a
    # flag that forces listeners on, which is what makes the tracing actually
    # produce visible output.  This is a heavy-handed, global change intended
    # for diagnosis; pair it with [disableTracing] to undo it.
    #
    # Arguments:
    #   stateTypes -- The optional trace state types to apply, defaulting to a
    #                 value that enables the core mask and forces listeners.
    #   message    -- An optional boolean, default true; when true a descriptive
    #                 message accompanies the change, otherwise none is logged.
    #
    # Results:
    #   The result of the underlying [debug trace] command.
    # </help>

    return [debug trace -priority {=Always +NoLimits} \
        -category META_TRACING \
        -resetsystem true -resetlisteners true -forceenabled true \
        -statetypes $stateTypes -default true -log true -- \
        [expr {$message ? "Forcibly enabled maximum tracing." : ""}]]
  }

  proc disableTracing {
          {stateTypes "=CoreDisableMask +ForceListeners"} {message true} } {
    # <help>
    # This procedure forcibly turns off the engine's diagnostic tracing,
    # undoing the effect of [enableTracing].  It is used to silence tracing
    # after a diagnostic session, restoring quieter normal operation.
    #
    # How it works: it issues a [debug trace] command with the highest priority
    # and no limits, under the META_TRACING category, asking it to reset the
    # system and listener configuration, force tracing disabled, apply the
    # given state types, and set the default.  When the message flag is true a
    # human-readable note is supplied; otherwise the message is empty.  Unlike
    # the enabling counterpart, it does not request logging of the action.
    #
    # Tricky details: the default state types combine a core disable mask with a
    # flag that forces listeners, ensuring the change is applied broadly.  This
    # is a global change intended to reverse a prior [enableTracing] call.
    #
    # Arguments:
    #   stateTypes -- The optional trace state types to apply, defaulting to a
    #                 value that selects the core disable mask and forces
    #                 listeners.
    #   message    -- An optional boolean, default true; when true a descriptive
    #                 message accompanies the change, otherwise none.
    #
    # Results:
    #   The result of the underlying [debug trace] command.
    # </help>

    return [debug trace -priority {=Always +NoLimits} \
        -category META_TRACING \
        -resetsystem true -resetlisteners true -forceenabled false \
        -statetypes $stateTypes -default true -- \
        [expr {$message ? "Forcibly disabled maximum tracing." : ""}]]
  }

  proc hideMyself { {hide true} } {
    # <help>
    # This procedure hides (or shows) the native console window associated with
    # the current process.  It is useful for tests or tools that wish to make
    # the console disappear while running and optionally bring it back.
    #
    # How it works: it obtains the native console window handle via the internal
    # NativeConsole helper.  If that handle is non-null (its string form is not
    # "0"), it computes the desired show/hide state and calls the internal
    # WindowOps ShowWindow helper to apply it, raising an error built from the
    # returned error object if the call does not report success.  If no console
    # window handle is available, it raises an error indicating the native
    # console window is unavailable.
    #
    # Tricky details: this depends on the native console support being present;
    # on platforms or builds without it the window handle will be unavailable
    # and an error is raised.  The "hide" argument is inverted internally to
    # produce the "show" flag passed to ShowWindow.
    #
    # Arguments:
    #   hide -- An optional boolean, default true; true hides the console
    #           window, false shows it.
    #
    # Results:
    #   The empty string on success.  An error is raised if the console window
    #   is unavailable or if the show/hide operation does not succeed.
    # </help>

    set hWnd [object invoke -create -alias -flags +NonPublic \
        CodeBrix.Platform.TclTk._Components.Private.NativeConsole GetWindow]

    if {[$hWnd ToString] ne "0"} then {
      set show [expr {!$hide}]
      set returnValue false; set error null

      set code [object invoke -flags +NonPublic \
          CodeBrix.Platform.TclTk._Components.Private.WindowOps ShowWindow \
          $hWnd $show returnValue error]

      if {$code ne "Ok"} then {
        error [getStringFromObjectHandle $error]
      }
    } else {
      error "native console window unavailable"
    }
  }

  proc getEngineFlagsForTest { {style 0} } {
    # <help>
    # This procedure computes the set of engine flags that a test should use so
    # that caching behavior does not perturb its results, and optionally formats
    # those flags for embedding in a particular test context.  It exists because
    # some tests must run with parse-state and argument caching disabled to
    # observe deterministic engine behavior, and the exact textual form needed
    # differs between test sites.
    #
    # How it works: under TclTk it consults build-time constraints and, when the
    # parse cache is compiled in, adds the flag that disables parse-state
    # caching; likewise it adds the flag disabling argument caching when that
    # feature is present.  When a non-zero style is requested, it joins the
    # accumulated flags with a comma and then formats them according to the
    # style: style 1 prefixes the joined list with a comma for inline use; style
    # 2 wraps the list in braces; style 3 wraps it in backslash-escaped braces.
    # When no flags accumulated, styles 2 and 3 yield the literal "None" while
    # other styles yield the empty string.  The inline comment beside each style
    # branch names the representative test that needs that form.
    #
    # Tricky details: under native Tcl, or when no caching features are compiled
    # in, the flag list is empty and the result depends solely on the style.
    # The brace-wrapping styles exist so the value can be dropped directly into
    # test bodies that expect a braced engine-flags argument or an escaped form.
    #
    # Arguments:
    #   style -- An optional integer selecting the output formatting, defaulting
    #            to zero (return the raw flag list).  Values 1, 2, and 3 select
    #            the inline-comma, brace-wrapped, and escaped-brace-wrapped forms
    #            respectively.
    #
    # Results:
    #   For style zero, the list of engine flags (possibly empty).  For a
    #   non-zero style, the formatted string described above, which may be the
    #   empty string or the literal "None" when no flags apply.
    # </help>

    set result [list]

    if {[isTclTk]} then {
      if {[haveConstraint compile.PARSE_CACHE]} then {
        lappend result NoCacheParseState
      }

      if {[haveConstraint compile.ARGUMENT_CACHE]} then {
        lappend result NoCacheArgument
      }
    }

    if {$style > 0} then {
      if {[llength $result] > 0} then {
        set result [join $result ", "]

        switch -exact -- $style {
          1 {
            set result [appendArgs ", " $result]; # basic-1.34
          }
          2 {
            set result [appendArgs \{ $result \}]; # parser-20.*
          }
          3 {
            set result [appendArgs \\\{ $result \\\}]; # parser-5.1
          }
        }
      } elseif {$style in [list 2 3]} then {
        set result None; # parser-20.* / parser-5.1
      } else {
        set result ""; # REDUNDANT: basic-1.34
      }
    }

    return $result
  }

  proc getProcessGroup { pid {varName ""} {quiet false} } {
    # <help>
    # This procedure looks up the process group identifier for a given process
    # on Unix-like systems and optionally reports it to the caller.  It supports
    # process-group based termination (see [killProcessGroup] and
    # [maybeKillProcessGroup]) by discovering the group a process belongs to.
    #
    # How it works: if a variable name was supplied, it links that caller
    # variable so the discovered group id can be stored there.  It then runs the
    # external "ps" utility to obtain the process group id for the given process
    # id, trimming whitespace from the output, all inside a [catch].  If the
    # command succeeds and the result is a strict integer, it optionally emits
    # an informational line to the test channel (unless quiet) and returns true,
    # having stored the group id into the linked variable.  Otherwise it returns
    # false.
    #
    # Tricky details: this relies on a Unix-style "ps -o pgid=" being available,
    # so it is not meaningful on Windows.  The output variable is only written
    # when a valid integer group id is obtained.  The diagnostic message is
    # itself wrapped in [catch] so logging problems cannot derail the lookup.
    #
    # Arguments:
    #   pid     -- The process identifier whose process group is sought.
    #   varName -- An optional caller variable name to receive the group id;
    #              when empty, the group id is not stored anywhere.
    #   quiet   -- An optional boolean, default false; when true, the
    #              informational message is suppressed.
    #
    # Results:
    #   True if the process group id was determined (and stored, if requested);
    #   false otherwise.
    # </help>

    if {[string length $varName] > 0} then {
      upvar 1 $varName pgid
    }

    if {[catch {
      string trim [exec -success Success -- ps -o pgid= $pid]
    } pgid] == 0 && [string is integer -strict $pgid]} then {
      if {!$quiet} then {
        catch {
          tputs [getTestChannelOrDefault] [appendArgs \
              "==== PROCESS " $pid " GROUP IS " $pgid \n]
        }
      }

      return true
    }

    return false
  }

  proc killProcessGroup { pgid {quiet false} } {
    # <help>
    # This procedure forcibly terminates an entire process group on Unix-like
    # systems.  It is used to ensure that a process and all of its descendants
    # are cleaned up together, for example when a test spawns child processes
    # that must not be left running.
    #
    # How it works: unless quiet, it first emits an informational line to the
    # test channel announcing the kill.  It then runs the external "kill"
    # utility with the KILL signal, targeting the negated group id (a leading
    # "-" before the group id is how the kill utility addresses a whole process
    # group).  If that command succeeds it returns true, otherwise false.
    #
    # Tricky details: this is an unconditional, non-catchable SIGKILL of an
    # entire group, so it is destructive; callers typically obtain the group id
    # from [getProcessGroup] first.  It is meaningful only on systems with a
    # Unix-style "kill" that understands negative process group targets.  The
    # diagnostic message is wrapped in [catch] so logging issues do not affect
    # the kill.
    #
    # Arguments:
    #   pgid  -- The process group identifier to terminate.
    #   quiet -- An optional boolean, default false; when true, the
    #            informational message is suppressed.
    #
    # Results:
    #   True if the kill command succeeded; false otherwise.
    # </help>

    if {!$quiet} then {
      catch {
        tputs [getTestChannelOrDefault] [appendArgs \
            "==== KILLING PROCESS GROUP " $pgid " NOW...\n"]
      }
    }

    if {[catch {
      exec -success Success -- kill -s KILL [appendArgs - $pgid]
    }] == 0} then {
      return true
    }

    return false
  }

  proc maybeKillProcessGroup { pid {self false} {quiet false} } {
    # <help>
    # This procedure attempts to terminate an entire process group on
    # POSIX-style platforms, where process groups exist and can be signaled
    # as a unit.  It exists so that test infrastructure can reliably tear
    # down a child process together with any grandchildren it may have
    # spawned, instead of leaking orphaned processes when a test ends.
    #
    # How it works: it only does anything when not running on Windows (since
    # Windows has no equivalent notion that this code targets).  It looks up
    # the process group of the target process and of the current process via
    # [getProcessGroup].  When the "self" flag is true, it looks up both
    # groups (mostly for diagnostic symmetry) and then kills the target's
    # group via [killProcessGroup].  When "self" is false, it additionally
    # guards against killing its own group: it proceeds only when the target
    # process id differs from the current one and the two groups differ,
    # which avoids accidentally terminating the running test process.
    #
    # Arguments:
    #   pid   -- The process identifier whose process group is the candidate
    #            for termination.
    #   self  -- A boolean; when true, the target's group is killed even if it
    #            could be the current process group.  Defaults to false, which
    #            enables the safety checks that prevent self-termination.
    #   quiet -- A boolean passed through to the lookup and kill helpers to
    #            suppress diagnostic output.  Defaults to false.
    #
    # Results:
    #   Whatever [killProcessGroup] returns when a group is actually killed;
    #   otherwise false, which is also the result on Windows or when the
    #   safety checks prevent any action.
    # </help>

    if {![isWindows]} then {
      set pid1 $pid;     # target process.
      set pid2 [pid];    # current process.
                         # allow killing self?
      if {$self} then {; # query both for diagnostics...
        if {[getProcessGroup $pid1 pgid1 $quiet] && \
            [getProcessGroup $pid2 pgid2 $quiet]} then {
          return [killProcessGroup $pgid1 $quiet]
        }
      } else {
        if {$pid1 != $pid2 && \
            [getProcessGroup $pid1 pgid1 $quiet] && \
            [getProcessGroup $pid2 pgid2 $quiet] && \
            $pgid1 != $pgid2} then {
          return [killProcessGroup $pgid1 $quiet]
        }
      }
    }

    return false
  }

  proc enableFailSafeExitAfter { {group false} {milliseconds 600000} } {
    # <help>
    # This procedure arms a "dead-man switch" that forcibly terminates the
    # current process after a timeout, as a last-resort safeguard against a
    # test run that hangs indefinitely.  It exists because an unattended test
    # suite that wedges (for example, on a deadlock or a blocking dialog) must
    # not hang forever; this guarantees the process eventually exits so that
    # automation can move on.
    #
    # How it works: it first calls the native [failSafeExitAfter] hook (the
    # "before" phase), ignoring errors.  When running in TclTk, it builds two
    # small callback scripts.  The first re-invokes the native hook in its
    # "after" phase.  The second waits the requested number of milliseconds,
    # then (unless suppressed by the no(failSafeAbort) flag) asks the default
    # test object to perform a fail-safe abort, optionally with a stack trace
    # (controlled by no(failSafeAbortWithTrace)), and finally forces process
    # exit -- either by killing the whole process group (when "group" is true
    # and [maybeKillProcessGroup] succeeds) or by killing just this process.
    # Both callbacks are scheduled two ways for redundancy: via the engine's
    # [after] event queue (so they run on this thread eventually) and via the
    # .NET thread pool (so they run immediately on a pooled thread that sleeps
    # for the timeout before acting).  The thread-pool callbacks are removed
    # in a [finally] block as a hedge against the process not actually exiting.
    #
    # Tricky details: the timeout is large by default (ten minutes) because it
    # is meant only to catch true hangs, not slow-but-progressing runs.  This
    # procedure does effectively nothing useful outside of TclTk beyond the
    # initial native hook call, since the scheduling machinery is TclTk-only.
    #
    # Arguments:
    #   group        -- A boolean; when true, the forced exit first tries to
    #                   kill the entire process group (to also reap children).
    #                   Defaults to false, meaning only this process is killed.
    #   milliseconds -- The timeout, in milliseconds, before the forced exit
    #                   fires.  Defaults to 600000 (ten minutes).
    #
    # Results:
    #   In TclTk, the result of the thread-pool scheduling on success, or
    #   false on failure; outside TclTk, an empty result.
    # </help>

    catch {failSafeExitAfter $milliseconds before}

    if {[isTclTk]} then {
      set script(1) [list apply [list [list args] {
        catch {failSafeExitAfter $milliseconds after}
      }]]

      set script(2) [list apply [list [list args] {
        if {[llength $args] > 0} then {
          set milliseconds [lindex $args 0]
        } else {
          if {[info exists \
              ::tcltk_debugger(failSafeExitAfterMilliseconds)]} then {
            set milliseconds \
                $::tcltk_debugger(failSafeExitAfterMilliseconds)
          } else {
            set milliseconds ""
          }
        }

        if {[string is integer -strict $milliseconds]} then {
          after $milliseconds
        }

        if {![info exists ::no(failSafeAbort)]} then {
          set withTrace true

          if {[info exists ::no(failSafeAbortWithTrace)]} then {
            set withTrace false
          }

          object invoke \
              CodeBrix.Platform.TclTk._Tests.Default TestFailSafeAbortWithTrace \
              Ok enableFailSafeExitAfter false $withTrace
        }

        if {!$group || \
            ![maybeKillProcessGroup $pid true]} then {
          kill -force -- [pid]
        }
      }]]

      #
      # NOTE: The script setup above will be evaluated
      #       (asynchronously, and eventually) on this
      #       thread, via the [after] event queue used
      #       by the engine.
      #
      foreach id [lsort -integer [array names script]] {
        after $milliseconds -priority Immediate -flags \
            +Immediate $script($id)
      }

      if {[catch {
        #
        # NOTE: The script built here will be evaluated
        #       (asynchronously, but immediately) on a
        #       pooled thread; therefore, it must wait
        #       for the specified number of milliseconds
        #       prior to using the [kill] command.
        #
        try {
          foreach id [lsort -integer [array names script]] {
            set callback($id) $script($id)
            lappend callback($id) $milliseconds

            object invoke \
                System.Threading.ThreadPool QueueUserWorkItem \
                $callback($id)
          }
        } finally {
          #
          # HACK: Just in case we do not actually exit the
          #       process, cleanup the callbacks we created
          #       above.
          #
          foreach id [lsort -integer [array names callback]] {
            catch {object removecallback $callback($id)}
          }
        }
      } result] == 0} then {
        return $result
      } else {
        return false
      }
    }
  }

  proc evalPackageIndexFile {
          fileName {directory ""} {ignoreFileDirectory false} } {
    # <help>
    # This procedure sources a Tcl/TclTk package index file (typically named
    # "pkgIndex.tcl") in a way that mimics how the package machinery normally
    # evaluates it.  It exists because such files conventionally rely on a
    # global "dir" variable holding the directory that contains them; calling
    # [source] directly would leave that variable unset and break the index.
    #
    # How it works: it determines the directory to advertise as "dir".  If a
    # directory is given explicitly, that is used.  Otherwise the directory is
    # derived from the index file's own path (via [file dirname]), unless
    # "ignoreFileDirectory" is true, in which case that derivation is skipped.
    # If the result is still empty or just ".", it falls back to the directory
    # of the running assembly (in TclTk) or the executable (in Tcl).  It then
    # saves any existing global "dir", sets it to the chosen directory, and
    # sources the index file at the global level ([uplevel #0]).  A [finally]
    # block restores the previous global "dir" (or unsets it if there was
    # none), so the caller's environment is left undisturbed.
    #
    # Arguments:
    #   fileName            -- The path of the package index file to source.
    #   directory           -- The directory to expose via the global "dir"
    #                          variable.  When empty (the default), it is
    #                          computed as described above.
    #   ignoreFileDirectory -- A boolean; when true, the index file's own
    #                          directory is not used as the fallback, forcing
    #                          the assembly/executable directory instead.
    #                          Defaults to false.
    #
    # Results:
    #   The result of sourcing the index file.
    # </help>

    if {[string length $directory] == 0} then {
      set directory [expr {
        $ignoreFileDirectory ? "" : [file dirname $fileName]
      }]

      if {[string length $directory] == 0 || $directory eq "."} then {
        if {[isTclTk]} then {
          set directory [file dirname [lindex [info assembly true] end]]
        } else {
          set directory [file dirname [info nameofexecutable]]
        }
      }
    }

    if {[info exists ::dir]} then {
      set savedDir $::dir
    } else {
      unset -nocomplain savedDir
    }

    try {
      set ::dir $directory

      return [uplevel #0 [list source $fileName]]
    } finally {
      if {[info exists savedDir]} then {
        set ::dir $savedDir
      } else {
        unset -nocomplain ::dir
      }
    }
  }

  proc cleanupAfterEvents { {quiet false} } {
    # <help>
    # This procedure cancels every pending [after] event currently queued in
    # the interpreter.  It exists so that tests can scrub leftover timer or
    # idle callbacks between runs, preventing a callback scheduled by one test
    # from firing during an unrelated later test and causing spurious failures
    # or state corruption.
    #
    # How it works: it enumerates all pending event ids via [after info] and
    # attempts to [after cancel] each one, counting the successful
    # cancellations.  Failures to cancel an individual event are reported (and
    # otherwise tolerated) when not running quietly.  Unless quiet, a summary
    # line is emitted to the test channel describing how many events were
    # cleaned up, or describing the overall failure.
    #
    # Arguments:
    #   quiet -- A boolean; when true, all diagnostic output is suppressed.
    #            Defaults to false, in which case messages go to the channel
    #            from [getTestChannelOrDefault].
    #
    # Results:
    #   The number of events successfully canceled on success, or -1 if the
    #   overall enumeration/cancellation loop itself failed.
    # </help>

    set count 0

    if {!$quiet} then {
      set channel [getTestChannelOrDefault]
    }

    if {[catch {
      foreach id [after info] {
        if {[catch {after cancel $id} error2] == 0} then {
          incr count; # canceled one more.
        } else {
          if {!$quiet} then {
            tputs $channel [appendArgs \
                "---- failed to cancel after event \"" \
                $id "\": " $error2 \n]
          }
        }
      }
    } error1] == 0} then {
      if {!$quiet} then {
        tputs $channel [appendArgs \
            "---- cleaned up " $count " after events\n"]
      }

      return $count
    } else {
      if {!$quiet} then {
        tputs $channel [appendArgs \
            "---- failed to cleanup after events (" \
            $count "): " $error1 \n]
      }

      return -1; # failure
    }
  }

  proc findParentDirectory { path name } {
    # <help>
    # This procedure walks upward from a starting path looking for an ancestor
    # directory whose final path component (its "tail") matches a given name,
    # returning that ancestor's full path.  It exists to locate a well-known
    # directory (for example, a checkout root or a named subtree) by climbing
    # the directory hierarchy from some deeper location.
    #
    # How it works: starting at "path", it repeatedly compares the tail of the
    # current path against "name"; on a match it returns the current path.
    # Otherwise it moves to the parent via [file dirname] and continues.  The
    # loop stops when the path becomes empty, when its tail becomes empty, or
    # when taking the parent no longer changes the path (i.e. the filesystem
    # root has been reached), at which point no match was found.
    #
    # Tricky details: the comparison is on the path tail only, so it matches a
    # directory by its own name regardless of where it sits.  An empty "name"
    # short-circuits the search and yields no match.
    #
    # Arguments:
    #   path -- The starting path from which to begin climbing.
    #   name -- The directory name to match against each ancestor's tail.
    #
    # Results:
    #   The full path of the first matching ancestor directory, or the empty
    #   string when no match is found.
    # </help>

    if {[string length $name] > 0} then {
      while {[string length $path] > 0} {
        set tail [file tail $path]
        if {[string length $tail] == 0} then {break}
        if {$tail eq $name} then {return $path}
        set newPath [file dirname $path]
        if {$newPath eq $path} then {break}
        set path $newPath
      }
    }

    return ""; # NOTE: Not found.
  }

  proc enableRuntimeOptionsForTcl { enable } {
    # <help>
    # This procedure turns on (or off) the native-Tcl fallbacks for TclTk's
    # "runtime option" procedures, which in Tcl are driven by a set of marker
    # environment variables.  It exists so that the shared script library can
    # emulate, under native Tcl, the runtime-option behavior that TclTk
    # provides intrinsically through its tcltk_platform(runtimeOptions) list.
    #
    # How it works: when enabling, it sets four marker environment variables --
    # tclHasRuntimeOption, tclListRuntimeOptions, tclAddRuntimeOption, and
    # tclRemoveRuntimeOption -- each to 1, which the corresponding fallback
    # procedures consult.  When disabling, it unsets those same variables
    # (ignoring the absence of any).  Note that this manipulates only the
    # environment markers; it does not itself read or modify the global
    # runtime-options list.
    #
    # Arguments:
    #   enable -- A boolean; when true the marker variables are set, when false
    #             they are removed.
    #
    # Results:
    #   An empty string.
    # </help>

    #
    # NOTE: Enable all fallbacks for the runtime option
    #       procedures (within the core script library)
    #       that rely upon the global list value within
    #       the "tcltk_platform(runtimeOptions)" script
    #       variable.
    #
    if {$enable} then {
      set ::env(tclHasRuntimeOption) 1
      set ::env(tclListRuntimeOptions) 1
      set ::env(tclAddRuntimeOption) 1
      set ::env(tclRemoveRuntimeOption) 1
    } else {
      unset -nocomplain ::env(tclRemoveRuntimeOption)
      unset -nocomplain ::env(tclAddRuntimeOption)
      unset -nocomplain ::env(tclListRuntimeOptions)
      unset -nocomplain ::env(tclHasRuntimeOption)
    }

    return ""
  }

  proc setupEvaluateViaTemporaryFile { varName name script } {
    # <help>
    # This procedure ensures a script is materialized on disk as a temporary
    # file, returning that file's name, and remembers the mapping in a caller
    # supplied tracking array.  It is the setup half of the "evaluate via
    # temporary file" mechanism, which exists so that scripts (for example,
    # debugger snippets) can be sourced from real files rather than evaluated
    # inline -- useful when file-based evaluation produces better diagnostics
    # or matches how production code loads scripts.
    #
    # How it works: it links the named variable in the caller's frame as an
    # array and computes a tracking element key of the form
    # "evaluateViaTemporaryFile:" followed by the logical name.  If that
    # element already exists, it validates the remembered file: the file must
    # still exist and its contents (read via [readSharedFile]) must match the
    # supplied script, erroring out otherwise -- this guards against name
    # collisions and stale files.  If the element does not yet exist and a
    # non-empty script was supplied, it allocates a fresh temporary file name,
    # writes the script to it, and records the mapping.  Supplying neither an
    # existing mapping nor a script is an error.
    #
    # Arguments:
    #   varName -- The name of a variable in the caller's frame used as the
    #              tracking array; it must be non-empty or an error is raised.
    #   name    -- A logical name identifying this script, used to form the
    #              array element key.
    #   script  -- The script text to write to the temporary file when one is
    #              being created; required (non-empty) unless a matching
    #              mapping already exists.
    #
    # Results:
    #   The name of the temporary file containing the script.  Various
    #   mismatch and missing-argument conditions raise an error.
    # </help>

    if {[string length $varName] == 0} then {
      error "variable name is required for a temporary script file"
    }

    upvar 1 $varName array
    set element [appendArgs evaluateViaTemporaryFile : $name]

    if {[info exists array($element)]} then {
      set fileName $array($element)

      if {![file exists $fileName]} then {
        error [appendArgs \
            "temporary file \"" $fileName "\" for \"" \
            $name "\" does not exist"]
      }

      if {$script ne [readSharedFile $fileName]} then {
        error [appendArgs \
            "temporary file \"" $fileName "\" for \"" \
            $name "\" does not match script"]
      }
    } elseif {[string length $script] > 0} then {
      set fileName [getTemporaryFileName]

      writeFile $fileName $script

      set array($element) $fileName
    } else {
      error [appendArgs \
          "cannot create temporary file for \"" $name \
          "\" without a script"]
    }

    return $fileName
  }

  proc evaluateViaTemporaryFile { varName name script {verbose 0} } {
    # <help>
    # This procedure writes a script to a temporary file, sources that file in
    # the caller's context, and (when appropriate) cleans the file up
    # afterward.  It exists so that a block of script can be evaluated as
    # though it were loaded from disk -- for example, to obtain file-based
    # error locations or to mirror how real script files are loaded -- without
    # the caller having to manage the temporary file lifecycle.
    #
    # How it works: if no tracking variable name is supplied, it defaults to
    # the TclTk "system" variable "tcltk_debugger".  Using a [try] construct
    # (which requires Tcl 8.6+, TclTk, or a shim), it links that variable as
    # the debugger array, calls [setupEvaluateViaTemporaryFile] to obtain the
    # file, and then sources the file via [uplevel 1] so it runs in the
    # caller's frame.  The [finally] block contains conditional cleanup logic
    # that, when triggered, deletes the temporary file unless the
    # no(deleteEvaluateViaTemporaryFile) flag is set; deletion errors are
    # reported only when verbose.  In practice, the cleanup is deferred to
    # [cleanupEvaluateViaTemporaryFiles], allowing the file to be reused.
    #
    # Arguments:
    #   varName -- The name of the tracking array variable; when empty, the
    #              "tcltk_debugger" system variable is used.
    #   name    -- A logical name identifying the script (see the setup helper).
    #   script  -- The script text to evaluate.
    #   verbose -- An integer verbosity level; when greater than zero, cleanup
    #              failures are reported to the test channel.  Defaults to 0.
    #
    # Results:
    #   The result of sourcing the temporary script file.
    # </help>

    #
    # NOTE: Example usage of this procedure should be similar to the
    #       following:
    #
    #       try {
    #         evaluateViaTemporaryFile "" <unique script name> {
    #           <script block here>
    #         }
    #       } finally {
    #         cleanupEvaluateViaTemporaryFiles ""
    #       }
    #
    if {[string length $varName] == 0} then {
      set varName tcltk_debugger; # HACK: TclTk "system" variable.
    }

    #
    # NOTE: Since this procedure uses the [try] command, it will
    #       require Tcl 8.6+ -OR- TclTk -OR- a shim.
    #
    try {
      upvar 1 $varName debugger

      set fileName [setupEvaluateViaTemporaryFile \
          debugger $name $script]

      return [uplevel 1 [list source $fileName]]
    } finally {
      if {[string length $varName] == 0 && \
          [info exists fileName] && \
          [string length $fileName] > 0} then {
        if {![info exists ::no(deleteEvaluateViaTemporaryFile)]} then {
          if {[info exists fileName] && \
              [string length $fileName] > 0 && \
              [file exists $fileName]} then {
            if {[catch {file delete $fileName} error]} then {
              if {$verbose > 0} then {
                tputs [getTestChannelOrDefault] [appendArgs \
                    "---- temporary script cleanup failure (1): " \
                    $error \n]
              }
            }
          }
        }
      }
    }
  }

  proc cleanupEvaluateViaTemporaryFiles { varName {verbose 0} } {
    # <help>
    # This procedure deletes all temporary script files previously created by
    # the "evaluate via temporary file" mechanism and tracked in a given
    # array, forgetting each mapping as its file is removed.  It is the
    # teardown companion to [setupEvaluateViaTemporaryFile] and
    # [evaluateViaTemporaryFile], and is typically called from a [finally]
    # block so that reusable temporary scripts do not accumulate on disk.
    #
    # How it works: if no tracking variable name is supplied, it defaults to
    # the TclTk "system" variable "tcltk_debugger".  It links that variable as
    # the debugger array and iterates, in sorted order, over every element
    # whose name matches the "evaluateViaTemporaryFile:*" pattern.  For each
    # existing regular file it attempts [file delete]; on success it unsets
    # the corresponding array element and records the deleted file name.  On a
    # deletion failure it leaves the mapping in place and, when verbose,
    # reports the error to the test channel.
    #
    # Arguments:
    #   varName -- The name of the tracking array variable to scan; when
    #              empty, the "tcltk_debugger" system variable is used.
    #   verbose -- An integer verbosity level; when greater than zero, cleanup
    #              failures are reported to the test channel.  Defaults to 0.
    #
    # Results:
    #   A list of the temporary file names that were successfully deleted.
    # </help>

    if {[string length $varName] == 0} then {
      set varName tcltk_debugger; # HACK: TclTk "system" variable.
    }

    set result [list]

    upvar 1 $varName debugger

    foreach name [lsort [array names \
        debugger evaluateViaTemporaryFile:*]] {
      set fileName $debugger($name)

      if {[file exists $fileName] && \
          [file isfile $fileName]} then {
        if {[catch {file delete $fileName} error] == 0} then {
          unset -nocomplain debugger($name)
          lappend result $fileName
        } else {
          if {$verbose > 0} then {
            tputs [getTestChannelOrDefault] [appendArgs \
                "---- temporary script cleanup failure (2): " \
                $error \n]
          }
        }
      }
    }

    return $result
  }

  proc getKnownTclVariables {} {
    # <help>
    # This procedure returns the sorted list of well-known global variable
    # names defined and used by the native Tcl core library and its shell
    # (such as argv, env, errorInfo, tcl_platform, and the auto_* loader
    # variables).  It exists so that state-cleanup logic can recognize these
    # as legitimate, expected globals and avoid destroying them when scrubbing
    # leftover variables between tests.
    #
    # How it works: it first guards on the call frame -- because only global
    # variables are meaningful here, it returns the empty list unless invoked
    # from the global frame (verified via [uplevel 1 info level] returning 0).
    # Otherwise it returns a hard-coded, lexically sorted list of the
    # documented Tcl variable names.
    #
    # Tricky details: the list is curated by hand from the Tcl documentation
    # and so may drift as Tcl evolves; it is platform-agnostic (it includes
    # every documented variable regardless of operating system).
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   A sorted list of well-known Tcl global variable names, or the empty
    #   list when not called from the global frame.
    # </help>

    #
    # HACK: If the caller is not the global frame (somehow?), then return
    #       nothing, as we can only handle global variables.
    #
    if {[uplevel 1 [list info level]] != 0} then {
      return [list]
    }

    #
    # HACK: This is the list of documented global variables that are used
    #       by the Tcl core library and/or its shell (on any platform).
    #       Please refer to the following web pages:
    #
    #       https://www.tcl.tk/man/tcl8.4/TclCmd/tclvars.htm
    #       https://wiki.tcl.tk/tclvars
    #
    return [lsort [list \
        argc \
        argv \
        argv0 \
        auto_execs \
        auto_index \
        auto_noexec \
        auto_noload \
        auto_oldpath \
        auto_path \
        env \
        errorCode \
        errorInfo \
        tclDefaultLibrary \
        tcl_interactive \
        tcl_libpath \
        tcl_library \
        tcl_patchLevel \
        tcl_pkgPath \
        tcl_platform \
        tcl_precision \
        tcl_prompt1 \
        tcl_prompt2 \
        tcl_rcFileName \
        tcl_rcRsrcName \
        tcl_traceCompile \
        tcl_traceExec \
        tcl_version \
        tcl_wordchars \
        tcl_nonwordchars \
        unknown_pending]]
  }

  proc getKnownTclTkVariables {} {
    # <help>
    # This procedure returns the sorted list of well-known global variable
    # names used by the TclTk core library and its shell that are not already
    # reported by [info sysvars] (currently the tcl_prompt1 through tcl_prompt8
    # interactive prompt variables).  It exists so that state-cleanup logic can
    # treat these as expected globals and not erase them when removing stray
    # variables between tests.
    #
    # How it works: like its companions, it returns the empty list unless
    # called from the global frame (since only global variables are
    # meaningful), then returns a hard-coded, lexically sorted list of names.
    #
    # Tricky details: this list is intentionally narrow -- it covers only the
    # extra TclTk-specific globals that the system-variable introspection does
    # not already surface, and is expected to grow as such variables are added.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   A sorted list of well-known TclTk global variable names, or the empty
    #   list when not called from the global frame.
    # </help>

    #
    # HACK: If the caller is not the global frame (somehow?), then return
    #       nothing, as we can only handle global variables.
    #
    if {[uplevel 1 [list info level]] != 0} then {
      return [list]
    }

    #
    # HACK: This is the list of documented global variables that are used
    #       by the TclTk core library and/or its shell (on any platform).
    #
    # TODO: This list should be updated in the event that extra variables
    #       are used by the TclTk core library (etc) and are purposely (?)
    #       not included in the [info sysvars] sub-command results.
    #
    return [lsort [list \
        tcl_prompt1 \
        tcl_prompt2 \
        tcl_prompt3 \
        tcl_prompt4 \
        tcl_prompt5 \
        tcl_prompt6 \
        tcl_prompt7 \
        tcl_prompt8]]
  }

  proc getKnownTestVariables {} {
    # <help>
    # This procedure returns the sorted list of global variable names that the
    # test harness itself relies upon (the large family of test_* variables
    # such as test_channel, test_constraints, test_log, test_run_id, and so
    # on, plus the bare "path" variable).  It exists so that state-cleanup
    # logic can preserve the harness's own configuration and bookkeeping
    # variables while still scrubbing variables left behind by individual
    # tests.
    #
    # How it works: it returns the empty list unless called from the global
    # frame (only globals are meaningful), then returns a hard-coded,
    # lexically sorted list of the test harness variable names.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   A sorted list of well-known test-harness global variable names, or the
    #   empty list when not called from the global frame.
    # </help>

    #
    # HACK: If the caller is not the global frame (somehow?), then return
    #       nothing, as we can only handle global variables.
    #
    if {[uplevel 1 [list info level]] != 0} then {
      return [list]
    }

    return [lsort [list \
        path \
        test_all_path \
        test_base_cops \
        test_base_cops_multipliers \
        test_break_on_leak \
        test_channel \
        test_configuration \
        test_constraints \
        test_cops \
        test_data_path \
        test_database \
        test_database_subst \
        test_database_table \
        test_database_type \
        test_exit_on_complete \
        test_extra_paths \
        test_file \
        test_flags \
        test_home_path \
        test_host \
        test_hosts \
        test_join_timeout \
        test_listed_leaks \
        test_log \
        test_log_id \
        test_log_path \
        test_log_queue \
        test_log_sentry \
        test_long_timeout \
        test_machine \
        test_mdas \
        test_name_prefix \
        test_package_path \
        test_path \
        test_platform \
        test_port \
        test_puts_state \
        test_random_order \
        test_repository_checkout \
        test_repository_file \
        test_repository_tags \
        test_repository_url \
        test_run_bucket \
        test_run_id \
        test_script \
        test_settings_path \
        test_statistics \
        test_stop_on_failure \
        test_stop_on_leak \
        test_stress_count \
        test_suffix \
        test_suite \
        test_suite_errors \
        test_suite_file \
        test_suite_running \
        test_tclsh \
        test_tclsh_raw \
        test_tclsh_verbose \
        test_threshold \
        test_timeout \
        test_timestamp \
        test_uncounted_leaks \
        test_visual_studio \
        test_verbose \
        test_volume \
        test_wait \
        test_well_known \
        test_wix]]
  }

  proc getKnownOtherVariables {} {
    # <help>
    # This procedure returns the sorted list of additional well-known global
    # variables that do not belong to the Tcl, TclTk, or test-harness
    # categories but must still be preserved during state cleanup -- for
    # example, the various path variables (base_path, bin_path, lib_path, and
    # the like), the no() flags array, and support arrays used by the C#
    # compilation and [exec] helper packages.  It exists to round out the set
    # of globals that cleanup logic should leave intact.
    #
    # How it works: it returns the empty list unless called from the global
    # frame.  Otherwise it builds a base list of path and flag variable names.
    # When NOT running on TclTk it appends "tcltk_platform" (so the emulated
    # runtime options it carries are preserved) and "tcltk_debugger" (so the
    # current test name used by [getTestName] survives); under real TclTk
    # these are system variables and need not be listed.  It always appends
    # "compileCSharp" and "getRuntimeCommandLine", the configuration arrays
    # used by the C# compiler and exec helper packages respectively.  Finally
    # it returns the whole set lexically sorted.
    #
    # Tricky details: the trailing "EXEMPT" comments on certain entries are
    # markers for tooling and are not part of the variable names.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   A sorted list of these "other" well-known global variable names, or
    #   the empty list when not called from the global frame.
    # </help>

    #
    # HACK: If the caller is (somehow?) not the global frame, we should
    #       return nothing, as we can only handle global variables.
    #
    if {[uplevel 1 [list info level]] != 0} then {
      return [list]
    }

    set result [list \
        base_path \
        bin_file \
        bin_path \
        core_bin_path \
        core_lib_path \
        key_path \
        lib_path \
        native_lib_path \
        no \
        root_path]

    #
    # HACK: When running on TclTk, tcltk_platform is a system variable
    #       and does not need to be returned from this procedure.
    #
    if {![isTclTk]} then {
      #
      # HACK: This is necessary to preserve runtime options, which are
      #       contained in the tcltk_platform(runtimeOptions) element.
      #
      lappend result tcltk_platform

      #
      # HACK: This is necessary to preserve the current test name for
      #       use by the [getTestName] procedure.
      #
      lappend result tcltk_debugger
    }

    #
    # HACK: This (optional global) array variable is used extensively
    #       by the script package used to compile arbitrary C# code at
    #       runtime.
    #
    lappend result compileCSharp; # EXEMPT

    #
    # HACK: This (optional global) array variable is used by the [exec]
    #       support package in order for it to determine the (optional)
    #       extra arguments to use for each runtime.
    #
    lappend result getRuntimeCommandLine; # EXEMPT

    #
    # NOTE: Return the full list of "other" well-known variables we are
    #       aware of, in sorted order.
    #
    return [lsort $result]
  }

  proc cleanState {
          {namespaceName ""} {excludePatterns ""} {noTclTk false}
          {noTest false} {noOther false} {checkOnly false} } {
    # <help>
    # This procedure removes "stray" variables from a call frame -- those that
    # are not among the recognized Tcl, TclTk, test-harness, or other
    # well-known globals -- so that test state can be reset to a clean
    # baseline.  It exists to detect and undo variable leakage caused by tests
    # that forget to clean up after themselves, and (in check-only mode) to
    # report on such leaks without actually disturbing anything.
    #
    # How it works: it builds the set of variables to consider via [info vars]
    # (optionally restricted to a namespace prefix) and the set of variables
    # to spare via [info sysvars] in TclTk, or [getKnownTclVariables] in Tcl.
    # Unless suppressed by the corresponding no* flags, it augments the
    # spared set with the known TclTk, test, and other variable names from
    # their respective helper procedures.  All of these introspection calls
    # run in the caller's frame via [uplevel 1].  It then walks every
    # candidate variable, skipping any that match an exclude pattern (tested
    # via [inverseLsearchGlob]) or that appear in the spared set; the rest are
    # the strays.  For each stray, when not in check-only mode it attempts to
    # [unset -nocomplain] the variable in the caller's frame and records an ok
    # or error entry; in check-only mode it does not unset, instead recording
    # whether the variable is an array or a scalar (or an error probing it).
    #
    # Tricky details: matching against the spared globals is exact, while the
    # exclude patterns are glob-style.  Because everything is performed via
    # [uplevel 1], the variables operated on are those of the immediate
    # caller, not of this procedure.
    #
    # Arguments:
    #   namespaceName   -- Optional namespace prefix; when non-empty, only
    #                      variables under that namespace are considered.
    #   excludePatterns -- A list of glob patterns; matching variables are
    #                      left untouched.
    #   noTclTk         -- A boolean; when true, the known TclTk variables are
    #                      not added to the spared set.  Defaults to false.
    #   noTest          -- A boolean; when true, the known test variables are
    #                      not added to the spared set.  Defaults to false.
    #   noOther         -- A boolean; when true, the known "other" variables
    #                      are not added to the spared set.  Defaults to false.
    #   checkOnly       -- A boolean; when true, strays are reported but not
    #                      unset.  Defaults to false.
    #
    # Results:
    #   A list describing the strays.  When unsetting, each entry is the
    #   variable name paired with "ok" or with "error" and a message.  In
    #   check-only mode, each entry is the variable name paired with "array"
    #   or "scalar" (or "error" and a message).
    # </help>

    set result [list]

    if {[string length $namespaceName] > 0} then {
      set command(all) [list \
          info vars [appendArgs $namespaceName ::*]]

      if {[isTclTk]} then {
        set command(sys) [list \
            info sysvars [appendArgs $namespaceName ::*]]
      } else {
        #
        # BUGBUG: There are no documented built-in
        #         script variables that reside in
        #         non-global namespaces within the
        #         native Tcl implementation.
        #
        # TODO: This may change in the future.
        #
        set command(sys) [list]
      }
    } else {
      set command(all) [list info vars]

      if {[isTclTk]} then {
        set command(sys) [list info sysvars]
      } else {
        set command(sys) [list getKnownTclVariables]
      }
    }

    set varNames(all) [uplevel 1 $command(all)]
    set varNames(sys) [uplevel 1 $command(sys)]

    if {!$noTclTk && [isTclTk]} then {
      eval lappend varNames(sys) [uplevel 1 getKnownTclTkVariables]
    }

    if {!$noTest} then {
      eval lappend varNames(sys) [uplevel 1 getKnownTestVariables]
    }

    if {!$noOther} then {
      eval lappend varNames(sys) [uplevel 1 getKnownOtherVariables]
    }

    foreach varName $varNames(all) {
      if {[inverseLsearchGlob false $excludePatterns $varName] == -1 && \
          [lsearch -exact $varNames(sys) $varName] == -1} then {
        #
        # NOTE: Remove the variable from the target call frame, ignoring
        #       any errors and then add the variable name to the overall
        #       result of this procedure.
        #
        if {$checkOnly || [catch {
          uplevel 1 [list unset -nocomplain $varName]
        } error] == 0} then {
          if {$checkOnly} then {
            if {[catch {expr {[uplevel 1 \
                [list array exists $varName]] ? "array" : "scalar"
            }} varResult] == 0} then {
              lappend result [list $varName $varResult]
            } else {
              lappend result [list $varName error $varResult]
            }
          } else {
            lappend result [list $varName ok]
          }
        } else {
          lappend result [list $varName error $error]
        }
      }
    }

    return $result
  }

  proc dumpState { {namespaceName ""} } {
    # <help>
    # This procedure captures a snapshot of all variables visible in the
    # caller's frame, returning a dictionary that records each variable's name
    # along with its kind and value.  It exists for diagnostics and for
    # before/after comparisons -- for example, to inspect or log the variable
    # state surrounding a test.
    #
    # How it works: it enumerates variables via [info vars] (optionally
    # restricted to a namespace prefix) in the caller's frame and sorts the
    # names.  For each name, performing all probes in the caller's frame via
    # [uplevel 1], it classifies the variable: an array becomes a value of the
    # form "array" followed by the [array get] contents; a defined scalar
    # becomes "scalar" followed by its value; anything else becomes
    # "undefined".  Each name and its classified value are appended to the
    # result.
    #
    # Arguments:
    #   namespaceName -- Optional namespace prefix; when non-empty, only
    #                    variables under that namespace are dumped.  Defaults
    #                    to empty, meaning all visible variables.
    #
    # Results:
    #   A dictionary mapping each variable name to a two-or-more-element list
    #   describing it: an "array" with its contents, a "scalar" with its
    #   value, or "undefined".
    # </help>

    set result [list]

    if {[string length $namespaceName] > 0} then {
      set command [list \
          info vars [appendArgs $namespaceName ::*]]
    } else {
      set command [list info vars]
    }

    set varNames [lsort [uplevel 1 $command]]

    foreach varName $varNames {
      if {[uplevel 1 [list array exists $varName]]} then {
        lappend result $varName [list \
            array [uplevel 1 [list array get $varName]]]
      } elseif {[uplevel 1 [list info exists $varName]]} then {
        lappend result $varName [list \
            scalar [uplevel 1 [list set $varName]]]
      } else {
        lappend result $varName [list undefined]
      }
    }

    return $result
  }

  proc needTestDoEvents {} {
    # <help>
    # This procedure decides whether the test harness needs to actively pump
    # the event loop (via [testDoEvents]) during tests.  It exists because
    # certain runtime configurations -- notably TclTk on Mono with WinForms --
    # will not make progress on queued GUI/window events unless the script
    # explicitly processes them, whereas other configurations handle this
    # transparently.
    #
    # How it works: if the no(needTestDoEvents) override flag is set it returns
    # true, forcing event processing (returning true is the exceptional case,
    # since the normal default is false).  Otherwise it returns true only when
    # all of the following hold: running under TclTk, running on Mono, and
    # having both the compile.WINFORMS and winForms constraints -- i.e. the
    # specific Mono-plus-WinForms scenario that requires manual pumping.  In
    # every other case (native Tcl, or TclTk on the .NET Framework/.NET Core,
    # or builds without WinForms) it returns false.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   True if the harness should manually process events, false otherwise.
    # </help>

    if {[info exists ::no(needTestDoEvents)]} then {
      #
      # HACK: Disable this procedure, thus forcing some events to be
      #       processed.  This returns true because the default (i.e.
      #       non-exceptional) result is false.
      #
      return true
    }

    if {[isTclTk] && [isMono] && [haveConstraint compile.WINFORMS] && \
        [haveConstraint winForms]} then {
      #
      # NOTE: This is TclTk running on Mono with WinForms support.
      #
      return true
    }

    #
    # NOTE: This is either native Tcl -OR- TclTk running on the .NET
    #       Framework (or .NET Core?) -OR- without WinForms support.
    #
    return false
  }

  proc testDoEvents { milliseconds } {
    # <help>
    # This procedure pumps the event loop for an approximate duration, giving
    # pending events (such as WinForms messages or queued callbacks) a chance
    # to be processed during a test.  It exists to let tests deterministically
    # service asynchronous work without busy-spinning, in environments where
    # [needTestDoEvents] indicates manual pumping is required.
    #
    # How it works: for a positive duration it chooses a sleep interval of at
    # least 50 milliseconds (or one-fortieth of the requested time, whichever
    # is larger) and loops until the accumulated elapsed time reaches the
    # requested total.  On each pass it processes events -- in TclTk via
    # [update +Count], which reports how many events ran and is added to the
    # count; in Tcl via plain [update], counting one pass -- then sleeps the
    # interval and adds it to the running total.  A duration of exactly zero
    # processes events a single time without sleeping.  A negative duration
    # does nothing.
    #
    # Tricky details: the elapsed total is approximate, accumulated from the
    # nominal sleep interval rather than measured wall-clock time, so the
    # actual time spent may exceed the request slightly.
    #
    # Arguments:
    #   milliseconds -- The approximate amount of time to spend processing
    #                   events: positive to loop for that long, zero to
    #                   process events once, negative to do nothing.
    #
    # Results:
    #   A two-element list: the number of event-processing passes (or events,
    #   in TclTk) and the approximate elapsed milliseconds.
    # </help>

    set count 0; set total 0

    if {$milliseconds > 0} then {
      set sleep [expr {max(50, int($milliseconds / 40.0))}]

      while {$total < $milliseconds} {
        if {[isTclTk]} then {
          incr count [update +Count]
        } else {
          update; incr count; # NOTE: Pending events (e.g. WinForms)?
        }

        after $sleep;         # NOTE: Sleep to prevent excess spinning.
        incr total $sleep;    # NOTE: Keep track of approx elapsed time.
      }
    } elseif {$milliseconds == 0} then {
      #
      # NOTE: The number of milliseconds is exactly zero, process
      #       events exactly one time.
      #
      if {[isTclTk]} then {
        incr count [update +Count]
      } else {
        update; incr count
      }
    } else {
      #
      # NOTE: The number of milliseconds is negative, do nothing.
      #
    }

    return [list $count $total]
  }

  proc trawputs { channel string } {
    # <help>
    # This procedure writes a string to an output channel with no trailing
    # newline and no repeat-collapsing -- the lowest-level "raw" output
    # primitive used by the test logging layer.  It exists so that higher-level
    # output helpers have a single, well-behaved place to actually emit bytes,
    # while transparently honoring any output interception that may be in
    # effect.
    #
    # How it works: if the channel is empty the message is silently discarded.
    # Otherwise, under native Tcl, if the harness has installed an output
    # interceptor (detected by the presence of a saved ::tcl::save::puts
    # command), it routes through that saved command so the bytes bypass the
    # interceptor and reach the real channel; in all other cases it uses the
    # ordinary [puts].  Output is always written with -nonewline so callers
    # control line termination themselves.
    #
    # Arguments:
    #   channel -- The output channel to write to; an empty value means
    #              discard the message.
    #   string  -- The string to write (no newline is appended).
    #
    # Results:
    #   An empty string.
    # </help>

    #
    # NOTE: If an output channel was provided, use it; otherwise, ignore
    #       the message.
    #
    if {[string length $channel] > 0} then {
      #
      # NOTE: Check if output is being actively intercepted by us.
      #
      if {![isTclTk] && \
          [llength [info commands ::tcl::save::puts]] > 0} then {
        ::tcl::save::puts -nonewline $channel $string
      } else {
        puts -nonewline $channel $string
      }
    }
  }

  proc doesTestOutputRepeat { channel string } {
    # <help>
    # This procedure implements consecutive-duplicate suppression for test
    # output: it tracks the most recently emitted line and tells the caller
    # whether the current line is an exact repeat that should be withheld.  It
    # exists to keep logs and consoles readable when a test emits the same line
    # many times in a row, replacing the flood with a single "was output a
    # total of N consecutive times" summary line.
    #
    # How it works: if the no(testOutputRepeat) flag is set, suppression is
    # disabled and it returns false (allow output).  Empty or whitespace-only
    # strings are always allowed without touching the tracking state.  All
    # remaining work is performed under a [vwaitLocked] on the global
    # ::test_puts_state, because in TclTk that state may be touched by multiple
    # threads.  It keeps a previousString and a repeatCount.  A reusable inner
    # script emits the pending "consecutive times" summary (using [toneputs])
    # and resets the count whenever a run of duplicates ends.  Partial-line
    # output (one not ending in a newline) flushes any pending summary, resets
    # the tracking state, and is allowed verbatim.  When there is no recorded
    # previous string, or the current string differs from it, the pending
    # summary is flushed if needed, the current string is recorded as the new
    # previous string, and output is allowed (returns false).  When the current
    # string matches the previous one, the repeat count is incremented (or
    # initialized) and output is withheld (returns true).
    #
    # Tricky details: the summary line is emitted lazily -- only when the run
    # of duplicates is broken or a partial line arrives -- and the count shown
    # is the total occurrences including the one originally emitted.  Several
    # branches use a compact "command; return value" form on a single line.
    #
    # Arguments:
    #   channel -- The output channel; used when emitting the deferred repeat
    #              summary line.
    #   string  -- The candidate output string being considered.
    #
    # Results:
    #   True if the string is a consecutive duplicate and should be suppressed;
    #   false if it should be emitted normally.
    # </help>

    #
    # NOTE: Is the test output repeat detection completely disabled?
    #
    if {[info exists ::no(testOutputRepeat)]} then {return false}

    #
    # NOTE: Is the string empty (i.e. emitting a blank line) -OR- does
    #       it consist only of whitespace?  If so, always allow it and
    #       avoid modifying our internal tracking state, for the sake
    #       of simplicity.
    #
    if {[string length $string] == 0 || \
        [string length [string trim $string]] == 0} then {
      return false
    }

    #
    # BUGFIX: In TclTk, it is possible that the "test_puts_state" global
    #         variable may be accessed from multiple threads, e.g. those
    #         that call into the [tputs] procedure; therefore, we use a
    #         variable lock to prevent it from getting into an internally
    #         inconsistent state.
    #
    vwaitLocked ::test_puts_state true {
      #
      # NOTE: Create a reusable script block that handles emitting the
      #       repeated output indicator (and resets the repeat count).
      #
      set maybeRepeatStringScript {
        if {[info exists ::test_puts_state(previousString)] && \
            [info exists ::test_puts_state(repeatCount)] && \
            $::test_puts_state(repeatCount) > 0} then {
          incr ::test_puts_state(repeatCount)

          set repeatString [appendArgs \
              $::test_puts_state(previousString) \
              "\t<was output a total of " \
              $::test_puts_state(repeatCount) \
              " consecutive times>\n"]

          toneputs $channel $repeatString
          set ::test_puts_state(repeatCount) 0
        }
      }

      #
      # HACK: For now, for partial line output, reset internal tracking
      #       state and allow it verbatim.
      #
      if {[string index $string end] ne "\n"} then {
        #
        # NOTE: *SPECIAL* Emit repeat count line now and reset it back
        #       to zero.
        #
        eval $maybeRepeatStringScript

        #
        # NOTE: Since the current string is partial line output, reset
        #       our internal tracking state and allow output verbatim.
        #
        unset -nocomplain ::test_puts_state; return false
      }

      #
      # NOTE: Have we not seen any valid previous string?
      #
      if {![info exists ::test_puts_state(previousString)]} then {
        #
        # NOTE: There was no previous string, so the current string is
        #       now the previous string.  It must be emitted directly.
        #
        set ::test_puts_state(previousString) $string; return false
      }

      #
      # NOTE: Is the current string different from the previous string?
      #
      if {![string equal $string $::test_puts_state(previousString)]} then {
        #
        # NOTE: *SPECIAL* Emit repeat count line now and reset it back
        #       to zero.
        #
        eval $maybeRepeatStringScript

        #
        # NOTE: Next, since previous string does not match the current
        #       one (i.e. it has never been emitted directly), so allow
        #       it to be emitted directly.
        #
        set ::test_puts_state(previousString) $string; return false
      }

      #
      # NOTE: Current string matches the previous one, so increment or
      #       reset the repeat count and prevent the current (repeated)
      #       string from being emitted (i.e. as it was already emitted
      #       once).
      #
      if {[info exists ::test_puts_state(repeatCount)]} then {
        incr ::test_puts_state(repeatCount); # another duplicate
      } else {
        set ::test_puts_state(repeatCount) 1; # first duplicate
      }

      return true
    }
  }

  proc dputs { string } {
    # <help>
    # This procedure writes a string to the engine's debug output sink via the
    # [debug output] command.  It is a terse convenience wrapper ("debug puts")
    # used to emit diagnostic text to the debug stream.
    #
    # Arguments:
    #   string -- The text to send to the debug output sink.
    #
    # Results:
    #   The result of the underlying [debug output] command.
    # </help>

    debug output $string
  }

  proc dlog { string } {
    # <help>
    # This procedure writes a string to the engine's debug log via the
    # [debug log] command.  It is a terse convenience wrapper ("debug log")
    # used to record diagnostic text in the debug log.
    #
    # Arguments:
    #   string -- The text to append to the debug log.
    #
    # Results:
    #   The result of the underlying [debug log] command.
    # </help>

    debug log $string
  }

  proc toneputs { channel string } {
    # <help>
    # This procedure emits a string to both the test output channel and the
    # test log file in one step, without any duplicate-suppression.  Its name
    # reflects that it outputs "one" copy unconditionally (in contrast to
    # [tputs], which filters consecutive duplicates).  It exists so that lines
    # which must always appear -- including the repeat-summary lines produced
    # by the duplicate detector -- can be written directly.
    #
    # How it works: it calls [trawputs] to write the string to the channel and
    # [tlog] to record it in the test log file.
    #
    # Arguments:
    #   channel -- The output channel to write to (may be empty to skip
    #              channel output).
    #   string  -- The text to emit and log.
    #
    # Results:
    #   The result of the [tlog] call.
    # </help>

    trawputs $channel $string; tlog $string
  }

  proc tputs { channel string } {
    # <help>
    # This procedure is the standard test-output primitive: it writes a string
    # to the test channel and log unless it is a consecutive duplicate, in
    # which case it is suppressed.  It is the routine that virtually all test
    # diagnostic output flows through, combining duplicate collapsing with
    # channel-plus-log emission.
    #
    # How it works: it consults [doesTestOutputRepeat] to decide whether the
    # string is a repeat that should be withheld; if not, it forwards the
    # string to [toneputs] for actual output and logging.
    #
    # Arguments:
    #   channel -- The output channel to write to (may be empty to skip
    #              channel output).
    #   string  -- The text to emit and log.
    #
    # Results:
    #   The result of [toneputs] when the string is emitted, or the empty
    #   result when it is suppressed as a duplicate.
    # </help>

    if {![doesTestOutputRepeat $channel $string]} then {
      toneputs $channel $string
    }
  }

  #
  # NOTE: This is a shim designed to act like tclLog.
  #
  proc ttclLog { string } {
    # <help>
    # This procedure is a drop-in replacement for the Tcl core's [tclLog]
    # routine, redirecting such logging through the test harness output
    # machinery.  It exists so that messages the Tcl library would normally
    # send to [tclLog] (for example, background error reports) are captured in
    # the test channel and log instead.
    #
    # How it works: it forwards the message, with a trailing newline appended,
    # to [tputs] using the channel from [getTestChannelOrDefault].
    #
    # Arguments:
    #   string -- The log message; a newline is appended automatically.
    #
    # Results:
    #   The result of the underlying [tputs] call.
    # </help>

    tputs [getTestChannelOrDefault] [appendArgs $string \n]
  }

  proc doesTestLogFileExist { fileName } {
    # <help>
    # This procedure reports whether a test log file both exists and is
    # non-empty.  It exists because the logging code treats a missing or
    # zero-length log file as needing a fresh "start sentry" header; this
    # predicate captures that "is there real content already?" check in one
    # safe place.
    #
    # How it works: it evaluates, inside a [catch], whether the file exists and
    # has a size greater than zero.  Any error during the probe, or a false
    # result, yields false; a successful true result yields true.
    #
    # Arguments:
    #   fileName -- The path of the candidate test log file.
    #
    # Results:
    #   True if the file exists and is non-empty, false otherwise (including on
    #   any error probing the file).
    # </help>

    if {[catch {
      expr {[file exists $fileName] && [file size $fileName] > 0}
    } result] == 0 && $result} then {
      return true
    } else {
      return false
    }
  }

  proc getTestLogStartSentry {} {
    # <help>
    # This procedure builds the "start sentry" line that marks the beginning
    # of a test log for a particular run.  The sentry embeds the current test
    # run identifier so that, later, tooling can recognize where a run's log
    # output begins and to which run it belongs.  It exists to centralize the
    # exact textual form of that marker.
    #
    # How it works: if the global ::test_run_id is not yet set, it generates a
    # fresh one via [getNewTestRunId] (a defensive fallback; ordinarily the
    # test prologue establishes it).  It then returns a line of the form
    # "**** START OF TEST LOG ..." that quotes the run id and ends with a
    # newline.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   The start-sentry line, including its trailing newline, embedding the
    #   current test run identifier.
    # </help>

    #
    # TODO: Why is this necessary here?  In general, the test prologue
    #       should take care of this?  Of course, that assumption would
    #       mean a slight increase in tight coupling between components.
    #
    if {![info exists ::test_run_id]} then {
      set ::test_run_id [getNewTestRunId]
    }

    return [appendArgs \
        "**** START OF TEST LOG \"" $::test_run_id "\" ****\n"]
  }

  proc readTestLogStartSentry { fileName } {
    # <help>
    # This procedure scans an existing log file for the first valid "start
    # sentry" line and returns the test run identifier embedded in it.  It
    # exists so that the run id associated with a previously written log can be
    # recovered by reading the file back, for example to correlate or resume
    # logging.
    #
    # How it works: it opens the file read-only and switches it to binary mode
    # via [makeBinaryChannel] for byte-faithful reading.  It reads line by
    # line, trimming each and re-appending a newline, and passes it to
    # [extractTestRunIdFromLogStartSentry].  The first line that yields a
    # non-empty id other than "<none>" wins: that id is saved and the scan
    # stops.  A read failure also stops the scan.  The channel is closed before
    # returning.
    #
    # Arguments:
    #   fileName -- The path of the log file to scan.
    #
    # Results:
    #   The test run identifier from the first matching start sentry, or the
    #   empty string if none was found.
    # </help>

    set channel [open $fileName RDONLY]
    makeBinaryChannel $channel
    set result ""

    while {![eof $channel]} {
      if {[catch {gets $channel line}] == 0} then {
        set trimLine [appendArgs [string trim $line] \n]
        set value [extractTestRunIdFromLogStartSentry $trimLine]

        if {[string length $value] > 0 && $value ne "<none>"} then {
          set result $value; # NOTE: Save the extracted value.
          break; # NOTE: First sentry found, stop now.
        }
      } else {
        break; # NOTE: Cannot read, do not care why.
      }
    }

    close $channel
    return $result
  }

  proc extractTestRunIdFromLogStartSentry { sentry } {
    # <help>
    # This procedure parses a single start-sentry line and extracts the test
    # run identifier it contains.  It is the inverse of [getTestLogStartSentry]
    # and the parsing engine behind [readTestLogStartSentry].
    #
    # How it works: it composes a fixed prefix and suffix matching the literal
    # "**** START OF TEST LOG ... ****" framing, then tries two capture
    # patterns in turn.  The first expects a hexadecimal run id of at least 32
    # uppercase hex digits (the native Tcl form); the second expects exactly 64
    # such digits (the TclTk form).  The captured id from whichever pattern
    # matches is returned.
    #
    # Tricky details: the two patterns reflect the differing run-id lengths
    # produced by Tcl versus TclTk; both anchor the digits between the same
    # surrounding text, including a trailing newline.
    #
    # Arguments:
    #   sentry -- A candidate sentry line to parse.
    #
    # Results:
    #   The extracted run identifier when the line is a valid start sentry,
    #   otherwise the literal string "<none>".
    # </help>

    set prefix {^\*\*\*\* START OF TEST LOG "}
    set suffix {" \*\*\*\*\n$}

    set pattern(1) [appendArgs $prefix {([0-9A-F]{32,})} $suffix]; # Tcl

    if {[regexp -- $pattern(1) $sentry dummy result]} then {
      return $result
    }

    set pattern(2) [appendArgs $prefix {([0-9A-F]{64})} $suffix]; # TclTk

    if {[regexp -- $pattern(2) $sentry dummy result]} then {
      return $result
    }

    return <none>
  }

  proc doesTestLogHaveStartSentry {} {
    # <help>
    # This procedure reports whether the current test log file already contains
    # the start sentry for the current run.  It exists so the logging layer can
    # avoid writing a duplicate sentry header when one is already present.
    #
    # How it works: it obtains the active log file name via [getTestLog].  If
    # there is one and it exists with content (per [doesTestLogFileExist]), it
    # computes the trimmed expected sentry from [getTestLogStartSentry], reads
    # the whole file with [readSharedFile], and returns true when the sentry
    # text is found anywhere within the file contents.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   True if the current log file contains the current run's start sentry,
    #   false otherwise.
    # </help>

    set fileName [getTestLog]

    if {[string length $fileName] > 0} then {
      if {[doesTestLogFileExist $fileName]} then {
        set sentry [string trim [getTestLogStartSentry]]

        if {[string length $sentry] > 0} then {
          set data [readSharedFile $fileName]

          if {[string first $sentry $data] != -1} then {
            return true
          }
        }
      }
    }

    return false
  }

  proc didTestLogHaveStartSentry { sentry varName } {
    # <help>
    # This procedure reports whether a start sentry has already been recorded
    # in the in-memory tracking variable for this session, and -- when it has,
    # but disagrees with the supplied sentry -- produces a diagnostic message
    # describing the mismatch.  It exists to detect the dangerous situation
    # where the log's run identity appears to have changed mid-session (for
    # example, because the log file was deleted and a new run id slipped in),
    # so the logging code can react appropriately.
    #
    # How it works: it checks the global ::test_log_sentry.  If that variable
    # is set, the function considers a sentry to have already been recorded and
    # returns true; additionally, if the recorded sentry differs from the
    # supplied one, it links the named variable in the caller's frame and
    # stores a message reporting the old and new run identifiers (extracted via
    # [extractTestRunIdFromLogStartSentry]).  If ::test_log_sentry is not set,
    # it returns false and leaves the caller's variable untouched.
    #
    # Arguments:
    #   sentry  -- The sentry being compared against any previously recorded
    #              one.
    #   varName -- The name of a variable in the caller's frame that receives
    #              a mismatch diagnostic message, but only when a previously
    #              recorded sentry differs from "sentry".
    #
    # Results:
    #   True if a start sentry was already recorded for this session, false
    #   otherwise.
    # </help>

    if {[info exists ::test_log_sentry]} then {
      if {$::test_log_sentry ne $sentry} then {
        upvar 1 $varName error

        set error [appendArgs \
            "---- test log start sentry mismatch error, was \"" \
            [extractTestRunIdFromLogStartSentry $::test_log_sentry] \
            "\", now \"" [extractTestRunIdFromLogStartSentry $sentry] \
            \"\n]
      }

      return true
    } else {
      return false
    }
  }

  proc setTestLogStartSentry { sentry varName } {
    # <help>
    # This procedure records the start sentry for the current session in the
    # in-memory tracking variable and produces a human-readable message noting
    # whether it was initialized for the first time or reinitialized over a
    # prior value.  It exists so the logging code can both remember which
    # sentry is in effect and emit a corresponding informational log line.
    #
    # How it works: it links the named variable in the caller's frame.  If the
    # global ::test_log_sentry was already set, it composes a "reinitialized"
    # message reporting both the new and previous run identifiers (extracted
    # via [extractTestRunIdFromLogStartSentry]); otherwise it composes an
    # "initialized" message with just the new run id.  Finally it stores the
    # supplied sentry into ::test_log_sentry.
    #
    # Arguments:
    #   sentry  -- The sentry to record as the current one.
    #   varName -- The name of a variable in the caller's frame that receives
    #              the initialized/reinitialized diagnostic message.
    #
    # Results:
    #   The newly stored sentry (the result of setting ::test_log_sentry).
    # </help>

    upvar 1 $varName result

    if {[info exists ::test_log_sentry]} then {
      set result [appendArgs \
          "---- test log start sentry reinitialized to \"" \
          [extractTestRunIdFromLogStartSentry $sentry] \
          "\", was \"" [extractTestRunIdFromLogStartSentry \
          $::test_log_sentry] \"\n]
    } else {
      set result [appendArgs \
          "---- test log start sentry initialized to \"" \
          [extractTestRunIdFromLogStartSentry $sentry] \
          \"\n]
    }

    set ::test_log_sentry $sentry
  }

  proc dtrace { string } {
    # <help>
    # This procedure emits a string through the engine's diagnostic trace
    # facility at a high, always-on priority.  It is a terse convenience
    # wrapper ("debug trace") for sprinkling trace output into scripts, and is
    # deliberately forgiving of failures.
    #
    # How it works: it calls [debug trace] with a priority of always/demand/
    # debug for the given string, wrapped in a [catch] so that any failure in
    # the trace subsystem is silently ignored rather than disrupting the
    # caller.
    #
    # Arguments:
    #   string -- The text to emit to the trace facility.
    #
    # Results:
    #   An empty string (the result of the surrounding [catch]; errors are
    #   suppressed).
    # </help>

    catch {
      debug trace -priority {:Always Demand Debug} -- $string
    }
  }

  proc tlog { string } {
    # <help>
    # This procedure appends a string to the configured test log file, first
    # flushing any queued log entries and ensuring the file is properly
    # prefixed with its start sentry.  It is the persistence half of the test
    # output system (the companion to channel output), and is invoked
    # indirectly whenever [toneputs]/[tputs] record a line.
    #
    # How it works: it obtains the log file name from [getTestLog]; if none is
    # configured, it does nothing.  All work happens under a [vwaitLocked] on
    # the global ::test_log_queue, because that queue is shared across threads.
    # It first drains the queue: for each queued entry, in integer-sorted
    # order, it writes the entry's non-empty text to the file (via
    # [appendSharedLogFile]), removes the entry, and once the queue is empty
    # unsets it.  Both when draining queued entries and when writing the
    # caller's string, if the log file does not yet exist with content it makes
    # sure the start sentry is written exactly once: it consults
    # [didTestLogHaveStartSentry] to avoid re-adding a sentry (which would
    # wrongly mark a deleted-and-recreated log as already complete), otherwise
    # it records the sentry via [setTestLogStartSentry] and appends the sentry
    # plus any resulting diagnostic line.  An empty caller string is ignored
    # for the direct-append step (though the queue is still drained).
    #
    # Tricky details: the start-sentry handling is duplicated for the queued
    # path and the direct path, and the careful "did we already have a sentry?"
    # check exists specifically to handle a log file that was deleted mid-run.
    #
    # Arguments:
    #   string -- The text to append to the log file; an empty string causes
    #             only the queue flush to occur.
    #
    # Results:
    #   An empty result.
    # </help>

    #
    # NOTE: If a test log file was configured, use it; otherwise, ignore the
    #       message.
    #
    set fileName [getTestLog]

    if {[string length $fileName] > 0} then {
      #
      # NOTE: Check for any queued test log data that needs to be sent to the
      #       log file prior to sending the current string.
      #
      # BUGFIX: As of beta 47, use of the "test_log_queue" global variable is
      #         thread-safe.
      #
      vwaitLocked ::test_log_queue true {
        if {[info exists ::test_log_queue]} then {
          #
          # NOTE: Process each queued log entry, in order, sending them to the
          #       test log file (as long as they are not empty strings).  Each
          #       entry is removed from the queue after it is sent to the test
          #       log file.
          #
          foreach entry [lsort -integer [array names ::test_log_queue]] {
            set newString $::test_log_queue($entry)

            if {[string length $newString] > 0} then {
              if {![doesTestLogFileExist $fileName]} then {
                set sentry [getTestLogStartSentry]

                if {[string length $sentry] > 0} then {
                  #
                  # BUGFIX: At this point, there should not be any record of
                  #         a previously used test log sentry.  If there is,
                  #         do not append a test log sentry again because the
                  #         test log file may have been deleted and we need
                  #         to make sure the test log is not considered as
                  #         "complete".
                  #
                  if {[didTestLogHaveStartSentry $sentry sentryError]} then {
                    if {[info exists sentryError]} then {
                      appendSharedLogFile $fileName $sentryError
                    }
                  } else {
                    setTestLogStartSentry $sentry sentryResult

                    appendSharedLogFile $fileName $sentry

                    if {[info exists sentryResult]} then {
                      appendSharedLogFile $fileName $sentryResult
                    }
                  }
                }
              }

              appendSharedLogFile $fileName $newString
            }

            unset ::test_log_queue($entry)
          }

          #
          # NOTE: If all entries in the test log queue were just processed,
          #       unset the entire array now.
          #
          if {[array size test_log_queue] == 0} then {
            unset ::test_log_queue
          }
        }
      }

      #
      # NOTE: If an empty string is supplied by the caller, do nothing.
      #
      if {[string length $string] > 0} then {
        if {![doesTestLogFileExist $fileName]} then {
          set sentry [getTestLogStartSentry]

          if {[string length $sentry] > 0} then {
            #
            # BUGFIX: At this point, there should not be any record of a
            #         previously used test log sentry.  If there is, do
            #         not append a test log sentry again because the test
            #         log file may have been deleted and we need to make
            #         sure the test log is not considered as "complete".
            #
            if {[didTestLogHaveStartSentry $sentry sentryError]} then {
              if {[info exists sentryError]} then {
                appendSharedLogFile $fileName $sentryError
              }
            } else {
              setTestLogStartSentry $sentry sentryResult

              appendSharedLogFile $fileName $sentry

              if {[info exists sentryResult]} then {
                appendSharedLogFile $fileName $sentryResult
              }
            }
          }
        }

        appendSharedLogFile $fileName $string
      }
    }
  }

  proc getSoftwareRegistryKey { wow64 } {
    # <help>
    # This procedure returns the relative Windows registry key path under which
    # software settings live, choosing between the native "Software" path and
    # the WoW64 "Software\\Wow6432Node" redirected path.  It exists so that
    # registry-probing test code can find 32-bit application entries on 64-bit
    # Windows when desired.
    #
    # How it works: it returns the WoW64 path only when the caller requests it
    # ("wow64" is true) AND the platform machine architecture (from
    # ::tcl_platform(machine)) is one of the 64-bit values ia64, amd64, or
    # arm64 -- i.e. when the redirected node actually exists.  In every other
    # case it returns the plain "Software" path.
    #
    # Arguments:
    #   wow64 -- A boolean requesting the 32-bit-on-64-bit (WoW64) redirected
    #            registry path.
    #
    # Results:
    #   Either "Software\\Wow6432Node" or "Software", as a relative key path.
    # </help>

    if {$wow64 && [info exists ::tcl_platform(machine)] && [lsearch -exact \
        [list ia64 amd64 arm64] $::tcl_platform(machine)] != -1} then {
      #
      # NOTE: Return the WoW64 registry key name because we are running on a
      #       64-bit operating system and the caller specifically requested
      #       the WoW64 registry key name.
      #
      return Software\\Wow6432Node
    } else {
      #
      # NOTE: Return the native registry key name because we are either not
      #       running on a 64-bit operating system or the caller wants the
      #       native registry key name (i.e. not the WoW64 registry key name).
      #
      return Software
    }
  }

  proc haveConstraint { name } {
    # <help>
    # This procedure reports whether a named test constraint is currently
    # active.  Test constraints gate whether individual tests run, based on
    # platform, feature availability, build options, and similar conditions;
    # this is the basic query used throughout the suite to ask "is feature X
    # available?".
    #
    # How it works: under TclTk, constraints are stored as a list in
    # ::tcltk_tests(Constraints); the procedure returns true when that list
    # exists and contains the name.  Under native Tcl, constraints live in the
    # ::tcltest::testConstraints array; it returns true when an element for the
    # name exists and is itself true.
    #
    # Arguments:
    #   name -- The constraint name to test for.
    #
    # Results:
    #   A boolean: true if the constraint is present and enabled, false
    #   otherwise.
    # </help>

    if {[isTclTk]} then {
      return [expr {
          [info exists ::tcltk_tests(Constraints)] && \
          [lsearch -exact $::tcltk_tests(Constraints) $name] != -1}]
    } else {
      return [expr {
          [info exists ::tcltest::testConstraints($name)] && \
          $::tcltest::testConstraints($name)}]
    }
  }

  proc addConstraint { name {value 1} } {
    # <help>
    # This procedure registers a test constraint, optionally with a truth
    # value, so that subsequent tests can be gated on it.  It is the basic
    # mutator paired with [haveConstraint], used during test setup to declare
    # which features and conditions are available.
    #
    # How it works: under TclTk, where constraints are simply a list of active
    # names, it appends the name to ::tcltk_tests(Constraints) only if that
    # list exists, the name is not already present, and the supplied value is
    # true -- i.e. a false value adds nothing.  Under native Tcl it delegates
    # to [::tcltest::testConstraint], which stores the name with the given
    # boolean value (so a false value records a disabled constraint).
    #
    # Tricky details: the two backends differ in how a false value is treated
    # -- TclTk simply does not add it, whereas Tcl records it as disabled.
    #
    # Arguments:
    #   name  -- The constraint name to add.
    #   value -- The truth value of the constraint.  Defaults to 1 (true).
    #
    # Results:
    #   An empty string.
    # </help>

    if {[isTclTk]} then {
      if {[info exists ::tcltk_tests(Constraints)] && \
          [lsearch -exact $::tcltk_tests(Constraints) $name] == -1 && \
          $value} then {
        lappend ::tcltk_tests(Constraints) $name
      }
    } else {
      ::tcltest::testConstraint $name $value
    }

    return ""
  }

  proc haveOrAddConstraint { name {value ""} } {
    # <help>
    # This procedure is a dual-purpose constraint accessor: called with just a
    # name it queries the constraint, and called with a name and value it sets
    # the constraint.  It exists as a single entry point mirroring the native
    # Tcl [testConstraint] command's overloaded query/set behavior.
    #
    # How it works: under TclTk it inspects its own argument count via [info
    # level 0]; if only the name was supplied (two words total), it behaves as
    # [haveConstraint] and returns the current state.  If a value was also
    # supplied, it behaves as [addConstraint], coercing the value to a boolean.
    # Under native Tcl it simply forwards to [::tcltest::testConstraint], whose
    # own query-versus-set behavior depends on whether a value was given.
    #
    # Tricky details: the distinction between "query" and "set" hinges on
    # whether the optional value argument was actually passed, not merely on
    # whether it is empty -- hence the argument-count check under TclTk.
    #
    # Arguments:
    #   name  -- The constraint name to query or set.
    #   value -- When supplied, the truth value to set; when omitted, the call
    #            is a query.
    #
    # Results:
    #   When querying, the constraint's current state; when setting, the result
    #   of the underlying add/set operation.
    # </help>

    if {[isTclTk]} then {
      if {[llength [info level 0]] == 2} then {
        return [haveConstraint $name]
      }

      return [addConstraint $name [expr {bool($value)}]]
    } else {
      return [::tcltest::testConstraint $name $value]
    }
  }

  proc getConstraints {} {
    # <help>
    # This procedure returns the complete list of currently active test
    # constraint names.  It exists so that the full constraint set can be
    # snapshotted, logged, or cached (see [getCachedConstraints]).
    #
    # How it works: under TclTk it reads the ::tcltk_tests(Constraints) list
    # (inside a [catch] in case it is unset) and appends its elements to the
    # result.  Under native Tcl it iterates the ::tcltest::testConstraints
    # array and includes only those names whose stored value is true, since
    # Tcl can record disabled constraints.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   A list of the names of all active constraints (empty if there are
    #   none).
    # </help>

    set result [list]

    if {[isTclTk]} then {
      if {[catch {
        set ::tcltk_tests(Constraints)
      } constraints] == 0} then {
        eval lappend result $constraints
      }
    } else {
      foreach name [array names ::tcltest::testConstraints] {
        if {$::tcltest::testConstraints($name)} then {
          lappend result $name
        }
      }
    }

    return $result
  }

  proc getCachedConstraints {} {
    # <help>
    # This procedure returns a previously cached set of test constraints if one
    # is available, otherwise the current live set.  It exists to support
    # capturing the constraint set once (for example, before tests perturb it)
    # and replaying it later via [useCachedConstraints], avoiding recomputation
    # of expensive constraint detection.
    #
    # How it works: if the global ::test_constraints exists and is non-empty,
    # its value is returned as the cached set.  Otherwise it falls back to
    # [getConstraints] to report the currently active constraints.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   The cached constraint list when present, otherwise the live constraint
    #   list.
    # </help>

    if {[info exists ::test_constraints] && \
        [llength $::test_constraints] > 0} then {
      return $::test_constraints
    }

    return [getConstraints]
  }

  proc useCachedConstraints {} {
    # <help>
    # This procedure re-applies a cached set of test constraints, registering
    # each one as active.  It is the replay counterpart to
    # [getCachedConstraints], used to restore a known constraint set -- for
    # example, after state has been reset between test runs -- without
    # re-running constraint detection.
    #
    # How it works: it iterates the names returned by [getCachedConstraints]
    # and calls [addConstraint] for each, enabling them in the current
    # backend.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   The result of the final [addConstraint] (or an empty result when there
    #   are no cached constraints).
    # </help>

    foreach name [getCachedConstraints] {
      addConstraint $name
    }
  }

  proc removeConstraint { name } {
    # <help>
    # This procedure deactivates a named test constraint, undoing a prior
    # [addConstraint].  It exists so that test setup/teardown can selectively
    # disable a feature gate.
    #
    # How it works: under TclTk it locates the name in the
    # ::tcltk_tests(Constraints) list (if that list exists) and removes that
    # element via [lreplace].  Under native Tcl it unsets the corresponding
    # element of the ::tcltest::testConstraints array if present.  Removing a
    # constraint that is not set is harmless.
    #
    # Arguments:
    #   name -- The constraint name to remove.
    #
    # Results:
    #   An empty string.
    # </help>

    if {[isTclTk]} then {
      if {[info exists ::tcltk_tests(Constraints)]} then {
        set index [lsearch -exact $::tcltk_tests(Constraints) $name]

        if {$index != -1} then {
          set ::tcltk_tests(Constraints) [lreplace \
              $::tcltk_tests(Constraints) $index $index]
        }
      }
    } else {
      if {[info exists ::tcltest::testConstraints($name)]} then {
        unset ::tcltest::testConstraints($name)
      }
    }

    return ""
  }

  proc fixConstraints { constraints } {
    # <help>
    # This procedure normalizes a test constraint expression so that it is
    # acceptable to whichever test backend is in use.  It exists to bridge a
    # syntax gap: the native Tcltest package supports a richer [expr]-style
    # constraint expression, while the TclTk.Test package expects a simpler
    # whitespace-separated, implicitly-and-ed list of constraint names.
    #
    # How it works: it trims surrounding whitespace from the input.  When NOT
    # running under TclTk and the expression contains an exclamation point
    # (signaling a negated/expression constraint that spans multiple names), it
    # rewrites the whitespace-separated names into an explicit conjunction by
    # joining them with the logical-and operator, since the suite's convention
    # is that listed constraints are and-ed together.  Otherwise the trimmed
    # value is returned unchanged.
    #
    # Tricky details: the rewrite applies only on Tcl and only when a "!" is
    # present; TclTk constraints are passed through as-is, and simple
    # constraint lists without negation need no transformation.
    #
    # Arguments:
    #   constraints -- The raw constraint expression or list to normalize.
    #
    # Results:
    #   The normalized constraint expression suitable for the active backend.
    # </help>

    set result [string trim $constraints]

    if {[string length $result] > 0} then {
      #
      # HACK: Fixup for the semi-magical expression (via [expr]) test
      #       constraint syntax supported by the Tcltest package and not
      #       by the TclTk.Test package.  This needs to happen for Tcl
      #       in test constraints that contain any characters that are
      #       not alphanumeric, not a period, and not a colon (e.g. in
      #       this case, the exclamation point); however, it should only
      #       be required when the number of test constraints is greater
      #       than one.
      #
      if {![isTclTk]} then {
        if {[string first ! $result] != -1} then {
          #
          # HACK: All of our test constraints assume they are
          #       "logically and-ed" together.
          #
          set result [join [split $result] " && "]
        }
      }
    }

    return $result
  }

  proc getKnownPublicKeyTokens {} {; # TODO: Move to "constraints.tcltk"?
    # <help>
    # This procedure returns the set of "well-known" strong-name public key
    # tokens that identify the official TclTk core assemblies.  It exists so
    # that tests can recognize whether a loaded assembly was signed with one of
    # the trusted core keys (see [isCorePublicKeyToken]).
    #
    # How it works: if the configuration provides
    # ::test_well_known(publicKeyTokens), that value is returned, allowing the
    # list to be overridden.  Otherwise it returns a hard-coded list of the
    # recognized token strings.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   A list of public key token strings.
    # </help>

    if {[info exists ::test_well_known(publicKeyTokens)]} then {
      return $::test_well_known(publicKeyTokens)
    }

    #
    # HACK: This list of "well-known" public key tokens is hard-coded.
    #
    return [list \
        29c6297630be05eb 1e22ec67879739a2 358030063a832bc3 \
        8bf43b4749e46a0b]
  }

  proc isCorePublicKeyToken { publicKeyToken } {
    # <help>
    # This procedure reports whether a given strong-name public key token is
    # one of the well-known official TclTk core tokens.  It exists so that
    # tests can distinguish core-signed assemblies from third-party ones, for
    # example to gate behavior that should apply only to the genuine core.
    #
    # How it works: it retrieves the recognized tokens via
    # [getKnownPublicKeyTokens] and checks membership.  Under TclTk it uses the
    # "in" operator within an expression; under native Tcl it uses an exact
    # [lsearch].  Either way it returns true on a match.
    #
    # Arguments:
    #   publicKeyToken -- The public key token string to test.
    #
    # Results:
    #   True if the token is a recognized core token, false otherwise.
    # </help>

    set publicKeyTokens [getKnownPublicKeyTokens]

    if {[isTclTk]} then {
      set expr {$publicKeyToken in $publicKeyTokens}

      if {[expr $expr]} then {
        return true
      }
    } else {
      if {[lsearch -exact $publicKeyTokens $publicKeyToken] != -1} then {
        return true
      }
    }

    return false
  }

  proc isOfficialStableReleaseInProgress {} {
    # <help>
    # This procedure reports whether the test run is part of building an
    # official, stable release.  It exists because certain non-deterministic
    # tests (timing- or memory-sensitive ones) are made non-fatal during
    # official stable builds so that transient hiccups do not block a release;
    # this predicate detects that situation.
    #
    # How it works: it returns true only when both the OFFICIAL and STABLE
    # environment variables are present (their values are not examined, only
    # their existence), and false otherwise.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   True if both the OFFICIAL and STABLE environment variables exist, false
    #   otherwise.
    # </help>

    if {[info exists ::env(OFFICIAL)] && [info exists ::env(STABLE)]} then {
      return true
    } else {
      return false
    }
  }

  proc fixMemoryConstraints { constraints } {
    # <help>
    # This procedure augments a test constraint expression so that
    # memory-sensitive tests cannot fail the overall run under conditions where
    # transient memory behavior makes their pass/fail result unreliable.  It
    # exists to keep flaky, memory-dependent tests from breaking official
    # stable builds (or whenever the failMemoryTests override is set).
    #
    # How it works: under TclTk, if the no(failMemoryTests) flag is set, OR
    # both the "32bit" and "officialStableReleaseInProgress" constraints are
    # present, it appends the "fail.false" constraint (which marks the test's
    # failure as non-fatal) to the supplied constraints and normalizes the
    # whole thing via [fixConstraints].  In every other case -- and always
    # under native Tcl -- it simply returns the constraints normalized via
    # [fixConstraints] with no addition.
    #
    # Arguments:
    #   constraints -- The constraint expression to potentially augment.
    #
    # Results:
    #   The normalized constraint expression, with "fail.false" added when the
    #   memory-tolerance conditions are met.
    # </help>

    #
    # HACK: In TclTk, when the right test constraint is present, *any* tests
    #       where PASSED / FAILED results can vary non-deterministically due
    #       to transient memory issues (e.g. performance) are forbidden from
    #       causing the overall test run to fail.
    #
    if {[isTclTk]} then {
      if {[info exists ::no(failMemoryTests)] || ([haveConstraint 32bit] && \
          [haveConstraint officialStableReleaseInProgress])} then {
        return [fixConstraints [concat $constraints [list fail.false]]]
      } else {
        return [fixConstraints $constraints]
      }
    } else {
      return [fixConstraints $constraints]
    }
  }

  proc fixTimingConstraints { constraints } {
    # <help>
    # This procedure augments a test constraint expression so that
    # timing-sensitive tests cannot fail the overall run under conditions where
    # performance variation makes their pass/fail result unreliable.  It is the
    # timing-oriented counterpart to [fixMemoryConstraints], protecting
    # official stable builds (or runs with the failTimingTests override) from
    # flaky, time-dependent tests.
    #
    # How it works: under TclTk, if the no(failTimingTests) flag is set OR the
    # "officialStableReleaseInProgress" constraint is present, it appends the
    # "fail.false" constraint (marking failure as non-fatal) and normalizes via
    # [fixConstraints].  Otherwise -- and always under native Tcl -- it returns
    # the constraints normalized via [fixConstraints] without addition.
    #
    # Arguments:
    #   constraints -- The constraint expression to potentially augment.
    #
    # Results:
    #   The normalized constraint expression, with "fail.false" added when the
    #   timing-tolerance conditions are met.
    # </help>

    #
    # HACK: In TclTk, when the right test constraint is present, *any* tests
    #       where PASSED / FAILED results can vary non-deterministically due
    #       to timing issues (e.g. performance) are forbidden from causing
    #       the overall test run to fail.
    #
    if {[isTclTk]} then {
      if {[info exists ::no(failTimingTests)] || \
          [haveConstraint officialStableReleaseInProgress]} then {
        return [fixConstraints [concat $constraints [list fail.false]]]
      } else {
        return [fixConstraints $constraints]
      }
    } else {
      return [fixConstraints $constraints]
    }
  }

  proc testDebugBreak { {force 0} args } {
    # <help>
    # This procedure drops into an interactive debugger from within a running
    # test, on whichever runtime is in use.  It exists as a portable
    # breakpoint helper -- a single call that does the right thing under both
    # TclTk and native Tcl -- so tests and harness code can pause for
    # inspection.
    #
    # How it works: it does nothing if the no(testDebugBreak) flag is set.
    # Under TclTk, unless no(tcltkTestDebugBreak) is set, it breaks into the
    # integrated script debugger.  First, unless no(testDebugEmergency) is set,
    # it may enable "emergency" debugger mode: when "force" is greater than
    # zero and either "force" exceeds one or no emergency timestamp has yet
    # been recorded, it records a timestamp and turns on emergency mode once.
    # It then enters the debugger via [debug break], evaluated with [uplevel 1]
    # so the break occurs in the caller's frame.  Under native Tcl, unless
    # no(tclTestDebugBreak) is set, it loads and invokes the TclPro Debugger
    # attach interface (requiring the tcldebugger_attach package on the
    # auto-path), again via [uplevel 1].
    #
    # Tricky details: the various no() flags allow selectively disabling the
    # break globally or per-runtime; the "force" levels distinguish "break, but
    # only enable emergency mode if not already enabled" from "always (re)enable
    # emergency mode".  Extra "args" are accepted for call-site flexibility but
    # are not otherwise consumed here.
    #
    # Arguments:
    #   force -- An integer controlling emergency-mode enabling under TclTk:
    #            0 means do not enable emergency mode; greater than 0 enables it
    #            once; greater than 1 forces (re)enabling it.  Defaults to 0.
    #   args  -- Any additional arguments; accepted but not directly used.
    #
    # Results:
    #   The result of the underlying debugger break, or an empty string when
    #   the break is disabled by a no() flag.
    # </help>

    if {![info exists ::no(testDebugBreak)]} then {
      if {[isTclTk]} then {
        if {![info exists ::no(tcltkTestDebugBreak)]} then {
          #
          # NOTE: In TclTk, simply break into the interactive loop using the
          #       integrated script debugger.  First, unless forbidden from
          #       doing so, make sure that all the script debugger flags and
          #       subsystems are fully enabled and setup first.
          #
          if {![info exists ::no(testDebugEmergency)]} then {
            if {$force > 0 && (($force > 1) || \
                ![info exists ::tcltk_debugger(emergency)])} then {
              set ::tcltk_debugger(emergency) [clock seconds]
              host result Ok [debug emergency now]; # NOTE: Once.
            }
          }

          return [uplevel 1 [list debug break]]
        }
      } else {
        if {![info exists ::no(tclTestDebugBreak)]} then {
          #
          # NOTE: In native Tcl, attempt to use the TclPro Debugger interface.
          #       This requires that the TclPro Debugger interface package be
          #       present somewhere along the auto-path.
          #
          return [uplevel 1 {
            package require tcldebugger_attach; debugger_init; debugger_break
          }]
        }
      }
    }

    return ""
  }

  proc testSortDictionary { dictionary {integer false} } {
    # <help>
    # This procedure returns a copy of a dictionary sorted by its keys.  It
    # exists to produce stable, deterministic dictionary orderings for test
    # comparisons and output, since dictionary iteration order is not otherwise
    # guaranteed to be meaningful for assertions.
    #
    # How it works: it first groups the flat name/value dictionary into a list
    # of two-element pairs.  It then sorts those pairs by their first element
    # (the key) using [lsort -index 0], adding the -integer option when the
    # "integer" flag is set so keys compare numerically rather than as strings.
    # Finally it flattens the sorted pairs back into a flat name/value list.
    #
    # Arguments:
    #   dictionary -- The dictionary (flat name/value list) to sort.
    #   integer    -- A boolean; when true, keys are compared numerically.
    #                 Defaults to false (string comparison).
    #
    # Results:
    #   A new flat dictionary with the same entries ordered by key.
    # </help>

    set pairs [list]

    foreach {name value} $dictionary {
      lappend pairs [list $name $value]
    }

    set command [list lsort -index 0]
    if {$integer} then {lappend command -integer}
    lappend command $pairs

    set result [list]

    foreach pair [eval $command] {
      lappend result [lindex $pair 0] [lindex $pair 1]
    }

    return $result
  }

  proc testArrayGet { varName {integer false} } {
    # <help>
    # This procedure returns the contents of an array variable as a flat
    # name/value list, like [array get], but with the elements emitted in a
    # well-defined, sorted order.  It exists because [array get] returns its
    # pairs in an unspecified (hash) order, which makes array contents awkward
    # to compare, log, or assert against in a test; sorting the names first
    # produces stable, reproducible output.
    #
    # How it works: it resolves the named array in the caller's scope using
    # [upvar], sorts the array element names (optionally as integers), and then
    # walks those names in order, appending each name and its value to the
    # result.
    #
    # Arguments:
    #   varName -- The name of the array variable, resolved in the caller's
    #              scope.  If empty, the empty list is returned without touching
    #              any variable.
    #   integer -- Optional boolean; when true the element names are sorted
    #              numerically (lsort -integer) rather than in the default
    #              string order.  Defaults to false.
    #
    # Results:
    #   A flat list of alternating element names and values, ordered by the
    #   sorted element names.  The empty list is returned when varName is empty.
    # </help>

    #
    # NOTE: Returns the results of [array get] in a well-defined order.
    #
    if {[string length $varName] == 0} then {
      return [list]
    }

    #
    # NOTE: Refer to the array in the context of the caller.
    #
    upvar 1 $varName array

    #
    # NOTE: Build the command that will sort the array names into order.
    #
    set command [list lsort]
    if {$integer} then {lappend command -integer}
    lappend command [array names array]

    set result [list]

    foreach name [eval $command] {
      lappend result $name $array($name)
    }

    return $result
  }

  proc testArrayGet2 { varName {pattern ""} {integer false} } {
    # <help>
    # This procedure is a variant of [testArrayGet] that additionally accepts a
    # glob pattern restricting which array elements are returned.  Like its
    # sibling, it returns the contents of an array as a flat name/value list in
    # a well-defined, sorted order so the output is stable and easy to compare
    # in tests.  It exists for cases where only a subset of array elements (for
    # example, those sharing a common name prefix) is of interest.
    #
    # How it works: it resolves the named array in the caller's scope via
    # [upvar], obtains the element names matching the pattern (or all names when
    # no pattern is supplied), sorts them (optionally as integers), and then
    # emits each name with its value in that sorted order.
    #
    # Arguments:
    #   varName -- The name of the array variable, resolved in the caller's
    #              scope.  If empty, the empty list is returned.
    #   pattern -- Optional glob pattern; when non-empty, only element names
    #              matching it (via [array names]) are included.  When empty,
    #              all elements are included.  Defaults to empty.
    #   integer -- Optional boolean; when true the element names are sorted
    #              numerically rather than in string order.  Defaults to false.
    #
    # Results:
    #   A flat list of alternating element names and values for the matching
    #   elements, ordered by their sorted names.  The empty list is returned
    #   when varName is empty or no element matches.
    # </help>

    #
    # NOTE: Returns the results of [array get] in a well-defined order.
    #
    if {[string length $varName] == 0} then {
      return [list]
    }

    #
    # NOTE: Refer to the array in the context of the caller.
    #
    upvar 1 $varName array

    #
    # NOTE: Build the command that will sort the array names into order.
    #
    set command [list lsort]
    if {$integer} then {lappend command -integer}

    #
    # NOTE: If there is a pattern, use it; otherwise, all elements are
    #       returned.
    #
    if {[string length $pattern] > 0} then {
      lappend command [array names array $pattern]
    } else {
      lappend command [array names array]
    }

    set result [list]

    foreach name [eval $command] {
      lappend result $name $array($name)
    }

    return $result
  }

  proc testResultGet { script } {
    # <help>
    # This procedure evaluates a script in the caller's context and returns its
    # result, substituting a placeholder string when the script raises an
    # error.  It exists so that test logging and result-capturing code can
    # obtain "the result of a script, or an error marker" in a single call
    # without having to write its own [catch] handling and without letting an
    # error propagate.
    #
    # How it works: the script is run with [uplevel 1] (in the caller's frame)
    # inside a [catch].  On success the script's result is returned verbatim; on
    # any failure the literal string error (wrapped in angle brackets) is
    # returned instead.
    #
    # Arguments:
    #   script -- The script to evaluate in the caller's variable context.
    #
    # Results:
    #   The result of the script when it succeeds, otherwise the placeholder
    #   string consisting of the word error enclosed in angle brackets.
    # </help>

    set code [catch {uplevel 1 $script} result]
    return [expr {$code == 0 ? $result : "<error>"}]
  }

  proc testValueGet { varName {integer false} } {
    # <help>
    # This procedure returns the value of a variable in a uniform list form,
    # transparently handling both arrays and scalars.  It exists so that test
    # code can capture "the value of this variable" without first knowing
    # whether the variable is an array or an ordinary scalar.
    #
    # How it works: it inspects the named variable in the caller's scope.  If
    # it is an array, it behaves like [testArrayGet], returning a sorted flat
    # list of names and values (optionally sorting names as integers).  If it
    # is a scalar, it reads the value (via [set] evaluated in the caller's
    # frame) and returns it as a single-element list.
    #
    # Tricky details: array detection and value retrieval are all performed in
    # the caller's frame using [uplevel] and [upvar], so the variable is
    # resolved exactly as it would be at the call site.  The integer flag only
    # affects the array case.
    #
    # Arguments:
    #   varName -- The name of the variable (array or scalar), resolved in the
    #              caller's scope.  If empty, the empty list is returned.
    #   integer -- Optional boolean; when true, and the variable is an array,
    #              the element names are sorted numerically.  Defaults to false.
    #
    # Results:
    #   For an array, a flat sorted list of names and values.  For a scalar, a
    #   single-element list containing the scalar value.  The empty list is
    #   returned when varName is empty.
    # </help>

    #
    # NOTE: Returns the results of [array get] in a well-defined order
    #       -OR- the value of the scalar variable.
    #
    if {[string length $varName] == 0} then {
      return [list]
    }

    #
    # NOTE: Is the specified variable (in the context of the caller) an
    #       array?
    #
    if {[uplevel 1 [list array exists $varName]]} then {
      #
      # NOTE: Refer to the array in the context of the caller.
      #
      upvar 1 $varName array

      #
      # NOTE: Build the command that will sort the array names into order.
      #
      set command [list lsort]
      if {$integer} then {lappend command -integer}
      lappend command [array names array]

      set result [list]

      foreach name [eval $command] {
        lappend result $name $array($name)
      }
    } else {
      #
      # NOTE: Grab the value of the scalar variable in the context of the
      #       caller and then return both the name and the value.
      #
      set varValue [uplevel 1 [list set $varName]]
      set result [list $varValue]
    }

    return $result
  }

  proc getValueOrDefault { varName {default <none>} } {
    # <help>
    # This procedure returns the value of a variable in the caller's scope, or
    # a caller-supplied default when the variable is absent or empty.  It exists
    # to provide a concise "read with fallback" accessor for both arrays and
    # scalar variables.
    #
    # How it works: it checks (in the caller's frame) whether the named
    # variable is an array; if so, it returns the result of [array get] when
    # that result is non-empty.  Otherwise it checks whether the variable
    # exists as a scalar and returns its value when that value has a non-zero
    # length.  In every other case (the variable does not exist, the array is
    # empty, or the scalar is the empty string) the default is returned.
    #
    # Tricky details: an existing-but-empty scalar, and an existing-but-empty
    # array, are both treated as "no usable value" and therefore yield the
    # default rather than an empty string.
    #
    # Arguments:
    #   varName -- The name of the variable to read, resolved in the caller's
    #              scope; it may name an array or a scalar.
    #   default -- Optional value returned when no usable value is found.
    #              Defaults to the literal string none enclosed in angle
    #              brackets.
    #
    # Results:
    #   The array contents (as a name/value list), the scalar value, or the
    #   default, per the rules above.
    # </help>

    if {[uplevel 1 [list array exists $varName]]} then {
      set value [uplevel 1 [list array get $varName]]

      if {[llength $value] > 0} then {
        return $value
      }
    } elseif {[uplevel 1 [list info exists $varName]]} then {
      set value [uplevel 1 [list set $varName]]

      if {[string length $value] > 0} then {
        return $value
      }
    }

    return $default
  }

  proc getFirstLineOfError { error } {
    # <help>
    # This procedure extracts and returns just the first line of a (possibly
    # multi-line) error message.  It exists to produce a concise, single-line
    # summary of an error for logging or display, discarding any trailing
    # detail such as a stack trace.
    #
    # How it works: it first normalizes line endings by mapping carriage
    # return and line feed pairs to a single line feed, then locates the first
    # line feed.  When a line feed is found, it returns the text preceding it;
    # otherwise (a single-line message) it returns the message unchanged.
    #
    # Tricky details: the index is adjusted so that the newline itself is
    # excluded from the returned range.  If the message begins with a newline
    # (so the computed end index is not greater than zero, meaning the first
    # line would be empty) the original message is returned as-is rather than
    # an empty string.
    #
    # Arguments:
    #   error -- The error message text to summarize; it may contain any mix of
    #            carriage-return and line-feed line endings.
    #
    # Results:
    #   The first line of the message, with line endings normalized, or the
    #   whole message when it has no usable first line break.
    # </help>

    set error [string map [list \r\n \n] $error]
    set index [string first \n $error]

    if {$index != -1} then {
      incr index -1

      if {$index > 0} then {
        return [string range $error 0 $index]
      }
    }

    return $error
  }

  proc calculateBogoCops { {milliseconds 2000} {legacy false} } {
    # <help>
    # This procedure measures an approximate, machine-relative performance
    # rating expressed in "bogo-COPS" (bogus commands-per-second).  It exists so
    # that the test suite can normalize timing-sensitive expectations across
    # machines of differing speed: a baseline rating captured on a reference
    # machine, divided by the rating of the current machine, yields a scaling
    # factor for performance thresholds (see [calculateRelativePerformance]).
    # The name deliberately echoes "BogoMIPS" to stress that the number is only
    # meaningful in relative, not absolute, terms.
    #
    # How it works: it spins the interpreter doing trivial work for roughly the
    # requested duration while sampling the interpreter command counter (via
    # [info cmdcount]) before and after, then divides the number of commands
    # executed by the elapsed time in seconds.  Several techniques are used
    # depending on the engine and flags.  When running in TclTk and not in
    # legacy mode, it prefers the robust timeout option of the [time] command if
    # that option is available.  If that option is unavailable (or legacy mode
    # is requested), it falls back to scheduling an [after] event that cancels a
    # busy [time] loop; this fallback carefully saves and restores the
    # interpreter readiness limit, the background error handler, and the [after]
    # flags so that the cancellation actually takes effect and so the
    # surrounding interpreter state is left undisturbed.  When running under
    # native Tcl, it simply busy-waits on [clock seconds] for the whole-second
    # portion of the requested duration.
    #
    # Tricky details: a Mono floating-point bug is worked around by forcing a
    # double conversion on that platform.  The [after]-based fallback has an
    # inherent race condition (documented inline) wherein the cancel event may
    # fire just outside the timed region; in that case, and on any internal
    # failure, an obviously invalid rating of zero is returned.  The global flag
    # indicating a running test suite is unset before raising the input
    # validation error so that a bad call does not leave that flag stuck.
    #
    # Arguments:
    #   milliseconds -- Optional approximate duration of the measurement, in
    #                   milliseconds; it must be greater than zero or an error
    #                   is raised.  Defaults to 2000.
    #   legacy       -- Optional boolean forcing use of the older [after]-based
    #                   measurement method even when the modern timeout option
    #                   is available; useful for comparative benchmarking.
    #                   Defaults to false.
    #
    # Results:
    #   A floating-point performance rating (commands per second).  A value of
    #   zero indicates the measurement failed (for example, due to the race
    #   condition described above).  An error is raised when milliseconds is not
    #   greater than zero.
    # </help>

    #
    # NOTE: Verify that the number of milliseconds requested is greater
    #       than zero.
    #
    if {$milliseconds <= 0} then {
      unset -nocomplain ::test_suite_running
      error "number of milliseconds must be greater than zero"
    }

    #
    # HACK: Different techniques are used to calculate the performance of
    #       the machine for Tcl and TclTk.
    #
    if {!$legacy && [isTclTk]} then {
      #
      # BUGBUG: Tcl 8.4 does not like this expression (and Tcl tries to
      #         compile it even though it will only actually ever be
      #         evaluated in TclTk).
      #
      set expr {[catch {
        string first -timeout [time nop 0 ---]
      } timeout] in [list 0 2] && $timeout != -1}

      #
      # HACK: Attempt to determine if the "-timeout" option for [time] is
      #       available.  If so, use it.
      #
      if {[expr $expr]} then {
        set code [catch {
          #
          # NOTE: This is the most robust method, i.e. use the "-timeout"
          #       option to the [time] command.
          #
          set before [info cmdcount]
          catch {time {nop} -1 -timeout $milliseconds}; # internal loop.
          set after [info cmdcount]

          #
          # HACK: Mono has a bug that results in excessive trailing zeros
          #       here (Mono bug #655780).
          #
          if {[isMono]} then {
            expr {double(($after - $before) / ($milliseconds / 1000.0))}
          } else {
            expr {($after - $before) / ($milliseconds / 1000.0)}
          }
        } result]

        #
        # NOTE: If we failed above, return an obviously invalid result
        #       instead.
        #
        if {$code == 0} then {
          return $result
        } else {
          return 0
        }
      } else {
        #
        # HACK: This calculation method (i.e. using [after] to cancel the
        #       [time] command after the specified number of milliseconds)
        #       is no longer necessary as of Beta 45; however, it will be
        #       retained for backward compatibility with previous releases
        #       solely for the purpose of running comparative benchmarks.
        #
        # NOTE: Save the current readiness limit for later restoration
        #       and then set the current readiness limit to always check
        #       the interpreter readiness (default).  If this was not
        #       done, the [interp cancel] command in this procedure may
        #       have no effect, which could cause this procedure to run
        #       forever.
        #
        set readylimit [interp readylimit {}]
        interp readylimit {} 0

        try {
          #
          # NOTE: Save the current background error handler for later
          #       restoration and then reset the current background
          #       error handler to nothing.
          #
          set bgerror [interp bgerror {}]
          interp bgerror {} ""

          try {
            #
            # NOTE: Save the current [after] flags for later restoration
            #       and then reset them to process events immediately.
            #
            set flags [after flags]
            after flags =Immediate

            try {
              set code [catch {
                #
                # NOTE: First, make sure that the [after] event queue
                #       for the interpreter is totally empty.
                #
                cleanupAfterEvents true

                #
                # NOTE: Schedule the event to cancel the script we are
                #       about to evaluate, capturing the name so we can
                #       cancel it later, if necessary.
                #
                set event [after $milliseconds [list interp cancel]]

                #
                # HACK: There is a potential "race condition" here.  If the
                #       specified number of milliseconds elapses before (or
                #       after) entering the [catch] script block (below)
                #       then the resulting script cancellation error will
                #       not be caught and we will be unable to return the
                #       correct result to the caller.
                #
                set before [info cmdcount]
                catch {time {nop} -1}; # uses the [time] internal busy loop.
                set after [info cmdcount]

                #
                # HACK: Mono has a bug that results in excessive trailing
                #       zeros here (Mono bug #655780).
                #
                if {[isMono]} then {
                  expr {double(($after - $before) / ($milliseconds / 1000.0))}
                } else {
                  expr {($after - $before) / ($milliseconds / 1000.0)}
                }
              } result]

              #
              # NOTE: If we failed due to the race condition explained
              #       above, return an obviously invalid result instead.
              #
              if {$code == 0} then {
                return $result
              } else {
                return 0
              }
            } finally {
              if {[info exists event]} then {
                catch {after cancel $event}
              }

              after flags [appendArgs = $flags]
            }
          } finally {
            interp bgerror {} $bgerror
          }
        } finally {
          interp readylimit {} $readylimit
        }
      }
    } else {
      #
      # NOTE: Record the initial Tcl command count.
      #
      set before [info cmdcount]

      #
      # NOTE: Calculate how many whole seconds we need to spin for.
      #
      set seconds [expr {$milliseconds / 1000}]

      #
      # NOTE: Calculate the starting and ending values of [clock seconds].
      #
      set now [clock seconds]
      set start $now; set stop [expr {$now + $seconds}]

      #
      # NOTE: Do nothing for X seconds (i.e. except call [clock seconds]).
      #
      while {$start <= $now && $now < $stop} {set now [clock seconds]}

      #
      # NOTE: Record the final Tcl command count.
      #
      set after [info cmdcount]

      #
      # NOTE: Calculate approximately how many Tcl commands per second were
      #       executed during the timed loop (above).  Due to various things,
      #       including overhead associated with [clock seconds], this number
      #       is not as accurate as the one for TclTk; however, it's generally
      #       good enough.
      #
      expr {($after - $before) / ($milliseconds / 1000.0)}
    }
  }

  proc calculateRelativePerformance { type value } {
    # <help>
    # This procedure scales a performance-related expectation to account for the
    # speed of the current machine relative to a reference baseline.  It exists
    # so that timing-sensitive test thresholds (an allowed elapsed time, or an
    # expected iteration count) written against a known reference machine remain
    # meaningful when the suite is run on faster or slower hardware.
    #
    # How it works: it uses two global ratings, the baseline rating and the
    # current machine rating, both produced by [calculateBogoCops].  For an
    # elapsed-time value it multiplies by the ratio of baseline to current
    # rating (a slower machine is allowed more time); for an iteration-count
    # value it multiplies by the ratio of current to baseline rating (a faster
    # machine is expected to complete more iterations).  When the relevant
    # ratings are unavailable, or the relevant divisor is zero, the value is
    # returned unchanged.
    #
    # Arguments:
    #   type  -- Selects the scaling direction; the literal string elapsed
    #            scales a duration, and the literal string iterations scales a
    #            count.  Any other value leaves the input unchanged.
    #   value -- The numeric expectation to scale.
    #
    # Results:
    #   The scaled value as a floating-point number, or the original value
    #   unchanged when no usable baseline information is present.
    # </help>

    #
    # NOTE: Adjust the expected performance number based on the
    #       relative performance of this machine, if available.
    #
    if {[info exists ::test_base_cops] && [info exists ::test_cops]} then {
      #
      # NOTE: Calibrate the expected performance numbers based
      #       on the ratio of the baseline performace to the
      #       current performance.
      #
      switch -exact -- $type {
        elapsed {
          if {$::test_cops != 0} then {
            return [expr {double($value) * \
                ($::test_base_cops / $::test_cops)}]
          }
        }
        iterations {
          if {$::test_base_cops != 0} then {
            return [expr {double($value) * \
                ($::test_cops / $::test_base_cops)}]
          }
        }
      }
    }

    return $value
  }

  proc formatTimeStamp { seconds {gmt false} } {
    # <help>
    # This procedure formats a number of seconds since the epoch into a
    # human-readable ISO-8601-style timestamp string.  It exists to provide a
    # single, consistent timestamp format for test logging that works in both
    # TclTk and native Tcl despite their differing [clock format] options.
    #
    # How it works: under TclTk it uses the engine's iso and isotimezone
    # options to [clock format].  Under native Tcl, which lacks those options,
    # it supplies an equivalent explicit format string producing a date and
    # time separated by the letter T and followed by the time-zone name.
    #
    # Arguments:
    #   seconds -- The time to format, as a count of seconds since the epoch.
    #   gmt     -- Optional boolean passed through to [clock format]; when true
    #              the timestamp is rendered in UTC rather than local time.
    #              Defaults to false.
    #
    # Results:
    #   A formatted timestamp string.
    # </help>

    if {[isTclTk]} then {
      return [clock format $seconds -gmt $gmt -iso -isotimezone]
    } else {
      return [clock format $seconds -gmt $gmt -format "%Y-%m-%dT%H:%M:%S %Z"]
    }
  }

  proc formatElapsedTime { seconds } {
    # <help>
    # This procedure formats a duration, given in whole seconds, into a
    # human-readable elapsed-time description.  It exists to make timing output
    # in test logs easier to read than a bare count of seconds.
    #
    # How it works: when running in TclTk with object support available, it
    # constructs a TimeSpan instance from the seconds and returns the seconds
    # together with the TimeSpan's readable string form (for example, showing
    # hours, minutes, and seconds).  Otherwise, because native Tcl has no
    # built-in command to format an elapsed time, it falls back to returning
    # just the number of whole seconds with a trailing label.
    #
    # Arguments:
    #   seconds -- The elapsed duration to format, as a whole number of
    #              seconds.
    #
    # Results:
    #   A descriptive string; in TclTk it includes both the raw seconds and a
    #   formatted elapsed-time form, and in native Tcl it is just the seconds
    #   with a units label.
    # </help>

    if {[isTclTk] && [llength [info commands object]] > 0} then {
      #
      # NOTE: Create a TimeSpan instance based on the number of whole
      #       seconds.
      #
      set timeSpan [object invoke -create -alias TimeSpan FromSeconds \
          $seconds]

      #
      # NOTE: Return the number of seconds and a human readable string
      #       representing the TimeSpan instance created based on that
      #       same number of seconds.
      #
      return [appendArgs $seconds " seconds (" \
          [getStringFromObjectHandle $timeSpan] " elapsed time)"]
    } else {
      #
      # NOTE: Unfortunately, there is no built-in native Tcl command
      #       that can correctly format an elapsed time; therefore,
      #       just return the number of whole seconds.
      #
      return [appendArgs $seconds " seconds"]
    }
  }

  proc sourceIfValid { type fileName } {
    # <help>
    # This procedure conditionally evaluates (sources) a script file in the
    # caller's context, logging what it does, and only when the file name is
    # non-empty.  It exists to support optional pre-test and post-test scripts
    # (and similar hooks) where the file name may legitimately be unset, the
    # file may not exist, and any error during evaluation must be reported and
    # then re-raised.
    #
    # How it works: when the file name is non-empty it logs a message (using the
    # default test channel) describing the action.  If the file exists, it is
    # sourced via [uplevel 1] so it runs in the caller's variable context; any
    # error is logged and then re-thrown with the original error information and
    # error code preserved (after unsetting the running-suite global flag).  If
    # the file does not exist, a "skipped" message is logged and nothing is
    # evaluated.  When the file name is empty, the procedure does nothing.
    #
    # Arguments:
    #   type     -- A short descriptive label for the kind of file (for
    #               example, prologue or epilogue) used only in the log
    #               messages.
    #   fileName -- The path of the script file to evaluate; an empty value
    #               means "do nothing".
    #
    # Results:
    #   An empty result on success or when nothing is done.  An error is
    #   re-raised if sourcing the file fails.
    # </help>

    if {[string length $fileName] > 0} then {
      set channel [getTestChannelOrDefault]

      if {[file exists $fileName]} then {
        tputs $channel [appendArgs \
            "---- evaluating " $type " file: \"" $fileName \"\n]

        if {[catch {uplevel 1 [list source $fileName]} error]} then {
          tputs $channel [appendArgs \
              "---- error during " $type " file: " $error \n]

          #
          # NOTE: The error has been logged, now re-throw it.
          #
          unset -nocomplain ::test_suite_running
          error $error $::errorInfo $::errorCode
        }
      } else {
        tputs $channel [appendArgs \
            "---- skipped " $type " file: \"" $fileName \
            "\", it does not exist\n"]
      }
    }
  }

  proc augmentTestArguments { varName value } {
    # <help>
    # This procedure appends the elements of a list-valued value onto a test
    # argument list held in a caller variable, but only if that value is itself
    # a well-formed list.  It exists to safely fold additional test arguments
    # (for example, those drawn from environment variables) into the argument
    # list, rejecting malformed values instead of corrupting the list.
    #
    # How it works: it links the named caller variable as the argument list,
    # validates that the supplied value parses as a proper list (using the
    # engine's list test under TclTk, or a [catch]ed [llength] under native
    # Tcl), and, when valid, appends each element of that value to the argument
    # list via [eval lappend].
    #
    # Arguments:
    #   varName -- The name of the caller variable holding the test argument
    #              list to extend; when empty, no variable is linked (and so
    #              nothing is appended).
    #   value   -- The candidate value to append; it must be a proper list for
    #              its elements to be added.
    #
    # Results:
    #   Boolean true when the value was a valid list (and thus appended), or
    #   false when it was not.
    # </help>

    if {[string length $varName] > 0} then {
      upvar 1 $varName args
    }

    set result false

    if {[isTclTk]} then {
      if {[string is list -strict $value]} then {
        set result true
      }
    } else {
      if {[catch {llength $value}] == 0} then {
        set result true
      }
    }

    if {$result} then {
      eval lappend args $value
    }

    return $result
  }

  proc processTestArguments { varName strict args } {
    # <help>
    # This procedure parses a list of command-line-style test arguments into a
    # set of recognized test options, storing the recognized ones in a caller
    # array and returning the ones it does not recognize.  It is the central
    # entry point used by the test prologue to turn the various sources of test
    # configuration into the test_flags array.
    #
    # How it works: it links the named caller variable as the destination array
    # and selects the default test output channel.  Unless explicitly
    # forbidden via the global no array, it first augments the incoming
    # arguments with values pulled from the TEST_ARGV, TEST_SYSTEM_ARGV, and
    # TEST_USER_ARGV environment variables (using [augmentTestArguments], with a
    # warning logged for any malformed value).  It then walks the combined
    # argument list against a fixed table of known option names.  For each known
    # option it consumes the following element as the option value and records
    # it in the array, logging an override message; a known option with no
    # following value is logged and ignored.  Arguments that are not recognized
    # are collected into the result; when not in strict mode the parser will, on
    # encountering a value that is itself a known option name, back up one
    # position so that the following known option is re-processed correctly.
    # Logging uses the queued [tqputs]/[tlog] path because this typically runs
    # before the test log file has been set up.
    #
    # Tricky details: option values are matched only by leading-dash convention
    # for the "unknown option" versus "unknown argument" distinction; the
    # resynchronization (backing up one element) only happens in non-strict
    # mode.  At the end the queued log output is flushed.
    #
    # Arguments:
    #   varName -- The name of the caller array that receives the recognized
    #              options (as element name/value pairs keyed by option name);
    #              when empty, no array is linked.
    #   strict  -- Boolean; when true the parser does not attempt to back up and
    #              resynchronize on a known option found in value position, and
    #              instead treats such cases as plain unknown name/value pairs.
    #   args    -- The remaining arguments to parse, a flat sequence of option
    #              names and their values.
    #
    # Results:
    #   A list of the unrecognized arguments, each formatted as a one- or
    #   two-element sub-list (an option or argument name, optionally followed by
    #   its value), suitable for further handling by the caller.
    # </help>

    #
    # NOTE: Initially, there are no unknown (i.e. unprocessed) arguments.
    #
    set result [list]

    #
    # NOTE: We are going to place the configured options in the variable
    #       identified by the name provided by the caller.
    #
    if {[string length $varName] > 0} then {
      upvar 1 $varName array
    }

    #
    # NOTE: Figure out where to send the output from processing the test
    #       arguments into options.
    #
    set channel [getTestChannelOrDefault]

    #
    # TODO: Add more support for standard "tcltest" options here.
    #
    set options [list \
        -breakOnLeak -configuration -constraints -exitOnComplete \
        -file -listedLeaks -logFile -logId -logPath -machine -match \
        -namePrefix -no -notFile -platform -postTest -preTest -postWait \
        -preWait -randomOrder -skip -startFile -stopFile -stopOnFailure \
        -stopOnLeak -suffix -suite -tclsh -threshold -uncountedLeaks \
        -verbose]

    #
    # NOTE: Unless explicitly forbidden, add all available test argument
    #       values from environment variables, if any.
    #
    if {![info exists ::no(augmentTestArguments)]} then {
      foreach name [list \
          TEST_ARGV TEST_SYSTEM_ARGV TEST_USER_ARGV] {
        if {[info exists ::env($name)]} then {
          set value $::env($name)

          if {![augmentTestArguments args $value]} then {
            tqputs $channel [appendArgs \
                "---- bad arguments from \"" $name \
                "\", must be a proper list: " $value \n]
          }
        }
      }
    }

    #
    # NOTE: Next, attempt to (recognize and) process each supported test
    #       option, in order.
    #
    set length [llength $args]

    for {set index 0} {$index < $length} {incr index} {
      #
      # NOTE: Grab the current list element, which should be the name of
      #       the test option.
      #
      set name [lindex $args $index]

      #
      # NOTE: Use the [tqputs] command here just in case the test log file
      #       has not been setup yet (i.e. by default, this procedure is
      #       almost always called by the test prologue file prior to the
      #       test log file having been setup and we do not want to just
      #       lose this output).
      #
      if {[lsearch -exact $options $name] != -1} then {
        #
        # NOTE: Is there another list element available for the value?  If
        #       not, this is not a valid test option.
        #
        if {$index + 1 < $length} then {
          incr index; set value [lindex $args $index]

          set array($name) $value

          tqputs $channel [appendArgs \
              "---- overrode test option \"" $name "\" with value \"" \
              $value \"\n]
        } else {
          tqputs $channel [appendArgs \
              "---- no value for test option \"" $name "\", ignored\n"]
        }
      } elseif {[string index $name 0] eq "-"} then {
        #
        # NOTE: Is there another list element available for the value?  If
        #       not, it does not conform to the standard command line name
        #       and value pattern.
        #
        if {$index + 1 < $length} then {
          incr index; set value [lindex $args $index]

          if {!$strict && [lsearch -exact $options $value] != -1} then {
            incr index -1; # HACK: Resynchronize with valid test option.
            lappend result [list $name]

            tqputs $channel [appendArgs \
                "---- no value for unknown test option \"" $name \
                "\", ignored, backing up one for test option \"" \
                $value \"...\n]
          } else {
            lappend result [list $name $value]

            tqputs $channel [appendArgs \
                "---- unknown test option \"" $name "\" with value \"" \
                $value "\", ignored\n"]
          }
        } else {
          lappend result [list $name]

          tqputs $channel [appendArgs \
              "---- no value for unknown test option \"" $name \
              "\", ignored\n"]
        }
      } else {
        #
        # NOTE: Is there another list element available for the value?  If
        #       not, it does not conform to the standard command line name
        #       and value pattern.
        #
        if {$index + 1 < $length} then {
          incr index; set value [lindex $args $index]

          if {!$strict && [lsearch -exact $options $value] != -1} then {
            incr index -1; # HACK: Resynchronize with valid test argument.
            lappend result [list $name]

            tqputs $channel [appendArgs \
                "---- no value for unknown argument \"" $name \
                "\", ignored, backing up one for test option \"" \
                $value \"...\n]
          } else {
            lappend result [list $name $value]

            tqputs $channel [appendArgs \
                "---- unknown argument \"" $name "\" with value \"" \
                $value "\", ignored\n"]
          }
        } else {
          #
          # NOTE: This is not an option of *any* kind that we know about.
          #       Ignore it and issue a warning.
          #
          lappend result [list $name]

          tqputs $channel [appendArgs \
              "---- unknown argument \"" $name "\", ignored\n"]
        }
      }
    }

    #
    # NOTE: Now, attempt to flush the test log queue, if available.
    #
    tlog ""

    #
    # NOTE: Return the nested list of unknown arguments, formatted as
    #       name/value pairs, to the caller.
    #
    return $result
  }

  proc makeUseOfTestDefaults { varName } {
    # <help>
    # This procedure populates a caller array with the default values for every
    # supported test flag.  It exists to establish a complete, known-good
    # starting point for the test_flags array before any command-line or
    # environment overrides are applied, so that downstream code can rely on
    # every flag element existing.
    #
    # How it works: it links the named caller variable as the flags array and
    # then assigns a default to each recognized flag element (test suite name,
    # machine, platform, configuration, name prefix, suffix, file include and
    # exclude patterns, start and stop files, match and skip patterns,
    # constraints, verbosity, log path/id/file, threshold, random ordering,
    # leak lists and break/stop behaviors, exit-on-complete, pre/post test
    # scripts and waits, the Tcl shell path, and the collected bad and no
    # arguments).  Most defaults are empty strings or empty lists, meaning
    # "use the built-in default behavior".
    #
    # Arguments:
    #   varName -- The name of the caller array to populate with defaults; when
    #              empty, no array is linked.
    #
    # Results:
    #   An empty string.
    # </help>

    if {[string length $varName] > 0} then {
      upvar 1 $varName test_flags
    }

    set test_flags(-suite) ""; # test suite name, default empty.
    set test_flags(-machine) ""; # machine architecture, default empty.
    set test_flags(-platform) ""; # build platform, default empty.
    set test_flags(-configuration) ""; # build configuration, default empty.
    set test_flags(-namePrefix) ""; # test name prefix, default empty.
    set test_flags(-suffix) ""; # build suffix, default empty.
    set test_flags(-file) [list *.tcltk]; # default to running all test files.
    set test_flags(-notFile) [list l.*.tcltk]; # COMPAT: Tcl.
    set test_flags(-startFile) [list]; # start running at these test files.
    set test_flags(-stopFile) [list]; # stop running after these test files.
    set test_flags(-match) [list *]; # default to running all tests.
    set test_flags(-skip) [list]; # default to skipping no tests.
    set test_flags(-constraints) [list]; # default to no manual constraints.
    set test_flags(-verbose) ""; # default to pass, body, skip, start, error.
    set test_flags(-logPath) ""; # default to using standard log file path.
    set test_flags(-logId) ""; # default to using no log identifier.
    set test_flags(-logFile) ""; # default to using standard log file naming.
    set test_flags(-threshold) ""; # default to requiring all tests to pass.
    set test_flags(-randomOrder) ""; # default to deterministic order.
    set test_flags(-uncountedLeaks) [list]; # defaults for uncounted resources.
    set test_flags(-listedLeaks) [list]; # defaults for listed resources.
    set test_flags(-breakOnLeak) ""; # default to continue on leak.
    set test_flags(-stopOnFailure) ""; # default to continue on failure.
    set test_flags(-stopOnLeak) ""; # default to continue on leak.
    set test_flags(-exitOnComplete) ""; # default to not exit after complete.
    set test_flags(-preTest) ""; # default to not evaluating anything.
    set test_flags(-postTest) ""; # default to not evaluating anything.
    set test_flags(-preWait) ""; # default to not waiting.
    set test_flags(-postWait) ""; # default to not waiting.
    set test_flags(-tclsh) ""; # Tcl shell, default empty.
    set test_flags(-bad) [list]; # these are the unrecognized arguments.
    set test_flags(-no) [list]; # default to not having any restrictions.

    return ""
  }

  proc makeUseOfTestArguments { varName } {
    # <help>
    # This procedure applies the values in a caller test-flags array to the
    # corresponding global test configuration variables.  It exists as the step
    # that "commits" parsed test flags into the global state that the rest of
    # the test harness actually consults, after the flags have been seeded with
    # defaults and overridden from the command line and environment.
    #
    # How it works: it links the named caller variable as the flags array, then
    # for each relevant flag element that is present and valid it sets the
    # matching global.  The processing prohibition flag is handled specially:
    # its value is treated as a dictionary of name/value pairs that are merged
    # into the global no array.  Other flags are copied to globals such as the
    # log path, log id, log file, threshold, random-order setting, the uncounted
    # and listed leak lists, the break-on-leak, stop-on-failure, stop-on-leak,
    # and exit-on-complete switches, the pre-test and post-test scripts, and the
    # pre-wait and post-wait delays.  Each copy is guarded by an existence check
    # and an appropriate type or non-empty check, so absent or malformed flag
    # values are simply left at their existing global defaults.
    #
    # Arguments:
    #   varName -- The name of the caller test-flags array to read; when empty,
    #              no array is linked.
    #
    # Results:
    #   An empty string.  Its effect is the side effect of updating the global
    #   test configuration variables.
    # </help>

    if {[string length $varName] > 0} then {
      upvar 1 $varName test_flags
    }

    if {[info exists test_flags(-no)] && \
        [llength $test_flags(-no)] > 0} then {
      #
      # NOTE: Set the test run prohibitions based on the provided
      #       command line argument value (which is assumed to be
      #       a "dictionary-style" list containing the name/value
      #       pairs to add to the global "no" array).
      #
      foreach {name value} $test_flags(-no) {
        set ::no($name) $value
      }
    }

    if {[info exists test_flags(-logPath)] && \
        [string length $test_flags(-logPath)] > 0} then {
      set ::test_log_path $test_flags(-logPath)
    }

    if {[info exists test_flags(-logId)] && \
        [string length $test_flags(-logId)] > 0} then {
      set ::test_log_id $test_flags(-logId)
    }

    if {[info exists test_flags(-logFile)] && \
        [string length $test_flags(-logFile)] > 0} then {
      set ::test_log $test_flags(-logFile)
    }

    if {[info exists test_flags(-threshold)] && \
        [string is integer -strict $test_flags(-threshold)]} then {
      set ::test_threshold $test_flags(-threshold)
    }

    if {[info exists test_flags(-randomOrder)] && \
        [string is boolean -strict $test_flags(-randomOrder)]} then {
      set ::test_random_order $test_flags(-randomOrder)
    }

    if {[info exists test_flags(-uncountedLeaks)] && \
        [string length $test_flags(-uncountedLeaks)] > 0} then {
      set ::test_uncounted_leaks $test_flags(-uncountedLeaks)
    }

    if {[info exists test_flags(-listedLeaks)] && \
        [string length $test_flags(-listedLeaks)] > 0} then {
      set ::test_listed_leaks $test_flags(-listedLeaks)
    }

    if {[info exists test_flags(-breakOnLeak)] && \
        [string is boolean -strict $test_flags(-breakOnLeak)]} then {
      set ::test_break_on_leak $test_flags(-breakOnLeak)
    }

    if {[info exists test_flags(-stopOnFailure)] && \
        [string is boolean -strict $test_flags(-stopOnFailure)]} then {
      set ::test_stop_on_failure $test_flags(-stopOnFailure)
    }

    if {[info exists test_flags(-stopOnLeak)] && \
        [string is boolean -strict $test_flags(-stopOnLeak)]} then {
      set ::test_stop_on_leak $test_flags(-stopOnLeak)
    }

    if {[info exists test_flags(-exitOnComplete)] && \
        [string is boolean -strict $test_flags(-exitOnComplete)]} then {
      set ::test_exit_on_complete $test_flags(-exitOnComplete)
    }

    if {[info exists test_flags(-preTest)] && \
        [string length $test_flags(-preTest)] > 0} then {
      set ::test_script(pre) $test_flags(-preTest)
    }

    if {[info exists test_flags(-postTest)] && \
        [string length $test_flags(-postTest)] > 0} then {
      set ::test_script(post) $test_flags(-postTest)
    }

    if {[info exists test_flags(-preWait)] && \
        [string is integer -strict $test_flags(-preWait)]} then {
      set ::test_wait(pre) $test_flags(-preWait)
    }

    if {[info exists test_flags(-postWait)] && \
        [string is integer -strict $test_flags(-postWait)]} then {
      set ::test_wait(post) $test_flags(-postWait)
    }

    return ""
  }

  proc getTclShellFileName { automatic kits machine } {
    # <help>
    # This procedure determines the file name (or full path) of a native Tcl
    # shell to use for interoperability testing.  It exists because the test
    # suite frequently needs to launch a real tclsh, and the right one to use
    # varies by platform, architecture, environment configuration, and the set
    # of Tcl installations actually present on the machine.
    #
    # How it works: it first builds a list of environment variable names to
    # consult (TclTk_Tcl_Shell, Tcl_Shell, TCLTK_TCLSH, and TCLSH), adding
    # machine- and platform-specific suffixed variants when a machine is given.
    # Each variable is checked; in manual mode (or under native Tcl) the first
    # value found is treated as an override and returned immediately, whereas in
    # automatic TclTk mode each value is merely added to the candidate list and
    # the search continues.  When running in TclTk, it then asks the engine for
    # the best dynamically loadable Tcl library and derives candidate
    # directories (the library directory, a sibling bin directory, and the
    # parent) in which to look.  Optionally (when kits is enabled) it also
    # constructs TclKit shell candidates named after the patch level, in both
    # dotted (common on Unix) and dot-stripped (common on Windows) forms, and
    # constructs ordinary tclsh candidates for each version in the supported
    # range, again in both naming forms, favoring the current operating
    # system's convention first.  Finally, unless forbidden, it probes the
    # candidates by attempting to query each one's full executable path; it
    # makes a first pass that also requires the shell's machine to match the
    # current process and a second pass without that requirement, returning the
    # path of the first candidate that responds successfully.
    #
    # Tricky details: the architecture and version probing relies on TclTk-only
    # commands and so is skipped entirely under native Tcl.  Various steps can
    # be individually disabled through entries in the global no array (for
    # example, directory discovery, executable probing, or machine matching).
    # The machine-matching first pass is skipped when machine querying is
    # disabled.
    #
    # Arguments:
    #   automatic -- Boolean; when true (and running in TclTk) environment
    #                variable values are treated as additional candidates rather
    #                than as immediate overrides, allowing the full search to
    #                proceed.
    #   kits      -- Boolean; when true, TclKit-style shell file names are also
    #                considered among the candidates.
    #   machine   -- The target machine architecture used to form
    #                machine-specific environment variable names and platform
    #                variants; an empty value disables that specialization.
    #
    # Results:
    #   The file name or full path of a usable Tcl shell.  If no candidate is
    #   found or verified, the fallback literal tclsh is returned.
    # </help>

    #
    # NOTE: Start out with an empty list of candiate Tcl shells.
    #
    set shells [list]

    #
    # NOTE: Figure out the environment variables to be checked.  If
    #       there was a machine specified, it will be used to check
    #       for machine-specific Tcl shells.
    #
    set names [list]

    foreach name [list TclTk_Tcl_Shell Tcl_Shell TCLTK_TCLSH TCLSH] {
      if {[string length $machine] > 0} then {
        set platform [machineToPlatform $machine true]

        if {[string length $platform] > 0} then {
          lappend names [appendArgs $name _ $platform]
        }

        set platform [machineToPlatform $machine false]

        if {[string length $platform] > 0} then {
          lappend names [appendArgs $name _ $platform]
        }

        lappend names [appendArgs $name _ $machine]
      }

      lappend names $name
    }

    #
    # NOTE: Check all environment variables (we know about) that
    #       may contain the path where the Tcl shell is located.
    #
    foreach name $names {
      #
      # NOTE: Grab the value of the environment variable.  This
      #       will be an empty string if it was not set.
      #
      set value [getEnvironmentVariable $name]

      #
      # TODO: Possibly add a check if the file actually exists
      #       here.
      #
      if {[string length $value] > 0} then {
        #
        # NOTE: *EXTERNAL* Use verbatim, no normalization.
        #
        if {$automatic && [isTclTk]} then {
          #
          # NOTE: In automatic mode, the environment variable
          #       value simply represents another candidate
          #       Tcl shell (i.e. it does not halt the search
          #       for other candidate Tcl shells).
          #
          lappend shells $value
        } else {
          #
          # NOTE: In manual mode, the environment variable
          #       value represents an "override" and halts
          #       the search for other candidate Tcl shells.
          #
          return $value
        }
      }
    }

    #
    # NOTE: The automatic Tcl shell detection is only available when
    #       running in TclTk.
    #
    if {[isTclTk]} then {
      #
      # NOTE: Attempt to check for the "best" available dynamically
      #       loadable Tcl library and then attempt to use its
      #       "associated" Tcl shell.  A very similar block of code
      #       is also used by the [checkForTclInstalls] procedure
      #       in the constraints package.
      #
      if {[catch {tcl select -architecture} tcl] == 0} then {
        #
        # NOTE: Figure out list of (Tcl install?) directories to
        #       search for all the candidate shell file names.
        #
        if {![info exists ::no(getTclShellDirectories)]} then {
          #
          # NOTE: Ok, attempt to grab the (dynamic library) file
          #       name from the dictionary value.
          #
          set fileName [getDictionaryValue $tcl fileName]

          if {[string length $fileName] > 0} then {
            set directories(1) [file dirname $fileName]; # "lib"
          }

          if {[info exists directories(1)]} then {
            set directories(2) \
                [file join [file dirname $directories(1)] bin]
          }

          if {[info exists directories(1)]} then {
            set directories(3) [file dirname $directories(1)]
          }
        }

        set directories(4) ""; # NOTE: Shell file name only.

        #
        # NOTE: Should we also consider TclKit shells?  If so, a bit
        #       more handling is required.
        #
        if {$kits} then {
          #
          # NOTE: Attempt to grab the patch level field from the
          #       dictionary value.
          #
          set dotPatchLevel [getDictionaryValue $tcl patchLevel]

          #
          # NOTE: Verify that the patch level we found is valid and that
          #       it conforms to the pattern we expect.
          #
          if {[string length $dotPatchLevel] > 0 && \
              [regexp -- {^\d+\.\d+\.\d+$} $dotPatchLevel]} then {
            #
            # NOTE: Check each of the candidate directories and finally
            #       without any directory component.
            #
            foreach name [lsort -integer [array names directories]] {
              #
              # NOTE: What is the directory, if any, to be checked?
              #
              set directory $directories($name)

              #
              # NOTE: Build candidate TclKit shell executable file name
              #       with the dot-separated patch level.  This is the
              #       common naming scheme on Unix.
              #
              set dotShell [appendArgs tclkit- $dotPatchLevel]

              if {[string length $directory] > 0} then {
                set dotShell [file join $directory $dotShell]
              }

              #
              # NOTE: Build the candidate TclKit shell executable file
              #       name with the patch level, removing the dot.  This
              #       is the common naming scheme on Windows.
              #
              set shell [appendArgs \
                  tclkit- [string map [list . ""] $dotPatchLevel]]

              if {[string length $directory] > 0} then {
                set shell [file join $directory $shell]
              }

              #
              # NOTE: Always favor TclKit shell executable file naming
              #       scheme for the current operating system first.
              #
              if {[isWindows]} then {
                lappend shells $shell
                lappend shells $dotShell
              } else {
                lappend shells $dotShell
                lappend shells $shell
              }
            }
          }
        }

        #
        # NOTE: Did we find one?  Attempt to grab the version
        #       field from the returned dictionary value.
        #
        set dotVersion [getDictionaryValue $tcl version]

        #
        # NOTE: Verify that the version we found is valid and that
        #       it conforms to the pattern we expect.
        #
        if {[string length $dotVersion] > 0 && \
            [regexp -- {^\d+\.\d+$} $dotVersion]} then {
          #
          # NOTE: Gather the list of candidate Tcl shells to check
          #       using the range of versions we are interested in,
          #       starting with the "best" available version and
          #       ending with the absolute minimum version supported
          #       by the TclTk core library.  A very similar block
          #       of code is also used by the [checkForTclShell]
          #       procedure in the constraints package.
          #
          foreach version [lsort -real -decreasing [tcl \
              versionrange -maximumversion $dotVersion]] {
            #
            # NOTE: Check each of the candidate directories.
            #
            foreach name [lsort -integer [array names directories]] {
              #
              # NOTE: What is the directory, if any, to be checked?
              #
              set directory $directories($name)

              #
              # NOTE: Build the candidate Tcl shell executable file
              #       name with the dot-separated version.  This is
              #       the common naming scheme on Unix.
              #
              set dotShell [appendArgs tclsh $version]

              if {[string length $directory] > 0} then {
                set dotShell [file join $directory $dotShell]
              }

              #
              # NOTE: Build the candidate Tcl shell executable file
              #       name with the version, removing the dot.  This
              #       is the common naming scheme on Windows.
              #
              set shell [appendArgs \
                  tclsh [string map [list . ""] $version]]

              if {[string length $directory] > 0} then {
                set shell [file join $directory $shell]
              }

              #
              # NOTE: Always favor Tcl shell executable file naming
              #       scheme for the current operating system first.
              #
              if {[isWindows]} then {
                lappend shells $shell
                lappend shells $dotShell
              } else {
                lappend shells $dotShell
                lappend shells $shell
              }
            }
          }
        }
      }

      #
      # NOTE: Are we allowed to check each candidate Tcl shell to see
      #       if it actually works?
      #
      if {![info exists ::no(getTclExecutableForTclShell)]} then {
        #
        # NOTE: First, perform one pass over the candidate Tcl shells,
        #       checking seeing if one of their machines matches that
        #       of the current process.  Finally, perform another pass
        #       over the candidate Tcl shells without checking their
        #       machines.  The first pass (without machine checks) is
        #       always skipped if we are forbidden from doing it, via
        #       use of procedure [getMachineForTclShell] being disabled.
        #
        if {[info exists ::no(getMachineForTclShell)]} then {
          set getMachines [list false]
        } else {
          set getMachines [list true false]
        }

        foreach getMachine $getMachines {
          #
          # NOTE: Check each candidate Tcl shell and query its fully
          #       qualified path from it.  If it cannot be executed,
          #       we know that candidate Tcl shell is not available.
          #
          foreach shell $shells {
            #
            # NOTE: Attempt to query the full executable file name of
            #       the candidate Tcl shell.  If this fails, consider
            #       candidate Tcl shell to be unusable.
            #
            if {[catch {
              getTclExecutableForTclShell $shell [getTclShellVerbosity]
            } executable] == 0 && $executable ne "error" && \
                ![string match "error: *" $executable]} then {
              #
              # NOTE: Check if this candidate Tcl shell is actually
              #       a match for the machine of the current process?
              #
              if {$getMachine} then {
                #
                # NOTE: Attempt to query the machine of the candidate
                #       Tcl shell.  If this fails, consider candidate
                #       Tcl shell to be unusable.
                #
                if {[catch {
                  getMachineForTclShell $shell [getTclShellVerbosity]
                } machine] || $machine eq "error" || \
                    [string match "error: *" $machine]} then {
                  #
                  # NOTE: No?  Skip this candidate Tcl shell, keep
                  #       going, etc.
                  #
                  continue
                }
              }

              #
              # NOTE: It looks like this Tcl shell is available.
              #       Return the fully qualified path to it now.
              #
              return $executable
            }
          }
        }
      }
    }

    #
    # NOTE: Return the fallback default.
    #
    return tclsh
  }

  proc getTemporaryPath { {usable true} {cloud false} } {
    # <help>
    # This procedure determines a directory suitable for temporary files (such
    # as test log files), honoring environment overrides and falling back to
    # platform defaults.  It exists to give the test suite a single, consistent,
    # cross-platform way to locate temporary storage, with optional preference
    # for a cloud-synchronized directory.
    #
    # How it works: it starts from a list of base environment variable names
    # (TCLTK_TEST_TEMP, TCLTK_TEMP, XDG_RUNTIME_DIR, TEMP, and TMP), optionally
    # inserting a cloud directory variable near the front when cloud preference
    # is requested.  It expands each base name into upper-, lower-, and
    # title-case variants and checks each in turn.  The first variable that is
    # set to a non-empty value wins; when the usable check is requested, the
    # candidate must also be an existing, writable directory to be accepted, and
    # the accepted path is returned normalized.  If no environment variable
    # yields a path, it falls back: in TclTk with object support it asks the
    # framework for the user cloud directory (when cloud is requested) or the
    # system temporary path; under native Tcl it falls back to the directory
    # containing the running shell executable.
    #
    # Tricky details: the cloud preference both changes which environment
    # variables are searched and which framework fallback is used.  The native
    # Tcl fallback (the executable's directory) may not be writable, especially
    # for an installed interpreter on a non-Windows platform, as noted inline.
    #
    # Arguments:
    #   usable -- Optional boolean; when true a candidate environment-supplied
    #             path must be an existing, writable directory to be accepted.
    #             When false, the first non-empty value is accepted as-is.
    #             Defaults to true.
    #   cloud  -- Optional boolean; when true, a cloud-synchronized directory is
    #             preferred, both in the environment search and in the
    #             framework fallback.  Defaults to false.
    #
    # Results:
    #   A normalized path to a temporary directory.
    # </help>

    #
    # NOTE: Initially, start with the list of legacy base environment
    #       variable names.
    #
    set baseNames [list \
        TCLTK_TEST_TEMP TCLTK_TEMP XDG_RUNTIME_DIR TEMP TMP]

    #
    # NOTE: If the caller enabled cloud support, insert appropriate
    #       base environment variable names near the front of the list
    #       (e.g. for test suite logs hosted on cloud drive providers).
    #       This may seem like a dumb idea; however, the log files are
    #       basically never bigger than "1Mb" and it may be useful for
    #       more than one user to be able to see them.  This decision
    #       is subject to change in the future.
    #
    if {$cloud} then {
      set baseNames [linsert $baseNames 2 XDG_CLOUD_DIR]
    }

    #
    # NOTE: Build list of "temporary directory" override environment
    #       variables to check.
    #
    set names [list]

    foreach name $baseNames {
      #
      # NOTE: Make sure we handle all the reasonable "cases" of the
      #       environment variable names.
      #
      lappend names [string toupper $name] [string tolower $name] \
          [string totitle $name]
    }

    #
    # NOTE: Check if we can use any of the environment variables.
    #
    foreach name $names {
      set value [getEnvironmentVariable $name]

      #
      # NOTE: First, make sure the environment variable was actually
      #       set to something.
      #
      if {[string length $value] > 0} then {
        #
        # NOTE: Next, when the "usable" argument is non-zero, attempt
        #       to make sure the returned temporary path is actually
        #       an existing directory, writable by us.
        #
        if {$usable} then {
          if {[file isdirectory $value] && [file writable $value]} then {
            return [file normalize $value]
          }
        } else {
          return [file normalize $value]
        }
      }
    }

    if {[isTclTk] && [llength [info commands object]] > 0} then {
      #
      # NOTE: Does the caller want to prefer a cloud drive provider
      #       directory?
      #
      if {$cloud} then {
        #
        # NOTE: TclTk cloud directory fallback, use whatever is found
        #       (first) on the file system.
        #
        return [file normalize [object invoke -flags +NonPublic \
            CodeBrix.Platform.TclTk._Components.Private.PathOps GetUserCloudDirectory]]
      } else {
        #
        # NOTE: TclTk fallback, use whatever is provided by underlying
        #       framework and/or operating system.
        #
        return [file normalize [object invoke System.IO.Path GetTempPath]]
      }
    } else {
      #
      # NOTE: Tcl fallback, just assume that we can use the directory
      #       where the executable is running for temporary storage.
      #       This will most likely not work for native Tcl, especially
      #       when it is running on a non-Windows platform, as Tcl will
      #       generally be installed into a location that would require
      #       elevated privileges in order to create and/or write files.
      #
      return [file normalize [file dirname [getShellExecutableName]]]
    }
  }

  proc getTemporaryFileName { {seconds 5} } {
    # <help>
    # This procedure returns the path of a temporary file name that does not yet
    # exist, for use as scratch storage during testing.  It exists to give the
    # test suite a unique temporary file name in both TclTk and native Tcl,
    # which lack a common command for this purpose.
    #
    # How it works: under TclTk it simply defers to the engine's [file
    # tempname].  Under native Tcl it locates a temporary directory via
    # [getTemporaryPath], then repeatedly generates a short pseudo-random
    # tmp-prefixed, .tmp-suffixed candidate file name (derived from random bits)
    # and checks whether it already exists, returning the first candidate that
    # does not.  It keeps trying until a free name is found or the time budget
    # is exhausted.
    #
    # Tricky details: the candidate name is built from a handful of hexadecimal
    # characters taken from a random double, so collisions are possible but
    # unlikely; the loop guards against running forever by bounding itself with
    # the seconds budget and raising an error if it cannot find a free name in
    # time.  The randomness is not cryptographic.
    #
    # Arguments:
    #   seconds -- Optional time budget, in seconds, for the native Tcl
    #              generation loop to find an unused name before giving up.
    #              Ignored under TclTk.  Defaults to 5.
    #
    # Results:
    #   The path of a temporary file that does not currently exist.  An error is
    #   raised under native Tcl if no free name can be generated within the time
    #   budget.
    # </help>

    if {[isTclTk]} then {
      return [file tempname]
    } else {
      set path [getTemporaryPath]

      set now [clock seconds]
      set start $now; set stop [expr {$now + $seconds}]

      while {$start <= $now && $now < $stop} {
        binary scan [binary format d* [expr {rand()}]] h* random
        set random [string toupper $random]

        set fileNameOnly [appendArgs \
            tmp [string index $random 0] [string index $random 1] \
            [string index $random end-1] [string index $random end] \
            .tmp]

        set fileName [file join $path $fileNameOnly]

        if {![file exists $fileName]} then {
          return $fileName
        }

        set now [clock seconds]
      }

      error "cannot generate temporary file name"
    }
  }

  proc checkOsAndModeForPath { path osVarName modeVarName } {
    # <help>
    # This procedure inspects a filesystem path on Unix-like systems, returning
    # whether it is on a supported operating system and, as a side effect,
    # reporting that operating system name and the path's raw mode bits to the
    # caller.  It exists as a shared helper for the readable-directory and
    # readable-file checks, which need the stat mode bits to distinguish file
    # types on Linux and Darwin.
    #
    # How it works: it requires the platform operating-system identifier to be
    # available, then optionally stores that identifier in the caller variable
    # named by osVarName.  It performs an [file lstat] on the path; on failure,
    # or when no mode is reported, or when the mode is not a wide integer, it
    # returns false.  Otherwise it stores the mode in the caller variable named
    # by modeVarName.  Finally it returns true only when the operating system is
    # one of the supported Unix-like systems (Linux or Darwin).
    #
    # Tricky details: this uses [lstat], so it reports on a symbolic link
    # itself rather than its target.  The two output variables are written via
    # [upvar] only when their names are non-empty, and the os value may be set
    # even in some cases where the procedure ultimately returns false.
    #
    # Arguments:
    #   path        -- The filesystem path to inspect.
    #   osVarName   -- The name of a caller variable to receive the operating
    #                  system identifier; pass an empty string to skip it.
    #   modeVarName -- The name of a caller variable to receive the raw stat
    #                  mode bits; pass an empty string to skip it.
    #
    # Results:
    #   Boolean true when the path could be stat'd and the operating system is a
    #   supported Unix-like system, otherwise false.
    # </help>

    if {![info exists ::tcl_platform(os)]} then {
      return false
    }

    if {[string length $osVarName] > 0} then {
      upvar 1 $osVarName os
    }

    set os $::tcl_platform(os)

    if {[catch {file lstat $path stat}]} then {
      return false
    }

    if {![info exists stat(mode)]} then {
      return false
    }

    if {[string length $modeVarName] > 0} then {
      upvar 1 $modeVarName mode
    }

    set mode $stat(mode)

    if {![string is wideinteger $mode]} then {
      return false
    }

    if {[lsearch -exact \
        [list Linux Darwin] $os] == -1} then {
      return false
    }

    return true
  }

  proc isDirectoryReadable { path } {
    # <help>
    # This procedure returns whether a path is a directory that can actually be
    # read.  It exists because a simple readability check is not always
    # sufficient on Unix-like systems, where it is worth confirming the path is
    # genuinely a directory (and not, say, a special file) before relying on it.
    #
    # How it works: it first requires the path to be a directory.  On non-Windows
    # systems it then uses [checkOsAndModeForPath] to obtain the stat mode bits
    # and confirms, by masking with the file-type mask and comparing against the
    # directory type constant, that the entry really is a directory; if that
    # check cannot be performed or fails, it returns false.  On all systems it
    # finishes by returning the result of the standard [file readable] test.
    #
    # Arguments:
    #   path -- The filesystem path to test.
    #
    # Results:
    #   Boolean true when the path is a readable directory, otherwise false.
    # </help>

    if {![file isdirectory $path]} then {
      return false
    }

    if {![isWindows]} then {
      if {![checkOsAndModeForPath $path os mode]} then {
        return false
      }

      set S_IFDIR 0x4000; # regular directory
      set S_IFMT 0xF000; # file type mask

      if {($mode & $S_IFMT) != $S_IFDIR} then {
        return false
      }
    }

    return [file readable $path]
  }

  proc isFileReadable { path } {
    # <help>
    # This procedure returns whether a path is a regular file that can actually
    # be read.  It is the file counterpart of [isDirectoryReadable] and exists
    # for the same reason: on Unix-like systems it is worth confirming the entry
    # is an ordinary regular file (not a directory, device, or other special
    # file) before treating it as a readable file.
    #
    # How it works: it first requires the path to be a file.  On non-Windows
    # systems it uses [checkOsAndModeForPath] to obtain the stat mode bits and
    # confirms, by masking with the file-type mask and comparing against the
    # regular-file type constant, that the entry really is a regular file;
    # otherwise it returns false.  On all systems it finishes by returning the
    # result of the standard [file readable] test.
    #
    # Arguments:
    #   path -- The filesystem path to test.
    #
    # Results:
    #   Boolean true when the path is a readable regular file, otherwise false.
    # </help>

    if {![file isfile $path]} then {
      return false
    }

    if {![isWindows]} then {
      if {![checkOsAndModeForPath $path os mode]} then {
        return false
      }

      set S_IFREG 0x8000; # regular file
      set S_IFMT 0xF000; # file type mask

      if {($mode & $S_IFMT) != $S_IFREG} then {
        return false
      }
    }

    return [file readable $path]
  }

  proc getFiles {
          directory include {exclude ""} {forceReadable false} } {
    # <help>
    # This procedure returns a sorted list of files in a directory matching an
    # include pattern, optionally excluding those matching a second pattern.  It
    # exists as a small cross-engine wrapper over directory listing, smoothing
    # over the differences between TclTk's [file list] and native Tcl's [glob].
    #
    # How it works: under TclTk, when the directory exists, it lists the entries
    # matching the include pattern (sorted in dictionary order), skips any whose
    # name matches the exclude pattern, and includes each remaining one only if
    # it is a readable file or if readability checking has been forced off.
    # Under native Tcl it uses [glob] restricted to readable files, applies the
    # same exclude filtering, and again sorts in dictionary order.
    #
    # Tricky details: the include and exclude patterns are glob patterns; an
    # empty exclude pattern disables exclusion.  The forceReadable flag only
    # affects the TclTk path, where it bypasses the per-file readability check
    # (the Tcl path already restricts to readable files via glob types).
    #
    # Arguments:
    #   directory     -- The directory to list.
    #   include       -- The glob pattern selecting files to include.
    #   exclude       -- Optional glob pattern; matching files are omitted.  An
    #                    empty value (the default) disables exclusion.
    #   forceReadable -- Optional boolean (TclTk only); when true, the per-file
    #                    readability check is skipped.  Defaults to false.
    #
    # Results:
    #   A dictionary-sorted list of matching file names.  The empty list is
    #   returned when the directory does not exist or nothing matches.
    # </help>

    set result [list]

    if {[isTclTk]} then {
      if {[file exists $directory] && \
          [file isdirectory $directory]} then {
        foreach fileName [lsort \
            -dictionary [file list $directory $include]] {
          if {[string length $exclude] == 0 || \
              ![string match $exclude $fileName]} then {
            if {$forceReadable || \
                [isFileReadable $fileName]} then {
              lappend result $fileName
            }
          }
        }
      }
    } else {
      foreach fileName [lsort \
          -dictionary [glob -directory $directory \
          -types {f r} -nocomplain -- $include]] {
        if {[string length $exclude] == 0 || \
            ![string match $exclude $fileName]} then {
          lappend result $fileName
        }
      }
    }

    return $result
  }

  proc getTestFiles {
          directories matchFilePatterns skipFilePatterns {quiet false} } {
    # <help>
    # This procedure gathers the list of test script files to run by scanning a
    # set of directories for files matching the desired patterns while skipping
    # those matching the exclusion patterns.  It exists as the file-discovery
    # step of the test runner, turning a directory specification into the
    # concrete set of test files.
    #
    # How it works: it first expands the directory list.  As a convenience, any
    # entry that looks like a bare variable name (an identifier) is, when such a
    # variable exists in the caller's scope and holds a proper list, replaced by
    # the directories named in that variable; this lets callers pass a variable
    # of directories indirectly.  Then, for each resolved directory, it collects
    # the files matching each of the include patterns and the files matching
    # each of the skip patterns (via [getFiles]), and adds to the result every
    # matched file that is not in the skip set.  Unless quiet output is
    # requested, it logs the number of directories drawn from each variable and
    # the total number of test files found.
    #
    # Tricky details: variable-name detection uses a strict identifier pattern,
    # and the indirect variable lookup is performed in the caller's frame; a
    # named variable that is not a proper list is silently skipped.  Files
    # matched by both an include and a skip pattern are excluded.
    #
    # Arguments:
    #   directories      -- A list of directories to scan; an entry that is a
    #                       bare identifier naming a caller list variable is
    #                       expanded to that variable's directories.
    #   matchFilePatterns -- A list of glob patterns selecting test files to
    #                        include.
    #   skipFilePatterns  -- A list of glob patterns selecting files to exclude.
    #   quiet            -- Optional boolean; when true, the informational log
    #                       messages are suppressed.  Defaults to false.
    #
    # Results:
    #   A list of the discovered test file paths.
    # </help>

    set result [list]

    #
    # NOTE: Figure out where to send the output from gathering the
    #       list of test files.
    #
    set channel [getTestChannelOrDefault]

    #
    # HACK: If any "directory" appears to look like a variable name,
    #       use that variable name, in the context of the caller, in
    #       order to obtain a list of directories where test files
    #       may be located.
    #
    set newDirectories [list]

    foreach directory $directories {
      if {[regexp -nocase -- {^[A-Z][0-9A-Z_]*$} $directory]} then {
        set varName $directory

        if {[uplevel 1 info exists $varName]} then {
          set varValue [uplevel 1 set $varName]

          if {[isTclTk]} then {
            if {![string is list -strict $varValue]} then {
              continue
            }
          } else {
            if {[catch {llength $varValue}]} then {
              continue
            }
          }

          eval lappend newDirectories $varValue

          if {!$quiet} then {
            set varLength [llength $varValue]

            tputs $channel [appendArgs \
                "---- added " $varLength " test file " \
                [expr {$varLength == 1 ? \
                    "directory" : "directories"}] \
                " from variable: " $varName \n]
          }

          continue
        }
      }

      lappend newDirectories $directory
    }

    set count 0

    foreach directory $newDirectories {
      set matchFileNames [list]

      foreach pattern $matchFilePatterns {
        eval lappend matchFileNames [getFiles $directory $pattern]
      }

      set skipFileNames [list]

      foreach pattern $skipFilePatterns {
        eval lappend skipFileNames [getFiles $directory $pattern]
      }

      foreach fileName $matchFileNames {
        if {[lsearch -exact $skipFileNames $fileName] == -1} then {
          lappend result $fileName; incr count
        }
      }
    }

    if {!$quiet} then {
      set length [llength $newDirectories]

      tputs $channel [appendArgs \
          "---- added " $count " test files from " \
          [expr {$length == 1 ? "directory" : "directories"}] \
          ": " $newDirectories \n]
    }

    return $result
  }

  proc getTestChildren {} {
    # <help>
    # This procedure returns the list of child (slave) interpreters of the
    # current interpreter, in a way that works across TclTk releases and native
    # Tcl versions.  It exists to paper over a terminology change: newer engines
    # expose this via [interp children] while older native Tcl only understands
    # [interp slaves].
    #
    # How it works: when running a sufficiently recent TclTk release it uses
    # [interp children].  Otherwise it tries [interp children] anyway (to handle
    # newer native Tcl that supports it) and, only if that fails, falls back to
    # the legacy [interp slaves] sub-command for backward compatibility with
    # older native Tcl.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   A list of the names of the current interpreter's child interpreters.
    # </help>

    if {[isStableTclTkRelease 45 true]} then {; # NOTE: Post Beta 45.
      #
      # NOTE: This version of TclTk should support the [interp children]
      #       sub-command.
      #
      return [interp children]; # Beta 46+
    } elseif {[catch {interp children} children] == 0} then {
      #
      # NOTE: The version of native Tcl in use appears to support the new
      #       [interp children] sub-command.
      #
      return $children; # Tcl 8.7+ (?)
    } else {
      #
      # NOTE: Unfortunately, this exact terminology is needed to retain
      #       backward compatibility with native Tcl 8.4+.  Please see:
      #
      #       https://urn.to/r/tcl_interp_slaves
      #
      return [interp slaves]; # COMPAT: Tcl.
    }
  }

  proc getTestRunId {} {
    # <help>
    # This procedure returns the current test run identifier, a unique string
    # that ties together all log output from a single test run.  It exists as a
    # safe accessor that yields an empty string when no run identifier has been
    # established.
    #
    # How it works: it returns the value of the global test run identifier
    # variable when it exists, otherwise the empty string.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   The current test run identifier, or the empty string when none is set.
    # </help>

    return [expr {[info exists ::test_run_id] ? $::test_run_id : ""}]
  }

  proc getTestRunBucket {} {
    # <help>
    # This procedure returns the current test run "bucket", an optional
    # grouping label used to organize test log files (for example, into a
    # named sub-directory).  It exists as a safe accessor that yields an empty
    # string when no bucket has been established.
    #
    # How it works: it returns the value of the global test run bucket variable
    # when it exists, otherwise the empty string.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   The current test run bucket, or the empty string when none is set.
    # </help>

    return [expr {[info exists ::test_run_bucket] ? $::test_run_bucket : ""}]
  }

  proc isValidGuid { value } {
    # <help>
    # This procedure returns whether a value is a well-formed GUID (globally
    # unique identifier).  It exists to validate identifiers, such as those
    # produced by an external uuidgen tool, in a way that works in both TclTk
    # and native Tcl.
    #
    # How it works: under TclTk it uses the engine's strict GUID string test.
    # Under native Tcl, which lacks that test, it matches the value against a
    # case-insensitive regular expression requiring the canonical hexadecimal,
    # hyphen-separated GUID layout (groups of 8, 4, 4, 4, and 12 hexadecimal
    # digits).
    #
    # Tricky details: the native Tcl check accepts the bare hyphenated form
    # only; it does not accept brace- or parenthesis-wrapped variants.
    #
    # Arguments:
    #   value -- The string to validate.
    #
    # Results:
    #   Boolean true when the value is a valid GUID, otherwise false.
    # </help>

    if {[isTclTk]} then {
      return [string is guid -strict $value]
    } else {
      set pattern [appendArgs \
          ^ {[0-9A-F]{8}} - {[0-9A-F]{4}} - {[0-9A-F]{4}} \
          - {[0-9A-F]{4}} - {[0-9A-F]{12}} \$]

      return [regexp -nocase -- $pattern $value]
    }
  }

  proc getNewTestRunId {} {
    # <help>
    # This procedure generates a fresh, highly unique identifier for a test run.
    # It exists so that each run of the test suite can be tagged with a distinct
    # identifier, which makes correlating and analyzing the resulting log files
    # much easier.
    #
    # How it works: unless forbidden via the global no array, it first obtains a
    # GUID, preferring the engine's [guid new] sub-command in TclTk and
    # otherwise attempting an external uuidgen tool (validating its output with
    # [isValidGuid]).  It then combines several sources of entropy and identity,
    # the host name, the process id, the thread id, the current time, a clock
    # clicks value, a random number, and the GUID, into a single string.  Under
    # TclTk (on the .NET Framework) it formats these with a hexadecimal format
    # string and returns a SHA-256 hash of the whole; on Mono, where the
    # variadic String.Format overload is unavailable, it builds the same content
    # by concatenation (stripping leading minus signs) before hashing.  Under
    # native Tcl it builds a hexadecimal string directly from the host name and
    # the formatted numeric pieces.
    #
    # Tricky details: several behaviors are individually suppressible through
    # the global no array (skipping the GUID entirely, skipping [guid new], or
    # skipping the uuidgen tool).  The TclTk path hashes the result for a fixed,
    # opaque identifier, whereas the native Tcl path returns the assembled
    # hexadecimal string; in both cases the goal is uniqueness in time and
    # space, not cryptographic secrecy.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   A unique test run identifier string.
    # </help>

    #
    # HACK: Unless forbidden from doing so, include a new GUID generated
    #       either via the [guid new] sub-command -OR- using the [exec]
    #       command to execute an external "uuidgen" tool, which may be
    #       present.
    #
    set guid ""

    if {![info exists ::no(newGuidForTestRun)]} then {
      if {![info exists ::no(guidNew)] && [isTclTk]} then {
        set guid [guid new]
      } elseif {![info exists ::no(uuidgenTool)] && [catch {
        exec -success Success -- uuidgen; # maybe in PATH?
      } exec] == 0 && [isValidGuid $exec]} then {
        set guid $exec
      }
    }

    #
    # HACK: Yes, this is a bit ugly; however, it creates a nice unique
    #       identifier to represent the test run, which makes analyzing
    #       the test log files a lot easier.
    #
    if {[isTclTk]} then {
      #
      # BUGBUG: Tcl 8.4 does not like this expression (and Tcl tries to
      #         compile it even though it will only actually ever be
      #         evaluated in TclTk).
      #
      set expr {random()}

      #
      # NOTE: Include the host name to make the result more unique in both
      #       time and space.  Also, hash the entire constructed string.
      #
      if {![isMono]} then {
        #
        # NOTE: When running on the .NET Framework, we can simply use the
        #       [string format] command.
        #
        return [hash normal sha256 [string format \
            "{0}{1:X8}{2:X8}{3:X16}{4:X16}{5:X16}{6}" [info host] [pid] \
            [info tid] [clock now] [clock clicks] [expr $expr] $guid]]
      } else {
        #
        # HACK: Mono does not currently support calling the String.Format
        #       overload that takes a variable number of arguments via
        #       reflection (Mono bug #636939).  Also, strip any leading
        #       minus signs for cleanliness.
        #
        return [hash normal sha256 [appendArgs [info host] [string \
            trimleft [pid] -] [string trimleft [info tid] -] [string \
            trimleft [clock now] -] [string trimleft [clock clicks] -] \
            [string trimleft [expr $expr] -] $guid]]
      }
    } else {
      #
      # NOTE: Generate a random number using [expr] and then convert it
      #       to a 64-bit integer.
      #
      binary scan [binary format d* [expr {rand()}]] w* random

      #
      # NOTE: Convert the host name to a hexadecimal string and include
      #       it in the result in an attempt to make it more unique in
      #       both time and space.
      #
      binary scan [info host] c* host
      set host [eval [list format [string repeat %X [llength $host]]] $host]

      #
      # NOTE: Build the final result with the [format] command, converting
      #       all the pieces to hexadecimal (except for the host, which is
      #       already hexadecimal).
      #
      set pid [pid]; set seconds [clock seconds]; set clicks [clock clicks]

      return [appendArgs \
          $host [format [appendArgs % [getLengthModifier $pid] X% \
          [getLengthModifier $seconds] X% [getLengthModifier $clicks] X% \
          [getLengthModifier $random] X] $pid $seconds $clicks $random] \
          $guid]
    }
  }

  proc getDefaultTestLogSubPath {} {
    # <help>
    # This procedure computes the default sub-path, relative to a base
    # temporary directory, under which test log files should be placed.  It
    # exists to keep log files tidily organized by run bucket and, by default,
    # by date.
    #
    # How it works: it starts with a logs directory joined with the current
    # test run bucket (which may be empty).  Unless per-day logging is disabled
    # via the global no array, it further appends a sub-directory named after
    # the current date in year-month-day form.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   A relative sub-path (such as logs joined with a bucket and a date) for
    #   storing test log files.
    # </help>

    set result [file join logs [getTestRunBucket]]

    if {![info exists ::no(testLogsPerDay)]} then {
      set result [file join $result \
          [clock format [clock seconds] -format %Y-%m-%d]]
    }

    return $result
  }

  proc getDefaultTestLogPath { executable {quiet false} } {
    # <help>
    # This procedure determines the default directory in which test log files
    # should be created, creating the appropriate sub-directory along the way.
    # It exists so that test logs are written to a sensible, usable, and (where
    # possible) date- and bucket-organized location.
    #
    # How it works: unless forbidden via the global no array, it uses the
    # configured temporary directory (requiring it to be usable, and optionally
    # cloud-hosted when local logging is disabled).  When temporary logging is
    # forbidden, it instead bases the path on the executable's location, with a
    # special case under .NET Core in TclTk that relocates near the binaries
    # because .NET Core reports itself as the executable-of-record.  It then,
    # unless disabled, attempts to create the dated/bucketed sub-directory
    # returned by [getDefaultTestLogSubPath] beneath that base; if creation
    # succeeds it returns that sub-directory, and if it fails it logs a warning
    # (unless quiet) and falls back to the base directory, which is known to
    # exist.
    #
    # Tricky details: several behaviors are governed by entries in the global
    # no array (whether to use the temporary directory, whether logs are local
    # versus cloud-hosted, and whether to create the dated sub-directory).  The
    # directory-creation failure is non-fatal.
    #
    # Arguments:
    #   executable -- The path of the shell executable, used to derive the base
    #                 directory when the temporary directory is not used.
    #   quiet      -- Optional boolean; when true, the warning about a failed
    #                 sub-directory creation is suppressed.  Defaults to false.
    #
    # Results:
    #   The directory path in which test log files should be created.
    # </help>

    #
    # NOTE: By default, use the configured temporary directory for
    #       test log files unless we are forbidden from doing so.
    #
    if {![info exists ::no(temporaryTestLog)]} then {
      #
      # HACK: The test log file MUST reside in a usable directory
      #       -AND- it MAY need to be hosted within a cloud drive
      #       provider directory.
      #
      set path [getTemporaryPath true [info exists ::no(localTestLog)]]
    } else {
      #
      # HACK: It seems that .NET Core considers itself to be the
      #       executable-of-record for the process; in that case,
      #       relocate the log file to be nearer the assemblies.
      #
      if {[isTclTk] && [isDotNetCore]} then {
        set path [info binary]
      } else {
        set path [file dirname $executable]
      }
    }

    #
    # NOTE: Attempt to create a "logs" sub-directory within the
    #       the (base) directory we determined above.  If this
    #       fails (for any reason), just fallback to the (base)
    #       directory we already have.
    #
    if {![info exists ::no(testLogsSubDirectory)]} then {
      set subPath ""

      if {[catch {
        #
        # HACK: By default, place log files within sub-directory
        #       based on the current date, unless forbidden from
        #       doing so.  In that case, just create and/or use
        #       the "logs" sub-directory.  If a test run bucket
        #       is present, use that too.
        #
        set subPath [file join $path [getDefaultTestLogSubPath]]

        #
        # HACK: Make sure the directory exists now.  If it does
        #       not -AND- it cannot be created, we will fallback
        #       to the (base) directory we determined above and
        #       which we know already exists.
        #
        file mkdir $subPath
      } error] == 0} then {
        return $subPath
      } else {
        #
        # HACK: Queue an error message indicating that something
        #       went horribly wrong (?) here.
        #
        if {!$quiet} then {
          tqputs [getTestChannelOrDefault] [appendArgs \
              "==== WARNING: creation of test logs directory \"" \
              $subPath "\" failed: " $error \n]
        }
      }
    }

    return $path
  }

  proc getTestLogPath {} {
    # <help>
    # This procedure returns the configured test log directory path, or an
    # empty string when none has been set.  It exists as a safe accessor for
    # the global test log path variable.
    #
    # How it works: it returns the configured log path when the corresponding
    # global variable exists, otherwise the empty string.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   The configured test log path, or the empty string when none is set.
    # </help>

    return [expr {[info exists ::test_log_path] ? $::test_log_path : ""}]
  }

  proc getTestLogId {} {
    # <help>
    # This procedure returns the configured test log identifier, formatted as a
    # dot-prefixed suffix suitable for embedding in a log file name, or an
    # empty string when none has been set.  It exists so that log file names
    # can optionally carry a distinguishing identifier.
    #
    # How it works: when the global log identifier variable exists, it returns
    # that identifier prefixed by a period (so it can be appended directly into
    # a file name); otherwise it returns the empty string.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   The log identifier prefixed with a period, or the empty string when
    #   none is set.
    # </help>

    return [expr {[info exists ::test_log_id] ? \
        [append result . $::test_log_id] : ""}]
  }

  proc getDefaultTestLog {} {
    # <help>
    # This procedure computes the default, fully qualified test log file name to
    # use when one has not been explicitly configured.  It exists so the test
    # harness always has a sensible place to write its log, including a name
    # that is unique to the process.
    #
    # How it works: it first honors a disable entry in the global no array,
    # returning an empty string when present.  As a special integration
    # convenience, if an environment variable of the same name as this procedure
    # is set, its value is returned verbatim (this lets an outer test run direct
    # a nested TclTk shell's log output without adding a command-line argument).
    # Otherwise it determines the base directory (the configured log path if
    # set, else the default computed by [getDefaultTestLogPath]) and constructs
    # a normalized file name from the shell executable's tail, the optional log
    # identifier, a test marker, and the process id, with a .log extension.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   A normalized default test log file name, or the empty string when
    #   default log determination has been disabled.
    # </help>

    if {[info exists ::no(getDefaultTestLog)]} then {
      return ""
    }

    #
    # HACK: This environment variable can be quite useful
    #       for "external integration", i.e. where a test
    #       suite ends up executing something that itself
    #       then executes a (nested) TclTk shell that may
    #       end up wanting to add something to the (outer)
    #       test log file, i.e. without having to directly
    #       add another command line argument to the TclTk
    #       shell command line.
    #
    if {[info exists ::env(getDefaultTestLog)]} then {
      return $::env(getDefaultTestLog)
    }

    set executable [getShellExecutableName]

    if {[info exists ::test_log_path]} then {
      set path $::test_log_path
    } else {
      set path [getDefaultTestLogPath $executable]
    }

    return [file normalize [file join $path [appendArgs \
        [file tail $executable] [getTestLogId] .test. [pid] .log]]]
  }

  #
  # HACK: Do not define the [newTestLog] test procedure if it apppears
  #       to already be present.  This is necessary due to the external
  #       log monitor tool needing to override this procedure prior to
  #       the test package actually being loaded.
  #
  if {[llength [info commands newTestLog]] == 0} then {
    #
    # WARNING: This procedure is RESERVED for use by external log
    #          monitoring tools, e.g. the official "watchCat" tool.
    #
    proc newTestLog { oldFileName newFileName } {
      # <help>
      # This procedure is a notification hook, invoked when the active test log
      # file name changes, that external log-monitoring tools may override.  It
      # exists as an extension point so that tools such as the official watchCat
      # log monitor can learn the new log file name after the test harness has
      # (re)configured it.  The default implementation defined here is
      # deliberately a no-op; it is only created when no implementation is
      # already present, because an external monitor typically installs its own
      # version before this test package is loaded.
      #
      # Arguments:
      #   oldFileName -- The previous test log file name (which may be empty
      #                  when there was none).
      #   newFileName -- The new test log file name now in effect.
      #
      # Results:
      #   An empty string; the default implementation performs no action.
      # </help>

      #
      # NOTE: This procedure is designed to be called by external code
      #       that wants to change the test log file name after it has
      #       already been setup.  This can be used to enable external
      #       log monitor tools to obtain the new test log file name.
      #
    }
  }

  proc getTestLog {} {
    # <help>
    # This procedure returns the currently configured test log file name, or an
    # empty string when none has been set.  It exists as a safe accessor for
    # the global test log file name variable.
    #
    # How it works: it returns the configured log file name when the global
    # variable exists, otherwise the empty string.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   The configured test log file name, or the empty string when none is
    #   set.
    # </help>

    return [expr {[info exists ::test_log] ? $::test_log : ""}]
  }

  proc getLastTestLog {} {
    # <help>
    # This procedure locates the most recent prior test log file, that is, the
    # newest log file from an earlier run, distinct from the current one.  It
    # exists to support comparing or referencing the previous run's log, for
    # example when summarizing changes between runs.
    #
    # How it works: it determines the current log file name (the configured one
    # if set, otherwise the default), normalizes it, and records its
    # modification time if it exists.  It then turns the name into a glob
    # pattern by replacing the embedded process-id component with a wildcard,
    # and recursively finds all matching log files.  Skipping the current log
    # file itself, it tracks the candidate with the latest modification time.
    # It returns that newest prior log file when one is found; failing that, it
    # returns the current log file name if it actually exists; otherwise it
    # returns the empty string.
    #
    # Tricky details: the previous-versus-current distinction relies on
    # comparing file names (via a same-file check), and the search hinges on the
    # log name containing a dotted numeric (process id) component that can be
    # replaced with a wildcard; if that substitution does not apply, the empty
    # string is returned.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   The path of the most recent prior test log file, or the current log file
    #   when it exists and no prior one is found, or the empty string.
    # </help>

    #
    # NOTE: Use the configured log file name -OR- what the configured
    #       log file name would be, by default, if it actually existed.
    #
    if {[info exists ::test_log]} then {
      set logFileName $::test_log
    } else {
      set logFileName [getDefaultTestLog]
    }

    set logFileName [file normalize $logFileName]

    set logTime [expr {[file exists $logFileName] ? \
        [file mtime $logFileName] : 0}]

    #
    # NOTE: Make the log file name into a pattern we can use to find
    #       the related log files.
    #
    if {[regsub -- {\.\d+\.} $logFileName {.*.} pattern]} then {
      set lastLogFile [list]

      foreach fileName [findFilesRecursive $pattern] {
        #
        # NOTE: Skip the current test log file, if found.
        #
        if {[isSameFileName $fileName $logFileName]} then {
          continue
        }

        #
        # NOTE: When was this log file last modified?
        #
        set time [file mtime $fileName]

        #
        # NOTE: Check if there has been no log file seen -OR- this
        #       log file has the latest modified time seen.
        #
        if {[llength $lastLogFile] == 0 || \
            $time > [lindex $lastLogFile 0]} then {
          #
          # NOTE: This is now the latest log file seen.
          #
          set lastLogFile [list $time $fileName]
        }
      }

      #
      # NOTE: Either return the last log file seen, if any -OR- the
      #       configured log file, if it actually exists.
      #
      if {[llength $lastLogFile] > 0} then {
        return [lindex $lastLogFile 1]
      } elseif {$logTime != 0} then {
        return $logFileName
      }
    }

    return ""
  }

  proc getTestSuite {} {
    # <help>
    # This procedure returns the effective name of the test suite currently
    # being run.  It exists to resolve the suite name from the layered sources
    # of configuration, preferring an explicit override and falling back to a
    # sensible default.
    #
    # How it works: it returns the suite name from the test flags array when
    # that flag is set and non-empty; otherwise it uses the global test suite
    # variable when present (whose default is established by the suite
    # prologue); failing both, it returns a built-in default that differs
    # depending on whether the suite is running under TclTk or native Tcl.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   The effective test suite name string.
    # </help>

    #
    # NOTE: Determine the effective test suite name and return it.  If the
    #       test suite name cannot be determined, return the default based
    #       on whether we are running in TclTk or native Tcl.
    #
    if {[info exists ::test_flags(-suite)] && \
        [string length $::test_flags(-suite)] > 0} then {
      #
      # NOTE: The test suite name has been manually overridden via the test
      #       flags; therefore, use it.
      #
      return $::test_flags(-suite)
    } elseif {[info exists ::test_suite]} then {
      #
      # NOTE: Use the test suite name.  The default value is set by the test
      #       suite prologue; however, this may have been overridden.
      #
      return $::test_suite
    } elseif {[isTclTk]} then {
      #
      # NOTE: Use the default test suite name for TclTk.
      #
      return "TclTk Test Suite for TclTk"
    } else {
      #
      # NOTE: Use the default test suite name for native Tcl.
      #
      return "TclTk Test Suite for Tcl"
    }
  }

  proc getTestSuiteFileName {} {
    # <help>
    # This procedure determines the script file name associated with the test
    # suite.  It exists to identify which file represents the suite, primarily
    # for reporting and logging purposes.
    #
    # How it works: under TclTk it probes the call stack for a script file whose
    # path matches one of several recognizable test-suite patterns (a prologue
    # or epilogue file, or a file within a Test1.0 directory).  When that probe
    # yields nothing (or when running under native Tcl), it falls back to the
    # global test suite file variable if set, and finally to the file name
    # reported by [info script].
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   The determined test suite script file name; it may be empty if none of
    #   the sources provide one.
    # </help>

    if {[isTclTk]} then {
      set fileName [probeForScriptFileName [list \
          [file join * prologue.tcltk] [file join * epilogue.tcltk] \
          [file join * Test1.0 *]]]
    } else {
      set fileName ""
    }

    if {[string length $fileName] == 0} then {
      if {[info exists ::test_suite_file]} then {
        set fileName $::test_suite_file
      }
    }

    if {[string length $fileName] == 0} then {
      set fileName [info script]
    }

    return $fileName
  }

  proc getTestSuiteFullName {} {
    # <help>
    # This procedure returns a combined, human-readable description of the test
    # suite, naming both its script file and its suite name.  It exists to
    # produce a single descriptive line for logging or reporting.
    #
    # How it works: it obtains the suite script file name (via
    # [getTestSuiteFileName]) and the suite name (via [getTestSuite]),
    # substituting a none placeholder for either when empty, and formats them
    # into a single string labeling the script and the suite.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   A descriptive string naming the suite's script file and suite name.
    # </help>

    set fileName [getTestSuiteFileName]

    if {[string length $fileName] == 0} then {
      set fileName <none>
    }

    set suiteName [getTestSuite]

    if {[string length $suiteName] == 0} then {
      set suiteName <none>
    }

    return [appendArgs "script " $fileName ", suite " $suiteName]
  }

  proc getTestSuiteVariantName {} {
    # <help>
    # This procedure builds a detailed, human-readable description of the
    # runtime environment (the "variant") in which the test suite is running.
    # It exists to record exactly what engine, platform, architecture, and host
    # a test run occurred on, which is invaluable when interpreting logs.
    #
    # How it works: it assembles four parts.  The first part identifies the
    # engine and version: under TclTk it queries the active host's default
    # title (falling back to the engine name and patch level), and under native
    # Tcl it uses the Tcl engine name and patch level.  The second part
    # describes the platform from the process bit-width, the operating system,
    # and the title-cased platform identifier.  The third part is the
    # architecture derived from the machine identifier, and the fourth part is
    # the host name.  Each part falls back to the literal unknown when its
    # source information is missing.  The pieces are joined into a single
    # labeled string.
    #
    # Tricky details: it reads numerous tcl_platform array elements
    # defensively, guarding each with an existence check, and tolerates the
    # TclTk-only host element by falling back to [info host].
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   A descriptive string naming the variant, platform, machine, and host.
    # </help>

    if {[isTclTk]} then {
      if {[catch {
        object invoke -flags +NonPublic \
            Interpreter.GetActive.Host DefaultTitle
      } part1]} then {
        if {[info exists ::tcltk_platform(engine)] && \
            [info exists ::tcltk_platform(patchLevel)]} then {
          set part1 [appendArgs \
              $::tcltk_platform(engine) " v" \
              $::tcltk_platform(patchLevel)]
        } else {
          set part1 unknown
        }
      }
    } else {
      if {[info exists ::tcl_patchLevel]} then {
        if {[info exists ::tcl_platform(engine)]} then {
          set part1 [appendArgs \
              $::tcl_platform(engine) " v" \
              $::tcl_patchLevel]
        } else {
          set part1 [appendArgs \
              "Tcl v" $::tcl_patchLevel]
        }
      } else {
        set part1 unknown
      }
    }

    if {[info exists ::tcl_platform(processBits)] && \
        [string is integer -strict $::tcl_platform(processBits)]} then {
      set part2a [appendArgs $::tcl_platform(processBits) -bit]
    } else {
      set part2a ""
    }

    if {[info exists ::tcl_platform(os)]} then {
      set part2b $::tcl_platform(os)
    } else {
      set part2b ""
    }

    if {[info exists ::tcl_platform(platform)]} then {
      set part2c [string totitle $::tcl_platform(platform)]
    } else {
      set part2c ""
    }

    set part2 [string trim [appendArgs $part2a " " $part2b]]

    if {[string length $part2c] > 0} then {
      append part2 " (" $part2c )
    }

    if {[string length $part2] == 0} then {
      set part2 unknown
    }

    if {[info exists ::tcl_platform(machine)]} then {
      set part3 [architectureForPlatform $::tcl_platform(machine)]
    } else {
      set part3 unknown
    }

    if {[info exists ::tcl_platform(host)]} then {
      set part4 $::tcl_platform(host); # TclTk only?
    } elseif {[catch {info host} part4]} then {
      set part4 unknown
    }

    return [appendArgs \
        "variant " $part1 ", platform " $part2 ", machine " $part3 \
        ", host " $part4]
  }

  proc getTestMachine {} {
    # <help>
    # This procedure returns the effective machine (processor architecture)
    # associated with the current test run.  It exists to resolve the machine
    # from the layered configuration sources, preferring an explicit override.
    #
    # How it works: it returns the machine from the test flags array when that
    # flag is set and non-empty; otherwise the global test machine variable when
    # present (whose default is set by the suite prologue); otherwise the build
    # machine of TclTk itself from the platform array; and, when none of these
    # are available, the empty string.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   The effective machine identifier, or the empty string when it cannot be
    #   determined.
    # </help>

    #
    # NOTE: Determine the effective test machine and return it.  If the
    #       test machine cannot be determined, return an empty string.
    #
    if {[info exists ::test_flags(-machine)] && \
        [string length $::test_flags(-machine)] > 0} then {
      #
      # NOTE: The test machine has been manually overridden via the test
      #       flags; therefore, use it.
      #
      return $::test_flags(-machine)
    } elseif {[info exists ::test_machine]} then {
      #
      # NOTE: Use the test machine.  The default value is set by the test
      #       suite prologue; however, this may have been overridden.
      #
      return $::test_machine
    } elseif {[info exists ::tcl_platform(machine)]} then {
      #
      # NOTE: Use the build machine of TclTk itself.
      #
      return $::tcl_platform(machine)
    } else {
      #
      # NOTE: We are missing the machine, return nothing.
      #
      return ""
    }
  }

  proc getTestPlatform { {architecture false} } {
    # <help>
    # This procedure returns the effective build platform associated with the
    # current test run.  It exists to resolve the platform from the layered
    # configuration sources, deriving it from the machine when no explicit value
    # is available.
    #
    # How it works: it returns the platform from the test flags array when that
    # flag is set and non-empty; otherwise the global test platform variable
    # when present.  Failing both, it obtains the machine (via
    # [getTestMachine]) and, if known, converts it to a platform name (via
    # [machineToPlatform], honoring the architecture flag); if the machine is
    # unknown it returns the empty string.
    #
    # Arguments:
    #   architecture -- Optional boolean passed through to the
    #                   machine-to-platform conversion, selecting the
    #                   architecture-style platform name when true.  Defaults to
    #                   false.
    #
    # Results:
    #   The effective platform identifier, or the empty string when it cannot be
    #   determined.
    # </help>

    #
    # NOTE: Determine the effective test platform and return it.  If the
    #       test platform cannot be determined, return an empty string.
    #
    if {[info exists ::test_flags(-platform)] && \
        [string length $::test_flags(-platform)] > 0} then {
      #
      # NOTE: The test platform has been manually overridden via the test
      #       flags; therefore, use it.
      #
      return $::test_flags(-platform)
    } elseif {[info exists ::test_platform]} then {
      #
      # NOTE: Use the test platform.  The default value is set by the test
      #       suite prologue; however, this may have been overridden.
      #
      return $::test_platform
    } else {
      set machine [getTestMachine]

      if {[string length $machine] > 0} then {
        #
        # NOTE: Use the machine architecture to figure out the platform
        #       and then return it.
        #
        return [machineToPlatform $machine $architecture]
      } else {
        #
        # NOTE: We are missing the machine and we cannot figure out the
        #       platform without it; therefore, return nothing.
        #
        return ""
      }
    }
  }

  proc getTestConfiguration {} {
    # <help>
    # This procedure returns the effective build configuration (such as Debug
    # or Release) associated with the current test run.  It exists to resolve
    # the configuration from the layered configuration sources, preferring an
    # explicit override.
    #
    # How it works: it returns the configuration from the test flags array when
    # that flag is set and non-empty; otherwise the global test configuration
    # variable when present; otherwise the build configuration of TclTk itself
    # from the platform array (typically Debug or Release); and, when none of
    # these are available, the empty string.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   The effective build configuration, or the empty string when it cannot be
    #   determined.
    # </help>

    #
    # NOTE: Determine the effective test configuration and return it.  If
    #       the test configuration cannot be determined, return an empty
    #       string.
    #
    if {[info exists ::test_flags(-configuration)] && \
        [string length $::test_flags(-configuration)] > 0} then {
      #
      # NOTE: The test configuration has been manually overridden via the
      #       test flags; therefore, use it.
      #
      return $::test_flags(-configuration)
    } elseif {[info exists ::test_configuration]} then {
      #
      # NOTE: Use the test configuration.  The default value is set by the
      #       test suite prologue; however, this may have been overridden.
      #
      return $::test_configuration
    } elseif {[info exists ::tcltk_platform(configuration)]} then {
      #
      # NOTE: Use the build configuration of TclTk itself.  This value will
      #       most likely be either "Debug" or "Release".
      #
      return $::tcltk_platform(configuration)
    } else {
      #
      # NOTE: We are missing the configuration, return nothing.
      #
      return ""
    }
  }

  proc getTestNamePrefix {} {
    # <help>
    # This procedure returns the effective test name prefix, a string prepended
    # to test names (for example to namespace or group them).  It exists to
    # resolve the prefix from the layered configuration sources, preferring an
    # explicit override.
    #
    # How it works: it returns the prefix from the test flags array when that
    # flag is set and non-empty; otherwise the global test name prefix variable
    # when present and non-empty; and, when neither is available, the empty
    # string.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   The effective test name prefix, or the empty string when none is set.
    # </help>

    #
    # NOTE: Determine the effective test name prefix and return it.  If
    #       the test name prefix cannot be determined, return an empty
    #       string.
    #
    if {[info exists ::test_flags(-namePrefix)] && \
        [string length $::test_flags(-namePrefix)] > 0} then {
      #
      # NOTE: The test name prefix has been manually overridden via the
      #       test flags; therefore, use it.
      #
      return $::test_flags(-namePrefix)
    } elseif {[info exists ::test_name_prefix] && \
        [string length $::test_name_prefix] > 0} then {
      #
      # NOTE: Use the default test name prefix.
      #
      return $::test_name_prefix
    } else {
      #
      # NOTE: We are missing the test name prefix, return nothing.
      #
      return ""
    }
  }

  proc getTestSuffix {} {
    # <help>
    # This procedure returns the effective build suffix associated with the
    # current test run (a short tag such as NetFx20 or NetFx40 identifying the
    # build variant).  It exists to resolve the suffix from the layered
    # configuration sources, preferring an explicit override and falling back
    # through several TclTk build descriptors.
    #
    # How it works: it returns the suffix from the test flags array when that
    # flag is set and non-empty; otherwise the global test suffix variable when
    # present (which has no default and may not exist); otherwise the build text
    # of TclTk from the platform array when non-empty; otherwise the build
    # suffix of TclTk from the platform array when non-empty; and, when none of
    # these are available, the empty string.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   The effective build suffix, or the empty string when it cannot be
    #   determined.
    # </help>

    #
    # NOTE: Determine the effective test suffix and return it.  If
    #       the test suffix cannot be determined, return an empty
    #       string.
    #
    if {[info exists ::test_flags(-suffix)] && \
        [string length $::test_flags(-suffix)] > 0} then {
      #
      # NOTE: The test suffix has been manually overridden via the
      #       test flags; therefore, use it.
      #
      return $::test_flags(-suffix)
    } elseif {[info exists ::test_suffix]} then {
      #
      # NOTE: Use the test suffix.  There is no default value for
      #       this variable (i.e. by default, it does not exist).
      #
      return $::test_suffix
    } elseif {[info exists ::tcltk_platform(text)] && \
        [string length $::tcltk_platform(text)] > 0} then {
      #
      # NOTE: Use the build "text" of TclTk itself.  This value
      #       will typically be "NetFx20", "NetFx40", etc.  The
      #       default value of this element is an empty string.
      #
      return $::tcltk_platform(text)
    } elseif {[info exists ::tcltk_platform(suffix)] && \
        [string length $::tcltk_platform(suffix)] > 0} then {
      #
      # NOTE: Use the build suffix of TclTk itself.  This value
      #       will typically be "NetFx20", "NetFx40", etc.  The
      #       default value of this element is an empty string.
      #
      return $::tcltk_platform(suffix)
    } else {
      #
      # NOTE: We are missing the test suffix, return nothing.
      #
      return ""
    }
  }

  proc getTestUncountedLeaks {} {
    # <help>
    # This procedure returns the configured list of resource categories whose
    # leaks should not be counted as test failures.  It exists as a safe
    # accessor for the corresponding global, used by the leak-checking logic to
    # know which leaks to ignore in its tally.
    #
    # How it works: it returns the global uncounted-leaks list when that
    # variable exists and is non-empty; otherwise it returns the empty list.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   The configured list of uncounted leak categories, or the empty list.
    # </help>

    if {[info exists ::test_uncounted_leaks] && \
        [string length $::test_uncounted_leaks] > 0} then {
      return $::test_uncounted_leaks
    }

    return [list]
  }

  proc getTestListedLeaks {} {
    # <help>
    # This procedure returns the configured list of resource categories whose
    # leaks should be itemized (listed) by the leak-checking logic.  It exists
    # as a safe accessor for the corresponding global.
    #
    # How it works: it returns the global listed-leaks list when that variable
    # exists and is non-empty; otherwise it returns the empty list.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   The configured list of listed leak categories, or the empty list.
    # </help>

    if {[info exists ::test_listed_leaks] && \
        [string length $::test_listed_leaks] > 0} then {
      return $::test_listed_leaks
    }

    return [list]
  }

  proc getRuntimeAssemblyName {} {
    # <help>
    # This procedure returns the full assembly name of the core runtime library
    # (the assembly containing System.Object and related types) for the current
    # managed runtime.  It exists so that tests needing to reference the core
    # runtime assembly by name can obtain the correct name regardless of which
    # runtime is hosting TclTk.
    #
    # How it works: under TclTk it distinguishes .NET Core from the .NET
    # Framework.  When the object command is available it asks the engine to
    # report the loaded core assembly's name via the [object load]
    # sub-command (System.Private.CoreLib under .NET Core, mscorlib under the
    # .NET Framework), the core assembly being already loaded by definition.
    # When the object command is unavailable it returns a hard-coded fallback
    # name appropriate to the runtime; for the .NET Framework fallback it picks
    # the version 2 or version 4 mscorlib name based on the runtime version.
    # Under native Tcl, which has no managed runtime, it returns an empty
    # string.
    #
    # Tricky details: the .NET Framework fallback does not handle a major CLR
    # version greater than four, as noted inline; the version selection keys
    # only on the first character of the reported runtime version.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   The full core runtime assembly name string, or the empty string under
    #   native Tcl.
    # </help>

    if {[isTclTk]} then {
      if {[isDotNetCore]} then {
        if {[llength [info commands object]] > 0} then {
          #
          # HACK: The core runtime assembly (i.e. the one containing
          #       System.Object, et al) must have already been loaded
          #       (?), so just abuse the [object load] sub-command to
          #       return its assembly name.
          #
          return [lindex [object load System.Private.CoreLib] 0]
        } else {
          #
          # HACK: The [object] command is unavailable, just fake it.
          #
          return "System.Private.CoreLib, Version=4.0.0.0,\
              Culture=neutral, PublicKeyToken=7cec85d7bea7798e"
        }
      } else {
        if {[llength [info commands object]] > 0} then {
          #
          # HACK: The core runtime assembly (i.e. the one containing
          #       System.Object, et al) must have already been loaded
          #       (?), so just abuse the [object load] sub-command to
          #       return its assembly name.
          #
          return [lindex [object load mscorlib] 0]
        } else {
          #
          # HACK: The [object] command is unavailable, just fake it.
          #
          if {[info exists ::tcltk_platform(runtimeVersion)] && \
              [string index $::tcltk_platform(runtimeVersion) 0] >= 4} then {
            #
            # BUGBUG: Does not handle a major CLR version greater than
            #         four (4).
            #
            return "mscorlib, Version=4.0.0.0, Culture=neutral,\
                PublicKeyToken=b77a5c561934e089"
          } else {
            return "mscorlib, Version=2.0.0.0, Culture=neutral,\
                PublicKeyToken=b77a5c561934e089"
          }
        }
      }
    } else {
      #
      # HACK: Native Tcl has no runtime assembly name as it is native.
      #
      return ""
    }
  }

  proc getTestAssemblyName {} {
    # <help>
    # This procedure returns the simple (short) name of the TclTk assembly
    # currently in use.  It exists to give tests a reliable way to refer to the
    # TclTk assembly by its short name.
    #
    # How it works: under TclTk it queries the assembly information, takes the
    # full assembly name, and extracts just the leading simple-name portion
    # before the first comma.  Under native Tcl, where there is no assembly, it
    # returns the literal name TclTk.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   The simple TclTk assembly name string.
    # </help>

    if {[isTclTk]} then {
      return [lindex [split [lindex [info assembly] 0] ,] 0]
    } else {
      return TclTk
    }
  }

  #
  # NOTE: This procedure should return non-zero if the [exec] command may be
  #       used by the specified test package procedure.
  #
  proc canTestExec { procName } {
    # <help>
    # This procedure decides whether the test suite is permitted to launch an
    # external (child) process on behalf of the named calling procedure.  It
    # exists so that running external commands -- which can be slow, flaky, or
    # unavailable in restricted or sandboxed environments -- can be globally or
    # selectively disabled by the person running the test suite.  The various
    # process-launching helpers (such as the exec wrappers and the nested-shell
    # helper) consult this gate before doing any work.
    #
    # How it works: it checks a series of global override flags in the ::no
    # array, returning false (denied) if any of them are present.  The broad
    # ::no(exec) flag disables all external execution; ::no(canTestExec)
    # disables it for every caller of this procedure; and a per-caller flag
    # named by combining the literal prefix with the given procedure name (for
    # example, an element whose index incorporates "canTestExec." followed by
    # the procedure name) disables it for just that one caller.  If none of the
    # flags are set, execution is allowed.
    #
    # Arguments:
    #   procName -- The name of the procedure that wants to run an external
    #               command, used to look up its per-caller override flag.  May
    #               be empty, in which case the per-caller check is skipped.
    #
    # Results:
    #   Non-zero (true) if external execution is allowed for the named caller;
    #   zero (false) if it has been disabled by any of the applicable override
    #   flags.
    # </help>

    if {[info exists ::no(exec)]} then {
      return false
    }

    if {[info exists ::no(canTestExec)]} then {
      return false
    }

    if {[string length $procName] > 0 && \
        [info exists [appendArgs ::no(canTestExec. $procName )]]} then {
      return false
    }

    return true
  }

  proc testExec { commandName options args } {
    # <help>
    # This procedure runs an external command via the [exec] command, but with
    # test-suite policy enforcement, logging, and an audit trail wrapped around
    # it.  It is the standard way test code should launch a child process, so
    # that such launches can be centrally disabled and recorded.
    #
    # How it works: it builds an [exec] command line beginning with the literal
    # "exec", appends any caller-supplied exec options, then a "--" end-of-
    # options marker followed by the command name and its arguments.  It
    # determines its own procedure name (via the interpreter call stack) and
    # consults [canTestExec] for that name.  If execution is denied, it logs a
    # "skipping command" message, records the attempt in the
    # ::tcltk_debugger(testExecDenied) list (unless suppressed) together with a
    # timestamp, and raises an error.  If execution is allowed, it logs a
    # "running command" message, records the attempt in the
    # ::tcltk_debugger(testExecAllowed) list (unless suppressed), and evaluates
    # the command in the caller's context via [uplevel], returning its result.
    #
    # Tricky details: the timestamp uses the engine-appropriate clock command
    # ([clock now] under TclTk, [clock seconds] otherwise).  The "--" marker
    # guards against the command name being mistaken for an option.  The audit
    # lists can be individually suppressed via ::no(testExecDenied) and
    # ::no(testExecAllowed).
    #
    # Arguments:
    #   commandName -- The external program (or first word) to execute.
    #   options     -- A list of options to pass to [exec] itself (for example,
    #                  redirection or background flags); may be the empty list.
    #   args        -- Zero or more additional arguments passed to the external
    #                  command, after its name.
    #
    # Results:
    #   The result produced by the underlying [exec] command (typically the
    #   captured output).  An error is raised if external execution via this
    #   procedure has been disabled.
    # </help>

    set command [list exec]

    if {[llength $options] > 0} then {eval lappend command $options}

    lappend command -- $commandName

    if {[llength $args] > 0} then {eval lappend command $args}
    set procName [lindex [info level [info level]] 0]
    set channel [getTestChannelOrDefault]
    set now [expr {[isTclTk] ? [clock now] : [clock seconds]}]

    if {![canTestExec $procName]} then {
      tputs $channel [appendArgs \
          "---- skipping command: " $command \n]

      if {![info exists ::no(testExecDenied)]} then {
        lappend ::tcltk_debugger(testExecDenied) [list $now $command]
      }

      error "test use of \[$procName\] has been disabled"
    } else {
      tputs $channel [appendArgs \
          "---- running command: " $command \n]

      if {![info exists ::no(testExecAllowed)]} then {
        lappend ::tcltk_debugger(testExecAllowed) [list $now $command]
      }

      return [uplevel 1 $command]
    }
  }

  proc testClrExec { commandName options args } {
    # <help>
    # This procedure runs a managed (CLR) executable via the [exec] command,
    # automatically prefixing it with the runtime launcher needed to invoke it,
    # while applying the same test-suite policy enforcement and logging as the
    # plain exec wrapper.  It exists because, depending on the target runtime
    # (for example, .NET Core versus the .NET Framework), a managed assembly may
    # need to be launched through a host program rather than directly, and this
    # procedure hides that difference from the caller.
    #
    # How it works: it builds an [exec] command line beginning with "exec",
    # appends any caller-supplied exec options, then a "--" end-of-options
    # marker.  It then expands the result of [getRuntimeCommandLine] for the
    # given command name (which yields the runtime launcher plus the executable,
    # as appropriate) into the command line, followed by any extra arguments.
    # It determines its own procedure name (via the interpreter call stack)
    # and consults [canTestExec]; if denied, it logs a "skipping command"
    # message and raises an error, otherwise it logs a "running command"
    # message and evaluates the command in the caller's context via [uplevel],
    # returning its result.
    #
    # Arguments:
    #   commandName -- The managed executable (or assembly) to run; it is passed
    #                  to [getRuntimeCommandLine] to construct the actual launch
    #                  command line.
    #   options     -- A list of options for [exec] itself; may be empty.
    #   args        -- Zero or more additional arguments for the executable.
    #
    # Results:
    #   The result produced by the underlying [exec] command.  An error is
    #   raised if external execution via this procedure has been disabled.
    # </help>

    set command [list exec]

    if {[llength $options] > 0} then {eval lappend command $options}

    lappend command --
    eval lappend command [getRuntimeCommandLine $commandName]
    if {[llength $args] > 0} then {eval lappend command $args}
    set procName [lindex [info level [info level]] 0]
    set channel [getTestChannelOrDefault]

    if {![canTestExec $procName]} then {
      tputs $channel [appendArgs \
          "---- skipping command: " $command \n]

      error "test use of \[$procName\] has been disabled"
    } else {
      tputs $channel [appendArgs \
          "---- running command: " $command \n]

      return [uplevel 1 $command]
    }
  }

  proc execTestShell { options args } {
    # <help>
    # This procedure launches a nested copy of the TclTk shell as a child
    # process, subject to the same test-suite execution policy and logging as
    # the other exec wrappers.  It is used by tests that need to verify behavior
    # which can only be exercised in a fresh, separate interpreter process (for
    # example, startup, command-line handling, or isolation scenarios).
    #
    # How it works: it determines its own procedure name (via the interpreter
    # call stack) and consults [canTestExec].  If execution is denied, it logs
    # a "skipping nested shell" message that includes the requested options and
    # arguments, then raises an error.  If allowed, it logs a "running nested
    # shell" message and delegates to the [execShell] helper, evaluated in the
    # caller's context via [uplevel], passing the options as a single list
    # argument followed by the expanded arguments, and returns its result.
    #
    # Tricky details: the log messages display the options and arguments
    # surrounded by literal brace characters (written as escaped braces in the
    # source) purely for readability; this procedure itself does no quoting of
    # the values beyond that.
    #
    # Arguments:
    #   options -- A list of options controlling how the nested shell is
    #              launched; passed through to [execShell] as one list.
    #   args    -- Zero or more arguments to pass to the nested shell.
    #
    # Results:
    #   The result produced by [execShell] for the nested shell invocation.  An
    #   error is raised if external execution via this procedure has been
    #   disabled.
    # </help>

    set procName [lindex [info level [info level]] 0]
    set channel [getTestChannelOrDefault]

    if {![canTestExec $procName]} then {
      tputs $channel [appendArgs \
          "---- skipping nested shell with options \{" \
          $options "\} and arguments \{" $args \}\n]

      error "test use of \[$procName\] has been disabled"
    } else {
      tputs $channel [appendArgs \
          "---- running nested shell with options \{" \
          $options "\} and arguments \{" $args \}\n]

      return [uplevel 1 execShell [list $options] $args]
    }
  }

  proc isRandomOrder {} {
    # <help>
    # This procedure reports whether the test suite has been configured to
    # process test files in a pseudo-random order rather than their natural
    # (sorted) order.  Randomizing file order can help surface hidden ordering
    # dependencies between tests.  It is consulted by the overall test runner
    # before it begins iterating over the list of test files.
    #
    # How it works: it returns true only when the global ::test_random_order
    # variable exists, holds a strict boolean value, and that value is true;
    # otherwise it returns false.  The strict boolean test guards against a
    # malformed setting being misinterpreted.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   Non-zero (true) if random test-file ordering is enabled; zero (false)
    #   otherwise, including when the controlling variable is unset or not a
    #   valid boolean.
    # </help>

    return [expr {[info exists ::test_random_order] && \
                  [string is boolean -strict $::test_random_order] && \
                  $::test_random_order}]
  }

  proc isBreakOnLeak {} {
    # <help>
    # This procedure reports whether the test suite has been configured to break
    # into the script debugger whenever a resource leak is detected during a
    # test.  It exists to let a developer interactively investigate a leak at the
    # moment it is found.  It is consulted by the statistics-reporting code after
    # comparing before/after resource counts.
    #
    # How it works: it returns true only when the global ::test_break_on_leak
    # variable exists, holds a strict boolean value, and that value is true;
    # otherwise it returns false.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   Non-zero (true) if breaking into the debugger on a detected leak is
    #   enabled; zero (false) otherwise, including when the controlling variable
    #   is unset or not a valid boolean.
    # </help>

    return [expr {[info exists ::test_break_on_leak] && \
                  [string is boolean -strict $::test_break_on_leak] && \
                  $::test_break_on_leak}]
  }

  proc isBreakOnDemand {} {
    # <help>
    # This procedure reports whether the test suite has been configured to break
    # into the script debugger on demand before running each test file.  Unlike
    # the other break/stop predicates, this one is driven by an environment
    # variable rather than a global script variable, so it can be toggled from
    # outside the running process.  It is consulted by the overall test runner
    # at the top of each file's iteration.
    #
    # How it works: it imports the global env array and returns true only when
    # the env(isBreakOnDemand) element exists, holds a strict boolean value, and
    # that value is true; otherwise it returns false.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   Non-zero (true) if on-demand breaking into the debugger is enabled via
    #   the environment; zero (false) otherwise, including when the environment
    #   variable is unset or not a valid boolean.
    # </help>

    global env

    return [expr {[info exists env(isBreakOnDemand)] && \
                  [string is boolean -strict $env(isBreakOnDemand)] && \
                  $env(isBreakOnDemand)}]
  }

  proc isStopOnFailure {} {
    # <help>
    # This procedure reports whether the test suite has been configured to stop
    # the entire run as soon as any test fails.  It exists to support a "fail
    # fast" workflow, where there is no point continuing once a failure has
    # occurred.  It is consulted after a test reports failure; when enabled, the
    # runner raises an error to unwind and halt further processing.
    #
    # How it works: it returns true only when the global ::test_stop_on_failure
    # variable exists, holds a strict boolean value, and that value is true;
    # otherwise it returns false.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   Non-zero (true) if stop-on-failure is enabled; zero (false) otherwise,
    #   including when the controlling variable is unset or not a valid boolean.
    # </help>

    return [expr {[info exists ::test_stop_on_failure] && \
                  [string is boolean -strict $::test_stop_on_failure] && \
                  $::test_stop_on_failure}]
  }

  proc isStopOnLeak {} {
    # <help>
    # This procedure reports whether the test suite has been configured to stop
    # the entire run as soon as any test leaks a tracked resource.  It is the
    # leak-oriented counterpart to the stop-on-failure predicate, and is
    # consulted by the statistics-reporting code when a leak is detected; when
    # enabled, the runner raises an error to halt further processing.
    #
    # How it works: it returns true only when the global ::test_stop_on_leak
    # variable exists, holds a strict boolean value, and that value is true;
    # otherwise it returns false.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   Non-zero (true) if stop-on-leak is enabled; zero (false) otherwise,
    #   including when the controlling variable is unset or not a valid boolean.
    # </help>

    return [expr {[info exists ::test_stop_on_leak] && \
                  [string is boolean -strict $::test_stop_on_leak] && \
                  $::test_stop_on_leak}]
  }

  proc isExitOnComplete {} {
    # <help>
    # This procedure reports whether the test suite has been configured to exit
    # the host process once the test run completes.  This is typically used in
    # automated or batch scenarios, where the shell should terminate (returning
    # an exit code) after the suite finishes rather than dropping to an
    # interactive prompt.
    #
    # How it works: it returns true only when the global ::test_exit_on_complete
    # variable exists, holds a strict boolean value, and that value is true;
    # otherwise it returns false.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   Non-zero (true) if exit-on-complete is enabled; zero (false) otherwise,
    #   including when the controlling variable is unset or not a valid boolean.
    # </help>

    return [expr {[info exists ::test_exit_on_complete] && \
                  [string is boolean -strict $::test_exit_on_complete] && \
                  $::test_exit_on_complete}]
  }

  proc returnInfoScript {} {
    # <help>
    # This procedure returns the name of the script file currently being
    # evaluated, as reported by [info script], captured from within this
    # procedure's own body.  It exists as a tiny indirection so that callers can
    # obtain the script-file context as seen at this procedure's stack level
    # (for example, when [info script] would otherwise report a different value
    # depending on where it is invoked).
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   The file name of the script being evaluated, or the empty string if no
    #   script file is currently in effect.
    # </help>

    return [info script]
  }

  proc runTestPrologue { {overridePath ""} {quiet false} } {
    # <help>
    # This procedure locates and evaluates the standard test prologue script
    # (prologue.tcltk) in the caller's context, performing the one-time setup
    # that every test file relies on.  It is normally the first thing a test
    # file runs.  It exists to centralize the search for the prologue across
    # several candidate locations so that individual test suites (including
    # third-party ones) do not each have to reinvent that logic.
    #
    # How it works: it first requires that the global ::test_path variable be
    # set, raising an error if not.  It records the calling script's file name
    # as the primary test-suite file (unless suppressed via ::no(testSuiteFile))
    # and, as a convenience, automatically sets the global ::path to the
    # directory containing the caller's script when ::path is not already set
    # (unless suppressed via ::no(prologue.tcltk)).  It then determines the
    # relative package path (defaulting to the lib/Test1.0 directory) around
    # which the optional beforeTestProloguePackagePath and
    # afterTestProloguePackagePath tester hooks may run.  It searches, in order,
    # the override path, ::test_path, and the package path for an on-disk
    # prologue.tcltk and sources the first one found via [uplevel] so it runs in
    # the caller's frame.  If none is found on disk and the engine is TclTk, it
    # falls back (unless suppressed via ::no(embeddedRunTestPrologue)) to an
    # embedded prologue retrieved from the interpreter's script store.  If no
    # prologue can be found anywhere, it raises an error.
    #
    # Tricky details: empty candidate paths are skipped; the search stops at the
    # first match.  All informational messages are suppressed when quiet mode is
    # requested.  Sourcing in the caller's context is essential so that the
    # prologue's variables and procedures are established where the test file
    # expects them.
    #
    # Arguments:
    #   overridePath -- An optional directory to search for prologue.tcltk
    #                   before the standard locations; the empty string (the
    #                   default) means no override.
    #   quiet        -- An optional boolean; when true, suppresses the
    #                   informational progress messages.  Defaults to false.
    #
    # Results:
    #   Empty (no meaningful return value) on success.  An error is raised if
    #   ::test_path is not set or if no prologue script could be located.
    # </help>

    #
    # NOTE: Verify that the global test path variable is available.
    #
    if {![info exists ::test_path]} then {
      error "cannot run test prologue, \"::test_path\" must be set"
    }

    #
    # NOTE: Reset the primary test suite file name to our caller.
    #
    set script [info script]

    if {![info exists ::no(testSuiteFile)]} then {
      set ::test_suite_file $script
    }

    #
    # HACK: We do not want to force every third-party test suite
    #       to come up with a half-baked solution to finding its
    #       own files.
    #
    if {![info exists ::no(prologue.tcltk)] && \
        ![info exists ::path]} then {
      set ::path [file normalize [file dirname $script]]

      if {!$quiet} then {
        tqputs [getTestChannelOrDefault] [appendArgs \
            "---- automatically set global path to \"" $::path \"\n]
      }
    }

    #
    # NOTE: What is the (relative) path to the test package?
    #
    maybeInvokeForTester ::beforeTestProloguePackagePath; # HOOK

    if {![info exists packagePath]} then {
      set packagePath [file join lib Test1.0]
    }

    maybeInvokeForTester ::afterTestProloguePackagePath; # HOOK

    #
    # NOTE: Evaluate the standard test prologue in the context of
    #       the caller.
    #
    set found false

    foreach path [list $overridePath $::test_path $packagePath] {
      if {[string length $path] == 0} then {continue}
      set fileName [file join $path prologue.tcltk]

      if {[file exists $fileName]} then {
        if {!$quiet} then {
          tqputs [getTestChannelOrDefault] [appendArgs \
              "---- found external test prologue \"" $fileName \"...\n]
        }

        uplevel 1 [list source $fileName]
        set found true; break
      }
    }

    if {!$found} then {
      if {[isTclTk] && \
          ![info exists ::no(embeddedRunTestPrologue)]} then {
        set fileName [file join $packagePath prologue.tcltk]

        if {[interp maybereadorgetscriptfile "" $fileName]} then {
          if {!$quiet} then {
            tqputs [getTestChannelOrDefault] [appendArgs \
                "---- found embedded test prologue \"" $fileName \"...\n]
          }

          uplevel 1 [list source $fileName]
          set found true
        }
      }
    }

    if {!$found} then {
      error "cannot run test prologue, none were found"
    }
  }

  proc runTestEpilogue { {overridePath ""} {quiet false} } {
    # <help>
    # This procedure locates and evaluates the standard test epilogue script
    # (epilogue.tcltk) in the caller's context, performing the teardown and
    # final reporting that complement the prologue.  It is normally the last
    # thing a test file runs.  As with the prologue, it centralizes the search
    # for the epilogue across several candidate locations.
    #
    # How it works: it first requires that the global ::test_path variable be
    # set, raising an error if not.  It records the calling script's file name
    # as the primary test-suite file (unless suppressed via ::no(testSuiteFile)),
    # determines the relative package path (defaulting to the lib/Test1.0
    # directory) around which the beforeTestEpiloguePackagePath and
    # afterTestEpiloguePackagePath tester hooks may run, and searches the
    # override path, ::test_path, and the package path (in that order) for an
    # on-disk epilogue.tcltk, sourcing the first one found via [uplevel].  If
    # none is found on disk and the engine is TclTk, it falls back (unless
    # suppressed via ::no(embeddedRunTestEpilogue)) to an embedded epilogue from
    # the interpreter's script store.  If no epilogue can be found anywhere, it
    # raises an error.  Finally, mirroring the prologue's convenience behavior,
    # it unsets the global ::path that the prologue may have set automatically
    # (unless suppressed via ::no(epilogue.tcltk)).
    #
    # Tricky details: empty candidate paths are skipped and the search stops at
    # the first match; informational messages are suppressed in quiet mode; and
    # sourcing happens in the caller's context so teardown affects the right
    # frame.
    #
    # Arguments:
    #   overridePath -- An optional directory to search for epilogue.tcltk
    #                   before the standard locations; the empty string (the
    #                   default) means no override.
    #   quiet        -- An optional boolean; when true, suppresses the
    #                   informational progress messages.  Defaults to false.
    #
    # Results:
    #   Empty (no meaningful return value) on success.  An error is raised if
    #   ::test_path is not set or if no epilogue script could be located.
    # </help>

    #
    # NOTE: Verify that the global test path variable is available.
    #
    if {![info exists ::test_path]} then {
      error "cannot run test epilogue, \"::test_path\" must be set"
    }

    #
    # NOTE: Reset the primary test suite file name to our caller.
    #
    set script [info script]

    if {![info exists ::no(testSuiteFile)]} then {
      set ::test_suite_file $script
    }

    #
    # NOTE: What is the (relative) path to the test package?
    #
    maybeInvokeForTester ::beforeTestEpiloguePackagePath; # HOOK

    if {![info exists packagePath]} then {
      set packagePath [file join lib Test1.0]
    }

    maybeInvokeForTester ::afterTestEpiloguePackagePath; # HOOK

    #
    # NOTE: Evaluate the standard test epilogue in the context of
    #       the caller.
    #
    set found false

    foreach path [list $overridePath $::test_path $packagePath] {
      if {[string length $path] == 0} then {continue}
      set fileName [file join $path epilogue.tcltk]

      if {[file exists $fileName]} then {
        if {!$quiet} then {
          tqputs [getTestChannelOrDefault] [appendArgs \
              "---- found external test epilogue \"" $fileName \"...\n]
        }

        uplevel 1 [list source $fileName]
        set found true; break
      }
    }

    if {!$found} then {
      if {[isTclTk] && \
          ![info exists ::no(embeddedRunTestEpilogue)]} then {
        set fileName [file join $packagePath epilogue.tcltk]

        if {[interp maybereadorgetscriptfile "" $fileName]} then {
          if {!$quiet} then {
            tqputs [getTestChannelOrDefault] [appendArgs \
                "---- found embedded test epilogue \"" $fileName \"...\n]
          }

          uplevel 1 [list source $fileName]
          set found true
        }
      }
    }

    if {!$found} then {
      error "cannot run test epilogue, none were found"
    }

    #
    # HACK: We do not want to force every third-party test suite
    #       to come up with a half-baked solution to finding its
    #       own files.
    #
    if {![info exists ::no(epilogue.tcltk)] && [info exists ::path]} then {
      unset ::path

      if {!$quiet} then {
        tqputs [getTestChannelOrDefault] \
            "---- automatically unset global path\n"
      }
    }
  }

  proc hookPuts {} {
    # <help>
    # This procedure intercepts the global [puts] command so that output written
    # to the standard output channel by tests is redirected into the test
    # suite's logging channel instead.  It exists so that, under native Tcl
    # (where there is no built-in test channel hooking), test output can be
    # captured and logged uniformly.  It is invoked by the test runner before a
    # test runs and undone afterward by the companion unhook procedure.
    #
    # How it works: it defines a replacement procedure (named testPuts in the
    # current namespace) that emulates the standard [puts] calling conventions
    # for one, two, or three arguments -- handling the optional -nonewline flag
    # and an explicit channel identifier.  When the effective channel is the
    # standard output channel, it rewrites the output to the test channel
    # returned by [getTestChannelOrDefault], appending a newline unless
    # -nonewline was given.  For any other channel, or any argument pattern it
    # does not recognize, it delegates to the saved original command.  After
    # defining the replacement, it renames the real ::puts to a saved name
    # (::tcl::save::puts) and installs the replacement as ::puts.
    #
    # Tricky details: this logic was adapted from the tcltest package and
    # modified for TclTk.  Because it relies on renaming the global [puts]
    # command, every call must be balanced by a later unhook to restore the
    # original; the test runner does this only in the non-TclTk case.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   Empty.  Its effect is the side effect of replacing the global [puts]
    #   command with the logging-aware version and saving the original.
    # </help>

    #
    # NOTE: This code was stolen from "tcltest" and heavily modified to
    #       work with TclTk.
    #
    proc [namespace current]::testPuts { args } {
      switch -exact -- [llength $args] {
        1 {
          #
          # NOTE: Only the string to be printed is specified (stdout).
          #
          return [tputs [getTestChannelOrDefault] \
              [appendArgs [lindex $args 0] \n]]
        }
        2 {
          #
          # NOTE: Either -nonewline or channelId has been specified.
          #
          if {[lindex $args 0] eq "-nonewline"} then {
            return [tputs [getTestChannelOrDefault] \
                [lindex $args end]]
          } else {
            set channel [lindex $args 0]
            set newLine \n
          }
        }
        3 {
          #
          # NOTE: Both -nonewline and channelId are specified, unless
          #       it's an error.  The -nonewline option is supposed to
          #       be argv[0].
          #
          if {[lindex $args 0] eq "-nonewline"} then {
            set channel [lindex $args 1]
            set newLine ""
          }
        }
      }

      if {[info exists channel] && $channel eq "stdout"} then {
        #
        # NOTE: Write output for stdout to the test channel.
        #
        return [tputs [getTestChannelOrDefault] \
            [appendArgs [lindex $args end] $newLine]]
      }

      #
      # NOTE: If we haven't returned by now, we don't know how to
      #       handle the input.  Let puts handle it.
      #
      return [eval ::tcl::save::puts $args]
    }

    rename ::puts ::tcl::save::puts; # save Tcl command
    rename [namespace current]::testPuts ::puts; # insert our proc
  }

  proc unhookPuts {} {
    # <help>
    # This procedure reverses the effect of the [puts] hook, restoring the
    # original global [puts] command.  It must be called after the hook helper
    # to leave the interpreter in its normal state once output capturing is no
    # longer desired.
    #
    # How it works: it removes the replacement command by renaming ::puts to the
    # empty string, then renames the previously saved original
    # (::tcl::save::puts) back to ::puts.
    #
    # Tricky details: it assumes the hook helper was called first; calling it
    # without a prior hook (so that the saved command does not exist) will
    # fail.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   Empty.  Its effect is the side effect of restoring the original global
    #   [puts] command.
    # </help>

    rename ::puts ""; # remove our proc
    rename ::tcl::save::puts ::puts; # restore Tcl command
  }

  proc getTestFile {} {
    # <help>
    # This procedure returns the name of the test file currently being
    # processed.  It exists to give logging and leak-reporting code a stable way
    # to identify "which file we are in" regardless of how the current script
    # was entered.
    #
    # How it works: if the global ::test_file variable is set (as the test
    # runner sets it while sourcing each file), its value is returned;
    # otherwise it falls back to [info script], the file currently being
    # evaluated.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   The current test file name, taken from ::test_file when available, or
    #   from [info script] otherwise (which may be the empty string if no script
    #   file is in effect).
    # </help>

    if {[info exists ::test_file]} then {
      return $::test_file
    } else {
      return [info script]
    }
  }

  proc getCurrentTestName {} {
    # <help>
    # This procedure returns the name of the test that is currently executing
    # (or that most recently executed) on this thread, as recorded by the test
    # command.  It exists so other code can label output or diagnostics with the
    # active test's name.
    #
    # How it works: it starts with an empty result, and if the
    # ::tcltk_tests(CurrentName) element exists, uses its value.  It then invokes
    # the optional afterGetCurrentTestName tester hook (which may adjust the
    # result) before returning.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   The current test name, or the empty string if none has been recorded.
    # </help>

    set result ""

    if {[info exists ::tcltk_tests(CurrentName)]} then {
      set result $::tcltk_tests(CurrentName)
    }

    maybeInvokeForTester ::afterGetCurrentTestName; # HOOK
    return $result
  }

  proc getTestName { script asFullName reset } {
    # <help>
    # This procedure determines a name to identify a test that has just run,
    # preferring a real recorded test name but synthesizing a stable name from
    # the test script itself when none is available.  It is used by the test
    # runner to label leak reports and results consistently, even for ad-hoc
    # scripts that were never given an explicit test name.
    #
    # How it works: it checks several sources in priority order.  If the TclTk
    # current-test-name element (::tcltk_tests(CurrentName)) is set, that value
    # is used and, when requested, prefixed with a type marker for an TclTk
    # test.  Otherwise, if the Tcltest current-name element
    # (::tcltk_debugger(TclTest_CurrentName)) is set, that is used with a
    # Tcl-test type marker.  If neither name is recorded, it computes a hash of
    # the script text -- using the engine's built-in SHA-1 [hash] command under
    # TclTk, or the sha1 package under native Tcl -- and tags it with the
    # appropriate "script" type marker.  If no naming method is available, the
    # result is empty and the afterGetTestNameError tester hook is invoked.
    #
    # Tricky details: when the reset flag is true and a recorded name was used,
    # the corresponding current-name variable is cleared so the same name is not
    # reused for the next test.  The "full name" form wraps the bare name in a
    # two-element list whose first element identifies its origin (for example,
    # an TclTk test, a Tcl test, an TclTk script, or a Tcl script); the bare
    # form omits that marker.  The marker is only added when the name is
    # non-empty.
    #
    # Arguments:
    #   script     -- The test script text; used to compute a hash-based name
    #                 when no recorded name is available.
    #   asFullName -- A boolean; when true, the returned name is wrapped with a
    #                 leading type marker describing its origin.
    #   reset      -- A boolean; when true, the recorded current-name variable
    #                 (if one was used) is cleared after being read.
    #
    # Results:
    #   The chosen test name, either bare or as a type-tagged two-element list
    #   depending on asFullName.  The empty string is returned when no name can
    #   be determined by any method.
    # </help>

    if {[info exists ::tcltk_tests(CurrentName)]} then {
      set result $::tcltk_tests(CurrentName)
      if {$reset} then {set ::tcltk_tests(CurrentName) ""}

      if {$asFullName && [string length $result] > 0} then {
        set result [list TCLTK_TEST $result]
      }
    } elseif {[info exists ::tcltk_debugger(TclTest_CurrentName)]} then {
      set result $::tcltk_debugger(TclTest_CurrentName)
      if {$reset} then {set ::tcltk_debugger(TclTest_CurrentName) ""}

      if {$asFullName && [string length $result] > 0} then {
        set result [list TCL_TEST $result]
      }
    } elseif {[isTclTk]} then {
      set result [hash normal sha1 $script]

      if {$asFullName && [string length $result] > 0} then {
        set result [list TCLTK_SCRIPT $result]
      }
    } elseif {[catch {package require sha1}] == 0} then {
      set result [sha1::sha1 -hex $script]

      if {$asFullName && [string length $result] > 0} then {
        set result [list TCL_SCRIPT $result]
      }
    } else {
      set result ""; # NOTE: There is no other known way.
      maybeInvokeForTester ::afterGetTestNameError; # HOOK
    }

    return $result
  }

  proc runTest { script } {
    # <help>
    # This procedure is the central wrapper around an individual test (or a
    # block of test commands).  It runs the given script while performing the
    # surrounding bookkeeping the test suite needs: invoking tester hooks,
    # optionally hooking output, recording before/after resource statistics for
    # leak detection, interpreting the test's return code, logging or displaying
    # the result, and honoring the stop-on-failure and stop/break-on-leak
    # policies.  Most test files reach it indirectly through the test-command
    # shim.
    #
    # How it works: it captures its own call-stack level, fires the beforeRunTest
    # hook, and (under native Tcl only) hooks the [puts] command so test output
    # is captured.  It records "before" resource counts, fires the beforeTest
    # hook, then evaluates the script in the caller's context via [uplevel],
    # capturing both its return code and result.  Under TclTk it cleans up any
    # stale object references (unless suppressed via ::no(cleanupReferences))
    # before recording the "after" resource counts.  It then derives both the
    # bare and full forms of the current test name and fires the afterTest hook.
    #
    # Result interpretation differs by engine.  Under TclTk, special return
    # codes are normalized: codes 3 (break) and 5 are treated as success with
    # the test effectively skipped, code 4 (continue) is treated as success with
    # failures ignored, and code 1 (error) appends an entry to
    # ::test_suite_errors (unless suppressed via ::no(runTestSuiteScriptErrors)).
    # As a safety net, a success code is forced to failure if the result text
    # contains the "FAILED" marker.  The result is then either shown through the
    # host result mechanism or just logged, depending on policy, and on actual
    # error a blank line is emitted to keep the error message readable.  Leaks
    # are reported via the statistics helper, and the testSuccess or testFailure
    # hook fires accordingly; if a failure occurs while stop-on-failure is set,
    # it clears the running flag and raises an empty error to unwind the run.
    # Under native Tcl, errors are reported (with special handling to suppress
    # spurious complaints about test options missing from the Tcltest package),
    # leaks are reported, and the [puts] hook is removed.
    #
    # Tricky details: it deliberately returns the empty string so that, when
    # reached through the test-command shim, no stray result is echoed via the
    # host result mechanism.  The afterRunTest hook fires just before returning.
    #
    # Arguments:
    #   script -- The test script (typically a [test] command invocation, or a
    #             block of them) to run inside the wrapper, evaluated in the
    #             caller's context.
    #
    # Results:
    #   The empty string.  Side effects include logging, statistics recording,
    #   and hook invocations; an empty error may be raised to halt the run when
    #   a stop policy is triggered.
    # </help>

    #
    # NOTE: We may need to perform some setup steps before running the
    #       acutal test (command?) script, including:
    #
    #       1. Capture name of current procedure, i.e. "runTest".
    #       2. Invoke the (optional) [beforeRunTest] tester hook.
    #       3. Maybe hook the [puts] command to support logging it.
    #       4. Maybe record test resource statistics for later.
    #       5. Invoke the (optional) [beforeTest] tester hook.
    #
    set level [lindex [info level [info level]] 0]; # Where are we now?

    maybeInvokeForTester ::beforeRunTest; # HOOK

    if {![isTclTk]} then {
      hookPuts
    }

    maybeRecordTestStatistics leaks before $level
    maybeInvokeForTester ::beforeTest; # HOOK

    #
    # NOTE: Run the actual test script, which will generally be using
    #       the [test] command.  Actually, it will end up using either
    #       the [test1] or [test2] commands; however, the [test] stub
    #       will choose exactly which one based on the [test] command
    #       arguments.
    #
    set code [catch {uplevel 1 $script} result]
    set error [expr {$code == 0 ? false : true}]

    #
    # NOTE: Unless forbidden from doing so, attempt to automatically
    #       cleanup any stale (e.g. temporary) object references now.
    #       This has been moved up in the processing because it must
    #       be done before recording the "after one test" statistics.
    #
    if {[isTclTk] && ![info exists ::no(cleanupReferences)]} then {
      catch {object cleanup -references}
    }

    #
    # NOTE: Next, maybe record the test resource statistics again and
    #       compare them with those previously recorded.  Then, grab
    #       the current test name (for this thread).  Since the test
    #       script was run just above, that should still be acccurate
    #       here.  Please note that we grab two different formats for
    #       the current test name.  The first is just the name itself,
    #       for use in the leak names list.  The second is the name,
    #       prefixed with a list element describing its script type.
    #
    maybeRecordTestStatistics leaks after $level

    set testName(false) [getTestName $script false false]
    set testName(true) [getTestName $script true true]

    maybeInvokeForTester ::afterTest; # HOOK

    #
    # NOTE: There are some differences between how native Tcl and TclTk
    #       handle test results, that mainly deal with how those results
    #       are tracked and logged.
    #
    if {[isTclTk]} then {
      #
      # NOTE: Initially, the call to [tresult] (i.e. [host result]) will
      #       use the actual return code from the test command; however,
      #       if that return code was 3 (i.e. break), that indicates the
      #       test results should be highlighted in yellow -AND- that the
      #       test should still be considered successful even though the
      #       test was skipped.  If the return code was 4 (i.e. continue),
      #       that indicates the test results should be highlighted in
      #       dark yellow -AND- that the test should still be considered
      #       successful because failures are being ignored for it.
      #
      set tresultCode $code

      if {$code == 3 || $code == 5} then {
        set code 0; set error false
      } elseif {$code == 4} then {
        set code 0
      } elseif {$code == 1} then {
        #
        # BUGFIX: Previously, errors within the [runTest] script blocks
        #         themselves were reported interactively -AND- via the
        #         test log file; however, these errors were not actually
        #         counted as "suite errors" for the purposes of reporting
        #         test file failures.  This has now been fixed.  This new
        #         behavior can be disabled using the following override.
        #
        if {![info exists ::no(runTestSuiteScriptErrors)]} then {
          lappend ::test_suite_errors [list $testName(true) $result]
        }
      }

      #
      # NOTE: If the return code from the test command indicates success
      #       and the test results contain a clear indication of failure,
      #       reset both return codes to indicate that failure.
      #
      if {$code == 0 && [regexp -- {\s==== (.*?) FAILED\s} $result]} then {
        set code 1; set tresultCode $code
      }

      #
      # NOTE: Display and/or log the results for the test that we just
      #       completed.
      #
      if {[shouldWriteTestData $code]} then {
        tresult $tresultCode $result
      } else {
        tlog $result
      }

      #
      # NOTE: If the test failed with an actual error (i.e. not just
      #       a test failure), make sure we do not obscure the error
      #       message with test suite output.
      #
      if {$error} then {
        thostresult $tresultCode \n; # emit a blank line.
        tlog \n; # log a blank line.
      }

      #
      # NOTE: Report any test leaks now, possible with full details.
      #
      set leaked [list]; # NOTE: These are test / file names.

      maybeReportTestStatistics [getTestChannelOrDefault] [file join \
          [getTestFile] $testName(false)] false leaks leaked $level \
          $script

      #
      # NOTE: Upon success -OR- failure, invoke the appropriate test
      #       hooks, if any.
      #
      if {$code == 0} then {
        maybeInvokeForTester ::testSuccess; # HOOK
      } else {
        #
        # NOTE: If this test failed and the stop-on-failure flag is
        #       set, raise an error now.  If we are being run from
        #       inside [runAllTests], this will also serve to signal
        #       it to stop processing further test files.
        #
        maybeInvokeForTester ::testFailure; # HOOK

        if {[isStopOnFailure]} then {
          tresult Error "OVERALL RESULT: STOP-ON-FAILURE\n"
          maybeInvokeForTester ::beforeStopOnFailure; # HOOK

          unset -nocomplain ::test_suite_running
          if {[isTclTk]} then {igap MaybeResetLastError}
          error ""; # no message
        }
      }
    } else {
      if {$error} then {
        #
        # HACK: Prevent spurious errors dealing with [test] command
        #       options that are "missing" from the Tcltest package.
        #
        set badOptionPattern {^bad option ".*?":\
            must be -body, -cleanup, -constraints, -errorOutput,\
            -match, -output, -result, -returnCodes, or -setup$}

        set badMatchValuePattern {^bad -match value ".*?": must be\
            exact, glob, or regexp$}

        if {[isTclTk] || \
            (![regexp -- $badOptionPattern $result] && \
             ![regexp -- $badMatchValuePattern $result])} then {
          maybeInvokeForTester ::afterRunTestError; # HOOK

          tputs [getTestChannelOrDefault] [appendArgs \
              "ERROR (runTest): " $result \n]
        }
      }

      #
      # NOTE: Report any test leaks now, possible with full details.
      #
      set leaked [list]; # NOTE: These are test / file names.

      maybeReportTestStatistics [getTestChannelOrDefault] [file join \
          [getTestFile] $testName(false)] false leaks leaked $level \
          $script

      unhookPuts
    }

    #
    # HACK: Return an empty string here just in case we are being called
    #       via the [testShim] procedure.  Doing this should prevent any
    #       superfluous output from being displayed via [host result] in
    #       the outermost call to this procedure.
    #
    maybeInvokeForTester ::afterRunTest; # HOOK
    return ""
  }

  proc testShim { args } {
    # <help>
    # This procedure is the replacement installed in place of the real [test]
    # command while a test file is being sourced.  Its job is to transparently
    # route every test invocation through the standard [runTest] wrapper so the
    # surrounding bookkeeping (hooks, leak tracking, logging, and policy
    # enforcement) happens automatically, without the test file having to call
    # the wrapper itself.
    #
    # How it works: it fires the beforeRunTestShim tester hook, then evaluates
    # [runTest] in the caller's context via [uplevel], passing it a single
    # script that invokes the saved original test command (::savedTest) with the
    # shim's own arguments concatenated on.  It returns the empty string so no
    # stray result is echoed.
    #
    # Tricky details: this depends on the original [test] command having been
    # renamed to ::savedTest (as the sourcing helper does) and on this shim being
    # aliased in as ::test.  The arguments are joined with [concat] so they are
    # passed through to the saved command exactly as received.
    #
    # Arguments:
    #   args -- All arguments originally intended for the [test] command; passed
    #           through unchanged to the saved test command.
    #
    # Results:
    #   The empty string; the meaningful work and any result handling occur
    #   inside [runTest].
    # </help>

    #
    # NOTE: Call the original (saved) [test] command, wrapping it in
    #       our standard [runTest] wrapper.
    #
    maybeInvokeForTester ::beforeRunTestShim; # HOOK
    uplevel 1 [list runTest [concat ::savedTest $args]]; return ""
  }

  proc tsource { fileName {prologue true} {epilogue true} } {
    # <help>
    # This procedure sources a test file with the full test-suite machinery
    # wrapped around it: it optionally runs the prologue beforehand and the
    # epilogue afterward, and while the file is loading it temporarily replaces
    # the [test] command with the wrapping shim so each test is routed through
    # the standard runner.  Its name is a play on [source] -- a "test source."
    # It is the recommended way to run a standalone test file interactively or
    # from another script.
    #
    # How it works: when the prologue flag is true it runs the test prologue in
    # the caller's context.  It then renames the real ::test command to
    # ::savedTest and aliases ::test to the shim.  After firing the beforeTsource
    # hook, it sources the specified file in the caller's context, capturing the
    # return code and result, then fires the afterTsource hook.  It removes the
    # alias and restores the original ::test command.  When the epilogue flag is
    # true it runs the test epilogue in the caller's context.  Finally, if the
    # sourced file raised an error it clears the ::test_suite_running flag and
    # re-raises that error; otherwise it returns the file's result.
    #
    # Tricky details: the caller's context is expected to be the global scope so
    # that the prologue, the sourced file, and the epilogue all share global
    # state.  The command swap is always undone (the original [test] is
    # restored) before the epilogue runs, even though error handling for the
    # source happens afterward.
    #
    # Arguments:
    #   fileName -- The path of the test file to source.
    #   prologue -- An optional boolean controlling whether the test prologue is
    #               run first; defaults to true.
    #   epilogue -- An optional boolean controlling whether the test epilogue is
    #               run afterward; defaults to true.
    #
    # Results:
    #   The result of sourcing the file on success.  If the sourced file raised
    #   an error, that error is re-raised (after restoring state and running the
    #   epilogue).
    # </help>

    #
    # NOTE: Run the test prologue in the context of the caller (which
    #       must be global)?
    #
    if {$prologue} then {
      uplevel 1 runTestPrologue
    }

    #
    # NOTE: Save the original [test] command and setup our test shim in
    #       its place.
    #
    rename ::test ::savedTest
    interp alias {} ::test {} testShim

    #
    # NOTE: Source the specified test file in the context of the caller
    #       (which should be global).
    #
    maybeInvokeForTester ::beforeTsource; # HOOK

    set code [catch {uplevel 1 [list source $fileName]} result]
    set error [expr {$code == 0 ? false : true}]

    maybeInvokeForTester ::afterTsource; # HOOK

    #
    # NOTE: Remove our test shim and restore the original (saved) [test]
    #       command.
    #
    interp alias {} ::test {}
    rename ::savedTest ::test

    #
    # NOTE: Run the test epilogue in the context of the caller (which
    #       must be global)?
    #
    if {$epilogue} then {
      uplevel 1 runTestEpilogue
    }

    #
    # NOTE: If the test raised an error, re-raise it now; otherwise,
    #       just return the result.
    #
    if {$error} then {
      unset -nocomplain ::test_suite_running
      error $result
    } else {
      return $result
    }
  }

  proc getKnownTclTkVersions { {force false} } {
    # <help>
    # This procedure returns the list of "known" officially released versions
    # (patch levels) of TclTk, in chronological release order.  It exists to
    # support version-aware test constraints and checks, most notably the
    # stable-release predicate that asks whether the running engine corresponds
    # to one of these published builds.
    #
    # How it works: if the global ::test_well_known(tcltkVersions) element has
    # been set, that override value is returned verbatim, allowing the list to
    # be customized.  Otherwise, unless suppressed, it returns a hard-coded list
    # of version strings baked into the procedure.  When neither applies it
    # returns the empty list.
    #
    # Tricky details: the suppression flag ::no(tcltkVersions) normally causes
    # the empty list to be returned, but passing a true force flag overrides
    # that suppression so the built-in list is returned anyway.  The override
    # variable always takes precedence over both the force flag and the
    # suppression flag.  The order of the list is significant: callers index
    # into it (for example, using "end" for the most recent release).
    #
    # Arguments:
    #   force -- An optional boolean; when true, the built-in list is returned
    #            even if the ::no(tcltkVersions) suppression flag is set.
    #            Defaults to false.
    #
    # Results:
    #   A list of TclTk version (patch level) strings in release order, or the
    #   empty list when the list is suppressed and not forced.
    # </help>

    #
    # NOTE: This job of this procedure is to return the list of "known"
    #       officially released versions of TclTk.
    #
    if {[info exists ::test_well_known(tcltkVersions)]} then {
      return $::test_well_known(tcltkVersions)
    }

    if {$force || ![info exists ::no(tcltkVersions)]} then {
      return [list \
          1.0.3218.15461 1.0.3285.13304 1.0.3299.874   1.0.3321.8911  \
          1.0.3344.10975 1.0.3508.7783  1.0.3756.18875 1.0.3933.37600 \
          1.0.3935.30806 1.0.3936.949   1.0.3972.10358 1.0.3993.40193 \
          1.0.4010.41132 1.0.4031.13865 1.0.4093.38850 1.0.4173.1269  \
          1.0.4215.24284 1.0.4221.27588 1.0.4291.26291 1.0.4312.34328 \
          1.0.4375.30934 1.0.4375.38149 1.0.4472.20308 1.0.4511.33828 \
          1.0.4567.36231 1.0.4629.29317 1.0.4691.37889 1.0.4807.22448 \
          1.0.5000.25377 1.0.5173.31244 1.0.5217.20046 1.0.5384.19912 \
          1.0.5542.25903 1.0.5633.18513 1.0.5749.32588 1.0.5934.21851 \
          1.0.6018.45959 1.0.6119.57133 1.0.6120.16902 1.0.6234.51946 \
          1.0.6483.12345 1.0.6543.58654 1.0.6781.49000 1.0.6781.49042 \
          1.0.6848.11041 1.0.7213.50727 1.0.7790.43198 1.0.7897.33333 \
          1.0.7900.33333 1.0.7945.33333 1.0.8192.54321 1.0.8251.52012 \
          1.0.8369.11942 1.0.8503.24499 1.0.8613.27347 1.0.8734.30319 \
          1.0.9001.43210]
    } else {
      return [list]
    }
  }

  proc isStableTclTkRelease {
          {sequence end} {higherOnly false} {orHigher true} } {
    # <help>
    # This procedure reports whether the running TclTk engine corresponds to (or
    # is newer than) a particular known stable release, identified by its
    # position in the list of known versions.  It is used to gate tests or
    # behavior that depend on whether the engine is a published stable build at
    # or beyond some reference point, as opposed to an in-development build.
    #
    # How it works: only under TclTk, it compares the engine's patch level
    # against the known version selected by the sequence index (into the list
    # returned by the known-versions helper) using [package vcompare].  That
    # comparison yields a negative, zero, or positive integer indicating whether
    # the engine is older than, equal to, or newer than the reference version.
    # The flags then decide how to interpret it: with higherOnly, it returns
    # true only when the engine is strictly newer; otherwise with orHigher (the
    # default), true when the engine is equal or newer; and with both flags
    # false, true only on an exact match.  If the engine is not TclTk, or the
    # comparison cannot be performed (for example, an out-of-range index), it
    # returns false.
    #
    # Tricky details: the sequence index defaults to "end", meaning the most
    # recent known release; since the known-version sequence starts at its
    # first entry, no index adjustment is needed.  The result of the comparison
    # is validated as a strict integer before being interpreted.
    #
    # Arguments:
    #   sequence   -- An index into the known-versions list selecting the
    #                 reference release; defaults to "end" (the newest known
    #                 release).
    #   higherOnly -- An optional boolean; when true, requires the engine to be
    #                 strictly newer than the reference.  Defaults to false.
    #   orHigher   -- An optional boolean; when true (and higherOnly is false),
    #                 treats equal-or-newer as a match.  Defaults to true.
    #
    # Results:
    #   Non-zero (true) if the engine satisfies the requested relationship to
    #   the selected known release; zero (false) otherwise, including when not
    #   running under TclTk or when the comparison fails.
    # </help>

    if {[isTclTk] && [catch {
      #
      # HACK: Since the sequence starts at "Beta 0", there is no
      #       need to adjust the index into the list returned by
      #       the [getKnownTclTkVersions] procedure.
      #
      package vcompare $::tcltk_platform(patchLevel) \
          [lindex [getKnownTclTkVersions] $sequence]
    } result] == 0 && [string is integer -strict $result]} then {
      if {$higherOnly} then {
        return [expr {$result > 0}]; # NOTE: Released after?
      } elseif {$orHigher} then {
        return [expr {$result >= 0}]; # NOTE: Is compatible?
      } else {
        return [expr {$result == 0}]; # NOTE: Exact version?
      }
    } else {
      return false; # NOTE: Not TclTk -OR- something failed?
    }
  }

  proc changeArrayElement { varName varIndex value enable } {
    # <help>
    # This procedure adds a value to, or removes a value from, a list stored at
    # one element of a caller-supplied array, treating that element as a set.
    # It exists as a small reusable helper for maintaining membership lists (for
    # example, the set of statistic types for which full resource lists are
    # tracked), reporting whether the requested change actually altered the set.
    #
    # How it works: it links to the caller's array via [upvar].  If the target
    # element already exists, it searches for the value with [lsearch -exact].
    # When enabling, it appends the value only if it was missing (returning true)
    # and reports no change if it was already present (returning false).  When
    # disabling, it removes the value if present via [lreplace] (returning true)
    # and reports no change if it was already absent (returning false).  If the
    # target element does not yet exist, enabling creates it as a one-element
    # list (returning true) and disabling does nothing (returning false).
    #
    # Arguments:
    #   varName  -- The name of the array variable in the caller's scope to
    #               modify, linked via [upvar].
    #   varIndex -- The array element (index) holding the list to treat as a set.
    #   value    -- The value to add or remove.
    #   enable   -- A boolean; true adds the value, false removes it.
    #
    # Results:
    #   Non-zero (true) if the set was actually changed (value added or removed),
    #   zero (false) if no change was needed (value already present when adding,
    #   or already absent when removing).
    # </help>

    upvar 1 $varName array

    if {[info exists array($varIndex)]} then {
      set index [lsearch -exact $array($varIndex) $value]

      if {$enable} then {
        if {$index != -1} then {
          return false; # no, it was present.
        } else {
          lappend array($varIndex) $value

          return true; # yes, it was missing.
        }
      } else {
        if {$index != -1} then {
          set array($varIndex) [lreplace \
              $array($varIndex) $index $index]

          return true; # yes, it was removed.
        } else {
          return false; # no, it was missing.
        }
      }
    } else {
      if {$enable} then {
        set array($varIndex) [list $value]

        return true; # yes, created with it.
      } else {
        return false; # no, there is nothing.
      }
    }
  }

  proc enableTestStatisticsLists { varName index statistics enable } {
    # <help>
    # This procedure enables or disables the detailed "list" tracking for one or
    # more resource-statistic types within a statistics array.  By default the
    # statistics machinery only counts how many of each tracked resource type
    # exist before and after a test; turning on list tracking additionally
    # records the actual names of those resources, so that a leak report can
    # show precisely which items appeared.  This procedure is how that opt-in is
    # configured per statistic type.
    #
    # How it works: it links to the caller's statistics array via [upvar] and
    # obtains the full set of valid statistic names from the names helper.  For
    # each requested statistic that is actually a recognized name, it toggles
    # membership of that statistic in the array element that records which
    # statistics have list tracking enabled (an index formed from the literal
    # "listed," prefix and the supplied index), using the array-element set
    # helper, and collects the per-statistic outcome.
    #
    # Tricky details: requested statistics that are not recognized names are
    # silently ignored.  Whether each toggle actually changed anything is
    # captured from the set helper and returned, so callers can tell which
    # statistics were newly enabled or disabled.
    #
    # Arguments:
    #   varName    -- The name of the statistics array variable in the caller's
    #                 scope, linked via [upvar].
    #   index      -- An index distinguishing this set of statistics (combined
    #                 with the "listed," prefix to form the controlling element).
    #   statistics -- A list of statistic type names to enable or disable list
    #                 tracking for; unrecognized names are ignored.
    #   enable     -- A boolean; true enables list tracking, false disables it.
    #
    # Results:
    #   A list of two-element results, one per recognized statistic, each
    #   pairing the statistic name with a boolean indicating whether its list
    #   tracking state was actually changed.
    # </help>

    #
    # NOTE: Enable or disable tracking lists for the specified
    #       object types that we track.
    #
    upvar 1 $varName array

    set allResults [list]
    set allStatistics [getNamesForTestStatistics]

    foreach statistic $statistics {
      if {[lsearch -exact $allStatistics $statistic] != -1} then {
        lappend allResults [list $statistic \
            [changeArrayElement array [appendArgs listed, $index] \
            $statistic $enable]]
      }
    }

    return $allResults
  }

  proc shouldRecordTestStatistics { type } {
    # <help>
    # This procedure decides whether resource (leak) statistics should be
    # recorded for a given recording context.  It exists so that the
    # potentially expensive work of snapshotting resource counts before and
    # after tests can be disabled, either entirely or for a specific context,
    # by the person running the suite.
    #
    # How it works: it returns true only when neither the broad ::no(leak)
    # override flag nor the context-specific flag (an element of the ::no array
    # whose index combines "leak," with the given type) is present; otherwise it
    # returns false.
    #
    # Arguments:
    #   type -- A short label identifying the recording context (for example,
    #           the phase or caller), used to look up the context-specific
    #           suppression flag.
    #
    # Results:
    #   Non-zero (true) if leak statistics should be recorded for this context;
    #   zero (false) if recording has been disabled globally or for this type.
    # </help>

    #
    # NOTE: Has the user explicitly forbid recording test
    #       (resource) statistics of some type, e.g. for
    #       [runTest] (e.g. via "::no(leak,runTest)"), et
    #       al?
    #
    if {![info exists ::no(leak)] && \
        ![info exists ::no(leak,$type)]} then {
      return true
    } else {
      return false
    }
  }

  proc shouldReportTestStatistics { type } {
    # <help>
    # This procedure decides whether recorded resource (leak) statistics should
    # be reported (displayed and logged) for a given context.  It is the
    # reporting-side counterpart to the recording-side predicate, allowing leak
    # output to be suppressed even when the statistics are still being recorded.
    #
    # How it works: it returns true only when neither the broad
    # ::no(runStatistics) override flag nor the context-specific flag (an element
    # of the ::no array whose index combines "runStatistics," with the given
    # type) is present; otherwise it returns false.
    #
    # Arguments:
    #   type -- A short label identifying the reporting context, used to look up
    #           the context-specific suppression flag.
    #
    # Results:
    #   Non-zero (true) if leak statistics should be reported for this context;
    #   zero (false) if reporting has been disabled globally or for this type.
    # </help>

    #
    # NOTE: Has the user explicitly forbid reporting test
    #       (resource) statistics of some type?
    #
    if {![info exists ::no(runStatistics)] && \
        ![info exists ::no(runStatistics,$type)]} then {
      return true
    } else {
      return false
    }
  }

  proc maybeRecordTestStatistics { varName index type } {
    # <help>
    # This procedure conditionally records resource (leak) statistics into a
    # caller-supplied array, doing the work only when recording is enabled for
    # the given context.  It is the guarded entry point that the test runner
    # calls to take "before" and "after" resource snapshots, so callers do not
    # have to repeat the enabled-or-not check themselves.
    #
    # How it works: it first consults the recording predicate for the given
    # type and does nothing if recording is disabled.  When enabled, it links to
    # the caller's array via [upvar], and -- if the environment requests it via
    # the [enableTestStatisticsLists] environment variable -- turns on detailed
    # list tracking for the statistic types named in that variable before taking
    # the snapshot.  It then delegates to the actual recording helper to capture
    # the counts (and any enabled lists) under the given index.
    #
    # Arguments:
    #   varName -- The name of the statistics array variable in the caller's
    #              scope, linked via [upvar].
    #   index   -- The index under which to store this snapshot (for example,
    #              "before" or "after").
    #   type    -- The recording context label, used to decide whether recording
    #              is enabled.
    #
    # Results:
    #   Empty.  Its effect is the side effect of populating the caller's array
    #   with the recorded statistics, when recording is enabled.
    # </help>

    if {[shouldRecordTestStatistics $type]} then {
      upvar 1 $varName array

      if {[info exists ::env(enableTestStatisticsLists)]} then {
        enableTestStatisticsLists array $index \
            $::env(enableTestStatisticsLists) true
      }

      recordTestStatistics array $index
    }
  }

  proc maybeReportTestStatistics {
          channel name stop statsVarName namesVarName type {script ""}
          {quiet false} } {
    # <help>
    # This procedure conditionally reports resource (leak) statistics by
    # comparing previously recorded "before" and "after" snapshots, doing the
    # work only when both recording and reporting are enabled for the given
    # context.  It is the guarded entry point the test runner calls after a test
    # or test file to surface any leaks.
    #
    # How it works: it checks both the recording predicate and the reporting
    # predicate for the given type; if either is disabled, it does nothing.
    # Otherwise it links to the caller's statistics array and leaked-names list
    # via [upvar] and delegates to the actual reporting helper, passing along
    # the channel, the name being reported on, the stop flag, and the quiet
    # flag.
    #
    # Arguments:
    #   channel      -- The output channel for the leak report.
    #   name         -- A label (typically a test or file name) identifying what
    #                   the statistics pertain to.
    #   stop         -- A boolean indicating whether the run is already stopping,
    #                   used by the helper to avoid trying to stop again.
    #   statsVarName -- The name of the statistics array variable in the
    #                   caller's scope, linked via [upvar].
    #   namesVarName -- The name of the leaked-names list variable in the
    #                   caller's scope, linked via [upvar].
    #   type         -- The context label, used to decide whether recording and
    #                   reporting are enabled.
    #   script       -- An optional associated test script; accepted for
    #                   interface compatibility.  Defaults to empty.
    #   quiet        -- An optional boolean; when true, suppresses the report's
    #                   output.  Defaults to false.
    #
    # Results:
    #   Empty when reporting is skipped; otherwise the result of the underlying
    #   reporting helper (which describes the leak count).
    # </help>

    if {[shouldRecordTestStatistics $type] && \
        [shouldReportTestStatistics $type]} then {
      upvar 1 $statsVarName array
      upvar 1 $namesVarName names

      reportTestStatistics $channel $name $stop array names $quiet
    }
  }

  proc recordTestStatistics { varName index } {
    # <help>
    # This procedure takes a snapshot of the current counts of every resource
    # type the test suite tracks for leak detection, storing them into a
    # caller-supplied array under a given index (typically "before" or "after").
    # By recording one snapshot before a test and another after it, the
    # reporting code can detect resources that were created but not cleaned up.
    # It is the workhorse behind the guarded recording entry point.
    #
    # How it works: it links to the caller's array via [upvar] and fires the
    # beforeRecordTestStatistics tester hook.  It seeds, if not already present,
    # the set of "uncounted" leaks (resources that exist but should not count as
    # leaks) and the set of statistics for which detailed name lists are tracked,
    # and stamps the snapshot with the current time.  It selects exact or glob
    # matching for the listed-leak comparison based on a runtime option, then
    # for each tracked resource type queries the current count (for example, the
    # number of pending afters, global variables, commands, procedures, open
    # channels, and so on), storing that count under an index combining the
    # statistic name with the supplied index.  When a statistic is configured
    # for list tracking, it also stores the full list of resource names.  Under
    # TclTk, it additionally records the many engine-specific resource types
    # (such as objects, app domains, interpreters, and Tcl integration
    # resources).
    #
    # Tricky details: individual queries can be suppressed via ::no(query,...)
    # flags, in which case that resource type is recorded as an empty set.
    # Certain "special" variables created by the test suite itself are
    # explicitly excluded so they are never mistaken for leaks.
    #
    # Arguments:
    #   varName -- The name of the statistics array variable in the caller's
    #              scope, linked via [upvar], into which counts (and optional
    #              lists) are written.
    #   index   -- The index distinguishing this snapshot from others (for
    #              example, "before" or "after").
    #
    # Results:
    #   Empty.  Its effect is the side effect of populating the caller's array
    #   with the recorded resource counts and any enabled name lists.
    # </help>

    #
    # NOTE: Record counts of all object types that we track.
    #
    upvar 1 $varName array

    ###########################################################################

    maybeInvokeForTester ::beforeRecordTestStatistics; # HOOK

    ###########################################################################

    if {![info exists array(uncounted,$index)]} then {
      set array(uncounted,$index) [getTestUncountedLeaks]
    }

    if {![info exists array(listed,$index)]} then {
      set array(listed,$index) [getTestListedLeaks]
    }

    ###########################################################################

    set array(time,$index) [clock seconds]; # keep track of when...

    ###########################################################################

    if {[hasRuntimeOption globForListedLeaks]} then {
      set mode -glob
    } else {
      set mode -exact
    }

    ###########################################################################

    if {![info exists ::no(query,afters)]} then {
      set list [after info]
    } else {
      set list [list]
    }

    set array(afters,$index) [llength $list]

    if {[info exists array(listed,$index)] && \
        [lsearch $mode $array(listed,$index) afters] != -1} then {
      set array(afters,$index,list) $list
    }

    ###########################################################################

    if {![info exists ::no(query,globals)]} then {
      set list [info globals]

      #
      # HACK: There are "special" variables that are created by the
      #       test suite itself, e.g. "test_suite_errors", that are
      #       NEVER to be considered as "leaked", i.e. even if they
      #       are missing in the "before" list -AND- present in the
      #       "after" list.
      #
      if {$index eq "after" && \
          ![info exists ::no(fixup,globals)]} then {
        set varIndex [lsearch -exact $list test_suite_errors]

        if {$varIndex != -1} then {
          set list [lreplace $list $varIndex $varIndex]
        }
      }
    } else {
      set list [list]
    }

    set array(variables,$index) [llength $list]

    if {[info exists array(listed,$index)] && \
        [lsearch $mode $array(listed,$index) variables] != -1} then {
      set array(variables,$index,list) $list
    }

    ###########################################################################

    if {![info exists ::no(query,commands)]} then {
      set list [info commands]
    } else {
      set list [list]
    }

    set array(commands,$index) [llength $list]

    if {[info exists array(listed,$index)] && \
        [lsearch $mode $array(listed,$index) commands] != -1} then {
      set array(commands,$index,list) $list
    }

    ###########################################################################

    if {![info exists ::no(query,procedures)]} then {
      set list [info procs]
    } else {
      set list [list]
    }

    set array(procedures,$index) [llength $list]

    if {[info exists array(listed,$index)] && \
        [lsearch $mode $array(listed,$index) procedures] != -1} then {
      set array(procedures,$index,list) $list
    }

    ###########################################################################

    if {![info exists ::no(query,namespaces)]} then {
      if {[isStableTclTkRelease 47 true]} then {; # NOTE: Post Beta 47.
        set list [namespace descendants ::]
      } else {
        set list [namespace children ::]
      }
    } else {
      set list [list]
    }

    set array(namespaces,$index) [llength $list]

    if {[info exists array(listed,$index)] && \
        [lsearch $mode $array(listed,$index) namespaces] != -1} then {
      set array(namespaces,$index,list) $list
    }

    ###########################################################################

    if {![info exists ::no(query,files)]} then {
      if {[info exists ::test_path]} then {
        set list [getFiles $::test_path * "" \
            [info exists ::no(query,files,readable)]]
      } else {
        set list [list]; # NOTE: Information not available.
      }
    } else {
      set list [list]
    }

    set array(files,$index) [llength $list]

    if {[info exists array(listed,$index)] && \
        [lsearch $mode $array(listed,$index) files] != -1} then {
      set array(files,$index,list) $list
    }

    ###########################################################################

    if {![info exists ::no(query,binaryFiles)]} then {
      if {[info exists ::bin_path]} then {
        set list [getFiles $::bin_path * "" \
            [info exists ::no(query,binaryFiles,readable)]]
      } else {
        set list [list]; # NOTE: Information not available.
      }
    } else {
      set list [list]
    }

    set array(binaryFiles,$index) [llength $list]

    if {[info exists array(listed,$index)] && \
        [lsearch $mode $array(listed,$index) binaryFiles] != -1} then {
      set array(binaryFiles,$index,list) $list
    }

    ###########################################################################

    #
    # NOTE: Should any temporary files be exluced from leak accounting?
    #
    if {[info exists ::no(excludedTemporaryFiles)]} then {
      set excludeTemporaryFiles $::no(excludedTemporaryFiles)
    } else {
      set excludeTemporaryFiles ""
    }

    if {![info exists ::no(query,temporaryFiles)]} then {
      set list [getFiles [getTemporaryPath] * $excludeTemporaryFiles \
          [info exists ::no(query,temporaryFiles,readable)]]
    } else {
      set list [list]
    }

    set array(temporaryFiles,$index) [llength $list]

    if {[info exists array(listed,$index)] && \
        [lsearch $mode $array(listed,$index) temporaryFiles] != -1} then {
      set array(temporaryFiles,$index,list) $list
    }

    ###########################################################################

    if {![info exists ::no(query,channels)]} then {
      set list [file channels]
    } else {
      set list [list]
    }

    set array(channels,$index) [llength $list]

    if {[info exists array(listed,$index)] && \
        [lsearch $mode $array(listed,$index) channels] != -1} then {
      set array(channels,$index,list) $list
    }

    ###########################################################################

    if {![info exists ::no(query,aliases)]} then {
      set list [interp aliases]
    } else {
      set list [list]
    }

    set array(aliases,$index) [llength $list]

    if {[info exists array(listed,$index)] && \
        [lsearch $mode $array(listed,$index) aliases] != -1} then {
      set array(aliases,$index,list) $list
    }

    ###########################################################################

    if {[info exists ::no(query,interpreters)] || \
        [catch {getTestChildren} list]} then {
      set list [list]
    }

    set array(interpreters,$index) [llength $list]

    if {[info exists array(listed,$index)] && \
        [lsearch $mode $array(listed,$index) interpreters] != -1} then {
      set array(interpreters,$index,list) $list
    }

    ###########################################################################

    if {![info exists ::no(query,environment)]} then {
      set list [array names env]
    } else {
      set list [list]
    }

    set array(environment,$index) [llength $list]

    if {[info exists array(listed,$index)] && \
        [lsearch $mode $array(listed,$index) environment] != -1} then {
      set array(environment,$index,list) $list
    }

    ###########################################################################

    if {![info exists ::no(query,loaded)]} then {
      set list [info loaded]
    } else {
      set list [list]
    }

    set array(loaded,$index) [llength $list]

    if {[info exists array(listed,$index)] && \
        [lsearch $mode $array(listed,$index) loaded] != -1} then {
      set array(loaded,$index,list) $list
    }

    ###########################################################################

    #
    # NOTE: These native resource types cannot be positively checked
    #       for leaks (i.e. because the "leak" may be from an external
    #       process).
    #
    if {![info exists ::no(uncountedTemporaryFiles)]} then {
      lappend array(uncounted,$index) temporaryFiles
    }

    ###########################################################################

    if {[isTclTk]} then {
      #########################################################################
      #
      # NOTE: Support for some of all of these entity types may not be
      #       present in the interpreter, initialize all these counts
      #       to zero and then try to query each one individually below
      #       wrapped in a catch.
      #
      #########################################################################

      if {[info exists ::no(query,previousPid)] || \
          [catch {info previouspid} list]} then {
        set list 0; # NOTE: Integer, zero for "not in use", negative ok.
      }

      #
      # NOTE: Convert the integer to a boolean.  True means the previous
      #       [pid] value has been used and not reset (i.e. leaked).
      #
      set array(previousPid,$index) [expr {$list != 0}]

      if {[info exists array(listed,$index)] && \
          [lsearch $mode $array(listed,$index) previousPid] != -1} then {
        set array(previousPid,$index,list) $list
      }

      #########################################################################

      if {[info exists ::no(query,scopes)] || \
          [catch {scope list} list]} then {
        set list [list]
      }

      set array(scopes,$index) [llength $list]

      if {[info exists array(listed,$index)] && \
          [lsearch $mode $array(listed,$index) scopes] != -1} then {
        set array(scopes,$index,list) $list
      }

      #########################################################################

      if {[info exists ::no(query,snippets)] || \
          [catch {getTestSnippets} list]} then {
        set list [list]
      }

      set array(snippets,$index) [llength $list]

      if {[info exists array(listed,$index)] && \
          [lsearch $mode $array(listed,$index) snippets] != -1} then {
        set array(snippets,$index,list) $list
      }

      #########################################################################

      if {[info exists ::no(query,assemblies)] || \
          [catch {object assemblies} list]} then {
        set list [list]
      }

      set array(assemblies,$index) [llength $list]

      if {[info exists array(listed,$index)] && \
          [lsearch $mode $array(listed,$index) assemblies] != -1} then {
        set array(assemblies,$index,list) $list
      }

      #########################################################################

      if {[info exists ::no(query,processes)] || \
          [catch {getProcesses ""} list]} then {
        set list [list]
      }

      set array(processes,$index) [llength $list]

      if {[info exists array(listed,$index)] && \
          [lsearch $mode $array(listed,$index) processes] != -1} then {
        set array(processes,$index,list) $list
      }

      #########################################################################

      if {[info exists ::no(query,appDomains)] || \
          [catch {getTestAppDomains} list]} then {
        set list [list]
      }

      set array(appDomains,$index) [llength $list]

      if {[info exists array(listed,$index)] && \
          [lsearch $mode $array(listed,$index) appDomains] != -1} then {
        set array(appDomains,$index,list) $list
      }

      #########################################################################

      if {[info exists ::no(query,objects)] || \
          [catch {info objects} list]} then {
        set list [list]
      }

      set array(objects,$index) [llength $list]

      if {[info exists array(listed,$index)] && \
          [lsearch $mode $array(listed,$index) objects] != -1} then {
        set array(objects,$index,list) $list
      }

      #########################################################################

      if {[info exists ::no(query,objectCallbacks)] || \
          [catch {info callbacks} list]} then {
        set list [list]
      }

      set array(objectCallbacks,$index) [llength $list]

      if {[info exists array(listed,$index)] && \
          [lsearch $mode $array(listed,$index) objectCallbacks] != -1} then {
        set array(objectCallbacks,$index,list) $list
      }

      #########################################################################

      if {[info exists ::no(query,objectTypes)] || \
          [catch {object types} list]} then {
        set list [list]
      }

      set array(objectTypes,$index) [llength $list]

      if {[info exists array(listed,$index)] && \
          [lsearch $mode $array(listed,$index) objectTypes] != -1} then {
        set array(objectTypes,$index,list) $list
      }

      #########################################################################

      if {[info exists ::no(query,objectInterfaces)] || \
          [catch {object interfaces} list]} then {
        set list [list]
      }

      set array(objectInterfaces,$index) [llength $list]

      if {[info exists array(listed,$index)] && \
          [lsearch $mode $array(listed,$index) objectInterfaces] != -1} then {
        set array(objectInterfaces,$index,list) $list
      }

      #########################################################################

      if {[info exists ::no(query,objectNamespaces)] || \
          [catch {object namespaces} list]} then {
        set list [list]
      }

      set array(objectNamespaces,$index) [llength $list]

      if {[info exists array(listed,$index)] && \
          [lsearch $mode $array(listed,$index) objectNamespaces] != -1} then {
        set array(objectNamespaces,$index,list) $list
      }

      #########################################################################
      #
      # NOTE: Support for some of all of these entity types may not be
      #       present in the interpreter, initialize all these counts
      #       to zero and then try to query each one individually below
      #       wrapped in a catch.
      #
      #########################################################################

      if {[info exists ::no(query,connections)] || \
          [catch {info connections} list]} then {
        set list [list]
      }

      set array(connections,$index) [llength $list]

      if {[info exists array(listed,$index)] && \
          [lsearch $mode $array(listed,$index) connections] != -1} then {
        set array(connections,$index,list) $list
      }

      #########################################################################

      if {[info exists ::no(query,transactions)] || \
          [catch {info transactions} list]} then {
        set list [list]
      }

      set array(transactions,$index) [llength $list]

      if {[info exists array(listed,$index)] && \
          [lsearch $mode $array(listed,$index) transactions] != -1} then {
        set array(transactions,$index,list) $list
      }

      #########################################################################

      if {[info exists ::no(query,modules)] || \
          [catch {info modules} list]} then {
        set list [list]
      }

      set array(modules,$index) [llength $list]

      if {[info exists array(listed,$index)] && \
          [lsearch $mode $array(listed,$index) modules] != -1} then {
        set array(modules,$index,list) $list
      }

      #########################################################################

      if {[info exists ::no(query,delegates)] || \
          [catch {info delegates} list]} then {
        set list [list]
      }

      set array(delegates,$index) [llength $list]

      if {[info exists array(listed,$index)] && \
          [lsearch $mode $array(listed,$index) delegates] != -1} then {
        set array(delegates,$index,list) $list
      }

      #########################################################################

      set haveTclCmd [expr {[llength [info commands tcl]] > 0}]

      #########################################################################

      if {[info exists ::no(query,tcl)] || \
          !$haveTclCmd || [catch {tcl ready} list]} then {
        set list False; # NOTE: Boolean, false is "not in use".
      }

      set array(tcl,$index) $list; # verbatim

      if {[info exists array(listed,$index)] && \
          [lsearch $mode $array(listed,$index) tcl] != -1} then {
        set array(tcl,$index,list) $list
      }

      #######################################################################

      if {[info exists ::no(query,tclInterps)] || \
          !$haveTclCmd || [catch {tcl interps} list]} then {
        set list [list]
      }

      set array(tclInterps,$index) [llength $list]

      if {[info exists array(listed,$index)] && \
          [lsearch $mode $array(listed,$index) tclInterps] != -1} then {
        set array(tclInterps,$index,list) $list
      }

      #######################################################################

      if {[info exists ::no(query,tclThreads)] || \
          !$haveTclCmd || [catch {tcl threads} list]} then {
        set list [list]
      }

      set array(tclThreads,$index) [llength $list]

      if {[info exists array(listed,$index)] && \
          [lsearch $mode $array(listed,$index) tclThreads] != -1} then {
        set array(tclThreads,$index,list) $list
      }

      #######################################################################

      if {[info exists ::no(query,tclCommands)] || \
          !$haveTclCmd || [catch {tcl command list} list]} then {
        set list [list]
      }

      set array(tclCommands,$index) [llength $list]

      if {[info exists array(listed,$index)] && \
          [lsearch $mode $array(listed,$index) tclCommands] != -1} then {
        set array(tclCommands,$index,list) $list
      }

      #########################################################################

      if {[info exists ::no(query,scriptThreads)] || [catch {
        #
        # NOTE: Grab the number of active threads that are active because
        #       of ScriptThread object instances.  This will only work if
        #       TclTk is Beta 31 or higher.
        #
        object invoke -flags +NonPublic ScriptThread activeCount
      } list]} then {
        set list 0; # NOTE: Integer, zero for "not in use", negative ok.
      }

      set array(scriptThreads,$index) $list; # verbatim

      if {[info exists array(listed,$index)] && \
          [lsearch $mode $array(listed,$index) scriptThreads] != -1} then {
        set array(scriptThreads,$index,list) $list
      }

      #########################################################################
      #
      # NOTE: These managed resource types cannot be positively checked
      #       for leaks (i.e. because the "leak" may be from an external
      #       process).
      #
      #########################################################################

      if {![info exists ::no(uncountedAssemblies)]} then {
        lappend array(uncounted,$index) assemblies
      }

      if {![info exists ::no(uncountedProcesses)]} then {
        lappend array(uncounted,$index) processes
      }
    }

    ###########################################################################

    maybeInvokeForTester ::afterRecordTestStatistics; # HOOK
  }

  proc getNamesForTestStatistics {} {
    # <help>
    # This procedure returns the canonical list of resource-type names that the
    # leak-tracking machinery knows how to count.  It is the single source of
    # truth shared by the recording, reporting, and list-enabling helpers, so
    # they all iterate over the same set of resource types.
    #
    # How it works: it builds a list beginning with the engine-neutral resource
    # types (such as pending afters, variables, commands, procedures,
    # namespaces, ordinary and binary files, temporary files, channels, aliases,
    # interpreters, environment variables, and loaded packages).  Around the
    # construction it fires the beforeGetNamesForTestStatistics and
    # afterGetNamesForTestStatistics tester hooks.  When running under TclTk, it
    # additionally appends the many engine-specific resource types (such as
    # scopes, assemblies, processes, app domains, objects and their related
    # callbacks/types/interfaces/namespaces, connections, transactions, modules,
    # delegates, and the various Tcl-integration resources).
    #
    # Tricky details: leaked assemblies are tracked for completeness, but a note
    # in the body explains the .NET runtime cannot truly unload an assembly
    # without tearing down the application domain, so such "leaks" are largely
    # informational.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   A list of resource-type names; longer when running under TclTk than
    #   under native Tcl.
    # </help>

    set result [list]

    maybeInvokeForTester ::beforeGetNamesForTestStatistics; # HOOK

    lappend result \
        afters variables commands procedures namespaces files binaryFiles \
        temporaryFiles channels aliases interpreters environment loaded

    if {[isTclTk]} then {
      #
      # TODO: For now, tracking "leaked" assemblies is meaningless because
      #       the .NET Framework has no way to unload them without tearing
      #       down the entire application domain.
      #
      lappend result \
          previousPid scopes assemblies processes appDomains objects \
          objectCallbacks objectTypes objectInterfaces objectNamespaces \
          connections transactions modules delegates tcl tclInterps \
          tclThreads tclCommands scriptThreads
    }

    maybeInvokeForTester ::afterGetNamesForTestStatistics; # HOOK

    return $result
  }

  proc reportTestStatistics {
          channel name stop statsVarName namesVarName {quiet false} } {
    # <help>
    # This procedure compares the "before" and "after" resource snapshots in a
    # statistics array, reports any resource types whose counts grew (i.e.
    # leaked), and -- depending on policy -- can halt the run or break into the
    # debugger when a real leak is found.  It is the engine behind the guarded
    # reporting entry point and produces the familiar leak messages in the test
    # log.
    #
    # How it works: it links to the caller's statistics array via [upvar],
    # obtains the list of tracked resource types, and ensures the global list of
    # leaked names exists.  After firing the beforeReportTestStatistics hook, it
    # walks each statistic: if either the "after" or "before" count is missing it
    # emits a MISSING message (unless quiet) and fires the corresponding hook;
    # if the "after" count exceeds the "before" count it records the statistic
    # as leaked, adds it to the global leaked-names list (unless it is an
    # "uncounted" leak), fires a leaked hook, and -- when not quiet and when
    # before/after name lists are available -- prints those lists.  Uncounted
    # leaks are reported but do not contribute to the real leak count.  After the
    # afterReportTestStatistics hook, if any real leaks were counted it fires the
    # testLeaked hook, ensures the name is recorded in the caller's leaked-names
    # list, and (unless quiet) honors policy: if stop-on-leak is set and the run
    # is not already stopping it raises an empty error to halt the run, else if
    # break-on-leak is set it breaks into the debugger.  If nothing leaked, it
    # fires the testNotLeaked hook.
    #
    # Tricky details: the stop flag guards against trying to stop a run that is
    # already stopping (for example, due to a failure).  Quiet mode suppresses
    # all output and the interactive stop/break behavior, leaving only the
    # returned count.  Name lists are formatted with the list-formatting helper
    # using a placeholder when empty.
    #
    # Arguments:
    #   channel      -- The output channel for the leak messages.
    #   name         -- A label (typically a test or file name) identifying what
    #                   is being reported on.
    #   stop         -- A boolean indicating the run is already stopping;
    #                   suppresses a redundant stop-on-leak halt.
    #   statsVarName -- The name of the statistics array in the caller's scope,
    #                   linked via [upvar].
    #   namesVarName -- The name of the leaked-names list in the caller's scope,
    #                   linked via [upvar] and updated when a leak is found.
    #   quiet        -- An optional boolean; when true, suppresses output and
    #                   the interactive stop/break behavior.  Defaults to false.
    #
    # Results:
    #   A two-element list of the form consisting of the literal "leak" followed
    #   by the number of real (counted) leaks detected.  May raise an empty
    #   error to halt the run when stop-on-leak applies.
    # </help>

    #
    # NOTE: Show what leaked, if anything.
    #
    set count 0; upvar 1 $statsVarName array
    set statistics [getNamesForTestStatistics]

    if {![info exists ::tcltk_debugger(leakedNames)]} then {
      set ::tcltk_debugger(leakedNames) [list]
    }

    maybeInvokeForTester ::beforeReportTestStatistics; # HOOK

    foreach statistic $statistics {
      if {![info exists array($statistic,after)]} then {
        if {!$quiet} then {
          tputs $channel [appendArgs "==== \"" $name "\" MISSING " \
              $statistic " AFTER\n"]
        }

        maybeInvokeForTester [appendArgs ::noAfter_ $statistic]; # HOOK
        continue
      }

      if {![info exists array($statistic,before)]} then {
        if {!$quiet} then {
          tputs $channel [appendArgs "==== \"" $name "\" MISSING " \
              $statistic " BEFORE\n"]
        }

        maybeInvokeForTester [appendArgs ::noBefore_ $statistic]; # HOOK
        continue
      }

      if {$array($statistic,after) > $array($statistic,before)} then {
        lappend array(statistics,leaked) $statistic

        if {![isTestUncountedLeak array $statistic]} then {
          lappend ::tcltk_debugger(leakedNames) $name $statistic
        }

        maybeInvokeForTester [appendArgs ::leaked_ $statistic]; # HOOK

        if {!$quiet} then {
          tputs $channel [appendArgs "==== \"" $name "\" LEAKED " \
              $statistic \n]
        }

        if {[info exists array($statistic,before,list)]} then {
          if {!$quiet} then {
            tputs $channel [appendArgs "---- " $statistic " BEFORE: " \
                [formatList $array($statistic,before,list) <none>] \n]
          }
        }

        if {[info exists array($statistic,after,list)]} then {
          if {!$quiet} then {
            tputs $channel [appendArgs "---- " $statistic " AFTER: " \
                [formatList $array($statistic,after,list) <none>] \n]
          }
        }

        if {[isTestUncountedLeak array $statistic]} then {
          continue
        }

        incr count
      } else {
        maybeInvokeForTester [appendArgs ::notLeaked_ $statistic]; # HOOK
      }
    }

    maybeInvokeForTester ::afterReportTestStatistics; # HOOK

    #
    # NOTE: Were any resource leaks detected during the (current) test
    #       run?
    #
    if {$count > 0} then {
      #
      # NOTE: Some kind of resource was leaked by the test.  Invoke the
      #       (optional) test suite hook now, before doing anything else.
      #
      maybeInvokeForTester ::testLeaked; # HOOK

      #
      # NOTE: Make sure the name is recorded in the list of names that
      #       leaked something.
      #
      upvar 1 $namesVarName names

      if {[lsearch -exact $names [file tail $name]] == -1} then {
        lappend names [file tail $name]
      }

      #
      # NOTE: Disable test suite interaction in quiet mode.  Just return
      #       the leak count.
      #
      if {!$quiet} then {
        #
        # NOTE: If we are supposed to stop (or break into the debugger)
        #       whenever a test leak is detected, do it now.
        #
        # BUGFIX: If we are already stopping (e.g. due to test failure),
        #         do not try to stop again.
        #
        if {!$stop && [isStopOnLeak]} then {
          tresult Error "OVERALL RESULT: STOP-ON-LEAK\n"
          maybeInvokeForTester ::beforeStopOnLeak; # HOOK

          unset -nocomplain ::test_suite_running
          if {[isTclTk]} then {igap MaybeResetLastError}
          error ""; # no message
        } elseif {[isBreakOnLeak]} then {
          testDebugBreak 1
        }
      }
    } else {
      #
      # NOTE: No (tracked) resources were leaked by the test.  Invoke the
      #       (optional) test suite hook now, before doing anything else.
      #
      maybeInvokeForTester ::testNotLeaked; # HOOK
    }

    return [list leak $count]
  }

  proc formatList { list {default ""} {columns 1} } {
    # <help>
    # This procedure renders a list as human-readable, indented, multi-line text
    # for display in test-suite output and logs.  It exists to make leak lists,
    # file lists, and similar collections easy to read rather than printing them
    # as a single dense line.
    #
    # How it works: it walks the elements, emitting a newline before every group
    # of "columns" items so the output wraps into rows, and prefixing each item
    # with a tab.  Empty elements are shown as a placeholder marker so blanks are
    # visible.  The entire formatting is wrapped in a [catch]; if anything goes
    # wrong it returns the empty string.  On success, if the built text is
    # non-empty it is returned, otherwise the supplied default is returned.
    #
    # Tricky details: a column counter is decremented per item and reset to the
    # column count whenever it reaches zero, which is what triggers the row
    # breaks; with the default of one column, each item appears on its own line.
    #
    # Arguments:
    #   list    -- The list of items to format.
    #   default -- The value to return when the list produces no text (for
    #              example, an empty list); defaults to the empty string.
    #   columns -- The number of items to place per row before wrapping;
    #              defaults to 1.
    #
    # Results:
    #   The formatted multi-line string, or the default when there is nothing to
    #   format, or the empty string if formatting raised an error.
    # </help>

    if {[catch {
      set result ""
      set count 1

      foreach item $list {
        if {[incr count -1] == 0} then {
          set count $columns
          append result \n
        }

        append result \t

        if {[string length $item] > 0} then {
          append result $item
        } else {
          append result <noItem>
        }
      }
    }] == 0} then {
      return [expr {[string length $result] > 0 ? $result : $default}]
    } else {
      return ""
    }
  }

  proc formatListAsDict { list {default ""} } {
    # <help>
    # This procedure renders a flat name/value list (a dictionary) as
    # human-readable, indented text with one "name: value" entry per line.  It
    # is used to display dictionary-like data, such as per-type leak counts, in
    # test-suite output.
    #
    # How it works: it iterates over the list two elements at a time as name and
    # value pairs.  Each entry is placed on its own indented line.  The name is
    # quoted with double quotes only when it contains characters outside the
    # simple word set (letters, digits, and underscore); a plain name is shown
    # unquoted.  A "name: value" separator joins the two.  Empty names and empty
    # values are shown with placeholder markers.  The whole process is wrapped
    # in a [catch]; on error it returns the empty string, and on success it
    # returns the built text or, if that text is empty, the supplied default.
    #
    # Arguments:
    #   list    -- A flat list of alternating names and values to format.
    #   default -- The value to return when the list produces no text; defaults
    #              to the empty string.
    #
    # Results:
    #   The formatted multi-line "name: value" string, or the default when there
    #   is nothing to format, or the empty string if formatting raised an error.
    # </help>

    if {[catch {
      set result ""

      foreach {name value} $list {
        append result \n\t

        if {[string length $name] > 0} then {
          if {[regexp -- {^[_\w]*$} $name]} then {
            set wrap ""
          } else {
            set wrap \"
          }

          append result $wrap $name $wrap
        } else {
          append result <noName>
        }

        append result ": "

        if {[string length $value] > 0} then {
          append result $value
        } else {
          append result <noValue>
        }
      }
    }] == 0} then {
      return [expr {[string length $result] > 0 ? $result : $default}]
    } else {
      return ""
    }
  }

  proc formatLeakedNames { list {default ""} } {
    # <help>
    # This procedure reorganizes a flat list of test-name and statistic-name
    # pairs (each pair noting that a particular test leaked a particular
    # resource type) into a grouped, sorted summary, collecting all the
    # statistic types that leaked under each test name.  It exists to turn the
    # raw running list of leaks into a tidy per-test overview for final
    # reporting.
    #
    # How it works: it iterates over the input two elements at a time as a test
    # name and a statistic name.  Empty test names and empty statistic names are
    # replaced with placeholder markers.  When a test name looks like a file path
    # (the file or its containing directory exists), it is shortened to just its
    # tail (the file name) for readability.  Each statistic name is accumulated
    # into a per-test list.  Finally it walks the test names in sorted order and
    # builds a flat result list pairing each test name with its list of leaked
    # statistic names.
    #
    # Tricky details: the default argument is accepted for interface
    # consistency with the other formatting helpers but is not actually used to
    # substitute for empty output here.
    #
    # Arguments:
    #   list    -- A flat list of alternating test names and statistic names.
    #   default -- Accepted for interface consistency; defaults to the empty
    #              string.
    #
    # Results:
    #   A flat list pairing each (sorted) test name with the list of statistic
    #   names that leaked under it.  An empty input yields the empty list.
    # </help>

    foreach {testName statisticName} $list {
      if {[string length $testName] == 0} then {
        set testName <noName>
      } elseif {[file exists $testName] || \
          [file exists [file dirname $testName]]} then {
        set testName [file tail $testName]
      }

      if {[string length $statisticName] == 0} then {
        set statisticName <noValue>
      }

      lappend map($testName) $statisticName
    }

    set result [list]

    foreach testName [lsort [array names map]] {
      lappend result $testName $map($testName)
    }

    return $result
  }

  proc pathToRegexp { path {list false} } {
    # <help>
    # This procedure converts a file-system path into a regular expression that
    # matches that exact path literally, by escaping every character that has a
    # special meaning to the regular expression engine.  It is used wherever a
    # path needs to be embedded inside a larger pattern (for example, in
    # output-matching constraints) without its punctuation being misinterpreted
    # as regexp syntax.
    #
    # How it works: it builds a character-substitution map that prefixes a
    # backslash before each metacharacter -- including the backslash itself, the
    # dollar sign, parentheses, the star, plus, minus, period, question mark,
    # square brackets, the caret, and the brace characters -- and applies it
    # with [string map].  Optionally, the input is first wrapped as a single
    # list element before escaping.
    #
    # Tricky details: directory separators and the extension separator (period)
    # are the usual concern; on Windows the backslash separator itself is a
    # metacharacter and must be escaped, whereas the forward slash used on Unix
    # has no special meaning.  The brace characters are escaped as literal
    # backslash-brace sequences in the map, expressed in the source without ever
    # leaving an unbalanced brace.
    #
    # Arguments:
    #   path -- The file-system path to convert into an escaped regular
    #           expression fragment.
    #   list -- An optional boolean; when true, the path is first wrapped as a
    #           single list element before escaping.  Defaults to false.
    #
    # Results:
    #   A regular expression string that matches the given path literally.
    # </help>

    #
    # NOTE: This procedure needs to escape all characters that
    #       have any special meaning to the regular expression
    #       engine.  Typically, the only characters we need to
    #       really worry about are the directory separator and
    #       the file extension separator (e.g. backslash and
    #       period on Windows and/or forward slash and period
    #       on Unix).  Since the forward slash has no special
    #       meaning to the regular expression engine, Windows
    #       is somewhat more difficult to handle.
    #
    set map [list \
        \\ \\\\ \$ \\\$ ( \\( ) \\) * \\* + \\+ - \\- . \\. \
        ? \\? \[ \\\[ \] \\\] ^ \\^ \{ \\\{ \} \\\}]

    return [string map $map [expr {$list ? [list $path] : $path}]]
  }

  proc assemblyNameToRegexp { assemblyName {list false} } {
    # <help>
    # This procedure converts an assembly name into a regular expression that
    # matches it literally, escaping the characters that have special meaning to
    # the regular expression engine and that can legally appear in an assembly
    # name (chiefly the period).  It is the assembly-name analogue of the
    # path-escaping helper, used where an assembly name is embedded inside a
    # larger pattern.
    #
    # How it works: as a deliberate shortcut, it simply delegates to the
    # path-escaping helper, passing the assembly name and the list flag through
    # unchanged, since that helper already escapes the relevant characters.
    #
    # Arguments:
    #   assemblyName -- The assembly name to convert into an escaped regular
    #                   expression fragment.
    #   list         -- An optional boolean; when true, the name is first wrapped
    #                   as a single list element before escaping.  Defaults to
    #                   false.
    #
    # Results:
    #   A regular expression string that matches the given assembly name
    #   literally.
    # </help>

    #
    # NOTE: This procedure needs to escape all characters that
    #       have any special meaning to the regular expression
    #       engine -AND- that can actually appear in a legal
    #       assembly name.  Normally, this would only include
    #       the period character.
    #
    # HACK: For now, just abuse the [pathToRegexp] procedure
    #       for this.
    #
    return [pathToRegexp $assemblyName $list]
  }

  proc maybeGetOption {
          argv varName {required true} {override true} {default ""}
          {class ""} } {
    # <help>
    # This procedure looks up the value of a named option within an
    # argument-pair list, with optional type validation, default handling, and
    # the ability to honor a pre-existing value.  It exists to give procedures a
    # uniform way to accept "-name value" style options while reporting exactly
    # how each option's value was determined.
    #
    # How it works: it links the result to the caller's named variable via
    # [upvar].  If that variable already holds a value, it is optionally type
    # checked (see below); then, if overriding is allowed, that pre-existing
    # value is remembered as a fallback, otherwise the procedure returns
    # immediately reporting the value was already present.  It then requires the
    # argument list to have an even number of elements (treating them as
    # name/value pairs) and scans for a pair whose name equals a dash followed
    # by the variable name.  If found, the matching value is optionally type
    # checked, assigned to the caller's variable, and the procedure reports
    # whether this overrode a pre-existing value or was a fresh find.  If no
    # match is found but a pre-existing value was present, that value stands.
    # If neither, a non-empty default is used (after optional type checking),
    # or, when the option is required, an error is raised, or, when not
    # required, it reports the option was missing.
    #
    # Tricky details: type validation, when a class is given, uses a strict
    # [string is] test and raises a descriptive error identifying whether the
    # offending value came from the present variable, the found pair, or the
    # default.  The option name is derived by prefixing the variable name with a
    # dash.  An odd-length argument list is rejected outright.
    #
    # Arguments:
    #   argv     -- The list of option name/value pairs to search.
    #   varName  -- The caller-scope variable that both seeds a possible
    #               pre-existing value and receives the resolved value; the
    #               searched option name is this with a leading dash.
    #   required -- An optional boolean; when true (the default), a missing
    #               option with no default raises an error.
    #   override -- An optional boolean; when true (the default), a value found
    #               in argv overrides a pre-existing variable value.
    #   default  -- An optional default value used when the option is absent;
    #               only applied when non-empty.  Defaults to empty.
    #   class    -- An optional [string is] class name; when non-empty, every
    #               candidate value is strictly validated against it.  Defaults
    #               to empty (no validation).
    #
    # Results:
    #   A status word describing the outcome: it reports that the value was
    #   already present and not overridden, was found, was overridden, was the
    #   pre-existing value when no match was found, came from the default, or
    #   was missing.  On a successful resolution the caller's variable is set.
    #   An error is raised for an odd-length argument list, a failed type check,
    #   or a missing required option.
    # </help>

    upvar 1 $varName optionValue

    set wasPresent false

    if {[info exists optionValue]} then {
      if {[string length $class] > 0 && \
          ![string is $class -strict $optionValue]} then {
        error [appendArgs \
            "present option value \"" $optionValue "\" is not " \
            $class]
      }

      if {$override} then {
        set wasPresent true
      } else {
        return isPresent
      }
    }

    set length [llength $argv]

    if {$length % 2} then {
      error "even number of arguments required (option pairs)"
    }

    set optionName [appendArgs - $varName]

    for {set index 0} {$index < $length} {incr index 2} {
      set name [lindex $argv $index]
      set value [lindex $argv [expr {$index + 1}]]

      if {$name eq $optionName} then {; # found?
        if {[string length $class] > 0 && \
            ![string is $class -strict $value]} then {
          error [appendArgs \
              "found option value \"" $value "\" is not " \
              $class]
        }

        set optionValue $value; return [expr {
          $wasPresent ? "isOverridden" : "isFound"
        }]
      }
    }

    if {$wasPresent} then {
      return wasPresent
    }

    if {[string length $default] > 0} then {
      if {[string length $class] > 0 && \
          ![string is $class -strict $default]} then {
        error [appendArgs \
            "default option value \"" $default "\" is not " \
            $class]
      }

      set optionValue $default; return isDefault
    } elseif {$required} then {
      error [appendArgs \
          "missing required option \"" $optionName \"]
    } else {
      return isMissing
    }
  }

  proc inverseLsearchGlob { noCase patterns element } {
    # <help>
    # This procedure performs the "inverse" of a glob-style [lsearch]: instead
    # of searching a list for a glob pattern, it searches a list of glob
    # patterns for the first one that matches a single fixed element.  It is
    # used throughout the file runner to test a file name against lists of
    # skip/start/stop patterns.
    #
    # How it works: it builds a [string match] command, adding the -nocase flag
    # when case-insensitive matching is requested, then iterates over the
    # pattern list in order, testing the element against each pattern.  It
    # returns the index of the first pattern that matches.
    #
    # Tricky details: matching uses glob semantics (via [string match]), the
    # element is treated as a literal string while the list entries are the
    # patterns, and only the first match is reported.
    #
    # Arguments:
    #   noCase   -- A boolean; when true, matching ignores case.
    #   patterns -- The list of glob patterns to test against the element.
    #   element  -- The single value to match against each pattern.
    #
    # Results:
    #   The zero-based index of the first matching pattern, or -1 if no pattern
    #   matches.
    # </help>

    #
    # NOTE: Perform the inverse of [lsearch -glob], attempt
    #       to match an element against a list of patterns.
    #
    set command [list string match]
    if {$noCase} then {lappend command -nocase}

    set length [llength $patterns]

    for {set index 0} {$index < $length} {incr index} {
      set pattern [lindex $patterns $index]

      if {[eval $command [list $pattern] [list $element]]} then {
        return $index
      }
    }

    return -1
  }

  proc removePathFromFileNames { path fileNames } {
    # <help>
    # This procedure shortens a list of file names by stripping the leading
    # directory from those that live directly in a given directory, leaving the
    # rest unchanged.  It exists to make test-run output more readable by
    # showing bare file names for files in the test directory while preserving
    # full paths for files located elsewhere.
    #
    # How it works: it walks the file-name list and, for each entry, compares
    # the normalized directory of the file with the normalized given path.  When
    # they are the same directory, it keeps only the file's tail (its bare
    # name); otherwise it keeps the file name as-is.
    #
    # Tricky details: the comparison normalizes both sides so that differing but
    # equivalent path spellings still match; only files immediately within the
    # given directory are shortened (files in subdirectories are left intact).
    #
    # Arguments:
    #   path      -- The directory whose path should be removed from matching
    #                file names.
    #   fileNames -- The list of file names to process.
    #
    # Results:
    #   A new list in the same order, with file names located directly in the
    #   given directory reduced to their tails and all others unchanged.
    # </help>

    set result [list]

    foreach fileName $fileNames {
      if {[file normalize [file dirname $fileName]] eq \
          [file normalize $path]} then {
        #
        # NOTE: Strip the path name from this file name.
        #
        lappend result [file tail $fileName]
      } else {
        lappend result $fileName
      }
    }

    return $result
  }

  proc formatDecimal { value {places 4} {zeros false} } {
    # <help>
    # This procedure formats a numeric value as a fixed-point decimal string
    # with a chosen number of fractional places, optionally trimming trailing
    # zeros.  It is used to present percentages and similar figures in test-run
    # progress output in a consistent, readable form.
    #
    # How it works: an empty input value yields an empty result.  Under TclTk,
    # when the object integration command is available, it formats the value via
    # the .NET String.Format facility using a numeric format string built from
    # the requested number of places -- using "0" placeholders when trailing
    # zeros are to be kept or "#" placeholders when they are to be dropped -- and
    # disposes of the temporary parsed Double object afterward.  Under native
    # Tcl, it uses the [format] command with a fixed-point conversion to the
    # requested number of places, then, unless trailing zeros are wanted,
    # manually strips trailing zeros and any leftover trailing decimal point.
    #
    # Tricky details: the two engines reach the same visual result by different
    # means; a note in the body remarks that the Tcl [format]-based path is the
    # cleaner of the two and that the TclTk path is a workaround pending a native
    # [format] command.
    #
    # Arguments:
    #   value  -- The numeric value to format; an empty string yields an empty
    #             result.
    #   places -- The number of fractional digits to format; defaults to 4.
    #   zeros  -- An optional boolean; when true, trailing zeros are preserved,
    #             when false (the default) they are trimmed.
    #
    # Results:
    #   The formatted decimal string, or the empty string when the input value
    #   is empty.
    # </help>

    #
    # NOTE: If the value is an empty string, do nothing and return an empty
    #       string.
    #
    if {[string length $value] == 0} then {
      return ""
    }

    #
    # NOTE: For now, use slightly different methods for formatting floating
    #       pointer numbers for native Tcl and TclTk.
    #
    if {[isTclTk] && [llength [info commands object]] > 0} then {
      #
      # HACK: This works; however, in order to do this kind of thing cleanly,
      #       we really need the Tcl [format] command.
      #
      set result [object invoke String Format [appendArgs "{0:0." \
          [string repeat [expr {$zeros ? "0" : "#"}] $places] "}"] \
          [set object [object invoke -create Double Parse $value]]]

      unset object; # dispose
    } else {
      #
      # NOTE: See, nice and clean when done in Tcl?
      #
      set result [format [appendArgs %. $places f] $value]

      #
      # HACK: Since native Tcl does not appear to expose a method to only
      #       preserve non-zero trailing digits, we may need to manually
      #       remove extra trailing zeros.
      #
      if {!$zeros} then {
        #
        # NOTE: Remove all trailing zeros and the trailing decimal point,
        #       if necessary.
        #
        set result [string trimright [string trimright $result 0] .]
      }
    }

    return $result
  }

  proc clearTestPercent { channel } {
    # <help>
    # This procedure clears the test-run progress indicator from the host title.
    # It is the companion to the progress-reporting procedure and is called once
    # the run completes (or no longer needs a progress display) so the host
    # window title is not left showing stale "percent complete" text.
    #
    # How it works: only under TclTk, it resets the host title to the empty
    # string via the [host title] command.  Under native Tcl it does nothing.
    #
    # Arguments:
    #   channel -- The output channel associated with the run; accepted for
    #              interface symmetry with the progress reporter but not used
    #              here.
    #
    # Results:
    #   Empty.  Its effect, under TclTk, is the side effect of clearing the host
    #   title.
    # </help>

    if {[isTclTk]} then {
      host title ""
    }
  }

  proc reportTestPercent {
          channel percent doneFiles totalFiles failedFiles leakedFiles } {
    # <help>
    # This procedure reports overall test-run progress, both to the test log
    # channel and (under TclTk) to the host window title.  It gives a running
    # summary -- percent complete plus tallies of tests and files -- so a long
    # run's status is visible at a glance.
    #
    # How it works: it gathers the cumulative test tallies from the appropriate
    # engine source (the tcltk_tests array under TclTk, or the tcltest numTests
    # array under native Tcl): total tests, failed tests, and skipped tests.  It
    # obtains the test suite name, suite file name, and variant name, falling
    # back to placeholder text for any that are empty.  It then composes two
    # messages -- a terse one for the host title and a more descriptive one for
    # the log -- each embedding the percent complete and the test and file
    # counts.  It writes the descriptive message to the given channel and, under
    # TclTk, sets the host title to the terse message.
    #
    # Arguments:
    #   channel     -- The output channel for the progress message.
    #   percent     -- The percent-complete figure (by files) to display.
    #   doneFiles   -- The number of files processed so far.
    #   totalFiles  -- The total number of files to process.
    #   failedFiles -- The number of files that had failing tests.
    #   leakedFiles -- The number of files that had leaking tests.
    #
    # Results:
    #   Empty.  Its effects are the logged progress message and, under TclTk,
    #   the updated host title.
    # </help>

    if {[isTclTk]} then {
      set totalTests $::tcltk_tests(Total)
      set failedTests $::tcltk_tests(Failed)
      set skippedTests $::tcltk_tests(Skipped)
    } else {
      set totalTests $::tcltest::numTests(Total)
      set failedTests $::tcltest::numTests(Failed)
      set skippedTests $::tcltest::numTests(Skipped)
    }

    set suiteName [getTestSuite]

    if {[string length $suiteName] == 0} then {
      set suiteName unknown
    }

    set suiteFileName [getTestSuiteFileName]

    if {[string length $suiteFileName] == 0} then {
      set suiteFileName unknown
    }

    set suiteVariantName [getTestSuiteVariantName]

    if {[string length $suiteVariantName] == 0} then {
      set suiteVariantName "variant unknown"
    }

    set status(title) [appendArgs \
        "---- test suite running, about " $percent "% complete (" \
        $totalTests " tests total, " $failedTests " tests failed, " \
        $skippedTests " tests skipped, " $doneFiles " files done, " \
        $totalFiles " files total, " $failedFiles " files failed, " \
        $leakedFiles " files leaked)..."]

    set status(tputs) [appendArgs \
        "---- test suite \"" $suiteName ", " $suiteVariantName \
        "\" running from \"" $suiteFileName "\", about " $percent \
        "% complete (" $totalTests " tests total, " $failedTests \
        " tests failed, " $skippedTests " tests skipped, " $doneFiles \
        " files done, " $totalFiles " files total, " $failedFiles \
        " files failed, " $leakedFiles " files leaked)..."]

    tputs $channel [appendArgs $status(tputs) \n]

    if {[isTclTk]} then {
      host title $status(title)
    }
  }

  proc reportArrayGet { varName } {
    # <help>
    # This procedure returns the contents of a caller-supplied array as a flat
    # name/value list, ordered for reporting by descending integer value.  It is
    # used to present count-style arrays (such as per-type leak counts) with the
    # largest counts first.
    #
    # How it works: an empty variable name yields the empty list.  Otherwise it
    # links to the caller's array via [upvar].  Unless disabled, it collects the
    # array entries as name/value pairs, sorts those pairs by their value as
    # integers in decreasing order, and flattens them back into a single
    # name/value list.  When the disabling override is present, it simply
    # returns the array's raw [array get] result with no sorting.
    #
    # Tricky details: the sort assumes the values are integers (as a note in the
    # body points out), which is appropriate for the count arrays this is meant
    # for; non-integer values would not sort meaningfully.  The override flag is
    # ::no(reportArrayGet).
    #
    # Arguments:
    #   varName -- The name of the array variable in the caller's scope, linked
    #              via [upvar]; an empty name yields the empty list.
    #
    # Results:
    #   A flat name/value list of the array's contents, sorted by value in
    #   descending integer order, or the unsorted [array get] result when
    #   sorting is disabled, or the empty list when no variable name is given.
    # </help>

    if {[string length $varName] == 0} then {
      return [list]
    }

    upvar 1 $varName array

    if {![info exists ::no(reportArrayGet)]} then {
      set list(1) [list]

      foreach {name value} [array get array] {
        lappend list(1) [list $name $value]
      }

      #
      # HACK: This assumes that we are dealing with integer values.
      #
      set list(2) [lsort -index 1 -integer -decreasing $list(1)]
      set list(3) [list]

      foreach pair $list(2) {
        lappend list(3) [lindex $pair 0] [lindex $pair 1]
      }

      return $list(3)
    } else {
      return [array get array]
    }
  }

  proc reportTestStatisticCounts { channel statsVarName } {
    # <help>
    # This procedure summarizes, at the end of a run, how many times each kind
    # of resource leaked across all tests, and writes that summary to the test
    # log.  It exists to give a final at-a-glance tally of leak types after the
    # detailed per-test leak messages have already scrolled by.
    #
    # How it works: it links to the caller's statistics array via [upvar].  If
    # the array recorded a running list of leaked statistic names, it counts the
    # occurrences of each distinct name into a temporary count array, flattens
    # that array into a value-sorted dictionary-style list via the array-get
    # reporting helper, and, when there is data, writes a "types of leaks
    # detected" message (formatted with the dictionary formatter) to the given
    # channel.  When no leaked-statistics list was recorded, it does nothing.
    #
    # Arguments:
    #   channel      -- The output channel for the summary message.
    #   statsVarName -- The name of the statistics array variable in the
    #                   caller's scope, linked via [upvar]; its recorded list of
    #                   leaked statistic names drives the summary.
    #
    # Results:
    #   Empty.  Its effect is the side effect of writing the leak-type summary
    #   to the channel when leaks were recorded.
    # </help>

    upvar 1 $statsVarName array

    #
    # NOTE: Were any counts recorded during the testing?
    #
    if {[info exists array(statistics,leaked)]} then {
      #
      # NOTE: Process each leak type in the list, recording any duplicates
      #       in the temporary count array.
      #
      foreach statistic $array(statistics,leaked) {
        if {[info exists count($statistic)]} then {
          incr count($statistic)
        } else {
          set count($statistic) 1
        }
      }

      #
      # NOTE: Flatten the temporary count array into a dictionary formatted
      #       list and then possibly display it (i.e. if it actually contains
      #       any data).
      #
      set statistics [reportArrayGet count]

      if {[llength $statistics] > 0} then {
        tputs $channel [appendArgs "---- types of leaks detected: " \
            [formatListAsDict $statistics <none>] \n]
      }
    }
  }

  proc runAllTests {
          channel path fileNames skipFileNames startFileNames stopFileNames } {
    # <help>
    # This procedure is the top-level driver that runs an entire collection of
    # test files, honoring ordering, skip/start/stop selection, progress
    # reporting, per-file leak tracking, and stop-on-failure behavior.  It is
    # what an overall test session ultimately calls to iterate over the files it
    # discovered and produce the run's summary output.
    #
    # How it works: it records its own call-stack level (used when recording
    # leak statistics).  If random ordering is enabled it shuffles the file
    # list.  Unless run metadata is suppressed, it logs the run path and the
    # file/skip lists.  It then iterates over the files, maintaining counts of
    # files processed and lists of files that had failing or leaking tests, and
    # periodically reports percent-complete progress (computed by files, not
    # tests) whenever that figure changes.  For each file it may break into the
    # debugger on demand; it applies the start-file selection (skipping files
    # until a starting file is seen), the stop-file selection (arranging to halt
    # after a stopping file), and the skip patterns (bypassing matching files).
    # For files that are actually run, it records "before" failure and resource
    # counts, sources the file (capturing errors), and afterward records "after"
    # counts to detect new failures and leaks, appending the file's tail to the
    # failed or leaked lists as appropriate and feeding the leak reporter.  File
    # errors are folded into the suite error list unless suppressed.  Skipped
    # and non-test files are logged.  When a stopping file or a stop-on-failure
    # condition is reached, the loop ends.  Finally it clears the progress
    # indicator, logs how many files were sourced along with the failing and
    # leaking file lists, and reports the aggregate leak-type counts.
    #
    # Tricky details: nearly every reporting and bookkeeping step can be
    # individually suppressed via ::no(...) override flags (for example, run
    # metadata, percent reporting, statistic counts, and the various
    # skipped/non-test/error-logging behaviors).  The percent figure is
    # recomputed and re-reported at several points so the display stays current
    # even across skipped files.  Leak statistics use the recorded call-stack
    # level so before/after snapshots line up correctly.
    #
    # Arguments:
    #   channel        -- The output channel for run metadata, progress, and
    #                     summary messages.
    #   path           -- The directory the test files were discovered in, used
    #                     for display and for shortening file names in output.
    #   fileNames      -- The list of test file names to process.
    #   skipFileNames  -- A list of glob patterns; files whose tails match are
    #                     skipped.
    #   startFileNames -- A list of glob patterns; files before the first match
    #                     are skipped (processing begins at the first match).
    #   stopFileNames  -- A list of glob patterns; processing halts after the
    #                     first matching file.
    #
    # Results:
    #   Empty.  Its effects are the test execution itself and the logged
    #   progress and summary output; failures and leaks are surfaced through the
    #   suite's shared state and hooks rather than a return value.
    # </help>

    set level [lindex [info level [info level]] 0]; # Where are we now?

    #
    # NOTE: Are we configured to run the test files in random order?
    #
    if {[isRandomOrder]} then {
      set fileNames [lshuffle $fileNames]
    }

    #
    # NOTE: Show the exact arguments we received since they may not
    #       have been displayed by the caller (or anybody else).
    #
    if {![info exists ::no(runMetadata)]} then {
      tputs $channel [appendArgs "---- test run path: \"" $path \"\n]

      tputs $channel [appendArgs "---- test run file names: " \
          [formatList [removePathFromFileNames $path $fileNames] <none>] \n]

      tputs $channel [appendArgs "---- test run skip file names: " \
          [formatList $skipFileNames <none>] \n]
    }

    #
    # NOTE: Keep going unless this becomes true (i.e. if one of the
    #       test files signals us to stop).
    #
    set stop false

    #
    # NOTE: So far, we have run no tests.
    #
    set count 0

    #
    # NOTE: So far, no files have had failing or leaking tests.
    #
    set failed [list]
    set leaked [list]

    #
    # NOTE: Process each file name we have been given by the caller...
    #
    set total [llength $fileNames]; set lastPercent -1

    foreach fileName $fileNames {
      #
      # NOTE: If configured to break into the debugger before running the
      #       test file, do it now.
      #
      if {[isBreakOnDemand]} then {
        testDebugBreak 1
      }

      #
      # NOTE: In terms of files, not tests, what percent done are we now?
      #
      set percent [formatDecimal \
          [expr {$total != 0 ? 100.0 * ($count / double($total)) : 0}]]

      if {$percent != $lastPercent} then {
        if {![info exists ::no(runPercent)]} then {
          reportTestPercent $channel $percent \
              $count $total [llength $failed] [llength $leaked]
        }

        set lastPercent $percent
      }

      #
      # NOTE: If the starting file names have been specified by the caller,
      #       skip over all the file names before one of them.
      #
      if {[llength $startFileNames] > 0} then {
        if {[inverseLsearchGlob false $startFileNames \
            [file tail $fileName]] != -1} then {
          #
          # NOTE: Now that we found the starting test file name, do not
          #       skip any more test files.
          #
          set startFileNames [list]
        } else {
          #
          # NOTE: We have not found the starting test file name yet, skip
          #       over this test file.
          #
          continue
        }
      }

      #
      # NOTE: If the stopping file names have been specified by the caller,
      #       skip over all the file names after one of them.
      #
      if {[llength $stopFileNames] > 0} then {
        if {[inverseLsearchGlob false $stopFileNames \
            [file tail $fileName]] != -1} then {
          #
          # NOTE: Now that we found the stopping test file name, do not
          #       run any more test files.
          #
          set stopFileNames [list]

          #
          # NOTE: This will terminate the loop right after the test file
          #       cleanup code (i.e. at the bottom of the loop).
          #
          set stop true
        }
      }

      #
      # NOTE: Skipping over any file name that matches a pattern in the
      #       list of file names to skip.
      #
      if {[inverseLsearchGlob false $skipFileNames \
          [file tail $fileName]] == -1} then {
        #
        # NOTE: Does the file name contain directory information?
        #
        if {[string length [file dirname $fileName]] <= 1} then {
          #
          # NOTE: If not, assume it is under the supplied test path.
          #
          set fileName [file normalize [file join $path $fileName]]
        }

        #
        # NOTE: The "magic" pattern we are looking for to determine if
        #       a given file is part of the formal test suite.
        #
        set pattern {^(\s)*runTest .*$}

        #
        # NOTE: Skip files that are not part of the test suite.
        #
        set data [readSharedFile $fileName]

        #
        # NOTE: Check for a match.
        #
        set match [regexp -line -- $pattern $data]

        #
        # NOTE: Failing that, in TclTk only, check if the data, when
        #       interpreted as Unicode, matches the pattern.
        #
        if {!$match && [isTclTk]} then {
          set match [regexp -line -- $pattern \
              [encoding convertfrom unicode $data]]
        }

        #
        # NOTE: Does this "look" like an actual test suite file?
        #
        if {$match} then {
          #
          # BUGFIX: Unset the current test file name so that variable
          #         accounting works correctly.  It will be reset below
          #         prior to running any actual test(s).
          #
          unset -nocomplain ::test_file

          #
          # NOTE: Get "before" resource counts for leak tracking purposes,
          #       optionally with full lists of tracked resources.  If the
          #       user has explicitly disabled resource leak checks, then
          #       nothing (much) will be done here.
          #
          maybeRecordTestStatistics leaks before $level

          #
          # NOTE: Let the test prologue code know which file we are
          #       evaluating.
          #
          set ::test_file $fileName

          #
          # NOTE: Record failed test count before this file.
          #
          if {[isTclTk]} then {
            set before $::tcltk_tests(Failed)
          } else {
            set before $::tcltest::numTests(Failed)
          }

          #
          # NOTE: Evaluate the test file, optionally waiting for a certain
          #       number of milliseconds before and/or after doing so.
          #
          if {[catch {
            #
            # NOTE: Are we being prevented from waiting before the file?
            #
            if {![info exists ::no(preWait)]} then {
              if {[info exists ::test_wait(pre)] && \
                  [string is integer -strict $::test_wait(pre)]} then {
                if {![info exists ::no(runMetadata)]} then {
                  tputs $channel [appendArgs \
                      "---- waiting for " $::test_wait(pre) \
                      " milliseconds before test file...\n"]
                }

                after $::test_wait(pre); # NOTE: Sleep.
              }
            }

            #
            # NOTE: Log that this test file has started.
            #
            maybeInvokeForTester ::beforeTestFile; # HOOK

            if {![info exists ::no(runStartFile)]} then {
              tputs $channel [appendArgs "==== \"" $fileName "\" START\n"]
            }

            #
            # NOTE: Evaluate the file in the context of the caller,
            #       catching any errors.  If an error is raised and
            #       the stop-on-failure flag is set, assume it was
            #       a test failure and that we need to stop any and
            #       all further processing of test files.
            #
            uplevel 1 [list source $fileName]

            #
            # NOTE: Log that this test file has ended.
            #
            maybeInvokeForTester ::afterTestFile; # HOOK

            if {![info exists ::no(runEndFile)]} then {
              tputs $channel [appendArgs "==== \"" $fileName "\" END\n"]

              tputs $channel [appendArgs \
                  "==== logging to: " [expr {[info exists ::test_log] && \
                  [string length $::test_log] > 0 ? [appendArgs \" \
                  $::test_log \"] : "<none>"}] \n]
            }

            #
            # NOTE: When running in TclTk and not explicitly forbidden
            #       from doing so, check the current memory load -AND-
            #       possibly attempt to forcibly clean things up now.
            #
            if {![info exists ::no(runCleanupMemory)] && [isTclTk]} then {
              if {[catch {debug memory} memory] == 0} then {
                set memoryLoad [getDictionaryValue $memory memoryLoad]; # %

                if {[string is integer -strict $memoryLoad] && \
                    $memoryLoad >= 0 && $memoryLoad <= 100} then {
                  if {[info exists ::env(runCleanupMemoryThreshold)]} then {
                    set memoryThreshold $::env(runCleanupMemoryThreshold)
                  } else {
                    set memoryThreshold 75; # TODO: Good default?
                  }

                  if {$memoryLoad > $memoryThreshold} then {
                    tputs $channel [appendArgs \
                        "==== MEMORY: load " $memoryLoad \
                        " is above automatic cleanup threshold " \
                        $memoryThreshold \n]

                    if {[catch {
                      uplevel #0 [list purgeAndCleanup $channel $fileName]
                    } memoryError]} then {
                      tputs $channel [appendArgs \
                          "==== WARNING: \[purgeAndCleanup\] for \"" \
                          $fileName "\" failed: " $memoryError \n]
                    }
                  } else {
                    tputs $channel [appendArgs \
                        "==== MEMORY: load " $memoryLoad \
                        " is below automatic cleanup threshold " \
                        $memoryThreshold \n]
                  }
                } elseif {[string length $memoryLoad] > 0} then {
                  tputs $channel [appendArgs \
                      "==== WARNING: bad memory load value \"" \
                      $memoryLoad \"\n]
                }
              }
            }

            #
            # NOTE: Are we being prevented from waiting after the file?
            #
            if {![info exists ::no(postWait)]} then {
              if {[info exists ::test_wait(post)] && \
                  [string is integer -strict $::test_wait(post)]} then {
                if {![info exists ::no(runMetadata)]} then {
                  tputs $channel [appendArgs \
                      "---- waiting for " $::test_wait(post) \
                      " milliseconds after test file...\n"]
                }

                after $::test_wait(post); # NOTE: Sleep.
              }
            }
          } error]} then {
            #
            # NOTE: Most likely, this error was caused by malformed or
            #       incorrect code in-between the tests themselves.  We
            #       need to report this.
            #
            if {![info exists ::no(runErrorFile)]} then {
              tputs $channel [appendArgs "==== \"" $fileName "\" ERROR \"" \
                  $error \"\n]

              tputs $channel [appendArgs \
                  "==== logging to: " [expr {[info exists ::test_log] && \
                  [string length $::test_log] > 0 ? [appendArgs \" \
                  $::test_log \"] : "<none>"}] \n]
            }

            #
            # NOTE: Stop further processing after this loop iteration?
            #
            if {[isStopOnFailure]} then {
              #
              # NOTE: This will terminate the loop right after the test
              #       file cleanup code (i.e. at the bottom of the loop).
              #
              set stop true

              #
              # BUGFIX: If there are no actual test failures recorded yet,
              #         make sure there is one now.  This is necessary to
              #         handle the case where an error occurs in a test
              #         file that does not directly cause at least one of
              #         its contained tests to fail.  Otherwise, the test
              #         suite will still be stopped; however, an overall
              #         result of success will be returned by the process.
              #
              if {[isTclTk]} then {
                if {$::tcltk_tests(Failed) == 0} then {
                  incr ::tcltk_tests(Total)
                  incr ::tcltk_tests(Failed)
                }
              } else {
                if {$::tcltest::numTests(Failed) == 0} then {
                  incr ::tcltest::numTests(Total)
                  incr ::tcltest::numTests(Failed)
                }
              }
            } else {
              #
              # NOTE: At this point, we know the test file had an error that
              #       probably caused it to skip a bunch of tests -AND- the
              #       option to stop-testing-on-error is not enabled.  That
              #       being said, we must not simply ignore the error.  The
              #       overall results of the test suite run must now reflect
              #       the failure.  Set a special variable for the epilogue
              #       to pick up on (later).
              #
              if {![info exists ::no(runTestSuiteFileErrors)]} then {
                lappend ::test_suite_errors \
                    [list [list FILE $fileName] $error]
              }
            }
          }

          #
          # NOTE: Record failed test count after this file.
          #
          if {[isTclTk]} then {
            set after $::tcltk_tests(Failed)
          } else {
            set after $::tcltest::numTests(Failed)
          }

          #
          # NOTE: Did this file have any failing tests?
          #
          if {$after > $before} then {
            lappend failed [file tail $fileName]
          }

          #
          # NOTE: In terms of files, not tests, what percent done are we now?
          #
          set percent [formatDecimal \
              [expr {$total != 0 ? 100.0 * ($count / double($total)) : 0}]]

          if {$percent != $lastPercent} then {
            if {![info exists ::no(runPercent)]} then {
              reportTestPercent $channel $percent \
                  $count $total [llength $failed] [llength $leaked]
            }

            set lastPercent $percent
          }

          #
          # NOTE: Unset the current test file name, it is no longer
          #       needed.
          #
          unset -nocomplain ::test_file

          #
          # NOTE: Get "after" resource counts for leak tracking purposes,
          #       optionally with full lists of tracked resources.  If the
          #       user has explicitly disabled resource leak checks, then
          #       nothing (much) will be done here.
          #
          maybeRecordTestStatistics leaks after $level

          maybeReportTestStatistics \
              $channel $fileName $stop leaks leaked $level
        } else {
          #
          # NOTE: This entire file has been skipped.  Record that fact in the
          #       test suite log file.
          #
          if {![info exists ::no(runNonTestFile)]} then {
            tputs $channel [appendArgs \
                "==== \"" $fileName "\" NON_TEST_FILE\n"]

            tputs $channel [appendArgs \
                "==== logging to: " [expr {[info exists ::test_log] && \
                [string length $::test_log] > 0 ? [appendArgs \" \
                $::test_log \"] : "<none>"}] \n]
          }
        }

        #
        # NOTE: Another file of some kind was processed.  It may have been
        #       skipped; however, that does not matter.
        #
        incr count

        #
        # NOTE: In terms of files, not tests, what percent done are we now?
        #
        set percent [formatDecimal \
            [expr {$total != 0 ? 100.0 * ($count / double($total)) : 0}]]

        if {$percent != $lastPercent} then {
          if {![info exists ::no(runPercent)]} then {
            reportTestPercent $channel $percent \
                $count $total [llength $failed] [llength $leaked]
          }

          set lastPercent $percent
        }

        #
        # NOTE: If the test file raised an error (i.e. to indicate a
        #       test failure with the stop-on-failure flag enabled),
        #       break out of the test loop now.
        #
        if {$stop} then {
          break
        }
      } else {
        #
        # NOTE: This entire file has been skipped.  Record that fact in the
        #       test suite log file.
        #
        if {![info exists ::no(runSkippedFile)]} then {
          tputs $channel [appendArgs "==== \"" $fileName "\" SKIPPED\n"]

          tputs $channel [appendArgs \
              "==== logging to: " [expr {[info exists ::test_log] && \
              [string length $::test_log] > 0 ? [appendArgs \" \
              $::test_log \"] : "<none>"}] \n]
        }

        #
        # NOTE: This file was skipped.
        #
        incr count
      }

      #
      # NOTE: In terms of files, not tests, what percent done are we now?
      #
      set percent [formatDecimal \
          [expr {$total != 0 ? 100.0 * ($count / double($total)) : 0}]]

      if {$percent != $lastPercent} then {
        if {![info exists ::no(runPercent)]} then {
          reportTestPercent $channel $percent \
              $count $total [llength $failed] [llength $leaked]
        }

        set lastPercent $percent
      }
    }

    #
    # NOTE: Reset the host title because we may have changed it in the for
    #       loop (above).
    #
    if {![info exists ::no(runPercent)]} then {
      clearTestPercent $channel
    }

    if {![info exists ::no(runMetadata)]} then {
      tputs $channel [appendArgs "---- sourced " $count " test " \
          [expr {$count > 1 ? "files" : "file"}] \n]

      #
      # NOTE: Show the files that had failing and/or leaking tests.
      #
      if {[llength $failed] > 0} then {
        tputs $channel [appendArgs "---- files with failing tests: " \
            [formatList $failed <none>] \n]
      }

      if {[llength $leaked] > 0} then {
        tputs $channel [appendArgs "---- files with leaking tests: " \
            [formatList $leaked <none>] \n]
      }
    }

    if {![info exists ::no(runStatisticCounts)]} then {
      reportTestStatisticCounts $channel leaks
    }
  }

  proc isTestSuiteRunning {} {
    # <help>
    # This procedure reports whether the test suite currently appears to be
    # running.  It exists so that code (for example, cleanup or error-handling
    # logic) can behave differently when invoked in the middle of a test run
    # versus standalone.  The flag it consults is set when a run begins and
    # cleared at various stop points.
    #
    # How it works: it returns true only when the global ::test_suite_running
    # variable exists and its value is itself true; otherwise it returns false.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   Non-zero (true) if the test suite appears to be running; zero (false)
    #   otherwise.
    # </help>

    #
    # NOTE: Return non-zero if the test suite appears to be running.
    #
    return [expr {[info exists ::test_suite_running] && \
        $::test_suite_running}]
  }

  proc getTestChannelOrDefault { {channel stdout} } {; # TODO: Good default?
    # <help>
    # This procedure returns the channel that test-suite output should be
    # written to, preferring the configured test channel but falling back to a
    # caller-supplied default.  It is used pervasively throughout the test
    # library so that logging and progress messages all go to a single,
    # consistently chosen channel.
    #
    # How it works: if the global ::test_channel variable is set, its value is
    # returned; otherwise the default argument is returned.
    #
    # Arguments:
    #   channel -- The fallback channel to use when no test channel has been
    #              configured; defaults to the standard output channel.
    #
    # Results:
    #   The configured test channel when ::test_channel is set, otherwise the
    #   supplied (or default) channel.
    # </help>

    if {[info exists ::test_channel]} then {
      return $::test_channel
    }

    return $channel
  }

  proc tryVerifyTestPath {} {
    # <help>
    # This procedure checks whether the currently configured test path appears
    # to be a usable directory of tests.  It exists as the validation step used
    # by [checkForAndSetTestPath] to decide whether a candidate path is good or
    # whether further candidates must be tried.
    #
    # How it works: it returns false unless every one of the following holds --
    # the global test_path variable exists, the path it names exists, that path
    # is a directory, and that directory is non-empty (contains at least one
    # matching file).  Only when all of these checks pass does it return true.
    #
    # Tricky details: an existing but empty directory is treated as not valid,
    # since a tests directory is expected to contain files; the emptiness check
    # is performed by listing the directory's files.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   Returns true when the global test path names a non-empty existing
    #   directory, false otherwise.
    # </help>

    #
    # NOTE: If the test path variable does not exist, the directory it
    #       points to does not exist (or is not really a directory), or
    #       it appears to be an empty directory, return false; otherwise,
    #       return true.
    #
    if {![info exists ::test_path] || \
        ![file exists $::test_path] || \
        ![file isdirectory $::test_path] || \
        [llength [getFiles $::test_path *]] == 0} then {
      return false
    }

    return true
  }

  proc checkForAndSetTestPath { whatIf {quiet false} } {
    # <help>
    # This procedure locates the directory containing the test suite files and
    # records it in the global test_path variable, trying a sequence of
    # candidate locations appropriate to the runtime and release layout.  It
    # exists so the test harness can find its tests whether it is running from
    # a source tree, a binary release, or a packaged test directory, under
    # either TclTk or native Tcl.
    #
    # How it works: it first chooses a diagnostic channel and then does nothing
    # unless the interpreter is not safe and the test path has not already been
    # set (file-system access is required, so this cannot run in a stock safe
    # interpreter).  It captures the current script name and branches on the
    # runtime.  Under TclTk it derives the library and base directories and
    # tries, in order, several candidate paths -- source-release library and
    # base layouts, the versioned Test package directory in a few locations,
    # the binary-release "Tests" directory (note the casing, which must match
    # the update tooling), and finally a "Tests" directory under the base.
    # Under native Tcl it tries a smaller set anchored on the script directory.
    # After each candidate is assigned it (optionally) logs a numbered
    # diagnostic, and it proceeds to the next candidate only when the current
    # one fails [tryVerifyTestPath] (or when running in what-if mode, which
    # forces every candidate to be evaluated).  A final diagnostic reports the
    # resolved path.
    #
    # Tricky details: in what-if mode the procedure exercises and logs every
    # candidate regardless of validity (useful for diagnosing path resolution)
    # rather than stopping at the first good one.  Each candidate is guarded by
    # the availability of the inputs it needs (library, base, or script), so
    # missing inputs simply skip that candidate.  Diagnostics are suppressed
    # when quiet is requested.  The casing of the "Tests" directory for binary
    # releases must stay in sync with the external update tool that creates it.
    #
    # Arguments:
    #   whatIf -- Boolean; when true, all candidate paths are evaluated and
    #             logged (the final test_path is whatever the last evaluated
    #             candidate set), rather than stopping at the first valid one.
    #   quiet  -- Boolean; when false, progress diagnostics are written to the
    #             test channel (default false).
    #
    # Results:
    #   No meaningful return value; the side effect is that the global
    #   test_path variable is set to the chosen directory (when one is found
    #   and it was not already set).
    # </help>

    #
    # NOTE: Figure out where to send diagnostic messages related to setting
    #       up the test path.
    #
    set channel [getTestChannelOrDefault]

    #
    # NOTE: Everything in this procedure requires access to the file system;
    #       therefore, it cannot be used in a stock "safe" interpreter.
    #
    if {![interp issafe] && ![info exists ::test_path]} then {
      #
      # NOTE: Grab the name of the current script file.  If this is an empty
      #       string, many test path checks will have to be skipped.
      #
      set script [info script]

      #
      # NOTE: TclTk and native Tcl have different requirements and possible
      #       locations for the test path; therefore, handle them separately.
      #
      if {[isTclTk]} then {
        #
        # NOTE: Grab the base directory and the library directory.  Without
        #       these, several test path checks will be skipped.
        #
        set library [getTestLibraryDirectory]; set base [info base]

        if {[string length $library] > 0} then {
          #
          # NOTE: Try the source release directory structure.  For this
          #       case, the final test path would be:
          #
          #           $library/../../Library/Tests
          #
          set ::test_path [file normalize [file join [file dirname [file \
              dirname $library]] Library Tests]]

          if {!$quiet} then {
            tqputs $channel [appendArgs \
                "---- checking #1 for TclTk test path at \"" \
                $::test_path \"...\n]
          }
        }

        if {[string length $base] > 0 && \
            ($whatIf || ![tryVerifyTestPath])} then {
          #
          # NOTE: Try the source release directory structure again; this
          #       time, assume only the embedded script library was used.
          #       For this case, the final test path would be:
          #
          #           $base/Library/Tests
          #
          set ::test_path [file normalize [file join $base Library Tests]]

          if {!$quiet} then {
            tqputs $channel [appendArgs \
                "---- checking #2 for TclTk test path at \"" \
                $::test_path \"...\n]
          }
        }

        if {[string length $script] > 0 && \
            ($whatIf || ![tryVerifyTestPath])} then {
          #
          # NOTE: Try for the test package directory.  For this case, the
          #       final test path would be:
          #
          #           $script/../Test1.0
          #
          set ::test_path [file normalize [file join [file dirname [file \
              dirname $script]] [appendArgs Test [info engine Version]]]]

          if {!$quiet} then {
            tqputs $channel [appendArgs \
                "---- checking #3 for TclTk test path at \"" \
                $::test_path \"...\n]
          }
        }

        if {[string length $base] > 0 && \
            ($whatIf || ![tryVerifyTestPath])} then {
          #
          # NOTE: Try for the test package directory again; this time, use
          #       the base path and assume the source release directory
          #       structure.  For this case, the final test path would be:
          #
          #           $base/lib/Test1.0
          #
          set ::test_path [file normalize [file join $base lib [appendArgs \
              Test [info engine Version]]]]

          if {!$quiet} then {
            tqputs $channel [appendArgs \
                "---- checking #4 for TclTk test path at \"" \
                $::test_path \"...\n]
          }
        }

        if {[string length $base] > 0 && \
            ($whatIf || ![tryVerifyTestPath])} then {
          #
          # NOTE: Try for the test package directory again; this time, use
          #       the base path.  For this case, the final test path would
          #       be:
          #
          #           $base/Test1.0
          #
          set ::test_path [file normalize [file join $base [appendArgs \
              Test [info engine Version]]]]

          if {!$quiet} then {
            tqputs $channel [appendArgs \
                "---- checking #5 for TclTk test path at \"" \
                $::test_path \"...\n]
          }
        }

        if {[string length $library] > 0 && \
            ($whatIf || ![tryVerifyTestPath])} then {
          #
          # NOTE: This must be a binary release, no "Library" directory
          #       then.  Also, binary releases have an upper-case "Tests"
          #       directory name that originates from the "update.bat"
          #       tool.  This must match the casing used in "update.bat".
          #       For this case, the final test path would be:
          #
          #           $library/../../Tests
          #
          set ::test_path [file normalize [file join [file dirname [file \
              dirname $library]] Tests]]

          if {!$quiet} then {
            tqputs $channel [appendArgs \
                "---- checking #6 for TclTk test path at \"" \
                $::test_path \"...\n]
          }
        }

        if {[string length $base] > 0 && \
            ($whatIf || ![tryVerifyTestPath])} then {
          #
          # NOTE: Fallback to using the base directory and checking for a
          #       "Tests" directory beneath it.  For this case, the final
          #       test path would be:
          #
          #           $base/Tests
          #
          set ::test_path [file normalize [file join $base Tests]]

          if {!$quiet} then {
            tqputs $channel [appendArgs \
                "---- checking #7 for TclTk test path at \"" \
                $::test_path \"...\n]
          }
        }

        if {!$quiet} then {
          tqputs $channel [appendArgs \
              "---- final TclTk test path is \"" \
              [expr {[info exists ::test_path] ? \
              $::test_path : "<none>"}] \"\n]
        }
      } else {
        if {[string length $script] > 0} then {
          #
          # NOTE: Try the source release directory structure.  For this
          #       case, the final test path would be:
          #
          #           $script/../../Library/Tests
          #
          set ::test_path [file normalize [file join [file dirname [file \
              dirname [file dirname $script]]] Library Tests]]

          if {!$quiet} then {
            tqputs $channel [appendArgs \
                "---- checking #1 for Tcl test path at \"" \
                $::test_path \"...\n]
          }
        }

        if {[string length $script] > 0 && \
            ($whatIf || ![tryVerifyTestPath])} then {
          #
          # NOTE: Try for the test package directory.  For this case, the
          #       final test path would be:
          #
          #           $script/../Test1.0
          #
          set ::test_path [file normalize [file join [file dirname [file \
              dirname $script]] Test1.0]]

          if {!$quiet} then {
            tqputs $channel [appendArgs \
                "---- checking #2 for Tcl test path at \"" \
                $::test_path \"...\n]
          }
        }

        if {[string length $script] > 0 && \
            ($whatIf || ![tryVerifyTestPath])} then {
          #
          # NOTE: This must be a binary release, no "Library" directory
          #       then.  Also, binary releases have an upper-case "Tests"
          #       directory name that originates from the "update.bat"
          #       tool.  This must match the casing used in "update.bat".
          #       For this case, the final test path would be:
          #
          #           $script/../../Tests
          #
          set ::test_path [file normalize [file join [file dirname [file \
              dirname [file dirname $script]]] Tests]]

          if {!$quiet} then {
            tqputs $channel [appendArgs \
                "---- checking #3 for Tcl test path at \"" \
                $::test_path \"...\n]
          }
        }

        if {!$quiet} then {
          tqputs $channel [appendArgs \
              "---- final Tcl test path is \"" \
              [expr {[info exists ::test_path] ? \
              $::test_path : "<none>"}] \"\n]
        }
      }
    }
  }

  proc configureTcltest { verbose match skip constraints imports force } {
    # <help>
    # This procedure prepares the "tcltest" testing facility for use, bridging
    # the differences between TclTk (where the functionality is built in) and
    # native Tcl (where the package must be loaded and configured).  It exists
    # as the single setup entry point so the test suite can run unchanged under
    # both interpreters.
    #
    # How it works: under TclTk it forces creation of the ::tcltest namespace,
    # installs the compatibility shims via [setupTestShims], and fakes the
    # presence of the tcltest package (the real functionality being built in).
    # Under native Tcl (and only when not in a safe interpreter) it detects
    # whether tcltest is already loaded, requires the package, and -- only if
    # it was not previously loaded -- configures its verbosity (defaulting to a
    # standard verbosity string when none is supplied).  It then copies the
    # match patterns, skip patterns, and constraints into tcltest, always adds
    # the pseudo-constraints fail.false and fail.true used by the TclTk suite,
    # and installs hooks so the current test name can be discovered: it saves
    # and wraps tcltest's internal DebugPuts, and rewrites one call site in
    # tcltest's RunTest to pass proper list structure.  Finally, if any import
    # names are given, it imports those tcltest commands (such as "test") into
    # the global namespace, optionally forcing over existing names.
    #
    # Tricky details: the DebugPuts/RunTest instrumentation is installed only
    # once (guarded by checking for the saved DebugPuts).  Several behaviors
    # are conditional: verbosity is only set on a fresh load; the namespace
    # import only happens when import names are provided; and nothing beyond
    # the TclTk branch runs in a safe interpreter.  The force flag adds the
    # -force option to the namespace import so existing commands are replaced.
    #
    # Arguments:
    #   verbose     -- The tcltest verbosity string; empty selects a default.
    #   match       -- A list of test-name match patterns to copy into tcltest;
    #                  empty copies none.
    #   skip        -- A list of test-name skip patterns to copy into tcltest;
    #                  empty copies none.
    #   constraints -- A list of test constraints to copy into tcltest; empty
    #                  copies none.
    #   imports     -- A list of tcltest command names to import into the
    #                  global namespace; empty imports none.
    #   force       -- Boolean; when true, the namespace import uses -force to
    #                  overwrite existing global commands.
    #
    # Results:
    #   No meaningful return value; the side effect is a configured tcltest
    #   facility (shims, package, configuration, instrumentation, and imports)
    #   ready for the test suite.
    # </help>

    #
    # NOTE: TclTk and native Tcl have different configuration requirements
    #       for the "tcltest" package.  For TclTk, the necessary testing
    #       functionality is built-in.  In native Tcl, the package must be
    #       loaded now and that cannot be done in a "safe" interpreter.
    #
    if {[isTclTk]} then {
      #
      # HACK: Flag the "test" and "runTest" script library procedures so
      #       that they use the script location of their caller and not
      #       their own.
      #
      # BUGBUG: Even this does not yet fix the script location issues in
      #         the test suite:
      #
      #         debug procedureflags test +ScriptLocation
      #         debug procedureflags runTest +ScriptLocation
      #
      # NOTE: Setup the necessary compatibility shims for the test suite.
      #
      namespace eval ::tcltest {}; # HACK: Force namespace creation now.
      setupTestShims true [expr {![isTestSuiteRunning]}]

      #
      # NOTE: Fake having the package as the functionality is built-in.
      #
      package provide tcltest 2.2.10; # Tcl 8.4
    } elseif {![interp issafe]} then {
      #
      # NOTE: Attempt to detect if the package is already loaded.
      #
      set loaded [expr {[catch {package present tcltest}] == 0}]

      #
      # NOTE: Always attempt to load the package.
      #
      package require tcltest

      #
      # NOTE: Configure it for our use (only when it was not loaded).
      #
      if {!$loaded} then {
        if {[string length $verbose] > 0} then {
          ::tcltest::configure -verbose $verbose
        } else {
          ::tcltest::configure -verbose pbste
        }
      }

      #
      # NOTE: We need to copy the TclTk test names to match over to Tcl.
      #
      if {[llength $match] > 0} then {
        ::tcltest::configure -match $match
      }

      #
      # NOTE: We need to copy the TclTk test names to skip over to Tcl.
      #
      if {[llength $skip] > 0} then {
        ::tcltest::configure -skip $skip
      }

      #
      # NOTE: We need to copy the TclTk test constraints over to Tcl.
      #
      if {[llength $constraints] > 0} then {
        ::tcltest::configure -constraints $constraints
      }

      #
      # NOTE: For the benefit of the TclTk test suite, always add the
      #       pseudo-constraints "fail.false" and "fail.true".
      #
      ::tcltest::testConstraint fail.false 1
      ::tcltest::testConstraint fail.true 1

      #
      # NOTE: Next, arrange things to make sure that we have some way
      #       to find out the current test name.
      #
      if {[llength \
          [info commands ::tcltest::SavedDebugPuts]] == 0} then {
        #
        # NOTE: Save original [::tcltest::DebugPuts] so that we can call
        #       into it ourselves.
        #
        rename ::tcltest::DebugPuts ::tcltest::SavedDebugPuts

        #
        # HACK: Change one call site for [::tcltest::DebugPuts] so that
        #       it uses proper list structure for its arguments.  This
        #       makes the semantics of our custom [::tcltest::DebugPuts]
        #       (more?) correct.
        #
        proc ::tcltest::RunTest [info args ::tcltest::RunTest] \
            [string map [list {DebugPuts 3 "Running $name {$script}"} \
            {DebugPuts 3 [list Running $name $script]}] [info body \
            ::tcltest::RunTest]]

        #
        # NOTE: Create our custom [::tcltest::DebugPuts], which may set
        #       the current test name, e.g. if the immediate caller is
        #       [::tcltest::RunTest] -AND- its first argument indicates
        #       a new test is being run.
        #
        proc ::tcltest::DebugPuts {level string} {
          # <help>
          # This procedure is a custom replacement for the native Tcl tcltest
          # internal DebugPuts routine, installed by [configureTcltest].  Its
          # purpose is to observe tcltest's internal debug output so that the
          # name of the test currently being run can be captured into the TclTk
          # debugger state, while still forwarding the call to the original
          # (saved) implementation so normal debug output is unaffected.
          #
          # How it works: when the TclTk debugger state is present, it inspects
          # the call inside a [catch]; if this is a level-three debug message
          # whose immediate caller is tcltest's RunTest (with or without the
          # namespace qualifier), and whose string argument is a three-element
          # list beginning with the word "Running", it extracts the test name
          # (the second list element) and stores it as the current test name in
          # the debugger array.  Regardless of whether a name was captured, it
          # then delegates to the saved DebugPuts (via [uplevel 1]) so the
          # original behavior and return value are preserved.
          #
          # Tricky details: the detection relies on the cooperating rewrite of
          # RunTest's call site (also performed by [configureTcltest]) so that
          # the message argument arrives as a proper three-element list; the
          # [catch] makes the name-capture best-effort and prevents any parsing
          # surprise from disrupting the forwarded call.
          #
          # Arguments:
          #   level  -- The tcltest debug level of the message (the test-name
          #             capture only triggers at level three).
          #   string -- The debug message; when it is a "Running" list emitted
          #             by RunTest, its second element is the test name.
          #
          # Results:
          #   Whatever the saved DebugPuts returns; as a side effect the current
          #   test name may be recorded in the TclTk debugger state.
          # </help>

          if {[info exists ::tcltk_debugger] && [catch {
            if {$level == 3 && [string trimleft \
                [lindex [info level -1] 0] :] in [list RunTest \
                tcltest::RunTest] && [llength $string] == 3 && \
                [lindex $string 0] eq "Running"} then {
              set name [lindex $string 1]
            }
          }] == 0 && [info exists name]} then {
            set ::tcltk_debugger(TclTest_CurrentName) $name
          }

          return [uplevel 1 \
              [list ::tcltest::SavedDebugPuts $level $string]]
        }
      }

      #
      # NOTE: We need the [test] command in the global namespace.
      #
      if {[llength $imports] > 0} then {
        set command [list namespace import]

        if {$force} then {
          lappend command -force
        }

        foreach import $imports {
          lappend command [appendArgs ::tcltest:: $import]
        }

        namespace eval :: $command
      }
    }
  }

  proc machineToPlatform { machine {architecture false} } {
    # <help>
    # This procedure maps a low-level machine/processor type name to the
    # platform name TclTk uses to describe it.  It exists to translate the
    # machine identifiers reported by the runtime or by binaries into the
    # consistent platform vocabulary used elsewhere in the test suite.
    #
    # How it works: it lower-cases the supplied machine name and matches it
    # with an exact [switch].  The intel case is special: when the architecture
    # flag is false and the host is Windows it returns "Win32" (the common
    # Windows label for 32-bit Intel), otherwise it returns "x86".  Other
    # machine types map directly -- arm to arm, ia64 to itanium, msil to clr,
    # amd64 to x64, ia32_on_win64 to wow64, and arm64 to arm64.  An
    # unrecognized machine yields "unknown".
    #
    # Tricky details: the architecture flag only affects the intel case,
    # choosing between the Windows-friendly "Win32" label and the more generic
    # "x86".  Case-insensitive matching is achieved by lower-casing the input
    # because a -nocase option is not available in older Tcl (pre-TIP #241).
    #
    # Arguments:
    #   machine      -- The machine/processor type name to convert (matched
    #                   case-insensitively).
    #   architecture -- Boolean; when false and on Windows, the intel case
    #                   yields "Win32"; otherwise that case yields "x86"
    #                   (default false).
    #
    # Results:
    #   The corresponding platform name string, or "unknown" when the machine
    #   type is not recognized.
    # </help>

    #
    # NOTE: Cannot use "-nocase" option here because Tcl 8.4 does not
    #       support it (i.e. because it is pre-TIP #241).
    #
    switch -exact -- [string tolower $machine] {
      intel {
        if {!$architecture && [isWindows]} then {
          return Win32
        } else {
          return x86
        }
      }
      arm {
        return arm
      }
      ia64 {
        return itanium
      }
      msil {
        return clr
      }
      amd64 {
        return x64
      }
      ia32_on_win64 {
        return wow64
      }
      arm64 {
        return arm64
      }
      default {
        return unknown
      }
    }
  }

  proc architectureForPlatform { platform } {
    # <help>
    # This procedure maps a platform name to its canonical processor
    # architecture identifier.  It is the rough inverse companion to
    # [machineToPlatform], normalizing the various spellings a platform may
    # appear under into a single architecture token.
    #
    # How it works: it lower-cases the supplied platform and matches it with an
    # exact [switch], collapsing synonyms onto a canonical result -- for
    # example intel, win32, and x86 all yield "x86"; ia64 and itanium yield
    # "ia64"; msil and clr yield "msil"; amd64 and x64 yield "x64"; and
    # ia32_on_win64 and wow64 yield "ia32_on_win64".  The arm and arm64
    # platforms map to themselves.  Anything unrecognized yields "unknown".
    #
    # Tricky details: case-insensitive matching is done by lower-casing the
    # input rather than via a -nocase option, because the latter is unavailable
    # in older Tcl (pre-TIP #241), keeping the procedure portable.
    #
    # Arguments:
    #   platform -- The platform name to convert (matched case-insensitively).
    #
    # Results:
    #   The canonical architecture identifier string, or "unknown" when the
    #   platform is not recognized.
    # </help>

    #
    # NOTE: Cannot use "-nocase" option here because Tcl 8.4 does not
    #       support it (i.e. because it is pre-TIP #241).
    #
    switch -exact -- [string tolower $platform] {
      intel -
      win32 -
      x86 {
        return x86
      }
      arm {
        return arm
      }
      ia64 -
      itanium {
        return ia64
      }
      msil -
      clr {
        return msil
      }
      amd64 -
      x64 {
        return x64
      }
      ia32_on_win64 -
      wow64 {
        return ia32_on_win64
      }
      arm64 {
        return arm64
      }
      default {
        return unknown
      }
    }
  }

  proc isTestUncountedLeak { statsVarName statistic } {
    # <help>
    # This procedure reports whether a particular resource statistic should be
    # treated as an "uncounted" leak -- that is, a difference between
    # before-test and after-test measurements that is expected and therefore
    # should not be flagged as a real leak.  It exists so leak-checking logic
    # can consult per-run allow-lists of statistics to ignore.
    #
    # How it works: it links to the caller's statistics array via [upvar], then
    # checks two allow-list entries within that array: one naming statistics to
    # ignore in the before-measurement and one for the after-measurement.  If
    # the given statistic name appears (by exact match) in either list, the
    # procedure returns true.
    #
    # Arguments:
    #   statsVarName -- Name, in the caller's frame, of the statistics array
    #                   that holds the "uncounted,before" and "uncounted,after"
    #                   allow-list entries.
    #   statistic    -- The name of the statistic to test against those
    #                   allow-lists.
    #
    # Results:
    #   Returns true when the statistic is listed as uncounted (in either the
    #   before or after allow-list), false otherwise.
    # </help>

    upvar 1 $statsVarName array

    if {[info exists array(uncounted,before)] && \
        [lsearch -exact $array(uncounted,before) $statistic] != -1} then {
      return true
    }

    if {[info exists array(uncounted,after)] && \
        [lsearch -exact $array(uncounted,after) $statistic] != -1} then {
      return true
    }

    return false
  }

  proc calculateTestConstraintCounts {
          skippedNames maximumVarName countsVarName } {
    # <help>
    # This procedure rolls up skipped-test information into per-constraint
    # counts, tallying how many tests were skipped because of each constraint
    # and tracking the largest such count.  It exists to turn raw skip data
    # into a concise summary suitable for reporting (and for aligning that
    # report's output via the maximum count).
    #
    # How it works: it links to the caller's maximum and counts variables via
    # [upvar], then branches on the runtime.  Under TclTk the input is a
    # dictionary mapping each test name to the list of constraints that caused
    # it to be skipped; the procedure iterates those test/constraint-list pairs
    # and increments the count for each constraint encountered.  Under native
    # Tcl the input is instead a dictionary of constraint names to already
    # computed counts, which are added into the running totals.  In both cases,
    # whenever a constraint's running total exceeds the current maximum (or no
    # maximum is set yet), the maximum is updated.
    #
    # Tricky details: the meaning of the first argument differs by runtime --
    # under TclTk it is per-test constraint lists, under native Tcl it is
    # pre-aggregated per-constraint counts -- but in both cases the counts
    # array accumulates per-constraint totals.  The counts and maximum
    # variables are updated in place and are intended to be (re)used across
    # multiple calls if desired.
    #
    # Arguments:
    #   skippedNames   -- The skip data to roll up: under TclTk a dictionary of
    #                     test name to skip-constraint list; under native Tcl a
    #                     dictionary of constraint name to count.
    #   maximumVarName -- Name, in the caller's frame, of the variable tracking
    #                     the largest per-constraint count seen.
    #   countsVarName  -- Name, in the caller's frame, of the array
    #                     accumulating per-constraint counts.
    #
    # Results:
    #   No meaningful return value; the named maximum and counts variables in
    #   the caller are updated in place.
    # </help>

    #
    # NOTE: Process the list of skipped tests, which is really a dictionary
    #       of test names to the list of constraints that caused them to be
    #       skipped.  We need to "roll them up", on a per-constraint basis,
    #       and produce counts for each constraint.  At the same time, we
    #       need to keep track of the maximum count seen, to help align the
    #       final output.
    #
    upvar 1 $maximumVarName maximum
    upvar 1 $countsVarName counts

    if {[isTclTk]} then {
      foreach {testName constraintNames} $skippedNames {
        foreach constraintName $constraintNames {
          if {[info exists counts($constraintName)]} then {
            incr counts($constraintName)
          } else {
            set counts($constraintName) 1
          }

          if {![info exists maximum] || \
              $counts($constraintName) > $maximum} then {
            set maximum $counts($constraintName)
          }
        }
      }
    } else {
      foreach {constraintName constraintCount} $skippedNames {
        if {[info exists counts($constraintName)]} then {
          incr counts($constraintName) $constraintCount
        } else {
          set counts($constraintName) $constraintCount
        }

        if {![info exists maximum] || \
            $counts($constraintName) > $maximum} then {
          set maximum $counts($constraintName)
        }
      }
    }
  }

  proc getRemoteMessageRaiseError {} {
    # <help>
    # This procedure returns the policy flag controlling whether the remote
    # logging code should raise script errors for problems it detects in
    # advance (as opposed to unexpected runtime errors).  Examples of such
    # anticipated problems include a missing required logging password or a
    # message that exceeds the configured size limit.  It exists so callers
    # like [logRemoteMessage] and [encodeRemoteMessage] can choose between
    # failing loudly and degrading gracefully.
    #
    # How it works: it consults an optional TclTk debugger setting; when that
    # setting is present and strictly true it is normalized to the boolean
    # true.  Regardless of the intermediate computation, the procedure as
    # written returns false, making "do not raise" the effective default.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   A boolean indicating whether anticipated remote-logging problems should
    #   be raised as errors; the effective default is false.
    # </help>

    #
    # HACK: Should script errors be raised when [logRemoteMessage] is
    #       unable to work correctly due to error conditions that are
    #       detected in advance, i.e. they are not unexpected errors?
    #
    if {[info exists ::tcltk_debugger(logRemoteMessageRaiseError)]} then {
      set raiseError $::tcltk_debugger(logRemoteMessageRaiseError)

      if {[string is true -strict $raiseError]} then {
        set raiseError true
      }
    }

    return false
  }

  proc getRemoteMessageRetries {} {
    # <help>
    # This procedure returns the number of times a failed remote log HTTPS
    # request should be retried.  It exists to make retry behavior configurable
    # while defaulting to no retries.
    #
    # How it works: it reads an optional retry count from an TclTk debugger
    # setting and returns it only when it is a valid non-negative integer;
    # otherwise (or when unset) it returns zero, meaning the request is
    # attempted once with no retries.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   A non-negative integer retry count; zero (the default) means do not
    #   retry.
    # </help>

    #
    # HACK: Should we retry the HTTPS request when it fails?  If so,
    #       how many times?  If this value is zero, no retries will
    #       be performed.
    #
    if {[info exists ::tcltk_debugger(logRemoteMessageRetries)]} then {
      set retries $::tcltk_debugger(logRemoteMessageRetries)

      if {[string is integer -strict $retries] && $retries >= 0} then {
        return $retries
      }
    }

    return 0; # NOTE: Do not retry.
  }

  proc getRemoteMessageLimit {} {
    # <help>
    # This procedure returns the maximum allowed size, in encoded bytes, for a
    # remote log message.  It exists so that the encoder can bound message size
    # to what the query-string-based transport can actually carry, while still
    # letting the limit be configured (including disabling logging entirely).
    #
    # How it works: it reads an optional configured limit from an TclTk
    # debugger setting, defaulting to -1 (meaning "use the maximum") when none
    # is set.  It computes a hard maximum from a set of simplifying assumptions
    # documented in the body (query-string and parameter-count ceilings, plus
    # Base-64 and URL encoding overhead).  If the configured limit is not a
    # valid non-negative integer, or is negative, or exceeds the hard maximum,
    # the hard maximum is used instead; an explicitly configured value within
    # range is honored.
    #
    # Tricky details: a configured value of exactly zero is preserved (it is a
    # valid non-negative integer within range) and is treated by callers such
    # as [logRemoteMessage] as a signal to disable remote logging entirely.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   The effective maximum encoded message length: the configured value when
    #   valid and in range, otherwise the computed hard maximum.
    # </help>

    #
    # NOTE: This should be the maximum possible remote message size,
    #       given the following set of simplifying assumptions:
    #
    #       1. The maximum possible query string is 262144 bytes.
    #
    #       2. The maximum number of allowed query parameters is 1000.
    #
    #       3. Each parameter needs one byte for '?' or '&' -AND- may
    #          need one byte for '='.
    #
    #       4. The overhead for Base-64 encoding is 4 / 3.
    #
    #       5. The overhead for URL encoding is 4 / 3.
    #
    if {[info exists ::tcltk_debugger(logRemoteMessageLimit)]} then {
      set limit $::tcltk_debugger(logRemoteMessageLimit)
    } else {
      set limit -1; # i.e. use maximum message limit
    }

    set maximumLimit [expr {
      (1024 * 128) - (1000 * 2)
    }]; # 129072 (minimum?) <= 191568 (tested) <= 262144 (maximum?)

    if {![string is integer -strict $limit] || \
        $limit < 0 || $limit > $maximumLimit} then {
      set limit $maximumLimit
    }

    return $limit
  }

  proc encodeRemoteMessage {
          messageVarName base64VarName limit raiseError } {
    # <help>
    # This procedure Base-64 encodes a remote log message and enforces a
    # maximum encoded-size limit, optionally truncating the message when it is
    # too large.  It exists because the remote logging path transmits the
    # message inside a query string, which has a practical length ceiling.
    #
    # How it works: it links to the caller's message and Base-64 variables via
    # [upvar], then Base-64 encodes the message (using the built-in encoder
    # under TclTk, or the base64 package under native Tcl).  If the encoded
    # length is within the limit, it returns true.  If it exceeds the limit and
    # error-raising is requested, it raises an error reporting the actual and
    # allowed lengths.  Otherwise it truncates: it approximates the maximum raw
    # message length that will fit (undoing the roughly four-thirds Base-64
    # expansion), rewrites the caller's message as a marker of the form
    # naming the original length followed by the truncated text, re-encodes it,
    # and returns false.
    #
    # Tricky details: both the message and Base-64 variables in the caller are
    # updated in place; on the truncation path the caller's message is replaced
    # with the annotated, shortened version so downstream signing and posting
    # operate on the same truncated content that was encoded.  The truncation
    # math is approximate (an inverse of the Base-64 growth factor) rather than
    # exact.
    #
    # Arguments:
    #   messageVarName -- Name, in the caller's frame, of the variable holding
    #                     the message; may be rewritten when truncation occurs.
    #   base64VarName  -- Name, in the caller's frame, of the variable that
    #                     receives the Base-64 encoded message.
    #   limit          -- The maximum allowed length of the Base-64 encoded
    #                     message.
    #   raiseError     -- Boolean; when true, an over-limit message raises an
    #                     error instead of being truncated.
    #
    # Results:
    #   Returns true when the message fit within the limit, false when it was
    #   truncated; the caller's message and Base-64 variables are updated
    #   accordingly.  Raises an error for an over-limit message when error
    #   raising is requested.
    # </help>

    upvar 1 $messageVarName message
    upvar 1 $base64VarName base64

    if {[isTclTk]} then {
      set base64 [base64 encode $message]
    } else {
      package require base64

      set base64 [::base64::encode $message]
    }

    set length [string length $base64]

    if {$length > $limit} then {
      if {$raiseError} then {
        error [appendArgs \
            "base64 remote message length " $length \
            " exceeds configured message limit " $limit]
      } else {
        #
        # HACK: Truncate message at the limit and then
        #       encode it again in Base-64.  This means
        #       we have to (approximately) calculate the
        #       maximum length for a UTF-8 message to be
        #       encoded with it.  Since Base-64 will end
        #       up increasing length by ($n * (4 / 3)),
        #       just attempt to undo that.
        #
        set messageLength [string length $message]
        set messageLimit [expr {int($limit / 4.0 * 3.0)}]

        set message [appendArgs \
            LOG_REMOTE_MESSAGE_TOO_BIG( $messageLength "): " \
            [string range $message 0 $messageLimit]]

        if {[isTclTk]} then {
          set base64 [base64 encode $message]
        } else {
          set base64 [::base64::encode $message]
        }
      }

      return false
    } else {
      return true
    }
  }

  proc getRemoteMessageDirectory {} {
    # <help>
    # This procedure determines (and ensures the existence of) the directory in
    # which queued remote log messages are stored.  It exists so that all of
    # the remote logging helpers agree on a single, valid, writable location
    # for the local message queue.
    #
    # How it works: it prefers the XDG_STATE_HOME environment variable when it
    # is set, otherwise it falls back to the system temporary path.  In either
    # case it validates that the chosen base is non-empty, is an existing
    # directory, and is writable, raising a descriptive error if any check
    # fails.  It then appends an "LRMQ" subdirectory (the log-remote-message
    # queue), and, when the corresponding runtime option is enabled, a further
    # per-process subdirectory named for the current process id.  Finally it
    # creates the resulting directory (so it is guaranteed to exist on return)
    # before returning its path.
    #
    # Tricky details: the per-process subdirectory (gated by a runtime option)
    # isolates each process's queue, which is useful when multiple processes
    # log concurrently.  The directory is created as a side effect, so callers
    # can rely on it existing immediately.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   The full path of the (now existing) remote message queue directory.
    #   Raises an error when the base location is missing, is not a directory,
    #   or is not writable.
    # </help>

    if {[info exist ::env(XDG_STATE_HOME)]} then {
      set directory $::env(XDG_STATE_HOME)

      if {[string length $directory] == 0} then {
        error "invalid state home"
      }

      if {![file isdirectory $directory]} then {
        error [appendArgs \
            "state home must be a directory: " $directory]
      }

      if {![file writable $directory]} then {
        error [appendArgs \
            "state home must be writable: " $directory]
      }
    } else {
      set directory [getTemporaryPath]

      if {[string length $directory] == 0} then {
        error "invalid temporary path"
      }

      if {![file isdirectory $directory]} then {
        error [appendArgs \
            "temporary path must be a directory: " $directory]
      }

      if {![file writable $directory]} then {
        error [appendArgs \
            "temporary path must be writable: " $directory]
      }
    }

    set directory [file join $directory LRMQ]; # logRemoteMessageQueue

    if {[hasRuntimeOption remoteMessagePidDirectory]} then {
      set directory [file join $directory [pid]]
    }

    file mkdir $directory; # NOTE: Must exist prior to return.

    return $directory
  }

  proc getRemoteMessageFileName { {directory ""} {prefix ""} } {
    # <help>
    # This procedure constructs a unique file name for a queued remote log
    # message, used when a message must be persisted to the local queue
    # directory (for fail-safe retention or out-of-process sending).  It exists
    # so that concurrent producers within or across processes do not collide.
    #
    # How it works: it defaults the directory to the standard queue directory
    # (via [getRemoteMessageDirectory]) when none is given, then counts the
    # existing ".lrm" files there to derive a sequence number.  It chooses an
    # identifier component based on context -- under TclTk either the context
    # id or the thread id (depending on a runtime option), and under native Tcl
    # the process id.  An optional caller prefix is included only if it
    # consists solely of an allowed character set (letters, digits, and
    # underscores), in which case a separating hyphen is appended; otherwise
    # the prefix is dropped.  The final name joins the directory with a name
    # composed of the id, a four-digit hex sequence number (the current count
    # plus one), the sanitized prefix, the root of a fresh temporary file name,
    # and the ".lrm" extension.
    #
    # Tricky details: the sequence number is derived from a point-in-time file
    # count, so uniqueness across truly simultaneous callers also relies on the
    # distinct id component and the random temporary-file root.  A prefix that
    # fails the character-set check is silently ignored rather than rejected.
    #
    # Arguments:
    #   directory -- Optional target directory for the queue file; empty (the
    #                default) uses the standard remote message directory.
    #   prefix    -- Optional name prefix; included only when it matches the
    #                allowed character set, otherwise omitted.
    #
    # Results:
    #   A full, unique file path (ending in ".lrm") suitable for writing a
    #   queued remote message.
    # </help>

    if {[string length $directory] == 0} then {
      set directory [getRemoteMessageDirectory]
    }

    set pattern [file join [file normalize $directory] *.lrm]
    set count [llength [glob -nocomplain -- $pattern]]

    if {[isTclTk]} then {
      if {[hasRuntimeOption remoteMessageCtxFileName]} then {
        set id [info context]
      } else {
        set id [info tid]
      }
    } else {
      set id [pid]
    }

    if {[string length $prefix] > 0 && \
        [regexp -nocase -- {^[_0-9A-Z]+$} $prefix]} then {
      append prefix -
    } else {
      set prefix ""
    }

    return [file join $directory [appendArgs $id - [format %04x \
        [expr {$count + 1}]] - $prefix [file rootname [file tail \
        [getTemporaryFileName]]] .lrm]]
  }

  proc isLogRemoteMessageOk { value } {
    # <help>
    # This procedure tests whether a remote logging server response indicates
    # success.  It centralizes the definition of a "good" acknowledgement so
    # that all of the remote logging helpers agree on how to recognize one.
    #
    # How it works: it matches the response against a regular expression
    # requiring the entire string to be the literal "OK" followed by a single
    # space and one or more digits (the digits typically being a server-side
    # count or identifier).
    #
    # Arguments:
    #   value -- The server response string to validate.
    #
    # Results:
    #   Returns true (non-zero) when the response matches the expected OK
    #   pattern, false otherwise.
    # </help>

    return [regexp -- {^OK \d+$} $value]; # VERIFY OK
  }

  proc logRemoteMessage {
          message {uri ""} {apiKey ""} {password ""} {channel stdout}
          {quiet false} } {
    # <help>
    # This procedure securely transmits a single log message to the remote
    # logging endpoint over HTTPS.  It is the low-level core of the remote
    # logging facility: it resolves the endpoint and credentials, encodes and
    # signs the message, posts it, verifies the server's acknowledgement, and
    # (under TclTk) manages a local "fail-safe" queue file so messages are not
    # lost when delivery fails.
    #
    # How it works: it defaults the endpoint URI, API key, and signing password
    # from arguments, environment variables, or built-in fallbacks (using a
    # fake API key and fake password when none is configured).  It UTF-8
    # encodes the message and Base-64 encodes it (honoring a size limit via
    # [encodeRemoteMessage]); a limit of exactly zero disables logging and
    # returns "DISABLED".  It then computes an HMAC-SHA1 of the message keyed by
    # the password and builds the query parameters (raw flag, API key, Base-64
    # message, and hash).  Under TclTk it optionally times the request, may
    # pre-write a fail-safe queue file, performs the upload (with the
    # configured retry count), and checks the response with
    # [isLogRemoteMessageOk]; a [try]/[finally] block reports timing, deletes
    # the fail-safe file on success, and retains or (re)writes queue and result
    # files on failure.  Under native Tcl it posts via the http package using a
    # common HTTP helper.
    #
    # Tricky details: the raise-error policy (from [getRemoteMessageRaiseError])
    # governs whether anticipated problems -- a missing required password, or a
    # message exceeding the size limit -- throw versus degrade gracefully (for
    # example by truncating an over-limit message or using a fake password).  A
    # bad or non-OK server response normally raises an error unless a
    # NoLogRemoteMessageError opt-out is present.  The inner [catch]-then-
    # re-raise pattern exists so the (error) result text is available inside the
    # [finally] block.  Various runtime options (fail-safe mode, result-file
    # writing, and a failure-simulation switch) alter the queue/file behavior.
    #
    # Arguments:
    #   message  -- The message text to log.
    #   uri      -- Optional logging endpoint URI; empty resolves a default
    #               (an auxiliary base URI plus "/log", or a hard-coded URI in
    #               native Tcl).
    #   apiKey   -- Optional API key; empty resolves from the environment or a
    #               fake placeholder.
    #   password -- Optional HMAC signing password; empty resolves from the
    #               environment, a password file, or (per policy) a fake value.
    #   channel  -- The channel used by the native-Tcl HTTP helper (default
    #               stdout).
    #   quiet    -- Boolean passed to the native-Tcl HTTP helper to suppress
    #               output (default false).
    #
    # Results:
    #   The server's response string (expected to match the OK pattern) on a
    #   successful post, or "DISABLED" when the message limit is zero.  Depending
    #   on policy and runtime options, a missing password, an over-limit
    #   message, or a bad/non-OK response may raise an error; otherwise failures
    #   degrade gracefully and the (error-tagged) result is returned.
    # </help>

    #
    # HACK: Should script errors be raised when [logRemoteMessage] is
    #       unable to work correctly due to error conditions that are
    #       detected in advance, i.e. they are not unexpected errors?
    #
    #       Some examples are:
    #
    #       1. Remote logging password is unavailable when required.
    #
    #       2. Message exceeds the configured message size limits.
    #
    set raiseError [getRemoteMessageRaiseError]

    #
    # NOTE: This procedure attempts to (securely) send the specified
    #       log message to the specified logging endpoint.
    #
    if {[string length $uri] == 0} then {
      if {[isTclTk]} then {
        set uri [appendArgs [getAuxiliaryBaseUri] /log]
      } elseif {[info exists ::env(AuxiliaryBaseUri)]} then {
        set uri [appendArgs $::env(AuxiliaryBaseUri) /log]
      } else {
        #
        # HACK: This URI is hard-coded for native Tcl.
        #
        set uri [appendArgs https://urn.to/r/log]
      }
    }

    if {[string length $apiKey] == 0} then {
      if {[info exists ::env(logRemoteMessageApiKey)]} then {
        set apiKey $::env(logRemoteMessageApiKey)
      } else {
        set apiKey 0000000000000000000000000000000000000000; # Fake.
      }
    }

    if {[string length $password] == 0} then {
      if {[info exists ::env(logRemoteMessagePassword)]} then {
        set password $::env(logRemoteMessagePassword)
      }
    }

    if {[string length $password] == 0} then {
      if {[info exists ::env(logRemoteMessagePasswordFile)]} then {
        set password [readSharedFile $::env(logRemoteMessagePasswordFile)]
      } else {
        if {$raiseError} then {
          error "password for remote message log is missing"
        } else {
          set password {nopenotarealpassword}; # Fake.
        }
      }
    }

    #
    # HACK: Yes, we should not be using the query string for passing
    #       the log message itself; however, it does work up to this
    #       limit, which is plenty big, so just do that.
    #
    set limit [getRemoteMessageLimit]

    #
    # NOTE: If the limit is exactly zero, remote logging is disabled
    #       and we should return now.
    #
    if {$limit == 0} then {
      return DISABLED
    }

    #
    # NOTE: Make sure the message string is encoded using UTF-8 and
    #       then encode it using Base-64, while honoring the limit,
    #       if any.
    #
    set message [encoding convertto utf-8 $message]
    encodeRemoteMessage message base64 $limit $raiseError

    #
    # NOTE: Next, calculate HMAC-SHA1 of the message, which will be
    #       verified by the server before the message is considered
    #       valid.
    #
    if {[isTclTk]} then {
      set hash [string tolower \
          [hash keyed hmacsha1 $message $password]]
    } else {
      package require sha1

      set hash [::sha1::hmac -hex -key $password $message]
    }

    set query [list \
        raw 1 apiKey $apiKey message $base64 hash $hash]

    if {[isTclTk]} then {
      if {![info exists ::no(NoTimeRemoteMessage)]} then {
        set start [clock now -gmt true]
      }

      set failSafe [hasRuntimeOption logRemoteMessageFailSafe]
      set directory [getRemoteMessageDirectory]
      set messageFileName [getRemoteMessageFileName $directory $hash]
      set resultFileName [appendArgs $messageFileName .rst]
      set retries [getRemoteMessageRetries]
      set ok false

      try {
        #
        # HACK: If "fail-safe" mode has been enabled (by the user),
        #       write the message to the local queue directory and
        #       then possible delete later if it actually ends up
        #       logged successfully to the remote server.
        #
        if {$failSafe} then {
          writeFile $messageFileName $message; # throw (?)

          set error [appendArgs \
              "logRemoteMessage: FAIL-SAFE CREATED: " $messageFileName]

          host result Break [appendArgs \
              "---- " $error \n]; # NOTE: Not really an error.
        }

        #
        # HACK: At first, the [catch] usage here is a bit puzzling,
        #       e.g. a script error is caught into a local variable
        #       (result) and then eventually re-raised?  This is so
        #       so the resulting (error?) message is available from
        #       inside the finally block (below), which is part of
        #       our containing [try] command.
        #
        if {[catch {
          if {[hasRuntimeOption simulateLogRemoteMessageFailure]} then {
            error "logRemoteMessageSimulateFailure option active"
          }

          string trim [uri upload \
              -timeouttype network -inline -retries $retries \
              -data $query -- $uri]
        } result]} then {
          set result [appendArgs "CAUGHT: " $result]
        }

        if {[isLogRemoteMessageOk $result]} then {
          set ok true
        } else {
          set error [appendArgs \
              "logRemoteMessage: BAD RESULT: " $result]

          host result Exception [appendArgs "---- " $error \n]

          #
          # TODO: By default, an error will be raised here unless
          #       we are forbidden from doing so.  Maybe consider
          #       changing this default?
          #
          if {![info exists ::no(NoLogRemoteMessageError)] && \
              ![info exists ::env(NoLogRemoteMessageError)]} then {
            error $error; # FAIL-SAFE
          }
        }

        return $result
      } finally {
        catch {
          if {[info exists start]} then {
            set stop [clock now -gmt true]
            set prefix [expr {$ok ? "SUCCESS" : "FAILURE"}]

            if {$stop >= $start} then {
              set elapsed [object invoke -create -alias \
                  TimeSpan FromTicks [expr {$stop - $start}]]

              host result Continue [appendArgs \
                  "---- logRemoteMessage: " $prefix \
                  ", POST took " [$elapsed ToString] \n]
            } else {
              host result Continue [appendArgs \
                  "---- logRemoteMessage: " $prefix \
                  ", BACKWARD time travel from " $start \
                  " to " $stop \n]
            }
          }
        }

        catch {; # REDUNDANT (?)
          if {$ok} then {
            #
            # HACK: If the message was logged successfully (to the
            #       remote server), delete the local queue message
            #       file if it exists (i.e. because it was written
            #       prior to attempting the remote logging).
            #
            if {$failSafe && [file exists $messageFileName]} then {
              catch {file delete $messageFileName}; # safe-to-delete
              catch {file rmdir $directory}; # maybe empty (?)

              set error [appendArgs \
                  "logRemoteMessage: FAIL-SAFE DELETED: " $messageFileName]

              host result Ok [appendArgs \
                  "---- " $error \n]; # NOTE: Not really an error.
            }
          } else {
            #
            # HACK: If the message was not logged successfully (to
            #       the remote server), write it to the local queue
            #       directory, for possible later (external to this
            #       process?) retries.
            #
            if {$failSafe && [file exists $messageFileName]} then {
              set error [appendArgs \
                  "logRemoteMessage: FAIL-SAFE RETAINED: " $messageFileName]

              host result Error [appendArgs \
                  "---- " $error \n]; # NOTE: This is really an error.
            } else {
              writeFile $messageFileName $message; # throw (?)

              if {[info exists result] && \
                  [hasRuntimeOption logRemoteMessageResultFile]} then {
                writeFile $resultFileName $result; # throw (?)
              }

              if {$failSafe} then {
                if {[file exists $resultFileName]} then {
                  set error [appendArgs \
                      "logRemoteMessage: RESULT CREATED: " $resultFileName]

                  host result Error [appendArgs \
                      "---- " $error \n]; # NOTE: This is really an error.
                }

                if {[file exists $messageFileName]} then {
                  set error [appendArgs \
                      "logRemoteMessage: FAIL-SAFE CREATED: " $messageFileName]

                  host result Error [appendArgs \
                      "---- " $error \n]; # NOTE: This is really an error.
                }
              }
            }
          }
        }
      }
    } else {
      package require http 2.0
      package require TclTk.Tools.Common

      namespace import -force \
          ::TclTk::Tools::Common::getFileViaHttp

      return [getFileViaHttp \
          $uri 20 $channel $quiet -binary true \
          -query [eval ::http::formatQuery $query]]
    }
  }

  proc logRemoteMessageFile {
          messageFileName {uri ""} {apiKey ""} {password ""} {channel stdout}
          {quiet false} {autoDelete true} } {
    # <help>
    # This procedure sends the contents of a queued remote-message file to the
    # logging endpoint and, on success, deletes the file (and related
    # artifacts).  It is the per-file worker used when draining the local
    # message queue.
    #
    # How it works: it reads the message text from the named file and sends it
    # via [logRemoteMessageWrapper] (forwarding the uri, apiKey, password,
    # channel, and quiet arguments).  When auto-deletion is enabled and the
    # send returned an OK result, it emits a success diagnostic and then
    # removes the message file, any companion result file (the message file
    # name with a ".rst" suffix), and -- if it now exists and is empty -- the
    # containing directory.
    #
    # Tricky details: deletion happens only on a confirmed OK result, so files
    # for failed sends are retained for later retry.  The directory removal is
    # wrapped in [catch] because the directory may not be empty (other queued
    # messages may remain).  Disabling auto-deletion leaves the file in place
    # regardless of outcome.
    #
    # Arguments:
    #   messageFileName -- Path of the queued message file to read and send.
    #   uri             -- Optional logging endpoint URI; empty selects the
    #                      default.
    #   apiKey          -- Optional API key; empty selects the default/fake
    #                      key.
    #   password        -- Optional signing password; empty selects the
    #                      configured or fake password.
    #   channel         -- The channel for diagnostics (default stdout).
    #   quiet           -- Boolean; when true, suppresses diagnostics (default
    #                      false).
    #   autoDelete      -- Boolean; when true, a successfully sent file and its
    #                      artifacts are deleted (default true).
    #
    # Results:
    #   The result returned by the send (the server response), with the file
    #   removed as a side effect when delivery succeeded and auto-deletion is
    #   enabled.
    # </help>

    set result [logRemoteMessageWrapper \
        [readFile $messageFileName] $uri $apiKey $password $channel $quiet]

    if {$autoDelete && [isLogRemoteMessageOk $result]} then {
      host result Ok [appendArgs \
          "---- logRemoteMessageFile: POSTED OK: " $messageFileName \n]

      if {[file exists $messageFileName]} then {
        file delete $messageFileName
      }

      set resultFileName [appendArgs $messageFileName .rst]

      if {[file exists $resultFileName]} then {
        file delete $resultFileName
      }

      set directory [file dirname $messageFileName]

      if {[file exists $directory]} then {
        catch {file rmdir $directory}; # maybe empty (?)
      }
    }

    return $result
  }

  proc logRemoteMessageQueue {
          directory {uri ""} {apiKey ""} {password ""} {channel stdout}
          {quiet false} {stopOnError false} } {
    # <help>
    # This procedure drains a directory of previously queued remote log
    # messages, attempting to send each one and removing those that are
    # delivered successfully.  It exists to flush the local "fail-safe" queue
    # written when earlier direct sends failed (or were deferred), so messages
    # are eventually delivered.
    #
    # How it works: it first validates that the directory argument names an
    # existing, writable directory, raising an error otherwise.  It then globs
    # for queue files (those with the ".lrm" extension) in that directory,
    # processes them in sorted order, and for each one calls
    # [logRemoteMessageFile] (forwarding the uri, apiKey, password, channel,
    # and quiet arguments), which itself deletes a file that is delivered
    # successfully.  After processing, and regardless of whether any files were
    # present, it attempts to remove the (now possibly empty) queue directory.
    #
    # Tricky details: when the stop-on-error flag is set, the first message
    # whose send does not return an OK result raises an error and halts the
    # drain; otherwise individual failures are tolerated and the loop
    # continues.  The trailing directory removal is intentionally redundant
    # with the per-file cleanup so an empty directory is tidied even when there
    # were no files to process.
    #
    # Arguments:
    #   directory  -- The queue directory to drain; must exist and be writable.
    #   uri        -- Optional logging endpoint URI; empty selects the default.
    #   apiKey     -- Optional API key; empty selects the default/fake key.
    #   password   -- Optional signing password; empty selects the configured
    #                 or fake password.
    #   channel    -- The channel for diagnostics (default stdout).
    #   quiet      -- Boolean; when true, suppresses diagnostics (default
    #                 false).
    #   stopOnError -- Boolean; when true, the first non-OK send raises an
    #                  error and stops the drain (default false).
    #
    # Results:
    #   No meaningful return value; the side effects are the delivery and
    #   deletion of queued message files and the removal of the empty queue
    #   directory.  Raises an error for an invalid directory, or (when
    #   stop-on-error is set) on the first failed send.
    # </help>

    if {[string length $directory] == 0 || \
        ![file isdirectory $directory] || \
        ![file writable $directory]} then {
      error [appendArgs \
          "invalid remote message queue directory: " $directory]
    }

    set pattern [file join \
        [file normalize $directory] *.lrm]; # logRemoteMessage

    foreach messageFileName [lsort [glob -nocomplain -- $pattern]] {
      set result [logRemoteMessageFile \
          $messageFileName $uri $apiKey $password $channel $quiet]

      if {$stopOnError && ![isLogRemoteMessageOk $result]} then {
        error [appendArgs "logRemoteMessageQueue: " $result]
      }
    }

    #
    # HACK: Even if there were no (message) files in the message
    #       queue directory, we should (still) try to delete an
    #       empty (?) message queue directory.  This is why this
    #       [file rmdir] command is being used at this point, in
    #       addition to being used in the [logRemoteMessageFile]
    #       procedure itself.
    #
    if {[file exists $directory]} then {
      catch {file rmdir $directory}; # maybe empty (?)
    }
  }

  proc logRemoteMessageWrapper {
          message {uri ""} {apiKey ""} {password ""} {channel stdout}
          {quiet false} {useLevel false} {milliseconds ""} } {
    # <help>
    # This procedure is the front door for sending a single remote log message,
    # adding an optional caller-name prefix and dispatching the actual send
    # either synchronously in this process or asynchronously in a separate
    # child shell.  It exists so callers do not have to choose between the
    # synchronous and out-of-process logging paths themselves.
    #
    # How it works: when requested (via the useLevel flag), it prepends the
    # name of the immediate calling command to the message so the log records
    # who emitted it.  It then decides on the delivery mechanism: if a
    # NoSynchronousRemoteMessage opt-out is present (in the global "no" array
    # or the environment), it writes the message to a queue file and launches a
    # separate test shell that requires the TclTk.Test package, applies the
    # configured delay, and calls [logRemoteMessageFile] on that file in the
    # background.  Otherwise it applies the delay inline (via [delayForTest])
    # and sends the message directly through [logRemoteMessage].
    #
    # Tricky details: the asynchronous path serializes the message to a file
    # and hands it off to a child process, returning the result of launching
    # that process rather than the eventual log outcome.  The useLevel prefix
    # is derived from [info level -1]; if that cannot be obtained it is simply
    # omitted.  The delay (see [delayForTest]) throttles server load on the
    # synchronous path and is also injected into the asynchronous child.
    #
    # Arguments:
    #   message      -- The message text to send.
    #   uri          -- Optional logging endpoint URI; empty selects the
    #                   default.
    #   apiKey       -- Optional API key; empty selects the default/fake key.
    #   password     -- Optional signing password; empty selects the configured
    #                   or fake password.
    #   channel      -- The channel for diagnostics (default stdout).
    #   quiet        -- Boolean; when true, suppresses diagnostics (default
    #                   false).
    #   useLevel     -- Boolean; when true, prefixes the message with the
    #                   calling command's name (default false).
    #   milliseconds -- Optional delay override, in milliseconds, applied
    #                   before sending.
    #
    # Results:
    #   On the synchronous path, the result of [logRemoteMessage] (the server
    #   response).  On the asynchronous path, the result of launching the child
    #   test shell that will perform the send.
    # </help>

    if {!$useLevel || \
        [catch {lindex [info level -1] 0} level]} then {
      set level ""
    }

    if {[string length $level] > 0} then {
      set message [appendArgs $level ": " $message]
    }

    if {[info exists ::no(NoSynchronousRemoteMessage)] || \
        [info exists ::env(NoSynchronousRemoteMessage)]} then {
      set messageFileName [getRemoteMessageFileName]

      writeFile $messageFileName $message

      return [execTestShell \
          [list -success Success] \
          -noArgumentsFileNames -initialize -postInitialize \
          [appendArgs \" [list package require TclTk.Test] \"] \
          -postInitialize \
          [appendArgs \" "delayForTest " $milliseconds \"] \
          -evaluate [appendArgs \" [list logRemoteMessageFile \
          $messageFileName $uri $apiKey $password $channel \
          $quiet] \"] &]
    } else {
      delayForTest $milliseconds

      return [logRemoteMessage \
          $message $uri $apiKey $password $channel $quiet]
    }
  }

  proc getRemoteMessageHeader { success } {
    # <help>
    # This procedure builds the standard header string that prefixes every
    # remote test-run log message, identifying the test run and its
    # environment.  It exists so that all remote messages share a consistent,
    # parseable preamble that ties them back to a specific run, source
    # checkout, and configuration.
    #
    # How it works: it collects a series of descriptive values -- the test run
    # id, the run bucket, the log identifier, the source repository url and
    # checkout, and the repository tags (with commas normalized to spaces) --
    # substituting placeholder tokens like <noId> or <noBucket> for any that
    # are unavailable.  It then assembles these, along with the test suite's
    # full name and variant name, into a single "TEST-RUN ..." header string.
    # If a non-empty success flag is supplied, the header is prefixed with
    # "SUCCESS " or "FAILURE " accordingly.  When command-line arguments are
    # present they are appended as an argv clause, and under TclTk it
    # additionally appends the runtime version and the full command line.
    #
    # Tricky details: the success argument is three-valued -- a true value
    # yields a SUCCESS prefix, a false value yields FAILURE, and an empty
    # string yields no prefix at all (used for plain informational messages).
    # The TclTk-only runtime-version lookup reaches into a non-public engine
    # helper to format a short image/runtime version.
    #
    # Arguments:
    #   success -- A boolean selecting the SUCCESS/FAILURE prefix, or an empty
    #              string for no prefix.
    #
    # Results:
    #   The assembled header string describing the current test run and its
    #   environment.
    # </help>

    set id [getTestRunId]
    if {[string length $id] == 0} then {set id <noId>}

    set bucket [getTestRunBucket]
    if {[string length $bucket] == 0} then {set bucket <noBucket>}

    set log [getTestLog]
    if {[string length $log] == 0} then {set log <noLog>}

    set url [getValueOrDefault ::test_repository_url <noUrl>]
    set checkout [getValueOrDefault ::test_repository_checkout <noCheckout>]

    set tags [getValueOrDefault ::test_repository_tags <noTags>]
    set tags [string map [list "  " " "] [string map [list , " "] $tags]]

    if {[string length $success] > 0} then {
      if {$success} then {
        set prefix "SUCCESS "
      } else {
        set prefix "FAILURE "
      }
    } else {
      set prefix ""
    }

    set result [appendArgs \
        $prefix "TEST-RUN " $id " bucket " $bucket ": " \
        [getTestSuiteFullName] ", url " $url ", checkout " \
        $checkout ", tags " $tags ", log " $log ", " \
        [getTestSuiteVariantName]]

    set argv [getValueOrDefault ::argv [list]]

    if {[llength $argv] > 0} then {
      append result ", argv " [list $argv]
    }

    if {[isTclTk]} then {
      set runtimeVersion [object invoke -flags +NonPublic \
          CodeBrix.Platform.TclTk._Components.Private.FormatOps ShortImageOrRuntimeVersion \
          [set assembly [object invoke Utility GetAssembly]] null null]

      if {[string length $runtimeVersion] > 0} then {
        append result ", runtime version " $runtimeVersion
      }

      set cmdLine [info cmdline]

      if {[string length $cmdLine] > 0} then {
        append result ", command line " [list $cmdLine]
      }
    }

    return $result
  }

  proc getRemoteTestResults { verbose } {
    # <help>
    # This procedure gathers the current test run statistics and formats them
    # into compact textual fragments suitable for appending to a remote log
    # message.  It produces two fragments: a "basic" detail string and an
    # "extra" detail string, the latter reserved for high-volume data (the full
    # list of skipped test names) that is logged separately when desired.
    #
    # How it works: it branches on whether it is running under TclTk or native
    # Tcl, reading the appropriate result counters.  Under TclTk it reports
    # Passed, Failed, Skipped, Disabled, and Total counts, the list of failed
    # test names, a per-constraint rollup of skipped tests (computed via
    # [calculateTestConstraintCounts]), the full skipped-name list (placed in
    # the extra fragment), and an elapsed-time duration in microseconds when
    # available.  Under native Tcl it reports the tcltest numTests counters,
    # the skipped-because constraint rollup, and the list of failing files.
    # Each statistic is appended as a ", name value" clause.
    #
    # Tricky details: by default a statistic is only emitted when it is
    # non-zero or its list is non-empty; passing a true verbose flag forces
    # every statistic to be included (substituting a placeholder such as
    # "<none>" for empty lists).  The skipped-names data is deliberately split
    # into the second fragment because it can be very large; callers can choose
    # whether to transmit it.
    #
    # Arguments:
    #   verbose -- Boolean; when true, all statistics are included even when
    #              zero or empty, otherwise only meaningful ones are emitted.
    #
    # Results:
    #   A two-element list: the first element is the basic detail string and
    #   the second is the extra detail string (holding the skipped-name list,
    #   possibly empty).
    # </help>

    set result(1) ""; set result(2) ""

    if {[isTclTk]} then {
      foreach name [list Passed Failed Skipped Disabled Total] {
        if {[info exists ::tcltk_tests($name)]} then {
          set value $::tcltk_tests($name)

          if {$verbose || $value != 0} then {
            append result(1) ", " [string tolower $name] " " \
                $value
          }
        }
      }

      if {[info exists ::tcltk_tests(FailedNames)]} then {
        set value $::tcltk_tests(FailedNames)

        if {$verbose || [llength $value] > 0} then {
          if {[llength $value] == 0} then {set value <none>}
          append result(1) ", failedNames " $value
        }
      }

      if {[info exists ::tcltk_tests(SkippedNames)]} then {
        set skippedNames $::tcltk_tests(SkippedNames)

        calculateTestConstraintCounts \
            $skippedNames maximum counts

        set value [testArrayGet counts]

        if {$verbose || [llength $value] > 0} then {
          if {[llength $value] == 0} then {set value <none>}
          append result(1) ", skippedConstraints " $value
        }

        #
        # HACK: Since the list of skipped test names can be quite
        #       large, return it to the caller as its own element
        #       of the result list.  This data is very valuable.
        #
        set value $skippedNames

        if {$verbose || [llength $value] > 0} then {
          if {[llength $value] == 0} then {set value <none>}
          append result(2) ", skippedNames " $value
        }
      }

      if {[info exists ::test_timestamp(elapsedMicroseconds)]} then {
        set value $::test_timestamp(elapsedMicroseconds)

        if {[string is double -strict $value]} then {
          append result(1) ", duration " [formatDecimal $value] \
              " microseconds"
        }
      }
    } else {
      foreach name [list Passed Failed Skipped Total] {
        if {[info exists ::tcltest::numTests($name)]} then {
          set value $::tcltest::numTests($name)

          if {$verbose || $value != 0} then {
            append result(1) ", " [string tolower $name] " " \
                $value
          }
        }
      }

      if {[array exists ::tcltest::skippedBecause]} then {
        calculateTestConstraintCounts \
            [array get ::tcltest::skippedBecause] maximum counts

        set value [testArrayGet counts]

        if {$verbose || [llength $value] > 0} then {
          if {[llength $value] == 0} then {set value <none>}
          append result(1) ", skippedConstraints " $value
        }
      }

      if {[info exists ::tcltest::failFiles]} then {
        set value $::tcltest::failFiles

        if {$verbose || [llength $value] > 0} then {
          if {[llength $value] == 0} then {set value <none>}
          append result(1) ", failFiles " $value
        }
      }
    }

    return [list $result(1) $result(2)]
  }

  #
  # HACK: The server bandwidth can be a very limited resource;
  #       therefore, wait at least X milliseconds before doing
  #       it again.
  #
  proc delayForTest { {milliseconds ""} } {
    # <help>
    # This procedure pauses execution for a (randomized) interval, used to
    # throttle activity such as remote message logging so that limited server
    # bandwidth is not overwhelmed (as the preceding HACK comment explains).
    # It can be disabled entirely, and the delay duration can be configured
    # from several sources.
    #
    # How it works: it first honors an opt-out -- if either the NoDelayForTest
    # entry exists in the global "no" array or the NoDelayForTest environment
    # variable is set, it returns immediately without waiting.  Otherwise it
    # resolves the base delay in milliseconds from, in priority order, the
    # explicit argument, an TclTk debugger setting, a DelayForTest environment
    # variable, and a test-timeout variable; if none yields a valid integer it
    # falls back to a default of 2000 milliseconds.  It then sleeps (via
    # [after]) for the base delay plus a random additional amount up to that
    # same 2000-millisecond default, so the actual pause is jittered.
    #
    # Tricky details: the integer validation differs slightly between TclTk and
    # native Tcl (using the "string is not integer" form under TclTk), but both
    # fall back to the default for non-integer values.  The random jitter means
    # the realized delay is always at least the base value and up to roughly
    # two seconds more.
    #
    # Arguments:
    #   milliseconds -- Optional base delay in milliseconds.  When empty (the
    #                   default) or not a valid integer, the value is taken
    #                   from configured sources or the built-in default.
    #
    # Results:
    #   Returns false when delaying is disabled (and no wait occurs); otherwise
    #   returns true after the randomized delay has elapsed.
    # </help>

    if {[info exists ::no(NoDelayForTest)] || \
        [info exists ::env(NoDelayForTest)]} then {
      return false
    }

    if {[string length $milliseconds] == 0 && \
        [info exists ::tcltk_debugger(delayForTest)]} then {
      set milliseconds $::tcltk_debugger(delayForTest)
    }

    if {[string length $milliseconds] == 0 && \
        [info exists ::env(DelayForTest)]} then {
      set milliseconds $::env(DelayForTest)
    }

    if {[string length $milliseconds] == 0 && \
        [info exists ::test_timeout]} then {
      set milliseconds $::test_timeout
    }

    set defaultMilliseconds 2000

    if {[isTclTk]} then {
      if {[string is not integer -strict $milliseconds]} then {
        set milliseconds $defaultMilliseconds
      }
    } else {
      if {![string is integer -strict $milliseconds]} then {
        set milliseconds $defaultMilliseconds
      }
    }

    after [expr {$milliseconds + int(rand() * $defaultMilliseconds)}]
    return true
  }

  proc logRemoteTestResults {
          success {channel stdout} {verbose false} {quiet false} } {
    # <help>
    # This procedure reports the outcome of a completed test run to the remote
    # logging endpoint, sending a summary of the pass/fail/skip statistics
    # tagged with overall success or failure.  It is the standard way the test
    # suite publishes its results to the central log.
    #
    # How it works: inside an outer [catch], it builds a run header reflecting
    # the supplied success flag and gathers the basic and extra result detail
    # from [getRemoteTestResults].  It forms the primary message by combining
    # the header with the basic detail, optionally echoes it to the channel,
    # and sends it via [logRemoteMessageWrapper], invoking a tester hook on
    # success or failure and accumulating either the response or an
    # ERROR-tagged entry.  When extra detail is present and the
    # logExtraTestResults runtime option is enabled, it sends a second "EXTRA"
    # message the same way.  If only one response was collected, it is
    # unwrapped from the list.
    #
    # Tricky details: each send is individually guarded by [catch], and the
    # outer [catch] guarantees the procedure does not throw; it instead emits a
    # success or failure diagnostic (unless quiet).  Whether the extra message
    # is sent depends on both its presence and the runtime option.
    #
    # Arguments:
    #   success -- A boolean (or empty) indicating overall run outcome, used to
    #              prefix the header with SUCCESS or FAILURE; empty omits the
    #              prefix.
    #   channel -- The channel for echoed diagnostics (default stdout).
    #   verbose -- Boolean; when true, includes zero-valued and otherwise
    #              omitted statistics in the detail (default false).
    #   quiet   -- Boolean; when true, suppresses diagnostic echoing (default
    #              false).
    #
    # Results:
    #   The collected response(s) from the logging endpoint: a single value
    #   when one message was sent, or a list (each entry a server response or
    #   an ERROR-tagged entry) when more were sent.  On an overall failure it
    #   returns the captured error result.  The procedure does not raise.
    # </help>

    if {[catch {
      set header [getRemoteMessageHeader $success]
      set detail [getRemoteTestResults $verbose]

      set basicDetail [lindex $detail 0]
      set extraDetail [lindex $detail 1]

      set newMessage [appendArgs $header $basicDetail]

      if {!$quiet} then {
        tputs $channel [appendArgs \
            "---- test results: " $newMessage \n]
      }

      set responses [list]

      if {[catch {
        logRemoteMessageWrapper $newMessage
      } response] == 0} then {
        maybeInvokeForTester ::logRemoteMessageOk; # HOOK
        lappend responses $response
      } else {
        maybeInvokeForTester ::logRemoteMessageError; # HOOK
        lappend responses [list ERROR $response]
      }

      if {[string length $extraDetail] > 0 && \
          [hasRuntimeOption logExtraTestResults]} then {
        set newMessage [appendArgs "EXTRA " $header $extraDetail]

        if {!$quiet} then {
          tputs $channel [appendArgs \
              "---- extra test results: " $newMessage \n]
        }

        if {[catch {
          logRemoteMessageWrapper $newMessage
        } response] == 0} then {
          maybeInvokeForTester ::logRemoteMessageOk; # HOOK
          lappend responses $response
        } else {
          maybeInvokeForTester ::logRemoteMessageError; # HOOK
          lappend responses [list ERROR $response]
        }
      }

      if {[llength $responses] == 1} then {
        set responses [lindex $responses 0]
      }

      set responses
    } result] == 0} then {
      if {!$quiet} then {
        tputs $channel [appendArgs \
            "---- success logging remote test results: " \
            $result \n]
      }
    } else {
      if {!$quiet} then {
        tputs $channel [appendArgs \
            "---- failure logging remote test results: " \
            $result \n]
      }
    }

    return $result
  }

  proc logRemoteTestRunMessage {
          message {results false} {uri ""} {apiKey ""} {password ""}
          {channel stdout} {verbose false} {quiet false} } {
    # <help>
    # This procedure composes and sends an arbitrary free-form message about a
    # test run to the remote logging endpoint, optionally including the current
    # test result statistics.  It complements [logRemoteTestResults] (which
    # always reports outcomes) by letting callers attach a custom message,
    # tagged as a "MESSAGE" record on the server.
    #
    # How it works: inside an outer [catch], it builds a run header (with no
    # success/failure prefix), and, when the results flag is set, gathers the
    # basic and extra result detail from [getRemoteTestResults].  It forms the
    # primary message by combining the literal "MESSAGE", the header, the basic
    # detail, and the caller's message text, optionally echoing it to the
    # channel, then sends it via [logRemoteMessageWrapper] (forwarding the uri,
    # apiKey, password, channel, and quiet arguments).  Success or failure of
    # that send drives a tester hook and accumulates either the response or an
    # error marker.  When extra detail is present and the corresponding runtime
    # option is enabled, a second "EXTRA" message is built and sent the same
    # way.  If only one response was collected, it is unwrapped from the list.
    #
    # Tricky details: every send is individually wrapped in [catch] so a
    # failure to transmit one message is captured as an error entry rather than
    # aborting; the overall outer [catch] further ensures the procedure does
    # not throw, instead reporting success or failure as a diagnostic when not
    # quiet.  Whether the extra-detail message is sent depends on both its
    # presence and the logExtraTestRunMessage runtime option.
    #
    # Arguments:
    #   message  -- The free-form message text to log.
    #   results  -- Boolean; when true, current test result statistics are
    #               gathered and included (default false).
    #   uri      -- Optional logging endpoint URI; empty selects the default.
    #   apiKey   -- Optional API key; empty selects the default/fake key.
    #   password -- Optional signing password; empty selects the configured or
    #               fake password.
    #   channel  -- The channel for echoed diagnostics (default stdout).
    #   verbose  -- Boolean; when true, result detail includes zero-valued and
    #               otherwise-omitted statistics (default false).
    #   quiet    -- Boolean; when true, suppresses diagnostic echoing (default
    #               false).
    #
    # Results:
    #   The collected response(s) from the logging endpoint: a single response
    #   value when only one message was sent, or a list of responses (each
    #   either a server response or an ERROR-tagged entry) when more were sent.
    #   The procedure does not raise on transmission failure.
    # </help>

    if {[catch {
      set header [getRemoteMessageHeader ""]
      set detail [expr {$results ? [getRemoteTestResults $verbose] : [list]}]

      set basicDetail [lindex $detail 0]
      set extraDetail [lindex $detail 1]

      set newMessage [appendArgs \
          "MESSAGE " $header $basicDetail ": " $message]

      if {!$quiet} then {
        tputs $channel [appendArgs \
            "---- remote message: " $newMessage \n]
      }

      set responses [list]

      if {[catch {
        logRemoteMessageWrapper $newMessage \
            $uri $apiKey $password $channel $quiet
      } response] == 0} then {
        maybeInvokeForTester ::logRemoteMessageOk; # HOOK
        lappend responses $response
      } else {
        maybeInvokeForTester ::logRemoteMessageError; # HOOK
        lappend responses [list ERROR $response]
      }

      if {[string length $extraDetail] > 0 && \
          [hasRuntimeOption logExtraTestRunMessage]} then {
        set newMessage [appendArgs "EXTRA " $header $extraDetail]

        if {!$quiet} then {
          tputs $channel [appendArgs \
              "---- extra remote message: " $newMessage \n]
        }

        if {[catch {
          logRemoteMessageWrapper $newMessage \
              $uri $apiKey $password $channel $quiet
        } response] == 0} then {
          maybeInvokeForTester ::logRemoteMessageOk; # HOOK
          lappend responses $response
        } else {
          maybeInvokeForTester ::logRemoteMessageError; # HOOK
          lappend responses [list ERROR $response]
        }
      }

      if {[llength $responses] == 1} then {
        set responses [lindex $responses 0]
      }

      set responses
    } result] == 0} then {
      if {!$quiet} then {
        tputs $channel [appendArgs \
            "---- success logging remote test message: " \
            $result \n]
      }
    } else {
      if {!$quiet} then {
        tputs $channel [appendArgs \
            "---- failure logging remote test message: " \
            $result \n]
      }
    }

    return $result
  }

  proc compileCanaryDyLib { {errorVarName ""} } {
    # <help>
    # This procedure compiles a tiny "canary" dynamic library (a macOS dylib)
    # from a trivial C source file, returning the path of the built library on
    # success.  It exists so that tests which require a real native shared
    # library to load can produce one on demand using the system C compiler,
    # without shipping a prebuilt binary.
    #
    # How it works: it creates a per-process temporary target directory and
    # computes the target library path (libCanary.dylib) within it.  If the
    # target already exists, it refuses to proceed (since it cannot safely
    # claim ownership of a file it did not create) and records an explanatory
    # message in the optional error variable.  Otherwise it writes a minimal C
    # source file defining a single function and invokes clang with
    # -dynamiclib (optimized, with an @rpath install name) to build the
    # library.  On a successful compile it deletes the temporary source file
    # and returns the target library path.  On failure it cleans up any partial
    # target, the source file, and the target directory, and returns the empty
    # string.
    #
    # Tricky details: this relies on clang being available on the path and is
    # inherently macOS-oriented (it produces a .dylib with macOS-specific
    # linker flags).  The error variable, when requested, is populated with an
    # explanatory message for the already-exists precondition failure; it is
    # also written by the [catch] around the clang invocation (since the upvar
    # aliases it to the catch result variable), so on clang failure it holds
    # the clang error message and on a successful compile it holds the clang
    # output.  Failure is still primarily signaled by the empty-string return.
    # All cleanup deletions are wrapped in [catch] so housekeeping problems do
    # not mask the real outcome.
    #
    # Arguments:
    #   errorVarName -- Optional name, in the caller's frame, of a variable to
    #                   receive an explanatory message when the build cannot be
    #                   attempted because the target already exists.
    #
    # Results:
    #   On success, the full path of the freshly built dynamic library.  On
    #   failure, the empty string (with the error variable possibly set for the
    #   already-exists case).
    # </help>

    if {[string length $errorVarName] > 0} then {
      upvar 1 $errorVarName error
    }

    set targetPath [file join [getTemporaryPath] [appendArgs p [pid]]]
    file mkdir $targetPath

    set targetFileNameOnly libCanary.dylib
    set targetFileName [file join $targetPath $targetFileNameOnly]

    if {[file exists $targetFileName]} then {
      #
      # NOTE: The caller (probably) does not own the target (temporary)
      #       file name because it already exists; therefore, we cannot
      #       do anything "safely".
      #
      set error [appendArgs \
          "cannot compile, target file already exists: " $targetFileName]
    } else {
      set sourceFileName [appendArgs [getTemporaryFileName] .c]
      writeFile $sourceFileName {int canary_sing(void) {return 42;}}

      if {[catch {
        exec -- clang -dynamiclib -O2 -o $targetFileName $sourceFileName \
            [appendArgs -Wl,-install_name,@rpath/ $targetFileNameOnly]
      } error] == 0} then {
        if {[file exists $sourceFileName]} then {
          catch {file delete $sourceFileName}
        }

        return $targetFileName; # SUCCESS
      } else {
        if {[file exists $targetFileName]} then {
          catch {file delete $targetFileName}
        }

        if {[file exists $sourceFileName]} then {
          catch {file delete $sourceFileName}
        }

        if {[file exists $targetPath]} then {
          if {[isTclTk]} then {
            catch {file rmdir $targetPath}
          } else {
            catch {file delete $targetPath}
          }
        }
      }
    }

    return ""
  }

  if {[isTclTk]} then {
    ###########################################################################
    ############################ BEGIN TclTk ONLY #############################
    ###########################################################################

    proc initializeTests {} {
      # <help>
      # This procedure resets and primes the global state used to run the TclTk
      # test suite, so that a fresh run starts from known, consistent values.
      # It exists as the single place that establishes the test-tracking
      # counters, the lists of test-name patterns to match and skip, the active
      # constraint set, and the verbosity configuration before any tests
      # execute.
      #
      # How it works: all of its work is performed in the global frame (via
      # [uplevel] to frame zero) so the state it builds is globally visible.
      # It zeroes the counters in the tcltk_tests array (Total, Skipped,
      # Disabled, Passed, Failed) and, inside a [catch] for compatibility with
      # older builds, the corresponding "Bug" counters.  It then derives the
      # match-name and skip-name pattern lists from the test_flags array
      # (defaulting to matching all tests and skipping none), initializes the
      # SkippedNames and FailedNames lists to empty, and assembles the active
      # constraint list from a constraints environment variable plus any
      # constraints supplied via test flags.  Finally it resolves the
      # verbosity: it reads a verbosity environment variable (defaulting to
      # "Default"), and if a verbose test flag is present it maps the long
      # human-readable verbosity keywords to their single-letter abbreviations
      # and splits them into a list, storing the result as the Verbose entry.
      #
      # Tricky details: the "Bug" counters are wrapped in a [catch] because
      # they only exist in newer engine builds.  The interplay between
      # environment variables and test flags means flag-supplied constraints
      # are appended to (not replacing) the environment-derived constraints,
      # while the verbose flag, when present, overrides the environment value.
      #
      # Arguments:
      #   None.
      #
      # Results:
      #   No meaningful return value; the side effect is the (re)initialization
      #   of the global test-tracking and configuration state.
      # </help>

      uplevel #0 {
        #
        # NOTE: Reset the information in the global "tests" array, which is
        #       used to interface with the internal test tracking information
        #       in the interpreter via a variable trace.
        #
        set tcltk_tests(Total) 0

        set tcltk_tests(Skipped) 0
        set tcltk_tests(Disabled) 0
        set tcltk_tests(Passed) 0
        set tcltk_tests(Failed) 0

        #
        # HACK: These are only present in beta 47 or later; therefore, wrap
        #       them in a [catch] block.
        #
        catch {
          set tcltk_tests(SkippedBug) 0
          set tcltk_tests(DisabledBug) 0
          set tcltk_tests(PassedBug) 0
          set tcltk_tests(FailedBug) 0
        }

        #
        # NOTE: Setup the lists of patterns to match test names against.  In
        #       TclTk, these originate from the command line arguments and are
        #       passed to the interpreter via this virtual array.
        #
        if {[info exists test_flags(-match)]} then {
          set tcltk_tests(MatchNames) $test_flags(-match); # run these tests.
        } else {
          set tcltk_tests(MatchNames) [list *]; # default to running all tests.
        }

        if {[info exists test_flags(-skip)]} then {
          set tcltk_tests(SkipNames) $test_flags(-skip); # skip these tests.
        } else {
          set tcltk_tests(SkipNames) [list]; # default to skipping no tests.
        }

        #
        # NOTE: What tests have been skipped, if any?
        #
        set tcltk_tests(SkippedNames) [list]

        #
        # NOTE: What tests have failed, if any?
        #
        set tcltk_tests(FailedNames) [list]

        #
        # NOTE: Initialize the list of active test constraints from the
        #       environment variable and/or the test flags.
        #
        set tcltk_tests(Constraints) [getEnvironmentVariable testConstraints]

        if {[info exists test_flags(-constraints)]} then {
          eval lappend tcltk_tests(Constraints) $test_flags(-constraints)
        }

        unset -nocomplain test_verbose
        set test_verbose [getEnvironmentVariable testVerbose]

        if {[string length $test_verbose] == 0} then {
          set test_verbose Default
        }

        if {[info exists test_flags(-verbose)] && \
            [string length $test_flags(-verbose)] > 0} then {
          #
          # NOTE: Map all test verbosity flags we support for script usage
          #       to their abbreviated names (which are all one letter) and
          #       then split them into a list.
          #
          set test_verbose [split [string map [list \
              Body B Pass P Skip S Start T Error E Line L \
              Fail F Reason R Time I Exit X StdOut O StdErr D \
              Enter N Leave A Track G Hook H] \
              $test_flags(-verbose)] ""]
        }

        set tcltk_tests(Verbose) $test_verbose; unset test_verbose
      }
    }

    proc setupTestShims { setup {quiet false} } {
      # <help>
      # This procedure installs or removes a set of compatibility "shim"
      # commands that let tests written for the native Tcl "tcltest" package
      # run under TclTk.  It exists because TclTk provides equivalent testing
      # functionality built in, so the handful of tcltest entry points those
      # tests expect must be faked (when setting up) and cleaned away (when
      # tearing down).
      #
      # How it works: when the setup flag is true, it conditionally creates
      # each shim only if a command of that name does not already exist -- a
      # "testConstraint" alias and a "::tcltest::testConstraint" alias both
      # pointing at [haveOrAddConstraint], plus empty do-nothing procedures
      # ::tcltest::cleanupTests and ::tcltest::loadTestedCommands.  When the
      # setup flag is false, it reverses these, removing the two procedures
      # (via [rename] to the empty name) and clearing the two aliases, again
      # only when they are present.  Each successful add or remove optionally
      # reports a one-line diagnostic to the test channel.
      #
      # Tricky details: every step is guarded by an existence check so the
      # procedure is safe to call redundantly and so it never clobbers a real
      # command that happens to already be defined.  Diagnostics are suppressed
      # when quiet mode is requested.
      #
      # Arguments:
      #   setup -- Boolean selecting the direction: true installs the shims,
      #            false removes them.
      #   quiet -- Boolean; when false, each add/remove emits a diagnostic to
      #            the test channel (default false).
      #
      # Results:
      #   No meaningful return value; the side effect is the creation or
      #   removal of the compatibility shim commands and aliases.
      # </help>

      set channel [getTestChannelOrDefault]

      if {$setup} then {
        #
        # HACK: Compatibility shim(s) for use with various tests in the Tcl
        #       test suite.  Make sure these commands do not already exist
        #       prior to attempt to adding them.
        #
        if {[llength [info commands testConstraint]] == 0} then {
          interp alias {} testConstraint {} haveOrAddConstraint

          if {!$quiet} then {
            tqputs $channel \
                "---- added \"testConstraint\" alias\n"
          }
        }

        if {[llength [info commands ::tcltest::testConstraint]] == 0} then {
          interp alias {} ::tcltest::testConstraint {} haveOrAddConstraint

          if {!$quiet} then {
            tqputs $channel \
                "---- added \"::tcltest::testConstraint\" alias\n"
          }
        }

        #
        # NOTE: This is needed by most tests in the Tcl test suite.  Make
        #       sure this command does not already exist prior to adding it.
        #
        if {[llength [info commands ::tcltest::cleanupTests]] == 0} then {
          proc ::tcltest::cleanupTests { args } {
            # <help>
            # This procedure is a do-nothing compatibility shim for the native
            # Tcl "tcltest" command of the same name.  Many tests in the Tcl
            # test suite call it (typically at the end of a test file) to
            # finalize and report results; under TclTk that bookkeeping is
            # handled elsewhere, so this stub simply accepts and ignores any
            # arguments and does nothing.  It is installed only when no real
            # command by this name already exists, and is removed again when
            # the test shims are torn down.
            #
            # Arguments:
            #   args -- Any arguments are accepted and ignored.
            #
            # Results:
            #   None; this procedure performs no action and returns the empty
            #   string.
            # </help>
          }

          if {!$quiet} then {
            tqputs $channel \
                "---- added \"::tcltest::cleanupTests\" procedure\n"
          }
        }

        #
        # NOTE: This is needed by some tests in the Tcl test suite.  Make
        #       sure this command does not already exist prior to adding it.
        #
        if {[llength [info commands \
            ::tcltest::loadTestedCommands]] == 0} then {
          proc ::tcltest::loadTestedCommands { args } {
            # <help>
            # This procedure is a do-nothing compatibility shim for the native
            # Tcl "tcltest" command of the same name.  Some tests in the Tcl
            # test suite call it to load the commands under test from an
            # external library; under TclTk the tested functionality is
            # built in, so this stub simply accepts and ignores any arguments
            # and does nothing.  It is installed only when no real command by
            # this name already exists, and is removed again when the test
            # shims are torn down.
            #
            # Arguments:
            #   args -- Any arguments are accepted and ignored.
            #
            # Results:
            #   None; this procedure performs no action and returns the empty
            #   string.
            # </help>
          }

          if {!$quiet} then {
            tqputs $channel \
                "---- added \"::tcltest::loadTestedCommands\" procedure\n"
          }
        }
      } else {
        #
        # NOTE: Remove the compatibility shim command aliases that we setup
        #       earlier.
        #
        if {[llength [info commands \
            ::tcltest::loadTestedCommands]] > 0} then {
          rename ::tcltest::loadTestedCommands ""

          if {!$quiet} then {
            tqputs $channel \
                "---- removed \"::tcltest::loadTestedCommands\" procedure\n"
          }
        }

        if {[llength [info commands ::tcltest::cleanupTests]] > 0} then {
          rename ::tcltest::cleanupTests ""

          if {!$quiet} then {
            tqputs $channel \
                "---- removed \"::tcltest::cleanupTests\" procedure\n"
          }
        }

        if {[llength [interp aliases ::tcltest::testConstraint]] > 0} then {
          interp alias {} ::tcltest::testConstraint {} {}

          if {!$quiet} then {
            tqputs $channel \
                "---- removed \"::tcltest::testConstraint\" alias\n"
          }
        }

        if {[llength [interp aliases testConstraint]] > 0} then {
          interp alias {} testConstraint {} {}

          if {!$quiet} then {
            tqputs $channel \
                "---- removed \"testConstraint\" alias\n"
          }
        }
      }
    }

    proc findStringInFile { fileName string } {
      # <help>
      # This procedure searches the entire contents of a file for a literal
      # substring and reports the position of its last occurrence.  It is used
      # by the test harness to detect whether a particular marker string is
      # present somewhere in a (possibly large) log file.
      #
      # How it works: it reads the whole file into memory and then uses [string
      # last] to find the highest index at which the search string occurs.
      # Crucially, it does this inside a [try] with a [finally] block that
      # purges the in-memory file data and forces a garbage collection, so the
      # potentially large log contents are not retained any longer than
      # necessary.
      #
      # Tricky details: matching is a plain literal substring search (not glob
      # or regexp).  Because [string last] returns -1 when the substring is
      # absent, a non-negative result indicates the string was found; the
      # accompanying comment frames this as "non-zero if found", so callers
      # should treat any value other than -1 as a match.  The aggressive
      # cleanup in the finally block is a deliberate memory-management measure
      # for large files.
      #
      # Arguments:
      #   fileName -- The path of the file to read and search.
      #   string   -- The literal substring to look for within the file.
      #
      # Results:
      #   The index of the last occurrence of the substring, or -1 when it does
      #   not appear in the file.
      # </help>

      try {
        #
        # NOTE: Read all the file data into memory now.
        #
        set data [readFile $fileName]

        #
        # NOTE: Check for the string in the entire (log) file and return
        #       non-zero if found.
        #
        return [string last $string $data]
      } finally {
        #
        # NOTE: We do not want to hold all the log file data in memory;
        #       therefore, do our very best to remove it now.
        #
        unset -nocomplain -purge -- data; debug collect
      }
    }

    proc invokePackageScanCommand { {paths null} {strict false} } {
      # <help>
      # This procedure triggers a scan of the package search path so that
      # package index information is (re)discovered, by obtaining and evaluating
      # the engine-provided package-scan command.  It exists so test setup code
      # can ensure packages are visible, optionally restricting the scan to a
      # specific set of paths.
      #
      # How it works (TclTk only): it asks the engine Utility for the package
      # scan command, passing the supplied paths.  If a usable command object
      # is returned, its textual form is evaluated at the global level (uplevel
      # to frame zero) to perform the scan; otherwise the accompanying error
      # object is turned into an error message.  The whole sequence runs inside
      # a [catch]: on success it returns true; on failure it either raises an
      # error (when strict mode is requested) or returns false.
      #
      # Tricky details: the scan command is executed in the global frame so any
      # state it establishes is globally visible.  The strict flag converts
      # what would otherwise be a quiet false return into a raised error that
      # includes the underlying failure message.
      #
      # Arguments:
      #   paths  -- The set of paths to scan, or the null object (the default)
      #             to let the engine choose the default scan paths.
      #   strict -- Boolean; when true, a scan failure raises an error instead
      #             of returning false (default false).
      #
      # Results:
      #   Returns true when the scan command was obtained and evaluated
      #   successfully.  Returns false on failure when not strict; raises an
      #   error describing the failure when strict.
      # </help>

      if {[catch {
        set error null

        set command [object invoke \
            -create Utility GetPackageScanCommand "" null \
            $paths error]

        if {[isNonNullObjectHandle $command]} then {
          uplevel #0 [getStringFromObjectHandle $command]
        } else {
          error [getStringFromObjectHandle $error]
        }
      } result] == 0} then {
        return true
      } elseif {$strict} then {
        error [appendArgs "scan auto-path failed: " $result]
      } else {
        return false
      }
    }

    proc maybeAppendNewLine { varName } {
      # <help>
      # This procedure conditionally appends a newline character to a string
      # held in a caller variable, but only when the string is non-empty and
      # does not already begin with whitespace.  It exists as a small
      # formatting helper for building up multi-line diagnostic or report text.
      #
      # How it works: it links to the caller's variable with [upvar].  If the
      # variable exists and is non-empty, it inspects the character at index
      # zero; when that first character is not whitespace, it appends a newline
      # to the value and returns true.  In all other cases it leaves the value
      # unchanged and returns false.
      #
      # Tricky details: despite the name suggesting an end-of-string check, the
      # decision is based on the FIRST character of the value (index zero), not
      # the last.  The append is therefore gated on the leading character not
      # being whitespace.
      #
      # Arguments:
      #   varName -- The name, in the caller's frame, of the string variable to
      #              potentially modify.
      #
      # Results:
      #   Returns true when a newline was appended, false otherwise; the named
      #   caller variable is updated in place when a newline is appended.
      # </help>

      upvar 1 $varName value

      if {[info exists value] && [string length $value] > 0} then {
        set lastChar [string index $value 0]

        if {[string is not space -strict $lastChar]} then {
          append value \n
          return true
        }
      }

      return false
    }

    proc shouldWriteTestData { code } {
      # <help>
      # This procedure decides whether per-test diagnostic data should be
      # written, based on the completion code of a test and the engine's own
      # internal policy.  It exists so the test harness can suppress writing
      # data in cases the engine considers uninteresting while still defaulting
      # to writing it when in doubt.
      #
      # How it works (TclTk only): when the object command is available, it
      # consults the non-public TestOps.ShouldWriteTestData helper with the
      # supplied completion code.  If that call succeeds and indicates that the
      # engine itself intends to write the data, this procedure returns false
      # (meaning the caller need not do so).  In every other situation --
      # including when the object command is unavailable, the helper errors, or
      # the helper indicates the engine will not write the data -- it returns
      # true.
      #
      # Tricky details: the boolean sense is intentionally inverted relative to
      # the engine helper's name; a true engine result causes a false return
      # here.  The conservative default is true, so callers err on the side of
      # writing the data.
      #
      # Arguments:
      #   code -- The completion (return) code of the test being considered.
      #
      # Results:
      #   Returns true when the caller should write the test data, false when
      #   the engine has indicated it will handle that itself.
      # </help>

      if {[llength [info commands object]] > 0 && [catch {
        object invoke -flags +NonPublic \
            CodeBrix.Platform.TclTk._Components.Private.TestOps ShouldWriteTestData "" $code
      } writeTestData] == 0 && $writeTestData} then {
        return false
      }

      return true
    }

    proc probeForScriptFileName {
            {excludePatterns ""} {overridePatterns ""} } {
      # <help>
      # This procedure searches the interpreter's stack of active script
      # locations and returns the file name of the most appropriate currently
      # executing script.  It exists to let library code discover "which script
      # am I really running on behalf of" when the immediate caller is itself a
      # library helper, using caller-supplied glob patterns to steer the choice
      # toward (or away from) particular files.
      #
      # How it works (TclTk only, and only when the object command is
      # available): it obtains the active interpreter's script-location stack
      # and walks it from the top, normalizing each location's file name.  For
      # each non-empty file name, it first consults the override patterns: if
      # the file name matches one of them (using an inverse glob search), that
      # file name is returned immediately.  Otherwise, if there are no exclude
      # patterns or the file name does not match any of them, that file name is
      # returned.  If the walk finds nothing suitable, the empty string is
      # returned.
      #
      # Tricky details: the override patterns take precedence and act as an
      # allow-list that short-circuits the search, while the exclude patterns
      # act as a deny-list applied only when no override matched; both are
      # tested with an inverse glob search.  The whole body runs inside a
      # [catch] whose return code is accepted when it is normal completion or a
      # return, so an internal [return] from within the loop is honored; any
      # other failure yields the empty string.
      #
      # Arguments:
      #   excludePatterns  -- Optional list of glob patterns; script file names
      #                       matching any of these are skipped unless an
      #                       override matched.  Empty means exclude nothing.
      #   overridePatterns -- Optional list of glob patterns; the first script
      #                       file name matching any of these is returned
      #                       immediately, ignoring the exclude list.
      #
      # Results:
      #   The normalized file name of the selected script location, or the
      #   empty string when none is suitable or when probing is not possible.
      # </help>

      if {[llength [info commands object]] > 0 && [catch {
        set locations [object invoke -alias -flags +NonPublic \
            Interpreter.GetActive ScriptLocations]

        set count [$locations Count]

        for {set index 0} {$index < $count} {incr index} {
          set location [$locations -alias Peek $index]

          if {[isNonNullObjectHandle $location]} then {
            set locationFileName [file normalize [$location FileName]]

            if {[string length $locationFileName] > 0} then {
              if {[llength $overridePatterns] > 0 && \
                  [lsearch -inverse -glob \
                      $overridePatterns $locationFileName] != -1} then {
                return $locationFileName
              }

              if {[llength $excludePatterns] == 0 || \
                  [lsearch -inverse -glob \
                      $excludePatterns $locationFileName] == -1} then {
                return $locationFileName
              }
            }
          }
        }

        return ""
      } result] in [list 0 2]} then {
        return $result
      }

      return ""
    }

    proc getPidFromTestLogFileName { fileName baseFileNameOnly } {
      # <help>
      # This procedure extracts the originating process id that is encoded in a
      # test log file name.  It exists to support the log cleanup helpers,
      # which need to know which process produced a given log file so they can
      # tell whether that process is still running.
      #
      # How it works: it builds a regular expression from the suite's base file
      # name, escaping the literal periods and turning any asterisk in the base
      # name into a non-greedy wildcard, and requiring the name to end with
      # ".test.<digits>.log" preceded by a path separator (slash or backslash).
      # It then matches that pattern against the full file name, capturing the
      # digit run as the process id, and returns it only if it is a valid
      # integer.
      #
      # Tricky details: the regexp uses a path-separator anchor so the base
      # name portion is matched against the file's own segment; the capture is
      # validated as a strict integer before being returned, guarding against
      # malformed names.
      #
      # Arguments:
      #   fileName         -- The full test log file name to parse.
      #   baseFileNameOnly -- The suite base file name expected to precede the
      #                       ".test.<pid>.log" suffix; may contain an asterisk
      #                       used as a wildcard.
      #
      # Results:
      #   The extracted process id as a string when the file name matches and
      #   yields a valid integer; otherwise the empty string.
      # </help>

      set pattern [appendArgs \
          {[/\\]} [string map [list . \\. * (?:.*?)?] \
          $baseFileNameOnly] {\.test\.(\d+)\.log$}]

      if {[regexp -skip 1 -- $pattern $fileName pid] && \
          [string is integer -strict $pid]} then {
        return $pid
      } else {
        return ""
      }
    }

    proc isActiveProcess { pid {default true} } {
      # <help>
      # This procedure reports whether a process with the given numeric id is
      # currently running.  It is used by the test log cleanup helpers to
      # decide whether log files belonging to a particular process are stale
      # and safe to remove.
      #
      # How it works: it attempts to obtain a managed Process object for the id
      # via System.Diagnostics.Process.GetProcessById.  If that lookup fails
      # (for example because no such process exists), the process is treated as
      # not active and false is returned.  Otherwise it refreshes the process
      # state and queries whether it has exited; if either of those operations
      # fails, the supplied default is returned.  When the process reports that
      # it has exited, false is returned; otherwise true.
      #
      # Tricky details: the default argument controls the answer only for the
      # ambiguous middle case where the process object was obtained but its
      # exit state could not be determined; it does not affect the
      # process-not-found case (always false) or a clear exited/running answer.
      #
      # Arguments:
      #   pid     -- The numeric process id to test.
      #   default -- The boolean result to return when the process exists but
      #              its exit state cannot be determined (default true).
      #
      # Results:
      #   Returns true when the process appears to be running, false when it is
      #   absent or has exited, and the supplied default when its state is
      #   indeterminate.
      # </help>

      if {[catch {
        object invoke -alias \
            System.Diagnostics.Process GetProcessById $pid
      } process]} then {
        return false
      }

      if {[catch {$process Refresh}] || \
          [catch {$process HasExited} exited]} then {
        return $default
      }

      if {[string is true -strict $exited]} then {
        return false
      }

      return true
    }

    #
    # WARNING: This procedure is ONLY intended to be used via the
    #          "clean.bat" batch tool.
    #
    proc checkActiveTestLogFile { baseFileNameOnly fileName } {
      # <help>
      # This procedure checks whether a single test log file belongs to a
      # process that is no longer running, emitting a marker on standard output
      # when it does.  As the preceding warning comment notes, it is intended
      # solely for use by the "clean.bat" batch tool, which consumes that
      # marker to decide whether the log file is safe to delete.
      #
      # How it works: it extracts the originating process id encoded in the log
      # file name (using [getPidFromTestLogFileName] together with the suite's
      # base file name).  If a valid id is found and [isActiveProcess] reports
      # that the process is not running, it writes the single character "1" to
      # standard output as the signal the batch tool expects.
      #
      # Tricky details: the output is deliberately minimal and is the
      # procedure's only externally meaningful effect; the contract is shared
      # with "clean.bat" and should not be changed casually.  When the file
      # name does not encode a usable process id, or the process is still
      # active, nothing is emitted.
      #
      # Arguments:
      #   baseFileNameOnly -- The base log file name (without the
      #                       ".test.<pid>.log" suffix) used to parse the
      #                       process id out of the file name.
      #   fileName         -- The full test log file name to examine.
      #
      # Results:
      #   No meaningful return value; writes "1" to standard output as a side
      #   effect when the associated process is inactive.
      # </help>

      set pid [getPidFromTestLogFileName $fileName $baseFileNameOnly]

      if {[string length $pid] > 0 && ![isActiveProcess $pid]} then {
        puts stdout 1; # NOTE: Output needed by "clean.bat"
      }
    }

    proc deleteInactiveTestLogFiles { baseDirectory baseFileNameOnly } {
      # <help>
      # This procedure cleans up test log files left behind by test-suite
      # processes that are no longer running.  It is the bulk-cleanup
      # counterpart to [checkActiveTestLogFile], typically driven by external
      # housekeeping tooling, and it removes both the stale log files and any
      # now-empty dated directories that contained them.
      #
      # How it works: starting from a base directory, it recursively finds all
      # files matching the per-suite log naming pattern (the base file name
      # followed by ".test.<pid>.log"), processing them in reverse-sorted
      # order.  For each file it extracts the originating process id with
      # [getPidFromTestLogFileName]; if that id is valid and its process is not
      # active (per [isActiveProcess]), it attempts to delete the file and
      # records it as deleted.  After deleting a file, if its containing
      # directory is distinct from the base directory and is named like an
      # ISO date (four digits, two digits, two digits separated by hyphens), it
      # tries to remove that directory and records it when successful.
      # Finally, it attempts to remove a "logs" subdirectory beneath the base
      # directory if it exists and is empty.
      #
      # Tricky details: deletions and directory removals are guarded so that
      # failures do not abort the sweep; a failure to delete an individual log
      # file is reported as a diagnostic to the test channel and processing
      # continues.  Only directories whose names match the strict date pattern
      # are eligible for removal, protecting unrelated directories.
      #
      # Arguments:
      #   baseDirectory    -- The root directory to search recursively for
      #                       matching test log files.
      #   baseFileNameOnly -- The base log file name (without the
      #                       ".test.<pid>.log" suffix) identifying the suite
      #                       whose logs should be considered.
      #
      # Results:
      #   A list of the file and directory paths that were deleted or removed
      #   during the sweep, in the order they were processed.
      # </help>

      set result [list]
      set channel [getTestChannelOrDefault]

      foreach fileName [lsort -decreasing [findFilesRecursive [file join \
          $baseDirectory [appendArgs $baseFileNameOnly .test.*.log]]]] {
        set pid [getPidFromTestLogFileName $fileName $baseFileNameOnly]

        if {[string length $pid] > 0 && ![isActiveProcess $pid]} then {
          if {[catch {file delete $fileName} error] == 0} then {
            lappend result $fileName; # deleted
            set directory [file dirname $fileName]

            if {![file same $directory $baseDirectory] && [regexp -- \
                {^\d{4}-\d{2}-\d{2}$} [file tail $directory]] && [catch {
              file rmdir $directory
            }] == 0} then {
              lappend result $directory; # removed
            }
          } else {
            #
            # TODO: Is this actually valid to use here?
            #
            tputs $channel [appendArgs \
                "---- inactive test log cleanup error: " $error \n]
          }
        }
      }

      set directory [file normalize [file join $baseDirectory logs]]

      if {[file isdirectory $directory] && [catch {
        file rmdir $directory
      }] == 0} then {
        lappend result $directory; # removed
      }

      return $result
    }

    proc isNetFx40 {} {
      # <help>
      # This procedure reports whether the .NET runtime currently hosting
      # TclTk is at least version 4.0 of the .NET Framework (the 4.0 RTM
      # release or later).  It exists to gate behavior or test constraints
      # that depend on features introduced in that runtime generation.
      #
      # How it works: it reads the detected framework version from the
      # global platform information array.  If that value is unavailable
      # it conservatively returns false.  Otherwise it compares the
      # detected version against the .NET Framework 4.0 RTM+ identifier
      # 4.0.30319.0 using package version comparison rules, returning true
      # when the detected version is greater than or equal to it.
      #
      # Tricky details: the sentinel constant 4.0.30319.0 is the lowest
      # possible value within the v4.0.30319 RTM+ that Microsoft
      # documents for every .NET Framework 4.x release (the family
      # identifier itself, with the build component set to zero).
      # Microsoft does not publish a single canonical build component
      # for the original 4.0 RTM, only the family form v4.0.30319 and
      # the constraint that the build component is less than 42000 for
      # 4.0 through 4.5.2 and exactly 42000 for 4.6 and later.  Using
      # 4.0.30319.0 as the lower bound therefore correctly accepts every
      # real 4.x build (whatever its true build component) and rejects
      # earlier runtimes such as 2.0.50727.x.
      #
      # Arguments:
      #   None.
      #
      # Results:
      #   Returns true when the hosting framework version is .NET
      #   Framework 4.0 RTM or newer, false otherwise (including when
      #   the framework version is unknown).
      # </help>

      if {![info exists ::tcltk_platform(frameworkVersion)]} then {
        return false
      }

      set haveVersion $::tcltk_platform(frameworkVersion)
      set wantVersion 4.0.30319.0; # .NET Framework 4.0 RTM+

      if {[package vcompare $haveVersion $wantVersion] >= 0} then {
        return true
      } else {
        return false
      }
    }

    proc createMultipartFormData {
            request {fileName ""} {boundaryVarName ""} } {
      # <help>
      # This procedure assembles an HTTP request body in the
      # "multipart/form-data" format (per RFC 2388), combining a set of named
      # form fields and, optionally, a single uploaded file.  It exists so that
      # tests can construct realistic file-upload request payloads, returning
      # the result as a managed String object suitable for use with the
      # networking commands.
      #
      # How it works: it first generates a random boundary token by Base-64
      # encoding fifty random characters and stripping the plus, slash, and
      # equals characters so the token is safe to use as a delimiter; this
      # token is also reported back through the optional boundary variable.  It
      # then iterates over the request dictionary (treated as alternating field
      # name and value pairs), emitting for each one a boundary line followed
      # by a Content-Disposition header naming the field and then the field
      # value, with the carriage-return/line-feed separators the format
      # requires.  If a file name is supplied, it appends an additional part
      # whose Content-Disposition includes the file's base name, declares an
      # octet-stream content type, and embeds the file's contents (read via the
      # shared-file reader).  When any parts were written, a closing boundary
      # is appended.
      #
      # Tricky details: line endings are explicit carriage-return/line-feed
      # pairs as mandated by the format.  The request argument must contain an
      # even number of elements so it can be consumed as name/value pairs.  The
      # result is wrapped in a String object created with a no-return-reference
      # object flag so it behaves as a plain string value.
      #
      # Arguments:
      #   request         -- A dictionary (even-length list) of form field
      #                      names and their values, each becoming one form-data
      #                      part.
      #   fileName        -- Optional path to a file to include as a file-upload
      #                      part; when empty (the default), no file part is
      #                      added.
      #   boundaryVarName -- Optional name, in the caller's frame, of a variable
      #                      that receives the generated boundary token.
      #
      # Results:
      #   A String object containing the complete multipart/form-data body.  If
      #   no fields and no file were provided, the body is empty (no closing
      #   boundary is emitted).
      # </help>

      #
      # FIXME: This needs to create textual data that conforms to the
      #        content type "multipart/form-data", per RFC 2388.
      #
      if {[string length $boundaryVarName] > 0} then {
        upvar 1 $boundaryVarName boundary
      }

      set boundary [string map \
          [list + "" / "" = ""] [base64 encode [expr {randstr(50)}]]]

      set result ""

      foreach {name value} $request {
        append result -- $boundary \r\n
        append result "Content-Disposition: form-data; name=\""
        append result $name \"\r\n\r\n
        append result $value \r\n
      }

      if {[string length $fileName] > 0} then {
        append result -- $boundary \r\n

        append result \
            "Content-Disposition: form-data; name=\"file\"; filename=\""

        append result [file tail $fileName] \"\r\n
        append result "Content-Type: application/octet-stream\r\n"
        # append result "Content-Transfer-Encoding: binary\r\n"
        append result \r\n
        append result [readSharedFile $fileName] \r\n
      }

      if {[string length $result] > 0} then {
        append result -- $boundary --\r\n
      }

      return [object create \
          -alias -objectflags +NoReturnReference String $result]
    }

    proc tcltk_haveShell { {varName ""} } {
      # <help>
      # This procedure determines whether an operating system command shell is
      # available and, optionally, reports its path to the caller.  It is used
      # by the shell [unknown] machinery to decide whether unknown commands can
      # be dispatched to a real shell, and to learn which shell to use.
      #
      # How it works: on Windows it looks for the ComSpec environment variable
      # (typically the path to cmd.exe); on other platforms it looks for the
      # SHELL environment variable.  If the relevant variable exists, its value
      # is stored into the optional caller variable and the procedure returns
      # true; otherwise it returns false.  Tester hooks are invoked before the
      # check, after a successful detection, and on the error (not-found) path.
      #
      # Arguments:
      #   varName -- Optional.  The name, in the caller's frame, of a variable
      #              that receives the detected shell path when a shell is
      #              found.  When empty (the default), no variable is set and
      #              only the boolean result is meaningful.
      #
      # Results:
      #   Returns true when a usable shell is found (and, if requested, sets the
      #   named variable to its path), false otherwise.
      # </help>

      if {[string length $varName] > 0} then {
        upvar 1 $varName shell
      }

      maybeInvokeForTester ::beforeHaveShell; # HOOK

      if {[isWindows]} then {
        if {[info exists ::env(ComSpec)]} then {
          set shell $::env(ComSpec)
          maybeInvokeForTester ::afterHaveShell; # HOOK
          return true
        }
      } else {
        if {[info exists ::env(SHELL)]} then {
          set shell $::env(SHELL)
          maybeInvokeForTester ::afterHaveShell; # HOOK
          return true
        }
      }

      maybeInvokeForTester ::haveShellError; # HOOK
      return false
    }

    proc tcltk_enableShellUnknown { {enable ""} {quiet false} } {
      # <help>
      # This procedure enables, disables, or queries the "shell [unknown]"
      # feature, which lets unknown command names typed at the interactive
      # prompt be run as external operating system shell commands.  It works by
      # swapping the standard global [unknown] procedure with the custom
      # [tcltk_shellUnknown] handler (and back again), preserving the original
      # under the name ::savedUnknown.  It exists as the single supported way
      # to toggle this behavior and to report whether it is currently in
      # effect.
      #
      # How it works: to enable, it verifies that the global [unknown] exists,
      # that no ::savedUnknown already exists (so the feature is not already
      # on), and that [tcltk_shellUnknown] is present; it then renames
      # ::unknown to ::savedUnknown and renames ::tcltk_shellUnknown into
      # ::unknown, records the shellUnknown_IsEnabled runtime option, and
      # returns true.  To disable, it performs the inverse renames (restoring
      # ::savedUnknown back to ::unknown and ::unknown back to
      # ::tcltk_shellUnknown), removes the runtime option, and returns true.
      # When called with no enable argument, it simply reports whether the
      # feature is currently enabled by checking for the expected combination
      # of command names.
      #
      # Tricky details: the rename operations only proceed when the full
      # expected set of preconditions holds, so a redundant enable or disable
      # is a no-op that returns false.  Successful state changes optionally
      # emit a diagnostic to the test channel unless quiet mode is requested.
      #
      # Arguments:
      #   enable -- A boolean selecting the action: a true value enables the
      #             feature, a false value disables it, and an empty string
      #             (the default) queries the current state without changing
      #             it.
      #   quiet  -- Boolean; when false, state changes emit a diagnostic to the
      #             test channel (default false).
      #
      # Results:
      #   When changing state, returns true if the change was actually applied
      #   and false if the preconditions were not met.  When querying (empty
      #   enable), returns true if the feature is currently enabled and false
      #   otherwise.
      # </help>

      if {[string length $enable] > 0} then {
        if {$enable} then {
          if {[llength [info commands ::unknown]] > 0 && \
              [llength [info commands ::savedUnknown]] == 0 && \
              [llength [info commands ::tcltk_shellUnknown]] > 0} then {
            rename ::unknown ::savedUnknown
            rename ::tcltk_shellUnknown ::unknown

            if {!$quiet} then {
              tputs [getTestChannelOrDefault] \
                  "---- enabled shell \[unknown\] handler\n"
            }

            addRuntimeOption shellUnknown_IsEnabled
            return true
          }
        } else {
          if {[llength [info commands ::unknown]] > 0 && \
              [llength [info commands ::savedUnknown]] > 0 && \
              [llength [info commands ::tcltk_shellUnknown]] == 0} then {
            rename ::unknown ::tcltk_shellUnknown
            rename ::savedUnknown ::unknown

            if {!$quiet} then {
              tputs [getTestChannelOrDefault] \
                  "---- disabled shell \[unknown\] handler\n"
            }

            removeRuntimeOption shellUnknown_IsEnabled
            return true
          }
        }
      } else {
        if {[llength [info commands ::unknown]] > 0 && \
            [llength [info commands ::savedUnknown]] > 0 && \
            [llength [info commands ::tcltk_shellUnknown]] == 0} then {
          return true
        }
      }

      return false
    }

    proc tcltk_isShellScriptLevel { {extraLevels 0} {quiet false} } {; # +1
      # <help>
      # This procedure determines whether the current command is executing at
      # the script nesting level that corresponds to a top-level interactive
      # shell line, as opposed to being nested inside some other evaluated
      # script.  It exists so that the shell [unknown] handler can confine its
      # "treat this as an external command" behavior to genuine interactive
      # prompt input and avoid hijacking command resolution that happens deep
      # inside procedures, [eval]ed scripts, or sourced files.
      #
      # How it works (TclTk only, and only when the object command is
      # available): it reads two non-public counters from the active
      # interpreter -- the total number of script evaluation levels and the
      # number of interactive script levels.  It then computes the expected
      # total as a fixed base of four levels (the levels always consumed by the
      # call chain through this procedure, documented in detail in the block
      # comment that follows) plus the interactive level count plus any caller
      # supplied extra levels.  If the actual total equals that expected total,
      # the current context is considered the interactive shell level.
      #
      # Tricky details: the fixed base of four is extremely sensitive to the
      # exact call structure between the interactive loop and this procedure;
      # the long block comment below enumerates each frame.  Callers that
      # introduce additional intervening frames (such as [tcltk_shellUnknown],
      # which passes three) must compensate via the extraLevels argument.  When
      # the counts do not match and quiet mode is off, a diagnostic showing the
      # two values is emitted to the test channel.  Any failure to read the
      # counters, or the absence of the object command, results in a false
      # return.
      #
      # Arguments:
      #   extraLevels -- An integer adjustment added to the expected level
      #                  count to account for additional frames between the
      #                  interactive loop and this call (default zero).
      #   quiet       -- Boolean; when false, a mismatch emits a diagnostic
      #                  message to the test channel (default false).
      #
      # Results:
      #   Returns true when the current script level matches the computed
      #   interactive shell level, false otherwise.
      # </help>

      #
      # NOTE: There are typically five levels of nested "scripts"
      #       at the point this procedure is called, as follows:
      #
      #       0 ==> 1: The EvaluateScript() from InteractiveLoop().
      #
      #       1 ==> 2: The [unknown] procedure (a.k.a. hooked by
      #                the [tcltk_shellUnknown] procedure), which
      #                is typically called from within the Engine
      #                unknown command handler; however, it should
      #                be noted that this does NOT cause a(nother)
      #                nested script evaluation as the resulting
      #                IExecute is merely substituted (via prefix)
      #                inline within the script engine itself, see
      #                ExecuteArguments().
      #
      #       2 ==> 3: The first [if] command block within the
      #                [tcltk_shellUnknown] procedure.
      #
      ##############################################################
      #
      #       3 ==> 4: The [tcltk_isShellScriptLevel] procedure.
      #
      #       4 ==> 5: The first [if] command block, below.
      #
      #       5 ==> 6: The second [if] command block, below.
      #
      #       6 ==> 7: The first [catch] command block, below.
      #
      #       Clearly, the above four levels are entered by simply
      #       executing this procedure body.  All the remaining
      #       script levels, if any (?), would be entered by code
      #       that is external to this procedure, e.g. from within
      #       the interactive loop, et al.
      #
      if {[llength [info commands object]] > 0} then {; # +1
        if {[catch {; # +1
          object invoke -flags +NonPublic \
              Interpreter.GetActive ScriptLevels; # 7 (?)
        } levels(0)] == 0 && [catch {
          object invoke -flags +NonPublic \
              Interpreter.GetActive InteractiveScriptLevels
        } levels(1)] == 0} then {; # +1
          #
          # NOTE: This is the number of script levels that are
          #       always used by this procedure (please see the
          #       block comment above).  As of June 2025, this
          #       value should be four.
          #
          set levels(thisProcedure) 4

          set levels(2) [expr {
            $levels(thisProcedure) + $levels(1) + $extraLevels
          }]

          if {$levels(0) == $levels(2)} then {
            return true
          } else {
            if {!$quiet} then {
              tputs [getTestChannelOrDefault] [appendArgs \
                  "---- mismatched shell script levels: " \
                  $levels(0) " versus " $levels(2) \n]
            }
          }
        }
      }

      return false
    }

    proc tcltk_appendExecArgs { viaShell varName args } {
      # <help>
      # This procedure appends a set of arguments, with appropriate quoting and
      # escaping, onto a command list being assembled in a caller variable.  It
      # exists to help build [exec] command lines for the shell [unknown]
      # machinery, handling the two cases of appending the arguments directly
      # versus wrapping them so they run through a POSIX shell via its "-c"
      # option.
      #
      # How it works: it links to the caller's command variable with [upvar],
      # then processes each incoming argument by escaping embedded backslashes
      # and double quotes; any argument containing whitespace, a double quote,
      # or a backslash is additionally wrapped in double quotes.  When the
      # via-shell flag is true, all of the (escaped) arguments are joined with
      # spaces into one shell command string, single quotes within it are
      # escaped by the standard close-escape-reopen idiom, the whole thing is
      # wrapped in single quotes, and a single element of the form invoking the
      # SHELL environment variable with "-c" and that quoted command is
      # appended.  When the flag is false, the escaped arguments are appended to
      # the command individually.
      #
      # Tricky details: the procedure mutates the caller's command list in
      # place (through [upvar]) and returns nothing meaningful; the result of
      # the final [lappend]/[eval lappend] is incidental.  The via-shell branch
      # assumes a POSIX-style shell is named by the SHELL environment variable.
      #
      # Arguments:
      #   viaShell -- Boolean.  When true, the arguments are bundled into a
      #               single shell command run via the SHELL environment
      #               variable and its "-c" option; when false, they are
      #               appended to the command directly.
      #   varName  -- The name, in the caller's frame, of the command list
      #               variable to append to.
      #   args     -- Zero or more arguments to escape, quote as needed, and
      #               append.
      #
      # Results:
      #   No meaningful return value; the named caller variable is updated in
      #   place.
      # </help>

      upvar 1 $varName command

      set newArgs [list]

      foreach arg $args {
        set arg [string map [list \\ \\\\ \" \\\"] $arg]

        if {[regexp -- {[\s\"\\]} $arg]} then {
          lappend newArgs [appendArgs \" $arg \"]
        } else {
          lappend newArgs $arg
        }
      }

      if {$viaShell} then {
        set shellCommand [join $newArgs " "]
        set shellCommand [string map [list ' '\\''] $shellCommand]
        set shellCommand [appendArgs ' $shellCommand ']

        lappend command [appendArgs \
            \" $::env(SHELL) " -c " $shellCommand \"]
      } else {
        eval lappend command $newArgs
      }
    }

    proc tcltk_shellBuildCommand { shell name args } {
      # <help>
      # This procedure builds the [exec]-based command list used by the shell
      # [unknown] handler ([tcltk_shellUnknown]) to run an external command
      # name through a particular operating system shell.  It centralizes all
      # of the platform-, shell-, and option-specific quirks involved in
      # invoking a command via "cmd.exe", a POSIX shell such as "/bin/bash", or
      # PowerShell, so that the rest of the machinery can stay simple.  It
      # exists because the correct invocation differs substantially across
      # shells (argument quoting, the command-introducing switch, whether all
      # arguments must be joined into one string, single-quote escaping, and so
      # on).
      #
      # How it works: it starts an [exec] command prefix with the -nocapture
      # option and then conditionally appends a series of [exec] options driven
      # by the active runtime options and the platform -- for example
      # -commandline (Windows argv parsing), -dequote, -quoteall, -success,
      # -directory (the current working directory), -trace, and -forprocessor.
      # It classifies the requested shell by examining the tail of its path:
      # whether it is cmd.exe (or a clone such as 4nt.exe or tcc.exe) and
      # whether it is PowerShell (PowerShell, PowerShell.exe, pwsh, or
      # pwsh.exe).  On Windows it normally appends the shell and the
      # appropriate command switch ("/C" for cmd.exe-style shells, "-Command"
      # for PowerShell); on non-Windows systems the structure is simpler and
      # typically adds the shell followed by "-c".  Finally it appends the
      # command name and its arguments, either as separate list elements or,
      # for shells that require it (notably PowerShell), joined into a single
      # argument string.  Many named tester hooks are invoked at each stage so
      # the test suite can observe or alter the construction.
      #
      # Tricky details: numerous runtime options (queried via
      # [hasRuntimeOption]) force or suppress specific behaviors, including
      # forcing the command-line parser, forcing or skipping the shell, forcing
      # the "/C" or "-Command" switch, forcing single-quote wrapping, and
      # forcing the command processor.  When PowerShell-style invocation is
      # selected, the command and its arguments are joined into one argument
      # and, when single-quote handling is enabled, embedded single quotes are
      # escaped by the close-escape-reopen idiom and the whole string is
      # wrapped in single quotes -- this is what allows constructs like running
      # PowerShell underneath a POSIX shell.  As a special case, a
      # pre-configured command prefix may be supplied through an TclTk debugger
      # variable; it must be a valid list, and if it is not, command building
      # is abandoned and the empty list is returned (signaling the caller to
      # skip shell execution).
      #
      # Arguments:
      #   shell -- The full path (or name) of the operating system shell to
      #            invoke, e.g. the value of the ComSpec or SHELL environment
      #            variable.
      #   name  -- The command name to run within that shell, e.g. DIR or
      #            Get-Process.
      #   args  -- Zero or more arguments to pass to that command.
      #
      # Results:
      #   A list representing the [exec] command (including options, the shell,
      #   the command-introducing switch, and the command with its arguments)
      #   ready to be evaluated.  The empty list is returned when a configured
      #   command prefix is present but malformed, indicating that no shell
      #   command should be run.
      # </help>

      set result [list]

      maybeInvokeForTester ::initialShellBuildCommand; # HOOK

      lappend result exec -nocapture

      if {[hasRuntimeOption shellUnknown_ForceCommandLine] || \
          [isWindows]} then {
        lappend result -commandline; # CommandLineToArgvW
      }

      if {[hasRuntimeOption shellUnknown_ForceDequote]} then {
        lappend result -dequote; # "<arg1>" ==> <arg1>
      }

      if {[hasRuntimeOption shellUnknown_ForceQuoteAll]} then {
        lappend result -quoteall; # cmd "<arg1>" ... "<argN>"
      }

      lappend result -success Success -directory [pwd]

      if {[hasRuntimeOption shellUnknown_EmitTrace]} then {
        lappend result -trace
      }

      set shellOnly [file tail $shell]

      if {[string match -nocase *cmd.exe $shellOnly]} then {
        set isCmdDotExe true
      } else {
        set isCmdDotExe false
      }

      if {[string match -nocase PowerShell $shellOnly] || \
          [string match -nocase PowerShell.exe $shellOnly] || \
          [string match -nocase pwsh $shellOnly] || \
          [string match -nocase pwsh.exe $shellOnly]} then {
        set isPowerShell true
      } else {
        set isPowerShell false
      }

      if {[hasRuntimeOption shellUnknown_ForceCommandProcessor]} then {
        set forProcessor true
      } elseif {$isCmdDotExe && \
          ![hasRuntimeOption shellUnknown_NoCommandProcessor]} then {
        set forProcessor true
      } else {
        set forProcessor false
      }

      if {$forProcessor} then {
        lappend result -forprocessor
      }

      maybeInvokeForTester ::optionsShellBuildCommand; # HOOK

      lappend result --

      if {([isWindows] && \
           ![hasRuntimeOption shellUnknown_NoShell]) || \
          [hasRuntimeOption shellUnknown_ForceShell]} then {
        lappend result $shell; # "cmd.exe" -OR- "/bin/bash", etc.

        if {(![isWindows] && \
             ![hasRuntimeOption shellUnknown_NoDashC]) || \
            [hasRuntimeOption shellUnknown_DashC]} then {
          lappend result -c; # Bash single command string.
        }
      }

      #
      # HACK: By default, append all command arguments as their
      #       own elements.  In some cases, e.g. PowerShell, we
      #       must combine all these elements into one argument
      #       prior to shell command execution.
      #
      set oneArgument false

      #
      # HACK: By default, single quotes are basically ignored.
      #       In some cases, e.g. PowerShell, we must wrap the
      #       resulting shell command in single quotes as well
      #       as escape embedded single quotes by doubling them
      #       up.
      #
      set singleQuote false

      maybeInvokeForTester ::beforeShellBuildCommand; # HOOK

      if {![info exists ::no(windowsShellBuildCommand)] && \
          [isWindows]} then {; # NOTE: Non-Windows is simpler.
        #
        # HACK: Generally, we want to use the "/C" option when
        #       using "cmd.exe" -OR- any of its various clones
        #       on Windows.  Alternatively, for PowerShell, we
        #       (apparently?) want to use a "-Command" prefix.
        #
        if {[hasRuntimeOption shellUnknown_ForceSlashC] || \
            $isCmdDotExe || \
            [string match -nocase 4nt.exe $shellOnly] || \
            [string match -nocase tcc.exe $shellOnly]} then {
          lappend result /C; # cmd.exe /C
        } elseif {[hasRuntimeOption shellUnknown_ForceDashCommand] || \
            $isPowerShell} then {
          set oneArgument true; # PowerShell.exe -Command <script>

          if {[hasRuntimeOption shellUnknown_ForceSingleQuote]} then {
            set singleQuote true; # Escape by doubling single quotes?
          }

          lappend result -Command; # PowerShell.exe -Command
        } elseif {[info exists \
            ::tcltk_debugger(shellUnknownCommandPrefix)]} then {
          #
          # HACK: Attempt to use the (pre-)configured shell command
          #       prefix, which MUST be a properly formatted list.
          #
          set prefix $::tcltk_debugger(shellUnknownCommandPrefix)

          if {[string is list -strict $prefix]} then {
            eval lappend result $prefix; # ??
          } else {
            set result [list]

            maybeInvokeForTester ::shellBuildCommandError; # HOOK

            return $result
          }
        }
      } else {
        if {[hasRuntimeOption shellUnknown_ForceDashCommand] || \
            $isPowerShell} then {
          set oneArgument true; # PowerShell -Command <script>

          if {![hasRuntimeOption shellUnknown_NoSingleQuote]} then {
            set singleQuote true; # Escape by doubling single quotes?
          }

          lappend result -Command; # PowerShell -Command
        }
      }

      maybeInvokeForTester ::afterShellBuildCommand; # HOOK

      if {$oneArgument} then {
        set subResult [list]

        lappend subResult $name; # e.g. Get-Process
        eval lappend subResult $args; # e.g. Win*

        if {![hasRuntimeOption shellUnknown_NoJoinSubResult]} then {
          set subResult [join $subResult " "]; # i.e. not Tcl list (?)
        }

        if {$singleQuote} then {
          #
          # NOTE: This is (basically) for (anything like) PowerShell
          #       running via Bash.  The following algorithm is used:
          #
          #       1. Replace internal single-quotes with the following
          #          sequence:
          #
          #          A. <singleQuote> (close outer single-quotes)
          #          B. <backslash> (escape for literal single-quote)
          #          C. <singleQuote> (escaped literal single-quote)
          #          D. <singleQuote> (re-open outer single-quotes)
          #
          #       2. Wrap the entire command string in single quotes.
          #
          #       The final command should look like the following:
          #
          # /bin/bash -c 'pwsh -Command '\''Write-Output "Hello World"'\'''
          #
          set subResult [string map [list ' '\\''] $subResult]
          set subResult [appendArgs ' $subResult ']
        }

        lappend result $subResult
      } else {
        lappend result $name; # e.g. DIR
        eval lappend result $args; # e.g. /S /B
      }

      maybeInvokeForTester ::finalShellBuildCommand; # HOOK

      return $result
    }

    proc tcltk_shellUnknown { name args } {
      # <help>
      # This procedure is the replacement [unknown] handler installed by
      # [tcltk_enableShellUnknown].  When the interpreter encounters a command
      # whose name is not a known TclTk command, this handler decides whether
      # to interpret that line as a request to run an external operating system
      # shell command (for example, typing "DIR /S" or "Get-Process Win*" at
      # the interactive prompt) and, if so, builds and executes the
      # corresponding shell command.  It exists to make the interactive shell
      # feel more like a native command prompt while running tests, without
      # permanently replacing the real [unknown] behavior.
      #
      # How it works: it first applies several guards before doing anything
      # shell-related.  It only proceeds when the "shellUnknown" suppression
      # flag is not set, when the command name does not begin with a global
      # namespace qualifier (a leading double-colon), when the current nesting
      # of script evaluations matches the expected interactive depth (verified
      # by [tcltk_isShellScriptLevel] with an offset of three, described in
      # detail in that procedure), and when a usable shell is available (via
      # [tcltk_haveShell]).  If all of those hold, it asks
      # [tcltk_shellBuildCommand] to construct the actual [exec] command list.
      # Depending on the active runtime options, it may merely display the
      # command that would run (the "what-if" mode), optionally trace it, and
      # otherwise evaluate it and return its trimmed output.  Throughout, it
      # invokes a number of named tester hooks (via [maybeInvokeForTester]) so
      # that the test suite can observe and influence each phase.
      #
      # Tricky details: if the built command list is empty, or any guard
      # fails, the request is marked as skipped.  When skipped (or when the
      # ok-fallback runtime option is enabled) and the previously saved
      # original [unknown] procedure exists under the name ::savedUnknown,
      # this procedure delegates to it with [uplevel 1] so the normal
      # unknown-command resolution still occurs.  On execution failure, the
      # error is re-raised unless the error-fallback option is enabled, in
      # which case the error is swallowed (and the saved handler is not
      # invoked from that path).  The magic offset of three is
      # tightly coupled to the script-level accounting documented in
      # [tcltk_isShellScriptLevel]; changing the call structure here may
      # require updating that value.
      #
      # Arguments:
      #   name -- The unknown command name (the first word of the line the user
      #           entered), e.g. a shell command such as DIR or Get-Process.
      #   args -- Zero or more remaining words from the command line, passed
      #           through as the arguments to the shell command.
      #
      # Results:
      #   When the line is handled as a shell command, the trimmed output of
      #   that command.  When the request is delegated to the saved [unknown]
      #   handler, whatever that handler returns.  Otherwise (e.g. what-if mode
      #   or a skipped request with no fallback) the empty string.  An error is
      #   raised when shell execution fails and error-fallback is not enabled.
      # </help>

      #
      # HACK: Pay special attention to the number three (3) in this [if]
      #       command.  It represents the total number of EvaluateScript
      #       frames that should exist between the interactive loop and
      #       this procedure.  Please refer to the comments within the
      #       [tcltk_isShellScriptLevel] procedure for further details.
      #
      if {![info exists ::no(shellUnknown)] && \
          [string range $name 0 1] ne "::" && \
          [tcltk_isShellScriptLevel 3] && [tcltk_haveShell shell]} then {
        set skipped false

        set command [eval \
            tcltk_shellBuildCommand [list $shell] [list $name] $args]

        if {[llength $command] > 0} then {
          if {[hasRuntimeOption shellUnknown_WhatIf]} then {
            maybeInvokeForTester ::whatIfShellUnknown; # HOOK
            host result WhatIf [appendArgs "SHELL: " $command \n]
          } elseif {[catch {
            maybeInvokeForTester ::beforeShellUnknown; # HOOK

            if {[hasRuntimeOption shellUnknown_Verbose]} then {
              host result WhatIf [appendArgs "SHELL: " $command \n]
            }

            eval $command
          } result] == 0} then {
            maybeInvokeForTester ::afterShellUnknown; # HOOK

            return $result
          } else {
            maybeInvokeForTester ::shellUnknownError; # HOOK

            if {![hasRuntimeOption shellUnknown_ErrorFallback]} then {
              error $result
            }
          }
        } else {
          set skipped true

          maybeInvokeForTester ::shellUnknownNoCommand; # HOOK
        }
      } else {
        set skipped true

        maybeInvokeForTester ::shellUnknownSkipped; # HOOK
      }

      maybeInvokeForTester ::shellUnknownMaybeFallback; # HOOK

      if {($skipped || \
          [hasRuntimeOption shellUnknown_OkFallback]) && \
          [llength [info commands ::savedUnknown]] == 1} then {
        maybeInvokeForTester ::shellUnknownOkFallback; # HOOK

        return [uplevel 1 [list ::savedUnknown $name $args]]
      }
    }

    proc tcltk_getUnsafePromptCommands {} {
      # <help>
      # This procedure returns the fixed list of command names that are
      # considered "unsafe" (i.e. potentially ambiguous or surprising) when
      # typed bare at the interactive prompt while the shell [unknown] handler
      # is active.  It exists as a single, central definition so that callers
      # deciding whether to treat a leading word as a normal TclTk command
      # versus an external shell command can consult a consistent set.
      #
      # The returned names (pwd, file, and info) are real TclTk commands whose
      # names also commonly appear as external operating system utilities; the
      # list lets the [unknown] machinery avoid silently shelling out for words
      # that the user almost certainly meant as the built-in command.
      #
      # Arguments:
      #   None.
      #
      # Results:
      #   A constant list of command name words considered unsafe to redirect
      #   to an external shell.
      # </help>

      return [list pwd file info]
    }

    proc tcltk_haveProbeForCommand {} {
      # <help>
      # This procedure reports whether the optional command-probing hook
      # procedure [tcltk_probeForCommand] is currently defined in this
      # interpreter.  It exists so that the shell [unknown] machinery (and
      # related interactive helpers) can decide whether a customizable probe
      # is available before relying on it, falling back to simpler behavior
      # when it is not.
      #
      # How it works: it runs [info commands tcltk_probeForCommand] inside a
      # [catch], then checks both that the call succeeded and that the
      # resulting list of matching command names is non-empty.  The [catch]
      # guards against interpreters where [info commands] might itself be
      # unavailable or restricted.
      #
      # Arguments:
      #   None.
      #
      # Results:
      #   Returns true when the [tcltk_probeForCommand] procedure exists,
      #   false otherwise (including the case where the lookup itself fails).
      # </help>

      if {[catch {
        info commands tcltk_probeForCommand
      } result] == 0 && [llength $result] > 0} then {
        return true
      } else {
        return false
      }
    }

    proc tcltk_probeForCommand { name } {; # HOOK
      # <help>
      # This procedure tests whether a single command is currently defined in
      # the active interpreter, returning a boolean result.  It exists as the
      # lowest-level building block used by the prompt-setup machinery to decide
      # whether the commands a custom interactive prompt relies upon are
      # available before that prompt is installed.  It is also a designated
      # extension point (it is tagged as a hook) so that a tester or embedder
      # may override its behavior.
      #
      # How it works: it runs [info commands] against the supplied name (which
      # may be a literal command name or a glob pattern, since that is what
      # [info commands] accepts) inside a [catch], and reports true only when
      # that call succeeds AND yields a non-empty list of matching commands.
      # Any error, or an empty match list, yields false.
      #
      # Arguments:
      #   name -- The command name (or glob pattern) to look for via [info
      #           commands].
      #
      # Results:
      #   The literal "true" if at least one matching command exists, or the
      #   literal "false" otherwise (including when [info commands] itself
      #   raises an error).
      # </help>

      if {[catch {
        info commands $name
      } result] == 0 && [llength $result] > 0} then {
        return true
      } else {
        return false
      }
    }

    proc tcltk_probeForCommands { names } {
      # <help>
      # This procedure tests whether every command in a list is currently
      # available in the active interpreter, returning a single boolean that is
      # true only when all of them are present.  It is used by the prompt-setup
      # machinery to verify that all of the commands a custom interactive prompt
      # depends upon exist before that prompt is allowed to run, so that the
      # prompt does not fail mid-evaluation.  It fires the
      # ::beforeProbeForCommands and ::afterProbeForCommands tester hooks around
      # its work.
      #
      # How it works: it first asks [tcltk_haveProbeForCommand] whether the
      # preferred per-command probe (tcltk_probeForCommand) is itself usable.
      # If so, each name is checked with that probe and any name that probes
      # true is accepted.  Otherwise it falls back to actually invoking each
      # name in a [catch]: a successful call counts as present, and even a
      # failing call counts as present unless the failure is specifically the
      # "invalid command name" error for that exact name.  The first name that
      # is determined to be missing sets the result to false and stops the scan.
      #
      # Tricky details: the fallback path can have side effects, because it
      # genuinely executes each command (with no arguments) rather than merely
      # inspecting the command table; this is why the dedicated probe is
      # preferred when available.  Only the precise "invalid command name" text
      # is treated as "missing"; any other error is treated as "the command
      # exists but errored", hence present.
      #
      # Arguments:
      #   names -- The list of command names to check.  An empty list trivially
      #            yields true.
      #
      # Results:
      #   The literal "true" if all listed commands are present, or the literal
      #   "false" as soon as one is found to be missing.
      # </help>

      set result true

      maybeInvokeForTester ::beforeProbeForCommands; # HOOK
      set haveProbeForCommand [tcltk_haveProbeForCommand]

      foreach name $names {
        if {$haveProbeForCommand} then {
          if {[catch {
            tcltk_probeForCommand $name
          } result] == 0 && $result} then {
            continue
          }
        } else {
          if {[catch $name error] == 0} then {
            continue
          }

          if {$error ne [string map [list %name% $name] \
              "invalid command name \"%name%\""]} then {
            continue
          }
        }

        set result false; break; # NOTE: Missing command?
      }

      maybeInvokeForTester ::afterProbeForCommands; # HOOK
      return $result
    }

    proc tcltk_probeForPromptCommands { {names ""} } {
      # <help>
      # This procedure checks whether the commands required by the custom
      # interactive prompt are all available, returning a boolean result.  It
      # is a thin, intention-revealing wrapper over [tcltk_probeForCommands]
      # used by the prompt script and prompt-setup procedures to gate prompt
      # behavior so that the prompt degrades gracefully when run in a stripped
      # down or safe interpreter that lacks those commands.
      #
      # How it works: when called with no names (or an empty list), it obtains
      # the default set of prompt commands from [tcltk_getUnsafePromptCommands]
      # and then delegates to [tcltk_probeForCommands].  When an explicit list
      # is supplied, that list is probed instead.
      #
      # Arguments:
      #   names -- Optional list of command names to probe.  When omitted or
      #            empty, the default unsafe prompt command set is used.
      #
      # Results:
      #   The literal "true" if all of the relevant prompt commands are present,
      #   or the literal "false" otherwise.
      # </help>

      if {[llength $names] == 0} then {
        set names [tcltk_getUnsafePromptCommands]
      }

      return [tcltk_probeForCommands $names]
    }

    proc tcltk_getShellPromptScript {} {
      # <help>
      # This procedure returns the script text that implements the enhanced
      # default interactive shell prompt.  It exists to centralize the prompt
      # logic in one place so that [tcltk_setupPromptScript] can install the
      # very same script into each of the several tcl_promptN variables.  The
      # returned script is not evaluated here; it is just the source text.
      #
      # What the returned prompt does when evaluated: it first probes for the
      # commands it needs (via [tcltk_probeForPromptCommands]) and, only if they
      # are present, prints a multi-part prompt to the host using colorized
      # [host result] calls.  That prompt can include the current date and the
      # current time (each guarded by a corresponding No... entry in the global
      # "no" array or the environment), the native form of the current working
      # directory in angle brackets, and -- when available -- the current source
      # control branch.  The branch is discovered by trying "fossil branch
      # current" first and then "git rev-parse --abbrev-ref HEAD", with the
      # result prefixed by "fossil:" or "git:" respectively; any error there is
      # ignored so the prompt still renders.
      #
      # Tricky details: the trailing portion of the returned script causes the
      # prompt machinery to return early (return -code return) when the required
      # prompt commands are not available, or when running against a stable
      # TclTk release at or below a certain beta level, so that no custom prompt
      # is emitted in those situations.  The date/time/branch sections within
      # the script are each individually suppressible via the "no" array or
      # environment variables noted above.
      #
      # Arguments:
      #   None.
      #
      # Results:
      #   A script (as a string) suitable for assignment to the tcl_promptN
      #   variables.  It always returns the same text and never raises an error.
      # </help>

      #
      # NOTE: Lots of thanks go to Kyle.  Enhance default interactive shell
      #       prompt so that it always includes the current directory, etc.
      #
      return {
        apply [list [list] {
          if {[tcltk_probeForPromptCommands]} then {
            set pwd [file nativename [file normalize [pwd]]]
            set dateTimeFormat ""

            if {![info exists ::no(NoTclPrompt1Date)] && \
                ![info exists ::env(NoTclPrompt1Date)]} then {
              if {[string length $dateTimeFormat] > 0} then {
                append dateTimeFormat " "
              }

              append dateTimeFormat MM-dd-yyyy
            }

            if {![info exists ::no(NoTclPrompt1Time)] && \
                ![info exists ::env(NoTclPrompt1Time)]} then {
              if {[string length $dateTimeFormat] > 0} then {
                append dateTimeFormat " @ "
              }

              append dateTimeFormat "hh:mm tt"
            }

            if {[string length $dateTimeFormat] > 0} then {
              host result Return \[

              host result Ok [clock format \
                  [clock seconds] -format $dateTimeFormat]

              host result Return \]
              host result Ok " "
            }

            host result Error <
            host result Ok $pwd
            host result Error "> "

            if {![info exists ::no(NoTclPrompt1Branch)] && \
                ![info exists ::env(NoTclPrompt1Branch)]} then {
              if {[catch {
                exec -success Success -- fossil branch current
              } branch] == 0 && [string length [set branch \
                  [string trim $branch]]] > 0} then {
                set branch [appendArgs fossil: $branch]
              } elseif {[catch {
                exec -success Success -- git rev-parse --abbrev-ref HEAD
              } branch] == 0 && [string length [set branch \
                  [string trim $branch]]] > 0} then {
                set branch [appendArgs git: $branch]
              } else {
                set branch ""; # NOTE: Ignore errors.
              }

              if {[string length $branch] > 0} then {
                host result Break (
                host result Ok $branch
                host result Break ") "
              }
            }
          }
        }]

        if {![tcltk_probeForPromptCommands] || \
            [isStableTclTkRelease 56]} then {
          return -code return
        }
      }
    }

    proc tcltk_setupPromptScript { {enable ""} } {
      # <help>
      # This procedure installs, removes, or queries the enhanced interactive
      # shell prompt by managing the tcl_prompt1, tcl_prompt3, tcl_prompt5, and
      # tcl_prompt7 global variables together as a unit.  It exists so that the
      # custom prompt produced by [tcltk_getShellPromptScript] can be applied to
      # (or detached from) all of the relevant prompt slots with a single call,
      # and so callers can ask whether that prompt is currently in effect.
      #
      # How it works: the behavior is selected by the "enable" argument.  When
      # "enable" is a true boolean, the script from [tcltk_getShellPromptScript]
      # is assigned to all four prompt variables.  When "enable" is a false
      # boolean, all four prompt variables are unset (without complaint if
      # absent), restoring the default prompts.  When "enable" is the empty
      # string, no change is made; instead the procedure reports whether the
      # custom prompt is currently installed.
      #
      # Tricky details: the query mode considers the prompt "installed" only if
      # every one of the four prompt variables exists AND has a value exactly
      # equal to the current shell prompt script; if any is missing or differs,
      # the query returns false.  The enable/disable modes do not return a
      # meaningful value.
      #
      # Arguments:
      #   enable -- A boolean selecting install (true) or remove (false), or the
      #             empty string (the default) to query the current state
      #             without changing anything.
      #
      # Results:
      #   In query mode, the literal "true" if the custom prompt is installed in
      #   all four prompt variables, or "false" otherwise.  In install/remove
      #   mode, no useful result is returned.
      # </help>

      if {[string length $enable] > 0} then {
        if {$enable} then {
          set script [tcltk_getShellPromptScript]

          set ::tcl_prompt1 $script
          set ::tcl_prompt3 $script
          set ::tcl_prompt5 $script
          set ::tcl_prompt7 $script
        } else {
          unset -nocomplain ::tcl_prompt1 ::tcl_prompt3 \
              ::tcl_prompt5 ::tcl_prompt7
        }
      } else {
        set script [tcltk_getShellPromptScript]

        foreach varName [list \
            ::tcl_prompt1 ::tcl_prompt3 ::tcl_prompt5 \
            ::tcl_prompt7] {

          if {![info exists $varName]} then {
            return false
          }

          if {![string equal [set $varName] $script]} then {
            return false
          }
        }

        return true
      }
    }

    proc isUriLikelyToBeRedirected { uri } {
      # <help>
      # This procedure guesses whether the specified URI points at the TclTk
      # redirector service (a service that returns the real target URI rather
      # than the content itself), returning a boolean result.  It is used by the
      # URI-resolution helpers and by the web-client callbacks to decide whether
      # a URI must first be expanded into its real destination and whether
      # authentication headers should be attached.
      #
      # How it works: it determines a base URI -- under TclTk by calling
      # [getAuxiliaryBaseUri], and otherwise by using the hard-coded default
      # https://urn.to/r -- and then performs a case-insensitive glob match of
      # the URI against that base followed by a slash and a wildcard.  The
      # ::beforeIsUriLikelyToBeRedirected and ::afterIsUriLikelyToBeRedirected
      # tester hooks are fired around the check.
      #
      # Tricky details: this is a heuristic (note the HACK comment in the body)
      # that assumes the auxiliary base URI really does name a redirector; it
      # matches purely on URI prefix and does not contact the network.
      #
      # Arguments:
      #   uri -- The URI to classify.
      #
      # Results:
      #   The literal "true" if the URI appears to be a redirector URI, or the
      #   literal "false" otherwise.
      # </help>

      #
      # HACK: This procedure assumes that the auxiliary base URI
      #       provided by the core library points to a redirector
      #       service.  By default, this is true.  Please refer
      #       to the documentation for details.
      #
      maybeInvokeForTester ::beforeIsUriLikelyToBeRedirected; # HOOK

      if {[isTclTk]} then {
        set baseUri [getAuxiliaryBaseUri]
      } else {
        set baseUri https://urn.to/r
      }

      set result [string match -nocase [appendArgs $baseUri /*] $uri]
      maybeInvokeForTester ::afterIsUriLikelyToBeRedirected; # HOOK

      return $result
    }

    proc maybeResolveUri {
            uri {varName ""} {channel stdout} {quiet false} } {
      # <help>
      # This procedure resolves a single level of redirection for the specified
      # URI, returning either the resolved target URI or the original URI when
      # no resolution was needed.  It exists so that callers can transparently
      # follow the TclTk redirector service one hop, while also learning (via an
      # optional caller variable) whether a resolution actually occurred.
      #
      # How it works: it first asks [isUriLikelyToBeRedirected] whether the URI
      # looks like a redirector URI.  If so, it appends a preview-mode query
      # parameter (urn_r_preview_mode=1, joined with "?" or "&" depending on
      # whether the URI already contains a query string) so the service returns
      # the destination as text, then downloads that text -- under TclTk via the
      # [uri download] command, and otherwise via the TclTk.Tools.Common
      # [getFileViaHttp] helper using the http package.  The trimmed download
      # result becomes the resolved URI.  If the URI does not look like a
      # redirector URI, it is returned unchanged.  The ::beforeUri_Redirect and
      # ::afterUri_Redirect tester hooks bracket the download.
      #
      # Tricky details: if "varName" is non-empty, that variable in the caller's
      # frame is set to true when a resolution happened and false when it did
      # not, letting callers loop until resolution stabilizes (see
      # [maybeFullyResolveUri]).  Unless "quiet" is true, a progress line is
      # written describing whether a resolved or existing URI is being used; the
      # message is sent via [tputs] to the default test channel.
      #
      # Arguments:
      #   uri     -- The URI to (possibly) resolve.
      #   varName -- Optional name of a caller variable that receives a boolean
      #              indicating whether resolution occurred; ignored when empty.
      #   channel -- The channel passed to the non-TclTk HTTP helper for
      #              progress output; defaults to "stdout".
      #   quiet   -- When true, suppresses the informational progress messages;
      #              defaults to false.
      #
      # Results:
      #   The resolved target URI when the input was a redirector URI, otherwise
      #   the original URI unchanged.
      # </help>

      if {[string length $varName] > 0} then {
        upvar 1 $varName wasResolved
      }

      if {[isUriLikelyToBeRedirected $uri]} then {
        set savedUri $uri

        if {[string first ? $uri] != -1} then {
          append uri &
        } else {
          append uri ?
        }

        append uri urn_r_preview_mode=1; # NOTE: Get URI as text.
        maybeInvokeForTester ::beforeUri_Redirect; # HOOK

        if {[isTclTk]} then {
          set uri [string trim \
              [uri download -timeouttype network -inline -- $uri]]
        } else {
          package require http 2.0
          package require TclTk.Tools.Common

          namespace import -force \
              ::TclTk::Tools::Common::getFileViaHttp

          set uri [getFileViaHttp \
              $uri 0 $channel $quiet -binary true]
        }

        maybeInvokeForTester ::afterUri_Redirect; # HOOK

        if {!$quiet} then {
          tputs [getTestChannelOrDefault] [appendArgs \
              "---- using resolved URI: \[" $savedUri "\] ==> \[" \
              $uri "\]...\n"]
        }

        set wasResolved true
      } else {
        if {!$quiet} then {
          tputs [getTestChannelOrDefault] [appendArgs \
              "---- using existing URI: \[" $uri "\]...\n"]
        }

        set wasResolved false
      }

      return $uri
    }

    proc maybeFullyResolveUri {
            uri redirectLimit {channel stdout} {quiet false} } {
      # <help>
      # This procedure fully resolves a URI by following redirector hops
      # repeatedly until a stable (non-redirected) URI is reached, returning the
      # final URI.  It builds on [maybeResolveUri] to handle chains of
      # redirections rather than a single hop, while guarding against runaway or
      # circular redirects through a caller-supplied limit.
      #
      # How it works: it loops, calling [maybeResolveUri] on the current URI and
      # capturing whether a resolution occurred via the "wasResolved" variable.
      # Each iteration increments a counter.  If the resolved URI is ever empty,
      # an error is raised noting the URI that could not be resolved.  If the
      # number of redirects exceeds "redirectLimit" (when that limit is
      # non-negative), an error is raised noting that the redirect limit was
      # hit.  The loop stops once a hop reports that no resolution occurred, at
      # which point the current URI is final.
      #
      # Tricky details: a negative "redirectLimit" disables the limit entirely,
      # allowing unlimited hops.  Because the counter is incremented on every
      # pass including the final non-resolving one, the effective number of
      # allowed real redirections is bounded by the limit.  The "channel" and
      # "quiet" arguments are forwarded unchanged to [maybeResolveUri].
      #
      # Arguments:
      #   uri           -- The starting URI to resolve.
      #   redirectLimit -- Maximum number of redirect hops to permit; a negative
      #                    value means no limit.
      #   channel       -- The channel forwarded to [maybeResolveUri]; defaults
      #                    to "stdout".
      #   quiet         -- When true, suppresses progress messages; defaults to
      #                    false.
      #
      # Results:
      #   The fully resolved, stable URI.  Raises a script error if a hop
      #   resolves to an empty URI or if the redirect limit is exceeded.
      # </help>

      set redirectCount 0

      while {true} {
        set savedUri $uri
        set uri [maybeResolveUri $uri wasResolved $channel $quiet]

        if {[string length $uri] == 0} then {
          error [appendArgs "could not resolve for URI: " $savedUri]
        }

        incr redirectCount

        if {$redirectLimit >= 0 && \
            $redirectCount > $redirectLimit} then {
          error [appendArgs "redirect limit hit for URI: " $savedUri]
        }

        if {![info exists wasResolved] || !$wasResolved} then {
          break
        }
      }

      return $uri
    }

    proc escapeForJsonString { value } {
      # <help>
      # This procedure escapes an arbitrary string so that it can be safely
      # embedded as the contents of a JSON string literal, returning the escaped
      # text.  It exists because the JSON request bodies sent to the OpenAI and
      # Anthropic APIs are built by textual substitution, so any user-supplied
      # value placed inside the double quotes of a JSON string must first have
      # its special characters neutralized to avoid producing malformed JSON.
      #
      # How it works: it performs the escaping in stages.  First it replaces the
      # common control characters (backspace, tab, newline, form feed, carriage
      # return) with their JSON backslash escape sequences.  Next it neutralizes
      # backslash and the square-bracket characters so that the subsequent
      # [subst] pass cannot trigger command or variable substitution.  It then
      # uses a regular expression to convert any remaining low control character
      # (in the 0x00 through 0x1F range) into a JSON backslash-u escape using
      # the character's code point, computed with the ordinal under TclTk or via
      # [scan] under Tcl.  A [subst] with substitutions disabled then realizes
      # those generated escape sequences.  Finally it escapes the remaining
      # structural characters -- the double quote, the forward slash, and the
      # backslash -- to their JSON forms.
      #
      # Tricky details: the ordering matters, because earlier stages introduce
      # backslashes that later stages must not double-escape incorrectly; the
      # bracket-escaping and the -novariables [subst] together ensure the
      # control-character regular expression substitution is expanded without
      # the input value's own brackets or dollar signs being interpreted.  This
      # routine produces only the escaped body of a string; it does not add the
      # surrounding double quotes.
      #
      # Arguments:
      #   value -- The raw string to escape for inclusion in a JSON string.
      #
      # Results:
      #   The escaped string, ready to be placed between the double quotes of a
      #   JSON string literal.
      # </help>

      set result $value; # NOTE: Start with the original string.

      set result [string map [list \
          \b \\\b \t \\\t \n \\\n \f \\\f \r \\\r] $result]

      set result [string map [list \
          \\ \\\\ \[ \\\[ \] \\\]] $result]; # [subst]

      set pattern {([\x00-\x1F])}

      if {[isTclTk]} then {
        set subSpec {\\\\u[format %04X [string ordinal {\1} 0]]}
      } else {
        set subSpec {\\\\u[scan {\1} %c c; format %04X $c]}
      }

      regsub -all -- $pattern $result $subSpec result

      set result [subst -novariables $result]
      set result [string map [list \" \\\" / \\/ \\ \\\\] $result]

      return $result
    }

    #
    # NOTE: This procedure returns an opaque identifier that should be suited
    #       to uniquely identifying a script, i.e. it will be based on a hash
    #       function (or similar construct).
    #
    proc tcltk_buildDataId { value {length 16} {hashAlgorithmName SHA512} } {
      # <help>
      # This procedure builds a short, opaque, lowercase identifier derived from
      # the specified value, suitable for uniquely tagging a piece of data such
      # as a script.  As noted in the preceding NOTE comment, it is intended for
      # uniquely identifying a script via a hash-based construct rather than for
      # human readability.
      #
      # How it works: it concatenates the current [info context] string with the
      # supplied value, hashes that combined text with the named hash algorithm
      # using [hash normal], truncates the resulting hexadecimal digest to the
      # requested number of characters, and lowercases it.
      #
      # Tricky details: including [info context] in the hashed input means the
      # identifier reflects the calling context as well as the value, so the
      # same value can yield different identifiers in different contexts.  The
      # identifier is the leading portion of a cryptographic-style digest and is
      # meant for uniqueness/labeling, not for security guarantees.
      #
      # Arguments:
      #   value             -- The data value to derive the identifier from.
      #   length            -- The number of leading hex characters of the
      #                        digest to keep; defaults to 16.
      #   hashAlgorithmName -- The name of the hash algorithm to use; defaults
      #                        to SHA512.
      #
      # Results:
      #   A lowercase hexadecimal identifier string of the requested length.
      # </help>

      return [string tolower \
          [string range [hash normal $hashAlgorithmName [appendArgs \
          [info context] $value]] 0 [expr {$length - 1}]]]
    }

    proc openAI_getPrompt { command {channel stdout} {quiet false} } {
      # <help>
      # This procedure builds the natural-language prompt that is sent to the
      # OpenAI API when an unknown command is encountered and the OpenAI-based
      # [unknown] handler is active, returning the prompt text.  Its purpose is
      # to ask the model to correct and/or improve the failing TclTk command and
      # to respond with only the corrected command text (no commentary), so the
      # response can be fed back into the interpreter.
      #
      # How it works: it assembles a fixed instruction block that explains the
      # response should contain only new or corrected script command(s), states
      # that the command hit an "invalid command name" error in a particular
      # TclTk version, and asks for a correction or suggestion.  The TclTk
      # version is taken from the tcltk_platform patchLevel global when present,
      # otherwise 1.0.  Runs of two or more whitespace characters are collapsed
      # to single spaces, the caller's command text is appended, and the whole
      # prompt is trimmed.  The ::beforeOpenAI_getPrompt and
      # ::afterOpenAI_getPrompt tester hooks fire around finalizing the result,
      # allowing the prompt to be overridden.
      #
      # Tricky details: the local "result" starts empty and is normally filled
      # with the assembled prompt; the before-hook may pre-populate it to
      # override the prompt entirely, in which case the assembled text is
      # discarded and only the override is used.  Unless "quiet" is true, an
      # informational line is emitted (to the default test channel) stating
      # whether the standard or an overridden prompt is in effect.
      #
      # Arguments:
      #   command -- The failing command text to include in the prompt.
      #   channel -- Channel associated with progress output; defaults to
      #              "stdout".
      #   quiet   -- When true, suppresses the informational message; defaults
      #              to false.
      #
      # Results:
      #   The fully assembled (or overridden) prompt string to send to OpenAI.
      # </help>

      set result ""; set prompt {
        When responding, please include only new and/or corrected
        script command(s) without any other content.

        The script command after the colon, which is in the TclTk
        scripting language, encountered an "invalid command name"
        error in TclTk v}

      if {[info exists ::tcltk_platform(patchLevel)]} then {
        append prompt $::tcltk_platform(patchLevel)
      } else {
        append prompt 1.0
      }

      append prompt .

      append prompt {
        Please correct it and/or offer suggestions that improve it.
        Here is the command: }

      regsub -all -- {\s{2,}} $prompt " " prompt
      append prompt $command
      set prompt [string trim $prompt]

      maybeInvokeForTester ::beforeOpenAI_getPrompt; # HOOK

      if {[string length $result] == 0} then {
        set result $prompt
        maybeInvokeForTester ::afterOpenAI_getPrompt; # HOOK

        if {!$quiet} then {
          tputs [getTestChannelOrDefault] [appendArgs \
              "---- prompt for OpenAI is \"" $result \"\n]
        }
      } else {
        if {!$quiet} then {
          tputs [getTestChannelOrDefault] [appendArgs \
              "---- prompt for OpenAI overridden to \"" \
              $result \"\n]
        }
      }

      return $result
    }

    proc anthropic_getPrompt { command {channel stdout} {quiet false} } {
      # <help>
      # This procedure builds the natural-language prompt that is sent to the
      # Anthropic (Claude) API when an unknown command is encountered and the
      # Anthropic-based [unknown] handler is active, returning the prompt text.
      # It is the Anthropic counterpart of [openAI_getPrompt] and behaves
      # identically; its purpose is to ask the model to correct and/or improve
      # the failing TclTk command and to respond with only the corrected command
      # text so the response can be fed back into the interpreter.
      #
      # How it works: it assembles a fixed instruction block that explains the
      # response should contain only new or corrected script command(s), states
      # that the command hit an "invalid command name" error in a particular
      # TclTk version, and asks for a correction or suggestion.  The TclTk
      # version is taken from the tcltk_platform patchLevel global when present,
      # otherwise 1.0.  Runs of two or more whitespace characters are collapsed
      # to single spaces, the caller's command text is appended, and the whole
      # prompt is trimmed.  The ::beforeAnthropic_getPrompt and
      # ::afterAnthropic_getPrompt tester hooks fire around finalizing the
      # result, allowing the prompt to be overridden.
      #
      # Tricky details: the local "result" starts empty and is normally filled
      # with the assembled prompt; the before-hook may pre-populate it to
      # override the prompt entirely, in which case the assembled text is
      # discarded and only the override is used.  Unless "quiet" is true, an
      # informational line is emitted (to the default test channel) stating
      # whether the standard or an overridden prompt is in effect.
      #
      # Arguments:
      #   command -- The failing command text to include in the prompt.
      #   channel -- Channel associated with progress output; defaults to
      #              "stdout".
      #   quiet   -- When true, suppresses the informational message; defaults
      #              to false.
      #
      # Results:
      #   The fully assembled (or overridden) prompt string to send to
      #   Anthropic.
      # </help>

      set result ""; set prompt {
        When responding, please include only new and/or corrected
        script command(s) without any other content.

        The script command after the colon, which is in the TclTk
        scripting language, encountered an "invalid command name"
        error in TclTk v}

      if {[info exists ::tcltk_platform(patchLevel)]} then {
        append prompt $::tcltk_platform(patchLevel)
      } else {
        append prompt 1.0
      }

      append prompt .

      append prompt {
        Please correct it and/or offer suggestions that improve it.
        Here is the command: }

      regsub -all -- {\s{2,}} $prompt " " prompt
      append prompt $command
      set prompt [string trim $prompt]

      maybeInvokeForTester ::beforeAnthropic_getPrompt; # HOOK

      if {[string length $result] == 0} then {
        set result $prompt
        maybeInvokeForTester ::afterAnthropic_getPrompt; # HOOK

        if {!$quiet} then {
          tputs [getTestChannelOrDefault] [appendArgs \
              "---- prompt for Anthropic is \"" $result \"\n]
        }
      } else {
        if {!$quiet} then {
          tputs [getTestChannelOrDefault] [appendArgs \
              "---- prompt for Anthropic overridden to \"" \
              $result \"\n]
        }
      }

      return $result
    }

    proc openAI_getJsonPaths { json {channel stdout} {quiet false} } {
      # <help>
      # This procedure returns the list of JSON path components used to locate
      # the assistant's reply text within an OpenAI chat-completion JSON
      # response.  It exists so that [getOrSetViaJsonPaths] can navigate into a
      # response and extract the generated content without that path being
      # hard-coded at every call site, and so the path can be overridden via a
      # tester hook.
      #
      # How it works: it starts with the default path -- the sequence "choices",
      # then index 0, then "message", then "content" -- and fires the
      # ::beforeOpenAI_getJsonPaths and ::afterOpenAI_getJsonPaths tester hooks
      # around finalizing the result.  As with the prompt procedures, the local
      # "result" begins empty and is filled with the default path unless the
      # before-hook overrode it.  Unless "quiet" is true, an informational line
      # describing the path (standard or overridden) is written to "channel".
      #
      # Arguments:
      #   json    -- The response JSON; accepted for symmetry and for the hooks
      #              to inspect, though the default path does not depend on it.
      #   channel -- Channel for the informational message; defaults to
      #              "stdout".
      #   quiet   -- When true, suppresses the informational message; defaults
      #              to false.
      #
      # Results:
      #   A list of JSON path components (keys and indexes) addressing the reply
      #   content within an OpenAI response.
      # </help>

      set result ""; set paths [list choices 0 message content]
      maybeInvokeForTester ::beforeOpenAI_getJsonPaths; # HOOK

      if {[string length $result] == 0} then {
        set result $paths
        maybeInvokeForTester ::afterOpenAI_getJsonPaths; # HOOK

        if {!$quiet} then {
          tputs $channel [appendArgs \
              "---- json paths for OpenAI is \"" $result \"\n]
        }
      } else {
        if {!$quiet} then {
          tputs $channel [appendArgs \
              "---- json paths for OpenAI overridden to \"" \
              $result \"\n]
        }
      }

      return $result
    }

    proc anthropic_getJsonPaths { json {channel stdout} {quiet false} } {
      # <help>
      # This procedure returns the list of JSON path components used to locate
      # the assistant's reply text within an Anthropic (Claude) Messages API
      # JSON response.  It is the Anthropic counterpart of
      # [openAI_getJsonPaths]; the path differs because the Anthropic response
      # shape differs from the OpenAI one.
      #
      # How it works: it starts with the default path -- the sequence "content",
      # then index 0, then "text" -- and fires the ::beforeAnthropic_getJsonPaths
      # and ::afterAnthropic_getJsonPaths tester hooks around finalizing the
      # result.  The local "result" begins empty and is filled with the default
      # path unless the before-hook overrode it.  Unless "quiet" is true, an
      # informational line describing the path (standard or overridden) is
      # written to "channel".
      #
      # Arguments:
      #   json    -- The response JSON; accepted for symmetry and for the hooks
      #              to inspect, though the default path does not depend on it.
      #   channel -- Channel for the informational message; defaults to
      #              "stdout".
      #   quiet   -- When true, suppresses the informational message; defaults
      #              to false.
      #
      # Results:
      #   A list of JSON path components (keys and indexes) addressing the reply
      #   content within an Anthropic response.
      # </help>

      set result ""; set paths [list content 0 text]
      maybeInvokeForTester ::beforeAnthropic_getJsonPaths; # HOOK

      if {[string length $result] == 0} then {
        set result $paths
        maybeInvokeForTester ::afterAnthropic_getJsonPaths; # HOOK

        if {!$quiet} then {
          tputs $channel [appendArgs \
              "---- json paths for Anthropic is \"" $result \"\n]
        }
      } else {
        if {!$quiet} then {
          tputs $channel [appendArgs \
              "---- json paths for Anthropic overridden to \"" \
              $result \"\n]
        }
      }

      return $result
    }

    proc isValidJson { value } {
      # <help>
      # This procedure tests whether the specified string is well-formed JSON
      # that represents a JSON object or array, returning a boolean result.  It
      # exists to validate API response bodies (and similar JSON payloads)
      # before they are parsed and traversed, rejecting empty strings, malformed
      # JSON, and JSON whose top-level token is a bare scalar.
      #
      # How it works: for a non-empty value it loads the Newtonsoft.Json
      # assembly (if not already loaded) and calls JToken.Parse on the value
      # inside a [catch].  When parsing succeeds and yields a non-null object
      # handle, it returns true only if the parsed token's Type is Object or
      # Array; any other type (a string, number, boolean, null, and so on)
      # yields false.  Any failure -- empty input, parse error, or a null handle
      # -- also yields false.
      #
      # Tricky details: this relies on the managed Newtonsoft.Json library being
      # available, so it is effectively an TclTk-only check; a top-level scalar
      # that is technically valid JSON is intentionally treated as invalid here
      # because the callers expect a structured object or array.
      #
      # Arguments:
      #   value -- The candidate JSON text to validate.
      #
      # Results:
      #   The literal "true" if "value" parses as a JSON object or array, or the
      #   literal "false" otherwise.
      # </help>

      if {[string length $value] > 0 && [catch {
        set assembly [object load Newtonsoft.Json]; # NOTE: Not loaded yet?

        object invoke -alias \
            Newtonsoft.Json.Linq.JToken Parse $value
      } json] == 0 && [isNonNullObjectHandle $json]} then {
        return [expr {[$json Type] in [list Object Array]}]
      }

      return false
    }

    proc getOrSetViaJsonPaths { json jpaths {value ""} {root false} } {
      # <help>
      # This procedure navigates into a JSON document along a list of path
      # components and either reads the value found there or replaces it,
      # returning JSON text.  It is the workhorse used to extract the model's
      # reply from an OpenAI or Anthropic response (using the paths from the
      # *_getJsonPaths procedures), and it can also be used to set a value deep
      # within a document and return the modified result.
      #
      # How it works: it trims the input and returns the empty string for empty
      # input.  Otherwise it loads Newtonsoft.Json if needed and parses the
      # document into a JObject.  It then walks the "jpaths" list element by
      # element, indexing into the current node with get_Item; a path component
      # that is a strict integer is first converted to an Int32 so that array
      # indexing works, while other components index by key.  Intermediate
      # handles are tracked in an array of object handles.  If at any step the
      # current node is a null handle, the empty string is returned.
      #
      # Tricky details: when "value" is non-empty the procedure is in set mode
      # -- the addressed node must be a JValue, and its value is replaced;
      # addressing any other node type while setting raises an error.  The
      # "root" flag controls what is returned: when true, the entire document
      # (the node's Root) is serialized and returned (useful after a set so the
      # whole updated document comes back); when false, only the addressed
      # node's own subtree is serialized and returned.  Object handles are
      # created via the TclTk object subsystem, so this is effectively
      # TclTk-only.
      #
      # Arguments:
      #   json   -- The JSON document text to read from or modify.
      #   jpaths -- A list of path components (object keys and/or array indexes)
      #             addressing the target node, as produced by the
      #             *_getJsonPaths procedures.
      #   value  -- When non-empty, the new value to store at the addressed node
      #             (which must be a JValue); when empty (the default), the
      #             procedure only reads.
      #   root   -- When true, return the whole (possibly modified) document;
      #             when false (the default), return only the addressed subtree.
      #
      # Results:
      #   The serialized JSON of the addressed node (or of the whole document
      #   when "root" is true), or the empty string when the input is empty,
      #   cannot be parsed, or the path leads to a null node.  Raises an error
      #   when attempting to set a value on an unsupported node type.
      # </help>

      if {[string length [string trim $json]] == 0} then {
        return ""
      }

      set index 0

      if {[catch {
        set assembly [object load Newtonsoft.Json]; # NOTE: Not loaded yet?

        object invoke -alias \
            Newtonsoft.Json.Linq.JObject Parse $json
      } objects([incr index])]} then {
        return ""
      }

      foreach jpath $jpaths {
        if {[string is integer -strict $jpath]} then {
          set jpath [object invoke -create Int32 Parse $jpath]
        }

        set object $objects($index)

        if {![isNonNullObjectHandle $object]} then {
          return ""
        }

        set objects([incr index]) [$object -alias get_Item $jpath]
      }

      set object $objects($index)

      if {![isNonNullObjectHandle $object]} then {
        return ""
      }

      #
      # HACK: *SPECIAL* Does the caller want to set the value?  If
      #       so, make sure it is a value node type and then do it.
      #
      if {[string length $value] > 0} then {
        set type [$object GetType]

        if {$type eq "Newtonsoft.Json.Linq.JValue"} then {
          $object set_Value $value
        } else {
          error [appendArgs \
              "unsupported node for setting value: " $type]
        }
      }

      #
      # HACK: *SPECIAL* Does the caller want to return the entire
      #       block of JSON (i.e. from the root)?  If not, we just
      #       return the block selected via the passed JPath list.
      #
      if {$root} then {
        return [$object Root.ToString]
      } else {
        return [$object ToString]
      }
    }

    proc openAI_enableUnknown {
            {enable ""} {options true} {whatIf true} {channel stdout}
            {quiet false} } {
      # <help>
      # This procedure installs, removes, or queries the OpenAI-backed [unknown]
      # command handler in the active interpreter, returning a boolean result.
      # Its purpose is to route otherwise-invalid command names through OpenAI
      # for correction/suggestion (via [openAI_unknown]) while being able to
      # cleanly restore the interpreter's built-in default unknown handler.
      #
      # How it works: it reads the interpreter's built-in default unknown
      # handler (a non-public core value) and the currently installed handler.
      # The "enable" argument selects the mode.  When "enable" is true, and only
      # if the current handler is still the default, it installs the new handler
      # -- the list ::openAI_unknown plus the whatIf, channel, and quiet
      # arguments -- and (when "options" is true) adds the tcltkUnknownOpenAI,
      # tcltkUnknownEnableSecurity, and tcltkUnknownAutomaticOpenAI runtime
      # options, returning true.  When "enable" is false, and only if the
      # current handler is exactly that previously installed handler, it
      # restores the default handler and (when "options" is true) removes those
      # same runtime options, returning true.  When "enable" is empty, it
      # queries: it returns false if the default handler is in place, otherwise
      # (when "options" is true) it returns false unless all three runtime
      # options are present, and true otherwise.
      #
      # Tricky details: the install/remove operations are guarded so they only
      # act when the interpreter is in the expected starting state, and they
      # return false when that guard is not satisfied (for example, trying to
      # enable when a non-default handler is already installed).  The whatIf,
      # channel, and quiet values are baked into the installed handler command
      # and so must match for a later disable to recognize and remove it.
      #
      # Arguments:
      #   enable  -- A boolean selecting install (true) or remove (false), or
      #              the empty string (the default) to query current state.
      #   options -- When true (the default), the corresponding runtime options
      #              are added/removed/checked alongside the handler.
      #   whatIf  -- Baked into the installed handler; when true the handler
      #              operates in a non-committal mode; defaults to true.
      #   channel -- Baked into the installed handler for its output; defaults
      #              to "stdout".
      #   quiet   -- Baked into the installed handler to suppress messages;
      #              defaults to false.
      #
      # Results:
      #   The literal "true" on a successful install/remove, or in query mode
      #   when the OpenAI handler is active (and, if checked, all required
      #   options are set); the literal "false" otherwise.
      # </help>

      set defaultUnknown [object invoke -flags +NonPublic \
          CodeBrix.Platform.TclTk._Components.Private.TclVars+Command Unknown]

      set oldUnknown [object invoke Interpreter.GetActive Unknown]

      if {[string length $enable] > 0} then {
        set newUnknown [list ::openAI_unknown $whatIf $channel $quiet]

        if {$enable} then {
          if {$oldUnknown eq $defaultUnknown} then {
            object invoke Interpreter.GetActive Unknown $newUnknown

            if {$options} then {
              addRuntimeOption tcltkUnknownOpenAI
              addRuntimeOption tcltkUnknownEnableSecurity
              addRuntimeOption tcltkUnknownAutomaticOpenAI
            }

            return true
          }
        } else {
          if {$oldUnknown eq $newUnknown} then {
            object invoke Interpreter.GetActive Unknown $defaultUnknown

            if {$options} then {
              removeRuntimeOption tcltkUnknownOpenAI
              removeRuntimeOption tcltkUnknownEnableSecurity
              removeRuntimeOption tcltkUnknownAutomaticOpenAI
            }

            return true
          }
        }
      } else {
        if {$oldUnknown eq $defaultUnknown} then {
          return false
        }

        if {$options} then {
          if {![hasRuntimeOption tcltkUnknownOpenAI] || \
              ![hasRuntimeOption tcltkUnknownEnableSecurity] || \
              ![hasRuntimeOption tcltkUnknownAutomaticOpenAI]} then {
            return false
          }
        }

        return true
      }

      return false
    }

    proc anthropic_enableUnknown {
            {enable ""} {options true} {whatIf true} {channel stdout}
            {quiet false} } {
      # <help>
      # This procedure installs, removes, or queries the Anthropic-backed
      # [unknown] command handler in the active interpreter, returning a boolean
      # result.  It is the Anthropic counterpart of [openAI_enableUnknown]; its
      # purpose is to route otherwise-invalid command names through Anthropic
      # (Claude) for correction/suggestion (via [anthropic_unknown]) while being
      # able to cleanly restore the interpreter's built-in default handler.
      #
      # How it works: it reads the interpreter's built-in default unknown
      # handler and the currently installed handler.  The "enable" argument
      # selects the mode.  When "enable" is true, and only if the current
      # handler is still the default, it installs the new handler -- the list
      # ::anthropic_unknown plus the whatIf, channel, and quiet arguments -- and
      # (when "options" is true) adds the tcltkUnknownAnthropic,
      # tcltkUnknownEnableSecurity, and tcltkUnknownAutomaticAnthropic runtime
      # options, returning true.  When "enable" is false, and only if the
      # current handler is exactly that previously installed handler, it
      # restores the default handler and (when "options" is true) removes those
      # same runtime options, returning true.  When "enable" is empty, it
      # queries: it returns false if the default handler is in place, otherwise
      # (when "options" is true) it returns false unless all three runtime
      # options are present, and true otherwise.
      #
      # Tricky details: the install/remove operations are guarded so they only
      # act when the interpreter is in the expected starting state, returning
      # false when that guard is not satisfied.  The whatIf, channel, and quiet
      # values are baked into the installed handler command and so must match
      # for a later disable to recognize and remove it.
      #
      # Arguments:
      #   enable  -- A boolean selecting install (true) or remove (false), or
      #              the empty string (the default) to query current state.
      #   options -- When true (the default), the corresponding runtime options
      #              are added/removed/checked alongside the handler.
      #   whatIf  -- Baked into the installed handler; when true the handler
      #              operates in a non-committal mode; defaults to true.
      #   channel -- Baked into the installed handler for its output; defaults
      #              to "stdout".
      #   quiet   -- Baked into the installed handler to suppress messages;
      #              defaults to false.
      #
      # Results:
      #   The literal "true" on a successful install/remove, or in query mode
      #   when the Anthropic handler is active (and, if checked, all required
      #   options are set); the literal "false" otherwise.
      # </help>

      set defaultUnknown [object invoke -flags +NonPublic \
          CodeBrix.Platform.TclTk._Components.Private.TclVars+Command Unknown]

      set oldUnknown [object invoke Interpreter.GetActive Unknown]

      if {[string length $enable] > 0} then {
        set newUnknown [list ::anthropic_unknown $whatIf $channel $quiet]

        if {$enable} then {
          if {$oldUnknown eq $defaultUnknown} then {
            object invoke Interpreter.GetActive Unknown $newUnknown

            if {$options} then {
              addRuntimeOption tcltkUnknownAnthropic
              addRuntimeOption tcltkUnknownEnableSecurity
              addRuntimeOption tcltkUnknownAutomaticAnthropic
            }

            return true
          }
        } else {
          if {$oldUnknown eq $newUnknown} then {
            object invoke Interpreter.GetActive Unknown $defaultUnknown

            if {$options} then {
              removeRuntimeOption tcltkUnknownAnthropic
              removeRuntimeOption tcltkUnknownEnableSecurity
              removeRuntimeOption tcltkUnknownAutomaticAnthropic
            }

            return true
          }
        }
      } else {
        if {$oldUnknown eq $defaultUnknown} then {
          return false
        }

        if {$options} then {
          if {![hasRuntimeOption tcltkUnknownAnthropic] || \
              ![hasRuntimeOption tcltkUnknownEnableSecurity] || \
              ![hasRuntimeOption tcltkUnknownAutomaticAnthropic]} then {
            return false
          }
        }

        return true
      }

      return false
    }

    proc verifyConfigurationDirectory { directory {pattern ""} } {
      # <help>
      # This procedure validates that the specified directory is usable as a
      # configuration directory (and, optionally, that it contains readable
      # files matching a pattern), raising an error on any problem and otherwise
      # returning a boolean.  It exists to give callers a single fail-fast check
      # with clear, specific diagnostics before they attempt to load
      # configuration or keyring material from a directory.
      #
      # How it works: it checks, in order, that the directory string has valid
      # path syntax, that it exists, that it is actually a directory, and that
      # it is readable; each failed check raises an error whose message names
      # the offending directory and the specific failure.  If a non-empty
      # "pattern" is supplied, the directory is normalized and globbed for files
      # matching that pattern: when none match, the procedure returns false;
      # when some match, each matching file must be readable or an error is
      # raised naming the unreadable file.
      #
      # Tricky details: the procedure distinguishes "directory is fine but no
      # files match the pattern" (returns false) from outright invalid or
      # inaccessible directories (raise errors).  When no pattern is given, the
      # file-presence check is skipped entirely and a valid, readable directory
      # simply yields true.
      #
      # Arguments:
      #   directory -- The directory path to validate.
      #   pattern   -- Optional glob pattern; when non-empty, the directory must
      #                contain at least one matching, readable file.
      #
      # Results:
      #   The literal "true" when the directory passes all checks (and, if a
      #   pattern was given, at least one matching readable file exists); the
      #   literal "false" when a pattern was given but no files match.  Raises a
      #   descriptive error for any invalid, missing, non-directory, or
      #   unreadable path, or for an unreadable matching file.
      # </help>

      if {[string is not path -strict $directory]} then {
        error [appendArgs \
            "verifyConfigurationDirectory: directory \"" \
            $directory "\" has invalid syntax"]
      }

      if {![file exists $directory]} then {
        error [appendArgs \
            "verifyConfigurationDirectory: directory \"" \
            $directory "\" does not exist"]
      }

      if {![file isdirectory $directory]} then {
        error [appendArgs \
            "verifyConfigurationDirectory: directory \""
            $directory "\" is not actually a directory"]
      }

      if {![file readable $directory]} then {
        error [appendArgs \
            "verifyConfigurationDirectory: directory \"" \
            $directory "\" is not readable"]
      }

      if {[string length $pattern] > 0} then {
        set directory [file normalize $directory]

        set fileNames [glob -nocomplain \
            [file join $directory $pattern]]

        if {[llength $fileNames] == 0} then {
          return false
        }

        foreach fileName $fileNames {
          if {![file readable $fileName]} then {
            error [appendArgs \
                "verifyConfigurationDirectory: file \"" \
                $fileName "\" is not readable"]
          }
        }
      }

      return true
    }

    proc openAI_getKeyRingDirectory { {channel stdout} {quiet false} } {
      # <help>
      # This procedure locates the directory that contains the OpenAI script
      # keyring file (keyRing.two.tcltk) and returns that directory, raising an
      # error if the keyring cannot be found.  It exists so that
      # [openAI_enableSecurity] can find and merge the trusted keyring before
      # making signed remote requests, and it supports both explicit
      # configuration and a brute-force search of likely locations.
      #
      # How it works: the ::beforeOpenAI_getKeyRingDirectory tester hook fires
      # first, and the local "result" may be pre-populated to override the
      # search.  Absent an override: if the OPENAI_KEYRING_DIRECTORY environment
      # variable is set, that directory is used provided it actually contains
      # the keyring file.  Otherwise it builds a candidate list -- the binary
      # directory, the keyring command's own directory (when the keyring command
      # exists), and the KAPOK_KEYRING_PATH, KAPOK_BIN_PATH, and KAPOK_LIB_PATH
      # environment directories -- and returns the first candidate that contains
      # the keyring file.  Several after-hooks fire on success.  Unless "quiet"
      # is true, an informational line naming the chosen (or overridden)
      # directory is written to "channel".
      #
      # Tricky details: if no candidate contains the keyring file, the
      # ::errorOpenAI_getKeyRingDirectory hook fires and an error is raised
      # stating the keyring file was not found; callers needing graceful
      # handling must catch it.  The override path short-circuits the entire
      # search.
      #
      # Arguments:
      #   channel -- Channel for the informational message; defaults to
      #              "stdout".
      #   quiet   -- When true, suppresses the informational message; defaults
      #              to false.
      #
      # Results:
      #   The directory path containing the OpenAI keyring file.  Raises a script
      #   error when the keyring cannot be located.
      # </help>

      set result ""; set fileNameOnly keyRing.two.tcltk
      maybeInvokeForTester ::beforeOpenAI_getKeyRingDirectory; # HOOK

      if {[string length $result] == 0} then {
        if {[info exists ::env(OPENAI_KEYRING_DIRECTORY)]} then {
          set directory $::env(OPENAI_KEYRING_DIRECTORY)
          set fileName [file join $directory $fileNameOnly]

          if {[file exists $fileName]} then {
            set result $directory
            maybeInvokeForTester ::afterOpenAI_getKeyRingDirectory; # HOOK

            if {!$quiet} then {
              tputs $channel [appendArgs \
                  "---- keyring directory for OpenAI is \"" $result \"\n]
            }

            return $result
          }
        } else {
          set directories [list [info binary]]

          if {[llength [info commands keyring]] > 0} then {
            lappend directories [keyring directory]
          }

          if {[info exists ::env(KAPOK_KEYRING_PATH)]} then {
            lappend directories $::env(KAPOK_KEYRING_PATH)
          }

          if {[info exists ::env(KAPOK_BIN_PATH)]} then {
            lappend directories $::env(KAPOK_BIN_PATH)
          }

          if {[info exists ::env(KAPOK_LIB_PATH)]} then {
            lappend directories $::env(KAPOK_LIB_PATH)
          }

          foreach directory $directories {
            set fileName [file join $directory $fileNameOnly]

            if {[file exists $fileName]} then {
              set result $directory
              maybeInvokeForTester ::after_openAI_getKeyRingDirectory; # HOOK

              if {!$quiet} then {
                tputs $channel [appendArgs \
                    "---- keyring directory for OpenAI is \"" $result \"\n]
              }

              return $result
            }
          }
        }
      } else {
        if {!$quiet} then {
          tputs $channel [appendArgs \
              "---- keyring directory for OpenAI overridden to \"" \
              $result \"\n]
        }

        return $result
      }

      maybeInvokeForTester ::errorOpenAI_getKeyRingDirectory; # HOOK

      error [appendArgs \
          "remote script keyring \"" $fileNameOnly "\" not found"]
    }

    proc anthropic_getKeyRingDirectory { {channel stdout} {quiet false} } {
      # <help>
      # This procedure locates the directory that contains the Anthropic script
      # keyring file (keyRing.two.tcltk) and returns that directory, raising an
      # error if the keyring cannot be found.  It is the Anthropic counterpart
      # of [openAI_getKeyRingDirectory] and is used by
      # [anthropic_enableSecurity] to find and merge the trusted keyring before
      # making signed remote requests.
      #
      # How it works: the ::beforeAnthropic_getKeyRingDirectory tester hook
      # fires first, and the local "result" may be pre-populated to override the
      # search.  Absent an override: if the ANTHROPIC_KEYRING_DIRECTORY
      # environment variable is set, that directory is used provided it actually
      # contains the keyring file.  Otherwise it builds a candidate list -- the
      # binary directory, the keyring command's own directory (when the keyring
      # command exists), and the KAPOK_KEYRING_PATH, KAPOK_BIN_PATH, and
      # KAPOK_LIB_PATH environment directories -- and returns the first
      # candidate that contains the keyring file.  Several after-hooks fire on
      # success.  Unless "quiet" is true, an informational line naming the
      # chosen (or overridden) directory is written to "channel".
      #
      # Tricky details: if no candidate contains the keyring file, the
      # ::errorAnthropic_getKeyRingDirectory hook fires and an error is raised
      # stating the keyring file was not found; callers needing graceful
      # handling must catch it.  The override path short-circuits the entire
      # search.
      #
      # Arguments:
      #   channel -- Channel for the informational message; defaults to
      #              "stdout".
      #   quiet   -- When true, suppresses the informational message; defaults
      #              to false.
      #
      # Results:
      #   The directory path containing the Anthropic keyring file.  Raises a
      #   script error when the keyring cannot be located.
      # </help>

      set result ""; set fileNameOnly keyRing.two.tcltk
      maybeInvokeForTester ::beforeAnthropic_getKeyRingDirectory; # HOOK

      if {[string length $result] == 0} then {
        if {[info exists ::env(ANTHROPIC_KEYRING_DIRECTORY)]} then {
          set directory $::env(ANTHROPIC_KEYRING_DIRECTORY)
          set fileName [file join $directory $fileNameOnly]

          if {[file exists $fileName]} then {
            set result $directory
            maybeInvokeForTester ::afterAnthropic_getKeyRingDirectory; # HOOK

            if {!$quiet} then {
              tputs $channel [appendArgs \
                  "---- keyring directory for Anthropic is \"" $result \"\n]
            }

            return $result
          }
        } else {
          set directories [list [info binary]]

          if {[llength [info commands keyring]] > 0} then {
            lappend directories [keyring directory]
          }

          if {[info exists ::env(KAPOK_KEYRING_PATH)]} then {
            lappend directories $::env(KAPOK_KEYRING_PATH)
          }

          if {[info exists ::env(KAPOK_BIN_PATH)]} then {
            lappend directories $::env(KAPOK_BIN_PATH)
          }

          if {[info exists ::env(KAPOK_LIB_PATH)]} then {
            lappend directories $::env(KAPOK_LIB_PATH)
          }

          foreach directory $directories {
            set fileName [file join $directory $fileNameOnly]

            if {[file exists $fileName]} then {
              set result $directory
              maybeInvokeForTester \
                  ::after_anthropic_getKeyRingDirectory; # HOOK

              if {!$quiet} then {
                tputs $channel [appendArgs \
                    "---- keyring directory for Anthropic is \"" \
                    $result \"\n]
              }

              return $result
            }
          }
        }
      } else {
        if {!$quiet} then {
          tputs $channel [appendArgs \
              "---- keyring directory for Anthropic overridden to \"" \
              $result \"\n]
        }

        return $result
      }

      maybeInvokeForTester ::errorAnthropic_getKeyRingDirectory; # HOOK

      error [appendArgs \
          "remote script keyring \"" $fileNameOnly "\" not found"]
    }

    proc openAI_writeScript { script } {
      # <help>
      # This procedure writes the specified script text to a freshly created
      # temporary .tcltk file and returns that file's name.  It exists so that
      # script content returned by OpenAI can be materialized on disk and then
      # sourced or evaluated (for example, within a sandbox) by the OpenAI
      # unknown-command handler.
      #
      # How it works: it constructs a temporary file name with a .tcltk
      # extension via [file tempname], registers that name for automatic cleanup
      # with [file cleanup], writes the script to it with [writeFile], and
      # returns the file name.  A finally block ensures that, regardless of how
      # the body exits, the file name (if it was created) is again passed to
      # [file cleanup] inside a [catch].
      #
      # Tricky details: because the file is registered for cleanup, it is a
      # short-lived scratch file; callers that need to read it must do so before
      # cleanup runs.  The cleanup in the finally clause is best-effort and
      # swallows errors.
      #
      # Arguments:
      #   script -- The script text to write to the temporary file.
      #
      # Results:
      #   The name of the temporary .tcltk file containing the script.
      # </help>

      try {
        set fileName [appendArgs [file tempname] .tcltk]

        file cleanup $fileName
        writeFile $fileName $script

        return $fileName
      } finally {
        if {[info exists fileName]} then {
          catch {file cleanup $fileName}
        }
      }
    }

    proc anthropic_writeScript { script } {
      # <help>
      # This procedure writes the specified script text to a freshly created
      # temporary .tcltk file and returns that file's name.  It is the Anthropic
      # counterpart of [openAI_writeScript] and behaves identically; it exists
      # so that script content returned by Anthropic can be materialized on disk
      # and then sourced or evaluated (for example, within a sandbox) by the
      # Anthropic unknown-command handler.
      #
      # How it works: it constructs a temporary file name with a .tcltk
      # extension via [file tempname], registers that name for automatic cleanup
      # with [file cleanup], writes the script to it with [writeFile], and
      # returns the file name.  A finally block ensures that, regardless of how
      # the body exits, the file name (if it was created) is again passed to
      # [file cleanup] inside a [catch].
      #
      # Tricky details: because the file is registered for cleanup, it is a
      # short-lived scratch file; callers that need to read it must do so before
      # cleanup runs.  The cleanup in the finally clause is best-effort and
      # swallows errors.
      #
      # Arguments:
      #   script -- The script text to write to the temporary file.
      #
      # Results:
      #   The name of the temporary .tcltk file containing the script.
      # </help>

      try {
        set fileName [appendArgs [file tempname] .tcltk]

        file cleanup $fileName
        writeFile $fileName $script

        return $fileName
      } finally {
        if {[info exists fileName]} then {
          catch {file cleanup $fileName}
        }
      }
    }

    proc openAI_haveSecurity { {channel stdout} {quiet false} } {
      # <help>
      # This procedure reports whether script security is currently active in
      # the interpreter, returning a boolean result.  It is used by the OpenAI
      # unknown-command handler and its sandbox helper to decide whether it is
      # safe to actually evaluate model-supplied script content (which should
      # only happen when signed-script security is in force).
      #
      # How it works: it checks that the security command exists (provided by
      # the Security.Core plugin) and then invokes that command with an empty
      # argument to query the current state -- effectively asking whether the
      # "allow signed only" policy is engaged.  It returns true only when both
      # the command exists and that query is true; otherwise it returns false.
      #
      # Tricky details: the "channel" and "quiet" arguments are accepted for
      # signature symmetry with the other OpenAI helpers but are not used by the
      # body.  When the security plugin is absent the procedure simply returns
      # false rather than erroring.
      #
      # Arguments:
      #   channel -- Accepted for symmetry; not used.  Defaults to "stdout".
      #   quiet   -- Accepted for symmetry; not used.  Defaults to false.
      #
      # Results:
      #   The literal "true" if signed-script security is active, or the literal
      #   "false" otherwise (including when the security command is unavailable).
      # </help>

      if {[llength [info commands security]] > 0} then {; # Security.Core
        if {[security ""]} then {; # AllowSignedOnly (?)
          return true
        }
      }

      return false
    }

    proc anthropic_haveSecurity { {channel stdout} {quiet false} } {
      # <help>
      # This procedure reports whether script security is currently active in
      # the interpreter, returning a boolean result.  It is the Anthropic
      # counterpart of [openAI_haveSecurity] and behaves identically; it is used
      # by the Anthropic unknown-command handler and its sandbox helper to
      # decide whether it is safe to actually evaluate model-supplied script
      # content.
      #
      # How it works: it checks that the security command exists (provided by
      # the Security.Core plugin) and then invokes that command with an empty
      # argument to query the current state -- effectively asking whether the
      # "allow signed only" policy is engaged.  It returns true only when both
      # the command exists and that query is true; otherwise it returns false.
      #
      # Tricky details: the "channel" and "quiet" arguments are accepted for
      # signature symmetry with the other Anthropic helpers but are not used by
      # the body.  When the security plugin is absent the procedure simply
      # returns false rather than erroring.
      #
      # Arguments:
      #   channel -- Accepted for symmetry; not used.  Defaults to "stdout".
      #   quiet   -- Accepted for symmetry; not used.  Defaults to false.
      #
      # Results:
      #   The literal "true" if signed-script security is active, or the literal
      #   "false" otherwise (including when the security command is unavailable).
      # </help>

      if {[llength [info commands security]] > 0} then {; # Security.Core
        if {[security ""]} then {; # AllowSignedOnly (?)
          return true
        }
      }

      return false
    }

    proc openAI_enableSecurity {
            {varName ""} {channel stdout} {quiet false} } {
      # <help>
      # This procedure attempts to enable script security and merge the OpenAI
      # trusted keyring into the active interpreter, returning a boolean
      # indicating whether security is now in effect.  It is invoked by the
      # OpenAI unknown-command handler so that model-supplied scripts can be
      # safely signed-verified before evaluation.
      #
      # How it works: inside a [catch], it sources the "enableSecurity" script
      # (which engages signed-script security) and then merges the
      # keyRing.two.tcltk keyring located via [openAI_getKeyRingDirectory] into
      # the interpreter's keyring.  Unless "quiet" is true, it reports the new
      # trusted script keyring.  If the entire sequence succeeds, the result is
      # true; if any step raises an error, the error is swallowed and the result
      # is false.
      #
      # Tricky details: when "varName" is non-empty, that variable in the
      # caller's frame is also set to the same boolean outcome, so the caller
      # can both receive the return value and observe it through the variable.
      # Failures (missing keyring, missing security support, and so on) are
      # intentionally non-fatal here, leaving security simply disabled.
      #
      # Arguments:
      #   varName -- Optional name of a caller variable to receive the boolean
      #              outcome; ignored when empty.
      #   channel -- Channel for the informational keyring message; defaults to
      #              "stdout".
      #   quiet   -- When true, suppresses the informational message; defaults
      #              to false.
      #
      # Results:
      #   The literal "true" if security was enabled and the keyring merged
      #   successfully, or the literal "false" otherwise.
      # </help>

      if {[string length $varName] > 0} then {
        upvar 1 $varName haveSecurity
      }

      if {[catch {
        source enableSecurity

        keyring merge [file join \
            [openAI_getKeyRingDirectory $channel $quiet] \
            keyRing.two.tcltk]; # 0x180558840e482cda

        if {!$quiet} then {
          tputs $channel [appendArgs \
              "---- trusted script keyring is now: " \
              [keyring script] \n]
        }
      } error] == 0} then {
        set haveSecurity true
      } else {
        set haveSecurity false
      }

      return $haveSecurity
    }

    proc anthropic_enableSecurity {
            {varName ""} {channel stdout} {quiet false} } {
      # <help>
      # This procedure attempts to enable script security and merge the
      # Anthropic trusted keyring into the active interpreter, returning a
      # boolean indicating whether security is now in effect.  It is the
      # Anthropic counterpart of [openAI_enableSecurity] and is invoked by the
      # Anthropic unknown-command handler so that model-supplied scripts can be
      # safely signed-verified before evaluation.
      #
      # How it works: inside a [catch], it sources the "enableSecurity" script
      # (which engages signed-script security) and then merges the
      # keyRing.two.tcltk keyring located via [anthropic_getKeyRingDirectory]
      # into the interpreter's keyring.  Unless "quiet" is true, it reports the
      # new trusted script keyring.  If the entire sequence succeeds, the result
      # is true; if any step raises an error, the error is swallowed and the
      # result is false.
      #
      # Tricky details: when "varName" is non-empty, that variable in the
      # caller's frame is also set to the same boolean outcome.  Failures
      # (missing keyring, missing security support, and so on) are intentionally
      # non-fatal here, leaving security simply disabled.
      #
      # Arguments:
      #   varName -- Optional name of a caller variable to receive the boolean
      #              outcome; ignored when empty.
      #   channel -- Channel for the informational keyring message; defaults to
      #              "stdout".
      #   quiet   -- When true, suppresses the informational message; defaults
      #              to false.
      #
      # Results:
      #   The literal "true" if security was enabled and the keyring merged
      #   successfully, or the literal "false" otherwise.
      # </help>

      if {[string length $varName] > 0} then {
        upvar 1 $varName haveSecurity
      }

      if {[catch {
        source enableSecurity

        keyring merge [file join \
            [anthropic_getKeyRingDirectory $channel $quiet] \
            keyRing.two.tcltk]; # 0x180558840e482cda

        if {!$quiet} then {
          tputs $channel [appendArgs \
              "---- trusted script keyring is now: " \
              [keyring script] \n]
        }
      } error] == 0} then {
        set haveSecurity true
      } else {
        set haveSecurity false
      }

      return $haveSecurity
    }

    proc openAI_cleanupSandbox { {channel stdout} {quiet false} } {
      # <help>
      # This procedure tears down the sandbox child interpreter used to safely
      # evaluate OpenAI-supplied scripts, returning an empty string.  It exists
      # so callers can reclaim the sandbox created by
      # [openAI_maybeEvaluateInSandbox] once it is no longer needed, leaving no
      # stale interpreter behind.
      #
      # How it works: the ::beforeOpenAI_cleanupSandbox tester hook fires first.
      # If the tcltk_debugger(sandbox) global exists and names a valid
      # interpreter, that interpreter is deleted with [interp delete], the
      # ::cleanupOpenAI_sandbox hook fires, and (unless "quiet" is true) a
      # message naming the deleted interpreter is written to "channel".  The
      # ::afterOpenAI_cleanupSandbox hook then fires, and finally the
      # tcltk_debugger(sandbox) element is unset (without complaint if absent).
      #
      # Tricky details: it is safe to call even when no sandbox exists -- the
      # deletion is guarded and the unset is no-complaint -- so it can be used
      # unconditionally as a cleanup step.
      #
      # Arguments:
      #   channel -- Channel for the informational message; defaults to
      #              "stdout".
      #   quiet   -- When true, suppresses the informational message; defaults
      #              to false.
      #
      # Results:
      #   The empty string.
      # </help>

      maybeInvokeForTester ::beforeOpenAI_cleanupSandbox; # HOOK

      if {[info exists ::tcltk_debugger(sandbox)] && \
          [string is interpreter $::tcltk_debugger(sandbox)]} then {
        set interp $::tcltk_debugger(sandbox)

        interp delete $interp
        maybeInvokeForTester ::cleanupOpenAI_sandbox; # HOOK

        if {!$quiet} then {
          tputs $channel [appendArgs \
              "---- sandbox interpreter \"" $interp "\" deleted\n"]
        }
      }

      maybeInvokeForTester ::afterOpenAI_cleanupSandbox; # HOOK
      unset -nocomplain ::tcltk_debugger(sandbox)

      return ""
    }

    proc anthropic_cleanupSandbox { {channel stdout} {quiet false} } {
      # <help>
      # This procedure tears down the sandbox child interpreter used to safely
      # evaluate Anthropic-supplied scripts, returning an empty string.  It is
      # the Anthropic counterpart of [openAI_cleanupSandbox]; it lets callers
      # reclaim the sandbox created by [anthropic_maybeEvaluateInSandbox] once
      # it is no longer needed.
      #
      # How it works: the ::beforeAnthropic_cleanupSandbox tester hook fires
      # first.  If the tcltk_debugger(sandbox) global exists and names a valid
      # interpreter, that interpreter is deleted with [interp delete], the
      # ::cleanupAnthropic_sandbox hook fires, and (unless "quiet" is true) a
      # message naming the deleted interpreter is written to "channel".  The
      # ::afterAnthropic_cleanupSandbox hook then fires, and finally the
      # tcltk_debugger(sandbox) element is unset (without complaint if absent).
      #
      # Tricky details: it is safe to call even when no sandbox exists -- the
      # deletion is guarded and the unset is no-complaint -- so it can be used
      # unconditionally as a cleanup step.
      #
      # Arguments:
      #   channel -- Channel for the informational message; defaults to
      #              "stdout".
      #   quiet   -- When true, suppresses the informational message; defaults
      #              to false.
      #
      # Results:
      #   The empty string.
      # </help>

      maybeInvokeForTester ::beforeAnthropic_cleanupSandbox; # HOOK

      if {[info exists ::tcltk_debugger(sandbox)] && \
          [string is interpreter $::tcltk_debugger(sandbox)]} then {
        set interp $::tcltk_debugger(sandbox)

        interp delete $interp
        maybeInvokeForTester ::cleanupAnthropic_sandbox; # HOOK

        if {!$quiet} then {
          tputs $channel [appendArgs \
              "---- sandbox interpreter \"" $interp "\" deleted\n"]
        }
      }

      maybeInvokeForTester ::afterAnthropic_cleanupSandbox; # HOOK
      unset -nocomplain ::tcltk_debugger(sandbox)

      return ""
    }

    proc openAI_maybeEvaluateInSandbox {
            fileName security {channel stdout} {quiet false} } {
      # <help>
      # This procedure evaluates a script file inside an isolated, reusable
      # safe child interpreter (the sandbox), returning the script's result.  It
      # exists so that potentially untrusted script content suggested by OpenAI
      # can be run with reduced privileges rather than directly in the caller's
      # interpreter.
      #
      # How it works: if no sandbox interpreter currently exists (the
      # tcltk_debugger(sandbox) global is missing or no longer names a valid
      # interpreter), it creates a new safe interpreter with [interp create
      # -safe], stores its handle in tcltk_debugger(sandbox), fires the
      # ::createOpenAI_sandbox hook, and (unless "quiet") reports the creation;
      # otherwise it reuses the existing sandbox and fires ::reuseOpenAI_sandbox.
      # Surrounding hooks ::beforeOpenAI_evaluateInSandbox and
      # ::afterOpenAI_evaluateInSandbox also fire.  It then requires that
      # security be available -- via [openAI_haveSecurity] -- before reading the
      # script file and evaluating it in the sandbox with [interp eval]; if
      # security is unavailable, it raises an error rather than running the
      # script.
      #
      # Tricky details: the sandbox is persistent across calls (cached in
      # tcltk_debugger(sandbox)) and is meant to be torn down later with
      # [openAI_cleanupSandbox].  The "security" argument is accepted but the
      # actual gating decision is made by re-checking [openAI_haveSecurity] at
      # evaluation time, so the script only runs when signed-script security is
      # genuinely in force.
      #
      # Arguments:
      #   fileName -- The path of the script file to read and evaluate in the
      #               sandbox.
      #   security -- A security indication from the caller; the procedure still
      #               independently verifies security before evaluating.
      #   channel  -- Channel for informational messages; defaults to "stdout".
      #   quiet    -- When true, suppresses informational messages; defaults to
      #               false.
      #
      # Results:
      #   The result of evaluating the script in the sandbox.  Raises an error
      #   when security is unavailable.
      # </help>

      maybeInvokeForTester ::beforeOpenAI_evaluateInSandbox; # HOOK

      if {![info exists ::tcltk_debugger(sandbox)] || [string \
          is not interpreter $::tcltk_debugger(sandbox)]} then {
        set ::tcltk_debugger(sandbox) [set interp [interp create -safe]]
        maybeInvokeForTester ::createOpenAI_sandbox; # HOOK

        if {!$quiet} then {
          tputs $channel [appendArgs \
              "---- sandbox interpreter \"" $interp "\" created\n"]
        }
      } else {
        set interp $::tcltk_debugger(sandbox)
        maybeInvokeForTester ::reuseOpenAI_sandbox; # HOOK
      }

      maybeInvokeForTester ::afterOpenAI_evaluateInSandbox; # HOOK

      if {[openAI_haveSecurity $channel $quiet]} then {
        return [interp eval $interp \
            [interp readorgetscriptfile {} $fileName]]
      } else {
        error [appendArgs \
            "security unavailable for sandbox in context: " \
            [info context]]
      }
    }

    proc anthropic_maybeEvaluateInSandbox {
            fileName security {channel stdout} {quiet false} } {
      # <help>
      # This procedure evaluates a script file inside an isolated, reusable
      # safe child interpreter (the sandbox), returning the script's result.  It
      # is the Anthropic counterpart of [openAI_maybeEvaluateInSandbox]; it lets
      # potentially untrusted script content suggested by Anthropic run with
      # reduced privileges rather than directly in the caller's interpreter.
      #
      # How it works: if no sandbox interpreter currently exists (the
      # tcltk_debugger(sandbox) global is missing or no longer names a valid
      # interpreter), it creates a new safe interpreter with [interp create
      # -safe], stores its handle in tcltk_debugger(sandbox), fires the
      # ::createAnthropic_sandbox hook, and (unless "quiet") reports the
      # creation; otherwise it reuses the existing sandbox and fires
      # ::reuseAnthropic_sandbox.  Surrounding hooks
      # ::beforeAnthropic_evaluateInSandbox and ::afterAnthropic_evaluateInSandbox
      # also fire.  It then requires that security be available -- via
      # [anthropic_haveSecurity] -- before reading the script file and
      # evaluating it in the sandbox with [interp eval]; if security is
      # unavailable, it raises an error rather than running the script.
      #
      # Tricky details: the sandbox is persistent across calls (cached in
      # tcltk_debugger(sandbox)) and is meant to be torn down later with
      # [anthropic_cleanupSandbox].  The "security" argument is accepted but the
      # actual gating decision is made by re-checking [anthropic_haveSecurity]
      # at evaluation time, so the script only runs when signed-script security
      # is genuinely in force.
      #
      # Arguments:
      #   fileName -- The path of the script file to read and evaluate in the
      #               sandbox.
      #   security -- A security indication from the caller; the procedure still
      #               independently verifies security before evaluating.
      #   channel  -- Channel for informational messages; defaults to "stdout".
      #   quiet    -- When true, suppresses informational messages; defaults to
      #               false.
      #
      # Results:
      #   The result of evaluating the script in the sandbox.  Raises an error
      #   when security is unavailable.
      # </help>

      maybeInvokeForTester ::beforeAnthropic_evaluateInSandbox; # HOOK

      if {![info exists ::tcltk_debugger(sandbox)] || [string \
          is not interpreter $::tcltk_debugger(sandbox)]} then {
        set ::tcltk_debugger(sandbox) [set interp [interp create -safe]]
        maybeInvokeForTester ::createAnthropic_sandbox; # HOOK

        if {!$quiet} then {
          tputs $channel [appendArgs \
              "---- sandbox interpreter \"" $interp "\" created\n"]
        }
      } else {
        set interp $::tcltk_debugger(sandbox)
        maybeInvokeForTester ::reuseAnthropic_sandbox; # HOOK
      }

      maybeInvokeForTester ::afterAnthropic_evaluateInSandbox; # HOOK

      if {[anthropic_haveSecurity $channel $quiet]} then {
        return [interp eval $interp \
            [interp readorgetscriptfile {} $fileName]]
      } else {
        error [appendArgs \
            "security unavailable for sandbox in context: " \
            [info context]]
      }
    }

    proc openAI_unknown { whatIf channel quiet name args } {
      # <help>
      # This procedure is an [unknown] command handler that, when enabled, asks
      # OpenAI to correct or suggest a replacement for a command that could not
      # be resolved, optionally evaluating the model's reply.  It exists to give
      # an interactive or test session an AI-assisted recovery path for invalid
      # command names; when not enabled it simply produces the standard "invalid
      # command name" error.  It is installed (and removed) via
      # [openAI_enableUnknown].
      #
      # How it works: it acts only when the tcltkUnknownOpenAI runtime option is
      # set.  In that case, inside a [catch], it optionally enables security
      # (when tcltkUnknownEnableSecurity is set) via [openAI_enableSecurity],
      # loads Newtonsoft.Json, reconstructs the failing command from "name" and
      # "args", and calls [openAI_chatCompletion] with a prompt from
      # [openAI_getPrompt].  The reply's content is extracted with
      # [getOrSetViaJsonPaths] using [openAI_getJsonPaths].  If content is
      # returned and automatic mode (tcltkUnknownAutomaticOpenAI) is set and
      # security is available, the content is written to a temp file via
      # [openAI_writeScript] and then either evaluated in the sandbox (when
      # tcltkUnknownSandboxOpenAI is set) or sourced in the caller's frame; on
      # success that result is returned with code ok.  Otherwise the content (or
      # the raw response) is returned as an error.  Numerous tester hooks fire
      # at the before/after/error points throughout.
      #
      # Tricky details: this handler can execute model-supplied code, so it is
      # deliberately gated behind multiple runtime options and a security check;
      # automatic evaluation only happens when both automatic mode and security
      # are in effect.  When "whatIf" is true the request is made in a
      # non-committal mode.  If anything in the AI path fails or is disabled, it
      # falls through to the conventional invalid-command-name error.
      #
      # Arguments:
      #   whatIf  -- When true, perform the request in a non-committal mode.
      #   channel -- Channel for informational and progress output.
      #   quiet   -- When true, suppress informational messages.
      #   name    -- The unresolved command name that triggered [unknown].
      #   args    -- The remaining arguments that were passed to that command.
      #
      # Results:
      #   On a successful automatic evaluation, the script's result (code ok).
      #   Otherwise an error: the suggested content, the raw response, or the
      #   standard "invalid command name" message when the AI path is disabled
      #   or yields nothing.
      # </help>

      #
      # NOTE: This is an [unknown] procedure that normally produces an
      #       appropriate error message; however, it can optionally try
      #       to ask OpenAI for corrections and/or suggestions.
      #
      if {[hasRuntimeOption tcltkUnknownOpenAI]} then {
        set haveSecurity false

        if {[catch {
          if {[hasRuntimeOption tcltkUnknownEnableSecurity]} then {
            openAI_enableSecurity haveSecurity $channel $quiet
          }

          set assembly [object load Newtonsoft.Json]; # NOTE: Not loaded yet?
        } result] == 0} then {
          set command [list]

          lappend command $name
          eval lappend command $args

          set response [openAI_chatCompletion \
              prompt [openAI_getPrompt $command $channel $quiet] \
              whatIf $whatIf channel $channel quiet $quiet]

          if {[string length $response] > 0} then {
            set content [getOrSetViaJsonPaths $response \
                [openAI_getJsonPaths $response $channel $quiet]]

            maybeInvokeForTester ::beforeOpenAI_unknownContent; # HOOK

            if {[string length $content] > 0} then {
              if {[hasRuntimeOption tcltkUnknownAutomaticOpenAI]} then {
                if {$haveSecurity} then {
                  if {[catch {
                    set fileName [openAI_writeScript $content]
                    maybeInvokeForTester ::beforeOpenAI_sandbox; # HOOK

                    if {[hasRuntimeOption tcltkUnknownSandboxOpenAI]} then {
                      openAI_maybeEvaluateInSandbox \
                          $fileName $haveSecurity $channel $quiet
                    } elseif {[openAI_haveSecurity $channel $quiet]} then {
                      uplevel 1 [list source $fileName]
                    }
                  } result] == 0} then {
                    maybeInvokeForTester ::afterOpenAI_unknownContent; # HOOK
                    return -code ok $result
                  }
                }
              }

              maybeInvokeForTester ::errorOpenAI_unknownContent; # HOOK
              return -code error $content
            }

            maybeInvokeForTester ::errorOpenAI_unknownResponse; # HOOK
            return -code error $response
          }
        }
      }

      maybeInvokeForTester ::errorOpenAI_unknownCommand; # HOOK
      return -code error [appendArgs "invalid command name \"" $name \"]
    }

    proc anthropic_unknown { whatIf channel quiet name args } {
      # <help>
      # This procedure is an [unknown] command handler that, when enabled, asks
      # Anthropic (Claude) to correct or suggest a replacement for a command
      # that could not be resolved, optionally evaluating the model's reply.  It
      # is the Anthropic counterpart of [openAI_unknown]; when not enabled it
      # simply produces the standard "invalid command name" error.  It is
      # installed (and removed) via [anthropic_enableUnknown].
      #
      # How it works: it acts only when the tcltkUnknownAnthropic runtime option
      # is set.  In that case, inside a [catch], it optionally enables security
      # (when tcltkUnknownEnableSecurity is set) via [anthropic_enableSecurity],
      # loads Newtonsoft.Json, reconstructs the failing command from "name" and
      # "args", and calls [anthropic_chatCompletion] with a prompt from
      # [anthropic_getPrompt].  The reply's content is extracted with
      # [getOrSetViaJsonPaths] using [anthropic_getJsonPaths].  If content is
      # returned and automatic mode (tcltkUnknownAutomaticAnthropic) is set and
      # security is available, the content is written to a temp file via
      # [anthropic_writeScript] and then either evaluated in the sandbox (when
      # tcltkUnknownSandboxAnthropic is set) or sourced in the caller's frame;
      # on success that result is returned with code ok.  Otherwise the content
      # (or the raw response) is returned as an error.  Numerous tester hooks
      # fire at the before/after/error points throughout.
      #
      # Tricky details: this handler can execute model-supplied code, so it is
      # deliberately gated behind multiple runtime options and a security check;
      # automatic evaluation only happens when both automatic mode and security
      # are in effect.  When "whatIf" is true the request is made in a
      # non-committal mode.  If anything in the AI path fails or is disabled, it
      # falls through to the conventional invalid-command-name error.
      #
      # Arguments:
      #   whatIf  -- When true, perform the request in a non-committal mode.
      #   channel -- Channel for informational and progress output.
      #   quiet   -- When true, suppress informational messages.
      #   name    -- The unresolved command name that triggered [unknown].
      #   args    -- The remaining arguments that were passed to that command.
      #
      # Results:
      #   On a successful automatic evaluation, the script's result (code ok).
      #   Otherwise an error: the suggested content, the raw response, or the
      #   standard "invalid command name" message when the AI path is disabled
      #   or yields nothing.
      # </help>

      #
      # NOTE: This is an [unknown] procedure that normally produces an
      #       appropriate error message; however, it can optionally try
      #       to ask Anthropic (Claude) for corrections and/or suggestions.
      #
      if {[hasRuntimeOption tcltkUnknownAnthropic]} then {
        set haveSecurity false

        if {[catch {
          if {[hasRuntimeOption tcltkUnknownEnableSecurity]} then {
            anthropic_enableSecurity haveSecurity $channel $quiet
          }

          set assembly [object load Newtonsoft.Json]; # NOTE: Not loaded yet?
        } result] == 0} then {
          set command [list]

          lappend command $name
          eval lappend command $args

          set response [anthropic_chatCompletion \
              prompt [anthropic_getPrompt $command $channel $quiet] \
              whatIf $whatIf channel $channel quiet $quiet]

          if {[string length $response] > 0} then {
            set content [getOrSetViaJsonPaths $response \
                [anthropic_getJsonPaths $response $channel $quiet]]

            maybeInvokeForTester ::beforeAnthropic_unknownContent; # HOOK

            if {[string length $content] > 0} then {
              if {[hasRuntimeOption tcltkUnknownAutomaticAnthropic]} then {
                if {$haveSecurity} then {
                  if {[catch {
                    set fileName [anthropic_writeScript $content]
                    maybeInvokeForTester ::beforeAnthropic_sandbox; # HOOK

                    if {[hasRuntimeOption \
                        tcltkUnknownSandboxAnthropic]} then {
                      anthropic_maybeEvaluateInSandbox \
                          $fileName $haveSecurity $channel $quiet
                    } elseif {[anthropic_haveSecurity \
                        $channel $quiet]} then {
                      uplevel 1 [list source $fileName]
                    }
                  } result] == 0} then {
                    maybeInvokeForTester \
                        ::afterAnthropic_unknownContent; # HOOK

                    return -code ok $result
                  }
                }
              }

              maybeInvokeForTester ::errorAnthropic_unknownContent; # HOOK
              return -code error $content
            }

            maybeInvokeForTester ::errorAnthropic_unknownResponse; # HOOK
            return -code error $response
          }
        }
      }

      maybeInvokeForTester ::errorAnthropic_unknownCommand; # HOOK
      return -code error [appendArgs "invalid command name \"" $name \"]
    }

    #
    # NOTE: This procedure may be by the _Tests.Default.ScriptWebClient class
    #       methods when it has been setup for an interpreter.  This procedure
    #       is designed to be used with the [openAI] procedure (below).  This
    #       procedure must reside in the global namespace.
    #
    # <callback>
    nproc openAI_scriptWebClient { args } {
      if {[catch {
        string trimleft [lindex [info level -1] 0] :; # NOTE: Which caller?
      } level]} then {
        set level ""
      }

      maybeInvokeForTester ::beforeOpenAI_scriptWebClient; # HOOK

      if {$level eq "openAI_chatCompletion" && \
          [methodName ToString] eq "GetWebRequest"} then {
        upvar 1 apiKey apiKey
        upvar 1 useProxy useProxy
        upvar 1 whatIf whatIf

        if {![info exists useProxy] || \
            [string is not true -strict $useProxy]} then {
          webRequest ContentType application/json
        }

        if {[isUriLikelyToBeRedirected [webRequest RequestUri]]} then {
          set token ""
        } else {
          if {[info exists useProxy] && \
              [string is true -strict $useProxy]} then {
            set token ""
          } elseif {[info exists whatIf] && \
              [string is true -strict $whatIf]} then {
            set token [guid null]
          } elseif {[info exists apiKey]} then {
            set token $apiKey
          } else {
            set token ""
          }
        }

        if {[string length $token] > 0} then {
          webRequest Headers.Add Authorization [appendArgs "Bearer " $token]
        }

        webRequest UserAgent [appendArgs \
            "TclTk/1.0 (" [string map [list "{} " ""] [version]] )]

        maybeInvokeForTester ::after_openAI_scriptWebClient; # HOOK
      }
    }

    #
    # NOTE: This procedure may be used by the _Tests.Default.ScriptWebClient
    #       class methods when it has been setup for an interpreter.  This
    #       procedure is designed to be used with the [anthropic_chatCompletion]
    #       procedure (below).  This procedure must reside in the global
    #       namespace.
    #
    # <callback>
    nproc anthropic_scriptWebClient { args } {
      if {[catch {
        string trimleft [lindex [info level -1] 0] :; # NOTE: Which caller?
      } level]} then {
        set level ""
      }

      maybeInvokeForTester ::beforeAnthropic_scriptWebClient; # HOOK

      if {$level eq "anthropic_chatCompletion" && \
          [methodName ToString] eq "GetWebRequest"} then {
        upvar 1 apiKey apiKey
        upvar 1 useProxy useProxy
        upvar 1 whatIf whatIf

        if {![info exists useProxy] || \
            [string is not true -strict $useProxy]} then {
          webRequest ContentType application/json
        }

        if {[isUriLikelyToBeRedirected [webRequest RequestUri]]} then {
          set token ""
        } else {
          if {[info exists useProxy] && \
              [string is true -strict $useProxy]} then {
            set token ""
          } elseif {[info exists whatIf] && \
              [string is true -strict $whatIf]} then {
            set token [guid null]
          } elseif {[info exists apiKey]} then {
            set token $apiKey
          } else {
            set token ""
          }
        }

        #
        # NOTE: The Anthropic API uses the "x-api-key" header for
        #       authentication (not the "Authorization: Bearer" scheme
        #       used by OpenAI).
        #
        if {[string length $token] > 0} then {
          webRequest Headers.Add x-api-key $token
        }

        #
        # NOTE: The Anthropic API requires an "anthropic-version" header
        #       specifying the API version to use.
        #
        webRequest Headers.Add anthropic-version 2023-06-01

        webRequest UserAgent [appendArgs \
            "TclTk/1.0 (" [string map [list "{} " ""] [version]] )]

        maybeInvokeForTester ::after_anthropic_scriptWebClient; # HOOK
      }
    }

    proc openAI_setupScriptWebClient {
            enable varName {channel stdout} {quiet false} } {
      # <help>
      # This procedure enables or disables the custom web-client callback used
      # for OpenAI chat-completion requests, and manages the associated
      # interpreter test flags.  It exists because those requests need to set
      # particular HTTP headers (content type and the bearer Authorization
      # header), which is accomplished through TclTk's ScriptWebClient
      # mechanism; this procedure wires that mechanism up and tears it back
      # down.
      #
      # How it works: when "enable" is true, and unless a ::scriptWebClient
      # command already exists, it renames the ::openAI_scriptWebClient callback
      # to ::scriptWebClient so the core will invoke it.  It then saves the
      # current interpreter test flags into the caller's variable named by
      # "varName" and adds the ScriptWebClientMask flag.  Before doing so it
      # verifies that the library was built with both the TEST and NETWORK
      # compile-options, raising an error if either is missing.  When "enable"
      # is false, it renames ::scriptWebClient back to ::openAI_scriptWebClient
      # (when appropriate) and, if a saved flag value exists in "varName",
      # restores the interpreter test flags from it and unsets that saved value.
      # Unless "quiet" is true, it reports the saved or restored flags.
      #
      # Tricky details: the rename dance is guarded so it only acts when the
      # expected starting state holds (for example, it will not clobber a
      # pre-existing ::scriptWebClient).  The "varName" variable is used in both
      # directions -- it receives the saved flags on enable and supplies them on
      # disable -- so the same variable must be passed to the paired calls.
      #
      # Arguments:
      #   enable  -- Boolean selecting setup (true) or teardown (false).
      #   varName -- Name of a caller variable used to save and later restore
      #              the interpreter test flags.
      #   channel -- Channel for the informational messages; defaults to
      #              "stdout".
      #   quiet   -- When true, suppresses the informational messages; defaults
      #              to false.
      #
      # Results:
      #   No useful result.  Raises an error on enable when the TEST and/or
      #   NETWORK compile-options are absent.
      # </help>

      if {$enable} then {
        #
        # HACK: Unless a [::scriptWebClient] procedure has already been
        #       defined, force ours to be used now.
        #
        if {[llength [info nprocs ::openAI_scriptWebClient]] > 0 && \
            [llength [info commands ::scriptWebClient]] == 0} then {
          rename ::openAI_scriptWebClient ::scriptWebClient
        }
      } else {
        #
        # NOTE: Attempt to restore all the original procedure names.
        #
        if {[llength [info nprocs ::openAI_scriptWebClient]] == 0 && \
            [llength [info commands ::scriptWebClient]] > 0} then {
          rename ::scriptWebClient ::openAI_scriptWebClient
        }
      }

      #
      # HACK: Use of ScriptWebClient is required here due to needing to
      #       adjust the HTTP headers, etc.
      #
      upvar 1 $varName savedTestFlags

      if {$enable} then {
        if {[info exists ::tcltk_platform(compileOptions)]} then {
          set options $::tcltk_platform(compileOptions)
        } else {
          set options [list]; # options missing?
        }

        if {[lsearch -exact $options TEST] == -1 || \
            [lsearch -exact $options NETWORK] == -1} then {
          error "library missing TEST and/or NETWORK compile-options"
        }

        set savedTestFlags [enableInterpreterTestFlags]; # query
        enableInterpreterTestFlags +ScriptWebClientMask true; # add

        if {!$quiet} then {
          tputs $channel [appendArgs \
              "---- saved interpreter test flags: " \
              $savedTestFlags \n]
        }
      } elseif {[info exists savedTestFlags]} then {
        enableInterpreterTestFlags [appendArgs = $savedTestFlags]; # reset
        unset savedTestFlags; # cleanup

        if {!$quiet} then {
          tputs $channel [appendArgs \
              "---- restored interpreter test flags: " \
              [enableInterpreterTestFlags] \n]
        }
      }
    }

    proc anthropic_setupScriptWebClient {
            enable varName {channel stdout} {quiet false} } {
      # <help>
      # This procedure enables or disables the custom web-client callback used
      # for Anthropic chat-completion requests, and manages the associated
      # interpreter test flags.  It is the Anthropic counterpart of
      # [openAI_setupScriptWebClient]; those requests need particular HTTP
      # headers (content type, the x-api-key header, and the anthropic-version
      # header) set through TclTk's ScriptWebClient mechanism, which this
      # procedure wires up and tears back down.
      #
      # How it works: when "enable" is true, and unless a ::scriptWebClient
      # command already exists, it renames the ::anthropic_scriptWebClient
      # callback to ::scriptWebClient so the core will invoke it.  It then saves
      # the current interpreter test flags into the caller's variable named by
      # "varName" and adds the ScriptWebClientMask flag.  Before doing so it
      # verifies that the library was built with both the TEST and NETWORK
      # compile-options, raising an error if either is missing.  When "enable"
      # is false, it renames ::scriptWebClient back to ::anthropic_scriptWebClient
      # (when appropriate) and, if a saved flag value exists in "varName",
      # restores the interpreter test flags from it and unsets that saved value.
      # Unless "quiet" is true, it reports the saved or restored flags.
      #
      # Tricky details: the rename dance is guarded so it only acts when the
      # expected starting state holds (for example, it will not clobber a
      # pre-existing ::scriptWebClient).  The "varName" variable is used in both
      # directions -- it receives the saved flags on enable and supplies them on
      # disable -- so the same variable must be passed to the paired calls.
      #
      # Arguments:
      #   enable  -- Boolean selecting setup (true) or teardown (false).
      #   varName -- Name of a caller variable used to save and later restore
      #              the interpreter test flags.
      #   channel -- Channel for the informational messages; defaults to
      #              "stdout".
      #   quiet   -- When true, suppresses the informational messages; defaults
      #              to false.
      #
      # Results:
      #   No useful result.  Raises an error on enable when the TEST and/or
      #   NETWORK compile-options are absent.
      # </help>

      if {$enable} then {
        #
        # HACK: Unless a [::scriptWebClient] procedure has already been
        #       defined, force ours to be used now.
        #
        if {[llength [info nprocs ::anthropic_scriptWebClient]] > 0 && \
            [llength [info commands ::scriptWebClient]] == 0} then {
          rename ::anthropic_scriptWebClient ::scriptWebClient
        }
      } else {
        #
        # NOTE: Attempt to restore all the original procedure names.
        #
        if {[llength [info nprocs ::anthropic_scriptWebClient]] == 0 && \
            [llength [info commands ::scriptWebClient]] > 0} then {
          rename ::scriptWebClient ::anthropic_scriptWebClient
        }
      }

      #
      # HACK: Use of ScriptWebClient is required here due to needing to
      #       adjust the HTTP headers, etc.
      #
      upvar 1 $varName savedTestFlags

      if {$enable} then {
        if {[info exists ::tcltk_platform(compileOptions)]} then {
          set options $::tcltk_platform(compileOptions)
        } else {
          set options [list]; # options missing?
        }

        if {[lsearch -exact $options TEST] == -1 || \
            [lsearch -exact $options NETWORK] == -1} then {
          error "library missing TEST and/or NETWORK compile-options"
        }

        set savedTestFlags [enableInterpreterTestFlags]; # query
        enableInterpreterTestFlags +ScriptWebClientMask true; # add

        if {!$quiet} then {
          tputs $channel [appendArgs \
              "---- saved interpreter test flags: " \
              $savedTestFlags \n]
        }
      } elseif {[info exists savedTestFlags]} then {
        enableInterpreterTestFlags [appendArgs = $savedTestFlags]; # reset
        unset savedTestFlags; # cleanup

        if {!$quiet} then {
          tputs $channel [appendArgs \
              "---- restored interpreter test flags: " \
              [enableInterpreterTestFlags] \n]
        }
      }
    }

    proc openAI_getTypes { {channel stdout} {quiet false} } {
      # <help>
      # This procedure returns the list of supported OpenAI request "type"
      # values, returning that list.  It exists so the model-selection helpers
      # ([openAI_getDefaultModel] and [openAI_getStandardModel]) can validate a
      # caller-supplied type against a single authoritative set, and so that set
      # can be overridden via a tester hook.
      #
      # How it works: it starts with the default list -- the empty string and
      # "chat" -- and fires the ::beforeOpenAI_getTypes and ::afterOpenAI_getTypes
      # hooks around finalizing the result.  As elsewhere, the local "result"
      # begins empty and is filled with the default list unless the before-hook
      # overrode it.  Unless "quiet" is true, an informational line describing
      # the types (default or overridden) is written to "channel".
      #
      # Arguments:
      #   channel -- Channel for the informational message; defaults to
      #              "stdout".
      #   quiet   -- When true, suppresses the informational message; defaults
      #              to false.
      #
      # Results:
      #   The list of valid OpenAI request types (by default, the empty string
      #   and "chat").
      # </help>

      set result ""; set types [list "" chat]
      maybeInvokeForTester ::beforeOpenAI_getTypes; # HOOK

      if {[string length $result] == 0} then {
        set result $types
        maybeInvokeForTester ::afterOpenAI_getTypes; # HOOK

        if {!$quiet} then {
          tputs $channel [appendArgs \
              "---- default types for OpenAI are \"" $result \"\n]
        }
      } else {
        if {!$quiet} then {
          tputs $channel [appendArgs \
              "---- default types for OpenAI overridden to \"" \
              $result \"\n]
        }
      }

      return $result
    }

    proc anthropic_getTypes { {channel stdout} {quiet false} } {
      # <help>
      # This procedure returns the list of supported Anthropic request "type"
      # values, returning that list.  It is the Anthropic counterpart of
      # [openAI_getTypes]; the model-selection helpers
      # ([anthropic_getDefaultModel] and [anthropic_getStandardModel]) use it to
      # validate a caller-supplied type, and the set can be overridden via a
      # tester hook.
      #
      # How it works: it starts with the default list -- the empty string and
      # "messages" -- and fires the ::beforeAnthropic_getTypes and
      # ::afterAnthropic_getTypes hooks around finalizing the result.  The local
      # "result" begins empty and is filled with the default list unless the
      # before-hook overrode it.  Unless "quiet" is true, an informational line
      # describing the types (default or overridden) is written to "channel".
      #
      # Arguments:
      #   channel -- Channel for the informational message; defaults to
      #              "stdout".
      #   quiet   -- When true, suppresses the informational message; defaults
      #              to false.
      #
      # Results:
      #   The list of valid Anthropic request types (by default, the empty
      #   string and "messages").
      # </help>

      set result ""; set types [list "" messages]
      maybeInvokeForTester ::beforeAnthropic_getTypes; # HOOK

      if {[string length $result] == 0} then {
        set result $types
        maybeInvokeForTester ::afterAnthropic_getTypes; # HOOK

        if {!$quiet} then {
          tputs $channel [appendArgs \
              "---- default types for Anthropic are \"" $result \"\n]
        }
      } else {
        if {!$quiet} then {
          tputs $channel [appendArgs \
              "---- default types for Anthropic overridden to \"" \
              $result \"\n]
        }
      }

      return $result
    }

    #
    # TODO: When more model types need to be supported by this module, add
    #       the needed OpenAI model names and types here.
    #
    proc openAI_getDefaultModel { type {channel stdout} {quiet false} } {
      # <help>
      # This procedure returns the default OpenAI model name to use for a given
      # request type, returning that model name.  It exists so the chat
      # completion machinery can pick a sensible model when the caller did not
      # specify one, while validating the requested type and allowing the model
      # to be overridden via a tester hook.
      #
      # How it works: it first obtains the set of valid types from
      # [openAI_getTypes].  The ::beforeOpenAI_getDefaultModel hook fires, and
      # the local "result" may be pre-populated to override the choice.  Absent
      # an override, if "type" is one of the valid types it selects the built-in
      # default model name and fires ::afterOpenAI_getDefaultModel; if "type" is
      # not valid, it raises an error listing the acceptable types.  Unless
      # "quiet" is true, an informational line names the chosen (or overridden)
      # model for the given type.
      #
      # Arguments:
      #   type    -- The request type; must be one of the values from
      #              [openAI_getTypes].
      #   channel -- Channel for the informational message; defaults to
      #              "stdout".
      #   quiet   -- When true, suppresses the informational message; defaults
      #              to false.
      #
      # Results:
      #   The default OpenAI model name for the type.  Raises an error when
      #   "type" is not a supported type.
      # </help>

      set result ""; set types [openAI_getTypes $channel $quiet]
      maybeInvokeForTester ::beforeOpenAI_getDefaultModel; # HOOK

      if {[string length $result] == 0} then {
        if {$type in $types} then {
          set result gpt-3.5-turbo; # TODO: Good default?
          maybeInvokeForTester ::afterOpenAI_getDefaultModel; # HOOK

          if {!$quiet} then {
            tputs $channel [appendArgs \
                "---- default model for OpenAI type " \
                [expr {[string length $type] > 0 ? \
                [appendArgs \" $type \"] : "<empty>"}] \
                " is \"" $result \"\n]
          }
        } else {
          error [appendArgs \
              "bad type, must be one of: " $types]
        }
      } else {
        if {!$quiet} then {
          tputs $channel [appendArgs \
              "---- default model for OpenAI type \"" \
              $type "\" overridden to \"" $result \"\n]
        }
      }

      return $result
    }

    #
    # TODO: When more model types need to be supported by this module, add
    #       the needed Anthropic model names and types here.
    #
    proc anthropic_getDefaultModel { type {channel stdout} {quiet false} } {
      # <help>
      # This procedure returns the default Anthropic model name to use for a
      # given request type, returning that model name.  It is the Anthropic
      # counterpart of [openAI_getDefaultModel]; it lets the chat completion
      # machinery pick a sensible model when the caller did not specify one,
      # while validating the requested type and allowing the model to be
      # overridden via a tester hook.
      #
      # How it works: it first obtains the set of valid types from
      # [anthropic_getTypes].  The ::beforeAnthropic_getDefaultModel hook fires,
      # and the local "result" may be pre-populated to override the choice.
      # Absent an override, if "type" is one of the valid types it selects the
      # built-in default model name and fires ::afterAnthropic_getDefaultModel;
      # if "type" is not valid, it raises an error listing the acceptable types.
      # Unless "quiet" is true, an informational line names the chosen (or
      # overridden) model for the given type.
      #
      # Arguments:
      #   type    -- The request type; must be one of the values from
      #              [anthropic_getTypes].
      #   channel -- Channel for the informational message; defaults to
      #              "stdout".
      #   quiet   -- When true, suppresses the informational message; defaults
      #              to false.
      #
      # Results:
      #   The default Anthropic model name for the type.  Raises an error when
      #   "type" is not a supported type.
      # </help>

      set result ""; set types [anthropic_getTypes $channel $quiet]
      maybeInvokeForTester ::beforeAnthropic_getDefaultModel; # HOOK

      if {[string length $result] == 0} then {
        if {$type in $types} then {
          set result claude-haiku-4-5-20251001; # TODO: Good default?
          maybeInvokeForTester ::afterAnthropic_getDefaultModel; # HOOK

          if {!$quiet} then {
            tputs $channel [appendArgs \
                "---- default model for Anthropic type " \
                [expr {[string length $type] > 0 ? \
                [appendArgs \" $type \"] : "<empty>"}] \
                " is \"" $result \"\n]
          }
        } else {
          error [appendArgs \
              "bad type, must be one of: " $types]
        }
      } else {
        if {!$quiet} then {
          tputs $channel [appendArgs \
              "---- default model for Anthropic type \"" \
              $type "\" overridden to \"" $result \"\n]
        }
      }

      return $result
    }

    #
    # TODO: When more model types need to be supported by this module, add
    #       the needed OpenAI model names and types here.
    #
    proc openAI_getStandardModel { type {channel stdout} {quiet false} } {
      # <help>
      # This procedure returns the "standard" (higher-capability) OpenAI model
      # name to use for a given request type, returning that model name.  It is
      # the companion of [openAI_getDefaultModel], offering a stronger model
      # choice for callers that want it, while validating the requested type and
      # allowing the model to be overridden via a tester hook.
      #
      # How it works: it first obtains the set of valid types from
      # [openAI_getTypes].  The ::beforeOpenAI_getStandardModel hook fires, and
      # the local "result" may be pre-populated to override the choice.  Absent
      # an override, if "type" is one of the valid types it selects the built-in
      # standard model name and fires ::afterOpenAI_getStandardModel; if "type"
      # is not valid, it raises an error listing the acceptable types.  Unless
      # "quiet" is true, an informational line names the chosen (or overridden)
      # standard model for the given type.
      #
      # Arguments:
      #   type    -- The request type; must be one of the values from
      #              [openAI_getTypes].
      #   channel -- Channel for the informational message; defaults to
      #              "stdout".
      #   quiet   -- When true, suppresses the informational message; defaults
      #              to false.
      #
      # Results:
      #   The standard OpenAI model name for the type.  Raises an error when
      #   "type" is not a supported type.
      # </help>

      set result ""; set types [openAI_getTypes $channel $quiet]
      maybeInvokeForTester ::beforeOpenAI_getStandardModel; # HOOK

      if {[string length $result] == 0} then {
        if {$type in $types} then {
          set result chatgpt-4o-latest; # TODO: Good default?
          maybeInvokeForTester ::afterOpenAI_getStandardModel; # HOOK

          if {!$quiet} then {
            tputs $channel [appendArgs \
                "---- standard model for OpenAI type " \
                [expr {[string length $type] > 0 ? \
                [appendArgs \" $type \"] : "<empty>"}] \
                " is \"" $result \"\n]
          }
        } else {
          error [appendArgs \
              "bad type, must be one of: " $types]
        }
      } else {
        if {!$quiet} then {
          tputs $channel [appendArgs \
              "---- standard model for OpenAI type \"" \
              $type "\" overridden to \"" $result \"\n]
        }
      }

      return $result
    }

    #
