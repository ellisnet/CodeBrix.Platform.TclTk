    #               Empty selects assignment or read-only behavior.
    #
    # Results:
    #   The resulting value of the host's "hostFlags" member after any change.
    # </help>

    return [enableFlags hostFlags $newFlags $enable \
        Field CodeBrix.Platform.TclTk._Hosts.Default Interpreter.GetActive.Host]
  }

