#
# NOTE: Use our own namespace here because even though we do not directly
#       support namespaces ourselves, we do not want to pollute the global
#       namespace if this script actually ends up being evaluated in Tcl.
#
# WARNING: Do not call any of these procedures unless you know exactly how
#          they work and are willing to accept broken script compatibility
#          later.  You have been warned.
#
# TODO: Consider breaking this file into several packages, each of which
#       should be relatively self-contained and focus on one consistent
#       theme or piece of functionality.
#
namespace eval ::TclTk {
  proc visibleCharsOnly { value } {
    # <help>
    # This procedure returns a copy of the specified string in which every
    # character has been forced into the range of printable, plain-ASCII
    # characters.  It exists so that arbitrary string values (for example,
    # binary data, control characters, or non-ASCII Unicode) can be safely
    # embedded in log output, error messages, or test results without
    # corrupting the display, breaking line layout, or emitting characters
    # the surrounding tooling cannot render.
    #
    # How it works: it walks the input one character at a time, obtaining the
    # ordinal (code point) of each character.  In TclTk the ordinal is taken
    # via the string ordinal sub-command; in native Tcl it is obtained with a
    # scan using the percent-c conversion.  Each ordinal is then clamped into
    # the printable ASCII band: values above 0x7E (tilde) first have their
    # high bit masked off, and if still above 0x7E are pinned to 0x7E, while
    # values below 0x20 (space) are shifted up by 0x20.  The resulting ordinal
    # is converted back to a character with format percent-c and appended to
    # the accumulated result.
    #
    # Tricky details: the masking and pinning are deliberately lossy, so the
    # transformation is not reversible and is intended purely for display.
    # The two code paths exist solely so the procedure behaves identically
    # under both TclTk and native Tcl.
    #
    # Arguments:
    #   value -- The string to sanitize.  It may contain any characters,
    #            including control codes and non-ASCII data.
    #
    # Results:
    #   A new string of the same length as the input, containing only visible
    #   plain-ASCII characters.  The empty string maps to the empty string.
    # </help>

    set result ""
    set length [string length $value]

    for {set index 0} {$index < $length} {incr index} {
      if {[isTclTk]} then {
        set ordinal [string ordinal $value $index]
      } else {
        scan [string index $value $index] %c ordinal
      }

      if {$ordinal > 0x7E} then {
        set ordinal [expr {$ordinal & 0x7F}]
      }

      if {$ordinal > 0x7E} then {
        set ordinal 0x7E
      }

      if {$ordinal < 0x20} then {
        set ordinal [expr {$ordinal + 0x20}]
      }

      append result [format %c $ordinal]
    }

    return $result
  }

  proc s_proc { name {args ""} {command ""} } {; # NOTE: "args" not last.
    # <help>
    # This procedure defines a "stub" procedure, i.e. a procedure whose body
    # does nothing of consequence and merely carries a placeholder help block.
    # It exists so that a procedure name can be declared (and later cloned,
    # annotated, or interactively redefined) before any real implementation is
    # written, which is convenient when scaffolding a script library or when a
    # debugging or testing workflow needs a named procedure to exist.
    #
    # How it works: it selects the defining command, defaulting to the ordinary
    # proc command when none is supplied, and validates that the chosen command
    # is either proc or its named variant.  When no argument specification is
    # supplied, the new procedure is given a single variadic parameter so that
    # it accepts any arguments.  A minimal body is constructed that contains
    # only a help block declaring the procedure to be a stub; if the debugger
    # state array provides custom stub body text, that text is appended to the
    # generated body.  Finally, the chosen defining command is invoked, via an
    # uplevel into the caller's frame, to actually create the procedure.
    #
    # Tricky details: the args parameter here is NOT this procedure's own
    # variadic catch-all; it is the literal argument list to give the procedure
    # being created, and it is intentionally not the last parameter.  Because
    # the defining command runs in the caller's frame, an unqualified name is
    # created relative to the caller's current namespace.
    #
    # Arguments:
    #   name    -- The name of the stub procedure to create.
    #   args    -- The argument specification (parameter list) for the new
    #              procedure.  When empty, a single variadic catch-all parameter
    #              is used so the stub accepts any arguments.
    #   command -- The defining command to use, which must be proc or its named
    #              variant.  When empty, the ordinary proc command is used.
    #
    # Results:
    #   The result of the underlying defining command, i.e. whatever creating
    #   the procedure returns (typically the empty string).
    # </help>

    # stub_procedure
    if {[string length $command] == 0} then {
      set command proc
    }

    if {[lsearch -exact [list proc nproc] $command] == -1} then {
      error "procedure command must be \[proc\] or \[nproc\]"
    }

    if {[llength $args] == 0} then {
      set args [list args]
    }

    set body {
      # <help>
      # This procedure is a stub.
      # </help>
    }

    if {[info exists ::tcltk_debugger(stubProcedureBody)]} then {
      append body \n\n $::tcltk_debugger(stubProcedureBody)
    }

    return [uplevel 1 [list $command $name $args $body]]
  }

  proc f_proc { name args body {command ""} } {; # NOTE: "args" not last.
    # <help>
    # This procedure defines a "flexible" procedure, i.e. it creates a named
    # procedure from a supplied argument list and body while optionally
    # appending extra debugger-supplied body text.  It exists as the working
    # counterpart to the stub creator, used throughout the library to declare
    # procedures in a way that can be transparently augmented for debugging or
    # instrumentation purposes and that prefers the richer named procedure
    # command when one is available.
    #
    # How it works: when no defining command is supplied, it chooses the named
    # procedure variant if running under TclTk and that command exists, and
    # otherwise falls back to the ordinary proc command; the chosen command is
    # then validated to be one of those two.  If the debugger state array
    # provides flexible procedure body text, that text is appended to the
    # supplied body.  Finally the chosen defining command is invoked, via an
    # uplevel into the caller's frame, to create the procedure with the given
    # name, argument list, and (possibly augmented) body.
    #
    # Tricky details: the args parameter here is NOT this procedure's own
    # variadic catch-all; it is the literal argument list to give the procedure
    # being created, and it is intentionally not the last parameter (the body
    # and command parameters follow it).  Because the defining command runs in
    # the caller's frame, an unqualified name is created relative to the
    # caller's current namespace.
    #
    # Arguments:
    #   name    -- The name of the procedure to create.
    #   args    -- The argument specification (parameter list) for the new
    #              procedure.
    #   body    -- The body for the new procedure, to which any configured
    #              debugger body text is appended.
    #   command -- The defining command to use, which must be proc or its named
    #              variant.  When empty, the named variant is preferred under
    #              TclTk if present, otherwise the ordinary proc command.
    #
    # Results:
    #   The result of the underlying defining command, i.e. whatever creating
    #   the procedure returns (typically the empty string).
    # </help>

    # flexible_procedure
    if {[string length $command] == 0} then {
      if {[isTclTk] && \
          [llength [info commands nproc]] > 0} then {
        set command nproc
      } else {
        set command proc
      }
    }

    if {[lsearch -exact [list proc nproc] $command] == -1} then {
      error "procedure command must be \[proc\] or \[nproc\]"
    }

    if {[info exists ::tcltk_debugger(flexibleProcedureBody)]} then {
      append body \n\n $::tcltk_debugger(flexibleProcedureBody)
    }

    return [uplevel 1 [list $command $name $args $body]]
  }

  f_proc promptForAndGetTextInput {
          {prompt ""} {title ""} {default ""} {noDots true}
          {canceledVarName ""} } {
    if {[string length $prompt] == 0} then {
      set prompt "Please enter some text input: "
    }

    if {[string length $title] == 0} then {
      if {[isTclTk]} then {
        set title [info engine]
      } elseif {[info exists ::tcl_platform(engine)]} then {
        set title $::tcl_platform(engine)
      } else {
        set title "TclTk Library"
      }
    }

    if {$noDots} then {; # NOTE: Forbid using all dots?
      set transform [list [list value varName] {
        set value [string trim $value]

        set endsInDot [expr {
          [string index $value end] eq "."
        }]

        if {[string length $varName] > 0} then {
          upvar 2 $varName canceled; # [apply] ==> [proc] ==> <caller>

          set dots [string repeat . [string length $value]]

          if {$value eq $dots} then {
            set canceled true
          } else {
            set canceled false
          }
        }

        set value [string trim $value .]

        if {$endsInDot && \
            [string length $value] > 0} then {
          append value .
        }

        return $value
      }]
    } else {
      set transform [list [list value varName] {
        return [string trim $value]
      }]
    }

    if {[isTclTk] && ![info exists ::no(inputBox)] && \
        [llength [info commands object]] > 0} then {
      if {[catch {
        object load Microsoft.VisualBasic
      } assembly] == 0} then {
        if {[catch {
          object invoke \
              Microsoft.VisualBasic.Interaction \
              InputBox $prompt $title $default
        } value] == 0} then {
          return [apply $transform $value $canceledVarName]
        }
      }
    }

    if {[string length $title] > 0} then {
      if {[isTclTk]} then {
        catch {host writebox -- $title; puts stdout ""}
      } else {
        catch {puts stdout [appendArgs "Title ==> " $title]}
      }
    }

    puts -nonewline stdout [appendArgs "Prompt ==> " $prompt]
    flush stdout

    return [apply $transform [gets stdin] $canceledVarName]
  }

  proc addTestScripts { scriptVarName args } {
    # <help>
    # This procedure appends one or more scripts to a caller-provided array
    # that is used to accumulate a numbered, ordered collection of scripts.
    # It exists as part of a small family of helpers (alongside the procedures
    # that evaluate and combine such collections) that let a caller queue up
    # several scripts, run them, and gather their results, which is useful for
    # batching test or setup scripts.
    #
    # How it works: it links to the caller's array by name, finds the highest
    # existing integer index already present (treating an empty array as index
    # zero), and then stores each supplied script under the next consecutive
    # integer index, counting how many were added.
    #
    # Tricky details: the array is keyed by integer indices and is shared with
    # the caller via an upvar link, so repeated calls extend the same numbered
    # collection rather than replacing it.  The indices are determined by the
    # existing maximum, so the numbering remains monotonic across calls.
    #
    # Arguments:
    #   scriptVarName -- The name, in the caller's frame, of the array used to
    #                    hold the numbered scripts.
    #   args          -- Zero or more scripts; each is stored under the next
    #                    consecutive integer index, in order.
    #
    # Results:
    #   The count of scripts that were added by this call.
    # </help>

    upvar 1 $scriptVarName script

    set count 0

    set indexes [lsort -integer [array names script]]
    set index [expr {[llength $indexes] > 0 ? [lindex $indexes end] : 0}]

    foreach arg $args {set script([incr index]) $arg; incr count}

    return $count
  }

  proc evaluateTestScripts {
          interp scriptVarName codeVarName resultVarName } {
    # <help>
    # This procedure evaluates every script in a caller-provided numbered
    # collection and records, for each one, its completion code and result.
    # It is the execution stage of the helper family that adds, evaluates, and
    # combines batches of scripts, and exists so a queued set of scripts can be
    # run in a single call with their individual outcomes captured rather than
    # aborting on the first failure.
    #
    # How it works: it links to three caller arrays by name (the scripts, the
    # codes, and the results), then iterates the scripts in ascending integer
    # index order.  For each script it performs a catch so that an error does
    # not stop the loop: the completion code is stored in the code array under
    # the same index and the script's result (or error message) is stored in
    # the result array under that index.  When an interpreter name is supplied
    # the script is run in that interpreter; otherwise it is run in the
    # caller's own frame.
    #
    # Tricky details: each script is wrapped in a list before being evaluated
    # so it is treated as a single command word.  The code and result arrays
    # are populated in place via the upvar links, keyed by the same indices as
    # the script array, so the three arrays stay aligned by index.  The return
    # value is a counter that is initialized but never incremented and is
    # therefore always zero.
    #
    # Arguments:
    #   interp        -- The name of the interpreter in which to evaluate each
    #                    script; when empty, the caller's frame is used.
    #   scriptVarName -- The name, in the caller's frame, of the array holding
    #                    the numbered scripts to evaluate.
    #   codeVarName   -- The name, in the caller's frame, of the array that
    #                    receives each script's completion code, by index.
    #   resultVarName -- The name, in the caller's frame, of the array that
    #                    receives each script's result or error, by index.
    #
    # Results:
    #   Always zero; the meaningful output is delivered through the code and
    #   result arrays.
    # </help>

    upvar 1 $scriptVarName script
    upvar 1 $codeVarName code
    upvar 1 $resultVarName result

    set count 0

    foreach index [lsort -integer [array names script]] {
      if {[string length $interp] > 0} then {
        set code($index) [catch [list \
            interp eval $interp $script($index)] result($index)]
      } else {
        set code($index) [catch [list \
            uplevel 1 $script($index)] result($index)]
      }
    }

    return $count
  }

  proc combineTestScriptResults {
          scriptVarName codeVarName resultVarName {debug false} } {
    # <help>
    # This procedure collates the per-script codes and results produced by the
    # evaluation stage into a single list of per-script dictionaries.  It is
    # the reporting stage of the helper family that adds, evaluates, and
    # combines batches of scripts, and exists so the outcome of running a whole
    # collection can be returned to a caller as one structured, easily iterated
    # value.
    #
    # How it works: it links to the three caller arrays by name (the scripts,
    # the codes, and the results), then walks the scripts in ascending integer
    # index order.  For each index it builds a sub-list that always begins with
    # the index, optionally includes the original script text when debugging is
    # requested, and includes the completion code and result whenever those
    # entries exist for that index.  Each sub-list is appended to the overall
    # list that is returned.
    #
    # Tricky details: the code and result entries are added only when present,
    # so an index whose script was never evaluated will still appear but with
    # just its index (and possibly its script).  When debugging is enabled the
    # script text is embedded in the output, which can be large.
    #
    # Arguments:
    #   scriptVarName -- The name, in the caller's frame, of the array holding
    #                    the numbered scripts.
    #   codeVarName   -- The name, in the caller's frame, of the array holding
    #                    each script's completion code, by index.
    #   resultVarName -- The name, in the caller's frame, of the array holding
    #                    each script's result, by index.
    #   debug         -- A boolean; when true, the original script text is
    #                    included in each per-script sub-list.
    #
    # Results:
    #   A list with one sub-list per script index.  Each sub-list is a
    #   dictionary that includes the index and, when available, the script,
    #   code, and result entries.
    # </help>

    upvar 1 $scriptVarName script
    upvar 1 $codeVarName code
    upvar 1 $resultVarName result

    set list [list]

    foreach index [lsort -integer [array names script]] {
      set subList [list index $index]

      if {$debug} then {
        lappend subList script $script($index)
      }

      if {[info exists code($index)]} then {
        lappend subList code $code($index)
      }

      if {[info exists result($index)]} then {
        lappend subList result $result($index)
      }

      lappend list $subList
    }

    return $list
  }

  proc newPackageId { {fileName false} } {
    # <help>
    # This procedure generates a fresh, pseudo-random 64-bit identifier,
    # formatted as a sixteen-digit hexadecimal string, and optionally wraps it
    # into a package index file name.  It exists to produce unique-enough names
    # for transient package index files and similar artifacts created during
    # testing, so that concurrent or repeated runs do not collide on a fixed
    # name.
    #
    # How it works: under TclTk it obtains a random number directly from the
    # expression engine's random() function and determines the script file
    # extension either from the engine's file-extension constant (when the
    # object command is available) or from a hard-coded default.  Under native
    # Tcl it synthesizes a 64-bit value by combining two 32-bit pseudo-random
    # halves and uses a different default extension.  The chosen number is then
    # formatted as a zero-padded sixteen-digit hexadecimal identifier.  When a
    # file name is requested, the identifier is wrapped with a fixed prefix and
    # the appropriate extension; otherwise the bare identifier is returned.
    #
    # Tricky details: the randomness is not cryptographically strong and is not
    # guaranteed to be globally unique, only unlikely to collide in practice.
    # The file extension differs between TclTk and native Tcl, reflecting their
    # respective script file conventions.
    #
    # Arguments:
    #   fileName -- A boolean; when true, the result is a package index file
    #               name built from the identifier; when false, the bare
    #               hexadecimal identifier is returned.
    #
    # Results:
    #   Either a sixteen-digit hexadecimal identifier string or, when a file
    #   name was requested, a package index file name incorporating that
    #   identifier and an appropriate extension.
    # </help>

    if {[isTclTk]} then {
      set number [expr {random()}]

      if {[llength [info commands object]] > 0} then {
        set extension [object invoke \
            CodeBrix.Platform.TclTk._Constants.FileExtension Script]
      } else {
        set extension .tcltk
      }
    } else {
      set random {wide(rand() * wide(0xFFFFFFFF))}

      set half(1) [expr $random]
      set half(2) [expr $random]

      set number [expr {($half(1) << 32) | $half(2)}]

      set extension .tcl
    }

    set id [format %016lx $number]

    if {$fileName} then {
      set result [appendArgs pkgIndex_ $id $extension]
    } else {
      set result $id
    }

    return $result
  }

  #
  # NOTE: This procedure attempts to locate the specified (named) parameter,
  #       optionally perform type validation on the resulting value, if any,
  #       and then return it.
  #
  proc getParameterFromAny { form query name {type ""} {default ""} } {
    # <help>
    # This procedure looks up a named parameter across two dictionaries, an
    # optional preferred source (the "form") and a fallback source (the
    # "query"), optionally validates the value against a string type, and
    # returns the first acceptable value found or a default.  It exists to
    # mimic the common web convention of resolving a parameter from posted form
    # data first and then from a query string, so callers do not have to repeat
    # that lookup-and-validate logic.
    #
    # How it works: it reads and trims the named value from the form dictionary
    # first; if that value is non-empty and either no type was requested or the
    # value satisfies the requested type, it is returned.  Otherwise it repeats
    # the same lookup and validation against the query dictionary.  If neither
    # source yields an acceptable value, the supplied default is returned.
    #
    # Tricky details: values are trimmed before testing, so leading or trailing
    # whitespace will not by itself make a value count as present.  When a type
    # is given, the strict form of the string type test is used, so values that
    # do not strictly match the type are skipped as though absent.
    #
    # Arguments:
    #   form    -- The preferred source dictionary searched first.
    #   query   -- The fallback source dictionary searched second.
    #   name    -- The name of the parameter to look up in each dictionary.
    #   type    -- The optional string type to validate against; when empty,
    #              no type validation is performed.
    #   default -- The value returned when no acceptable parameter is found.
    #
    # Results:
    #   The first non-empty, type-valid parameter value found (form before
    #   query), or the default when neither source provides one.
    # </help>

    set value [string trim [getDictionaryValue $form $name]]

    if {[string length $value] > 0} then {
      if {[string length $type] == 0 || \
          [string is $type -strict $value]} then {
        return $value
      }
    }

    set value [string trim [getDictionaryValue $query $name]]

    if {[string length $value] > 0} then {
      if {[string length $type] == 0 || \
          [string is $type -strict $value]} then {
        return $value
      }
    }

    return $default
  }

  #
  # NOTE: This procedure attempts to locate the index for the specified
  #       directory within a list of paths.  When not found, a negative
  #       value will be returned; otherwise, the matching index will be
  #       returned.
  #
  proc getIndexForDirectory { paths directory {noNormalize false} } {
    # <help>
    # This procedure searches a list of paths for one that refers to the same
    # directory as a given directory and returns its position, or a negative
    # value when no match is found.  It exists so that callers can locate a
    # directory within a path list (most notably the package auto-path) using
    # filesystem identity rather than mere string equality, which matters when
    # the same directory can be spelled in different ways.
    #
    # How it works: unless normalization is suppressed, it first normalizes the
    # target directory.  It then scans the path list by index.  Under TclTk it
    # compares each path to the target using the file same test, which checks
    # whether two paths denote the same filesystem object; under native Tcl it
    # compares the paths as strings.  When normalization is enabled, each path
    # is also normalized and compared a second time, so a match can be found
    # either against the raw path or its normalized form.  The index of the
    # first matching path is returned immediately.
    #
    # Tricky details: when normalization is disabled the comparison is purely
    # by the as-given spelling under native Tcl, so logically identical but
    # differently spelled paths may not match.  The TclTk file same test can
    # touch the filesystem.
    #
    # Arguments:
    #   paths       -- The list of paths to search.
    #   directory   -- The directory to locate within the list.
    #   noNormalize -- A boolean; when true, normalization of both the target
    #                  and the candidate paths is skipped.
    #
    # Results:
    #   The zero-based index of the first matching path, or a negative value
    #   when no path matches.
    # </help>

    if {!$noNormalize} then {
      set directory [file normalize $directory]
    }

    set length [llength $paths]

    for {set index 0} {$index < $length} {incr index} {
      set path [lindex $paths $index]

      if {[isTclTk]} then {
        if {[file same $path $directory]} then {
          return $index
        }
      } else {
        if {$path eq $directory} then {
          return $index
        }
      }

      if {!$noNormalize} then {
        set path [file normalize $path]

        if {[isTclTk]} then {
          if {[file same $path $directory]} then {
            return $index
          }
        } else {
          if {$path eq $directory} then {
            return $index
          }
        }
      }
    }

    return -1
  }

  #
  # NOTE: This procedure attempts to add the specified directory to the
  #       package auto-path if it is not already present.
  #
  proc maybeAddToAutoPath { directory {strict false} } {
    # <help>
    # This procedure adds a directory to the global package auto-path, but only
    # if it is not already present there.  It exists so callers can ensure a
    # directory is searched for packages without risking duplicate entries and
    # without having to test for prior membership themselves.
    #
    # How it works: it checks whether the global auto-path variable exists.  In
    # strict mode, a missing auto-path causes an immediate false result with no
    # change.  Otherwise, if the auto-path does not exist, or it exists but does
    # not already contain the directory (as determined by directory identity,
    # not plain string matching), the directory is appended and true is
    # returned; if the directory is already present, nothing is changed and
    # false is returned.
    #
    # Tricky details: membership is tested by directory identity via the
    # companion index lookup, so a directory already present under a different
    # spelling will be recognized and not added again.  The strict flag only
    # affects the behavior when the auto-path variable does not yet exist.
    #
    # Arguments:
    #   directory -- The directory to add to the auto-path.
    #   strict    -- A boolean; when true, a missing auto-path variable is
    #                treated as a non-actionable condition and false is
    #                returned without creating it.
    #
    # Results:
    #   True when the directory was actually added; false when it was already
    #   present or when strict mode short-circuited on a missing auto-path.
    # </help>

    global auto_path

    set exists [info exists auto_path]
    if {$strict && !$exists} then {return false}

    if {!$exists || \
        [getIndexForDirectory $auto_path $directory] == -1} then {
      lappend auto_path $directory; return true
    } else {
      return false
    }
  }

  proc maybeScanAutoPath { {directories ""} {strict false} {quiet false} } {
    # <help>
    # This procedure triggers a (re)scan of the package auto-path so that
    # package index files in the listed directories are discovered, and
    # optionally reports the indexes or names that became known.  It exists to
    # refresh package availability after directories have been added to the
    # auto-path, abstracting over the very different mechanisms TclTk and native
    # Tcl use to accomplish this.
    #
    # How it works: under TclTk, when the directories form a valid list, the
    # directory names (if any) are collected into a managed string list (or a
    # null reference when none are given) and the internal package scan command
    # is invoked over them with the strict flag.  On success, unless quiet was
    # requested, the now-known package indexes are formatted and logged to the
    # test channel.  Under native Tcl, the directories are appended to the
    # global auto-path and a forced package rescan is performed; on success the
    # known package names are similarly logged unless quiet.  In both engines an
    # invalid directory list or a failed scan either raises an error (when
    # strict) or simply returns false (when not strict).
    #
    # Tricky details: an empty directory list is valid and means scan using the
    # existing auto-path.  The strict flag governs whether invalid input or scan
    # failure becomes an error versus a false result.  The quiet flag suppresses
    # only the informational logging, not the scan itself.  The set of items
    # logged differs by engine (indexes under TclTk, names under native Tcl).
    #
    # Arguments:
    #   directories -- A list of directories to incorporate into the scan; an
    #                  empty list scans using the current auto-path.
    #   strict      -- A boolean; when true, invalid input or a failed scan
    #                  raises an error instead of returning false.
    #   quiet       -- A boolean; when true, the success report is not logged.
    #
    # Results:
    #   True when the scan succeeded; false when it failed or the input was
    #   invalid and strict mode was not in effect.  An error is raised on
    #   failure or invalid input when strict mode is in effect.
    # </help>

    if {[isTclTk]} then {
      if {[string is list -strict $directories]} then {
        if {[llength $directories] > 0} then {
          set paths [object create -alias StringList]

          foreach directory $directories {
            $paths Add $directory
          }
        } else {
          set paths null
        }

        if {[invokePackageScanCommand $paths $strict]} then {
          if {!$quiet} then {
            set indexes [lsort [package indexes]]

            if {[llength $indexes] == 0} then {
              set indexes <none>
            }

            tputs [getTestChannelOrDefault] [appendArgs \
                "---- success scanning package indexes: " \
                [formatList $indexes <none>] \n]
          }

          return true
        } else {
          return false
        }
      } elseif {$strict} then {
        error "invalid directory list"
      } else {
        return false
      }
    } else {
      if {[catch {llength $directories} length] == 0} then {
        global auto_path

        if {[catch {
          if {$length > 0} then {
            eval lappend auto_path $directories
          } else {
            set auto_path $auto_path
          }

          forceScanOfPackages; # pkgt.tcltk
        } error] == 0} then {
          if {!$quiet} then {
            set names [lsort [package names]]

            if {[llength $names] == 0} then {
              set names <none>
            }

            tputs [getTestChannelOrDefault] [appendArgs \
                "---- success scanning package indexes: " \
                [formatList $names <none>] \n]
          }

          return true
        } elseif {$strict} then {
          error [appendArgs "scan auto-path failed: " $error]
        } else {
          return false
        }
      } elseif {$strict} then {
        error [appendArgs "invalid directory list: " $length]
      } else {
        return false
      }
    }
  }

  #
  # NOTE: This procedure is designed to return non-zero only if we are
  #       running on the .NET Framework is 4.x on Windows 10 or higher.
  #       It will return zero when running on any non-Windows operating
  #       system as well as when running on any Mono or ".NET" runtimes.
  #       Please do not change (or even use) this procedure unless you
  #       understand exactly how it works.  This procedure will always
  #       return zero when evaluated in native Tcl.
  #
  proc haveModernNetFx {} {
    # <help>
    # This procedure reports whether the current runtime is the .NET Framework
    # 4.x running on Windows 10 or higher.  It exists to gate test constraints
    # and behaviors that are specific to a modern Windows .NET Framework
    # environment, distinguishing it from Mono, the cross-platform .NET runtime,
    # non-Windows platforms, and native Tcl.
    #
    # How it works: it first rules out anything that is not the desired
    # environment, returning false when not running under TclTk, not on Windows,
    # running under Mono, or running on the cross-platform .NET runtime.  It then
    # requires the platform operating-system version to be available and to be
    # at least Windows 10, comparing versions with the package version
    # comparison.  Finally it consults an internal runtime helper to confirm the
    # process is actually using the .NET Framework 4.x, returning true only when
    # all of these conditions hold.
    #
    # Tricky details: this is a deliberately narrow detection that depends on an
    # internal, non-public runtime helper and on the platform operating-system
    # version being populated; it always returns false under native Tcl.  It is
    # sensitive enough that it should not be changed casually.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   True only when running under TclTk on the .NET Framework 4.x on Windows
    #   10 or higher; otherwise false.
    # </help>

    if {![isTclTk] || ![isWindows] || [isMono] || [isDotNetCore]} then {
      return false
    }

    if {![info exists ::tcl_platform(osVersion)]} then {
      return false
    }

    set osVersion $::tcl_platform(osVersion)

    if {[package vcompare $osVersion 10.0] < 0} then {; # TODO: Windows 8.x?
      return false
    }

    if {![object invoke -flags +NonPublic \
        CodeBrix.Platform.TclTk._Components.Private.CommonOps+Runtime IsFramework40]} then {
      return false
    }

    return true
  }

  proc getDotNetCoreRuntimeVersions { {versionOnly false} } {
    # <help>
    # This procedure discovers the installed cross-platform .NET shared runtime
    # versions by querying the external dotnet command, returning either a
    # sorted list of stable version numbers or a sorted list of version-and-path
    # pairs.  It exists so that test setup and runtime-configuration logic can
    # learn which .NET runtimes are available on the host without hard-coding
    # them.
    #
    # How it works: it runs the dotnet list-runtimes command and, if that
    # succeeds, parses its output line by line.  Whitespace within each line is
    # collapsed and the line is split into fields; only lines whose first field
    # names the .NET core application shared framework are considered.  The
    # version field must match a strict numeric pattern (no pre-release or
    # private suffixes) to count as stable, and duplicates are skipped.  When
    # only versions are requested, the version string is collected; otherwise
    # the bracketed install path is extracted and, when it exists on disk, a
    # version-and-path pair is collected.  The result is sorted using the
    # package version comparison, by the version directly or by the first
    # element of each pair.
    #
    # Tricky details: it only sees runtimes native to the current process bit-
    # ness and relies on the correct dotnet command already being on the PATH
    # (the .NET root environment variable is intentionally ignored).  Only
    # strictly stable versions are reported, so suffixed pre-release builds are
    # excluded.  Standard error from the external command is not specially
    # handled so the procedure works under both native Tcl and TclTk.
    #
    # Arguments:
    #   versionOnly -- A boolean; when true, a list of bare version strings is
    #                  returned; when false, a list of version-and-path pairs is
    #                  returned.
    #
    # Results:
    #   A sorted list of installed stable runtime versions, either as plain
    #   version strings or as version-and-path pairs.  The empty list is
    #   returned when the dotnet command fails or no qualifying runtimes are
    #   found.
    # </help>

    #
    # HACK: This (implicitly) only considers the .NET runtimes that
    #       are native to the underlying process, i.e. x86 will not
    #       be considered when running in a 64-bit process.  Also,
    #       the correct "dotnet" command is assumed to already be
    #       present in the PATH, i.e. DOTNET_ROOT is purposely not
    #       considered.  Finally, since this procedure must work in
    #       both native Tcl 8.4 and TclTk, fancy stderr handling is
    #       not used for [exec].
    #
    set result [list]

    if {[catch {exec -- dotnet --list-runtimes} info] == 0} then {
      foreach line [string trim [split \
          [string map [list \r\n \n] [string trim $info]] \n]] {
        if {[string length $line] == 0} then {continue}
        regsub -all -- {\s+} $line " " line
        set fields [split $line " "]

        if {[llength $fields] >= 2 && \
            [lindex $fields 0] eq "Microsoft.NETCore.App"} then {
          #
          # NOTE: Extract the version value from the fields; also,
          #       only consider "stable" versions to be valid for
          #       our (test?) purposes.  This means that suffixes,
          #       e.g. "-private.X", etc, are unsupported.
          #
          set version [lindex $fields 1]

          if {[regexp -- {^\d+(?:\.\d+){1,2}$} $version] && \
              [lsearch -exact $result $version] == -1} then {
            if {$versionOnly} then {
              lappend result $version
            } else {
              if {[regexp -- {\s+\[(.*)\]$} $line dummy path] && \
                  [file exists $path]} then {
                lappend result [list $version $path]
              }
            }
          }
        }
      }
    }

    if {$versionOnly} then {
      return [lsort -command [list package vcompare] $result]
    } else {
      return [lsort -index 0 -command [list package vcompare] $result]
    }
  }

  proc detectDotNetCoreRuntimeVersion { {majorOnly false} } {
    # <help>
    # This procedure determines the version of the cross-platform .NET runtime
    # the current process is using, returning either the full version or just
    # its major component.  It exists so that other helpers (for example, those
    # that build target framework monikers or runtime configuration) can adapt
    # to the actual hosting runtime.
    #
    # How it works: it first consults the TclTk platform array's runtime version
    # entry, and if that is present returns either the leading major component
    # (the portion before the first dot) or the whole version.  If that entry is
    # absent it falls back to an environment variable that records the core
    # runtime version, applying the same major-only logic.
    #
    # Tricky details: when neither the platform array entry nor the environment
    # variable is set, the procedure falls through without an explicit return
    # and therefore yields the empty string.  The major-only extraction is a
    # simple split on the dot character, so it assumes a dotted version string.
    #
    # Arguments:
    #   majorOnly -- A boolean; when true, only the major version component is
    #                returned; when false, the full version is returned.
    #
    # Results:
    #   The detected runtime version (full or major-only), or the empty string
    #   when no version information is available.
    # </help>

    if {[info exists ::tcltk_platform(runtimeVersion)]} then {
      if {$majorOnly} then {
        return [lindex [split $::tcltk_platform(runtimeVersion) .] 0]
      } else {
        return $::tcltk_platform(runtimeVersion)
      }
    }

    if {[info exists ::env(CoreClrVersion)]} then {
      if {$majorOnly} then {
        return [lindex [split $::env(CoreClrVersion) .] 0]
      } else {
        return $::env(CoreClrVersion)
      }
    }
  }

  proc getDotNetCoreTargetFrameworkMoniker {
          {version ""} {includeVersion false} } {
    # <help>
    # This procedure maps a cross-platform .NET major version to its target
    # framework moniker prefix, optionally appending the version to form a full
    # moniker.  It exists so that build and runtime-configuration helpers can
    # construct the correct framework identifier for the runtime in use, taking
    # into account the historical change in moniker naming between the legacy
    # and modern .NET lines.
    #
    # How it works: when no version is supplied it detects the major version of
    # the current runtime.  It then maps that major version to a moniker prefix:
    # the legacy core-application prefix for the early major versions, and the
    # modern prefix for the supported newer major versions; any other version is
    # treated as unsupported and yields the empty string.  When inclusion of the
    # version is requested, the major version and a trailing dot-zero are
    # appended to the prefix.
    #
    # Tricky details: the supported version set is enumerated explicitly, so a
    # runtime newer than those listed is reported as unsupported (the empty
    # string) rather than guessed.  Only the major version drives the mapping;
    # any minor or patch detail is ignored.
    #
    # Arguments:
    #   version        -- The .NET major version to map; when empty, the current
    #                     runtime's major version is detected and used.
    #   includeVersion -- A boolean; when true, the major version and a trailing
    #                     dot-zero are appended to the moniker prefix.
    #
    # Results:
    #   The target framework moniker prefix (optionally with the version
    #   appended), or the empty string when the version is unsupported.
    # </help>

    if {[string length $version] == 0} then {
      set version [detectDotNetCoreRuntimeVersion true]
    }

    switch -exact -- $version {
      2 -
      3 {
        set result netcoreapp; # LEGACY
      }
      5 -
      6 -
      7 -
      8 -
      9 -
      10 {
        set result net; # SUPPORTED
      }
      default {
        return ""; # UNSUPPORTED
      }
    }

    if {$includeVersion} then {
      append result $version .0
    }

    return $result
  }

  proc getDotNetCoreRuntimeConfiguration { {version ""} } {
    # <help>
    # This procedure produces the JSON text of a cross-platform .NET runtime
    # configuration appropriate to a given major version.  It exists so that
    # test or tooling logic can emit a runtime configuration document (the kind
    # that pairs with a managed application to select the shared framework)
    # without hand-writing the JSON for each supported runtime.
    #
    # How it works: when no version is supplied it detects the current runtime's
    # major version.  It derives the target framework moniker for that version,
    # and if the version is unsupported (no moniker) it returns the empty
    # string.  Otherwise it takes a trimmed JSON template and substitutes the
    # moniker and version into the appropriate placeholders, producing a
    # document that requests the .NET core application shared framework and a
    # latest-major roll-forward policy.
    #
    # Tricky details: the embedded template is a fixed document with named
    # placeholders that are filled by string substitution; the result is plain
    # text, not a parsed structure.  Unsupported versions yield the empty string
    # rather than an error, mirroring the moniker helper's behavior.
    #
    # Arguments:
    #   version -- The .NET major version to target; when empty, the current
    #              runtime's major version is detected and used.
    #
    # Results:
    #   The JSON runtime configuration text for the requested version, or the
    #   empty string when the version is unsupported.
    # </help>

    if {[string length $version] == 0} then {
      set version [detectDotNetCoreRuntimeVersion true]
    }

    set targetFrameworkMoniker \
        [getDotNetCoreTargetFrameworkMoniker $version]

    if {[string length $targetFrameworkMoniker] == 0} then {
      return ""; # UNSUPPORTED
    }

    return [string map [list \
        %targetFrameworkMoniker% $targetFrameworkMoniker \
        %version% $version] [string trim {
      {
        "runtimeOptions": {
          "tfm": "%targetFrameworkMoniker%%version%.0",
          "framework": {
            "name": "Microsoft.NETCore.App",
            "version": "%majorVersion%.0.0"
          },
          "rollForward": "LatestMajor"
        }
      }
    }]]
  }

  #
  # NOTE: This procedure is designed to be used with "-constraintExpression"
  #       values in the test suite.  It should return non-zero only if the
  #       (culture-specific) number format for the current thread uses the
  #       Unicode symbol for infinity (i.e. U+221E) instead of the literal
  #       string "Infinity".
  #
  proc haveInfinitySymbol {} {
    # <help>
    # This procedure reports whether the current thread's culture-specific
    # number format represents infinity using the Unicode infinity symbol
    # rather than the literal word.  It exists to drive test constraints that
    # depend on how floating-point infinities are rendered, which varies by
    # culture and by runtime version.
    #
    # How it works: under TclTk it reaches into the runtime to obtain the
    # current thread, then its current culture, then that culture's number
    # format object, guarding each step against a null handle.  It collects the
    # positive and negative infinity symbols and compares them against the
    # Unicode infinity symbol and its negated form.  When the comparison matches
    # exactly it returns true; otherwise, or on any failure, it returns false.
    # Under native Tcl it always returns false.
    #
    # Tricky details: the check is wrapped so that any error reaching the
    # runtime objects results in a false answer rather than propagating.  It is
    # culture- and thread-sensitive, so the answer reflects the format in effect
    # at the moment of the call.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   True when both the positive and negative infinity symbols are the
    #   expected Unicode symbol forms; otherwise false (including under native
    #   Tcl or on any failure).
    # </help>

    if {![isTclTk]} then {
      return false
    }

    if {[catch {
      set thread [object invoke -alias \
          System.Threading.Thread CurrentThread]

      if {[isNonNullObjectHandle $thread]} then {
        set culture [$thread -alias CurrentCulture]

        if {[isNonNullObjectHandle $culture]} then {
          set numberFormat [$culture -alias NumberFormat]

          if {[isNonNullObjectHandle $numberFormat]} then {
            list [$numberFormat PositiveInfinitySymbol] \
                [$numberFormat NegativeInfinitySymbol]
          }
        }
      }
    } symbols] == 0 && $symbols eq [list \u221E -\u221E]} then {
      return true
    } else {
      return false
    }
  }

  #
  # NOTE: This procedure helps to declare procedures to be annotated as
  #       "private", which means they cannot be called outside of their
  #       own namespace.  This will not work on procedures in the global
  #       namespace.
  #
  # <public>
  proc private { command name arguments body } {
    # <<inline>>
    # <<nonCaching>>

    # <help>
    # This procedure defines another procedure and marks it as "private",
    # meaning it cannot be called from outside its own namespace.  It exists as
    # a thin, readable front end over the general annotation helper, enabling
    # encapsulation of helper procedures so they are not invoked across
    # namespace boundaries.
    #
    # How it works: it simply delegates to the annotation helper, requesting
    # that the private annotation be enabled on a procedure created from the
    # supplied defining command, name, argument list, and body, and returns
    # whatever that helper returns.
    #
    # Tricky details: this procedure is itself annotated to be evaluated inline
    # in the caller's frame so that an unqualified procedure name is defined in
    # the caller's current namespace rather than this one.  Privacy enforcement
    # does not apply to procedures in the global namespace, so this is only
    # meaningful for procedures defined within a real namespace.
    #
    # Arguments:
    #   command   -- The defining command to use, which must be proc or its
    #                named variant.
    #   name      -- The name of the procedure to create and mark private.
    #   arguments -- The argument specification (parameter list) for the new
    #                procedure.
    #   body      -- The body for the new procedure.
    #
    # Results:
    #   The result of the underlying annotation helper, i.e. whatever defining
    #   the annotated procedure returns.
    # </help>

    return [annotateProcedure \
        private true $command $name $arguments $body]
  }

  #
  # NOTE: This procedure helps to tag a procedure with an annotation.  This
  #       procedure uses the "inline" annotation, which means its body will
  #       be evaluated in the current call frame.  This is necessary so that
  #       when an unqualified procedure name is used, the resulting procedure
  #       is (re-)defined within the correct (current) namespace e.g. ::someNs,
  #       and not the namespace that happens to contain this procedure, e.g.
  #       the global namespace.
  #
  # <public>
  proc annotateProcedure {
          annotation enable command name {arguments ""} {body ""} } {
    # <<inline>>
    # <<nonCaching>>

    # <help>
    # This procedure adds or removes a named annotation on a procedure by
    # editing the special annotation tag comments embedded at the top of its
    # body, then (re)defines the procedure.  It exists as the general engine
    # behind annotation front ends (such as the private marker), letting the
    # script library tag procedures with engine-recognized annotations in a way
    # that works under both TclTk and native Tcl.
    #
    # How it works: it builds regular expressions that recognize the tag for
    # the given annotation (both the bare form and a parameterized form whose
    # name precedes a colon).  It validates the enable flag and the annotation
    # itself, using the engine's own type tests under TclTk and equivalent
    # regular-expression checks under native Tcl.  The defining command is
    # normalized and required to be proc or its named variant.  When the named
    # procedure already exists and either the argument list or body was omitted,
    # the missing pieces are recovered from the existing procedure (qualifying
    # the name into the current namespace when it is unqualified).  If the body
    # already contains the annotation tag and enabling was requested, that is an
    # error; if disabling was requested, the tag is stripped, erroring if
    # nothing was removed.  If the body lacks the tag and enabling was
    # requested, the tag comment is prepended to the body; if disabling was
    # requested in that case, it is an error.  Finally the chosen defining
    # command is invoked to (re)create the procedure with the edited body.
    #
    # Tricky details: this procedure is itself annotated to evaluate inline in
    # the caller's frame so that recovering an existing procedure's definition,
    # and redefining an unqualified name, happen relative to the caller's
    # current namespace.  The annotation tags are ordinary comments matched by
    # pattern, so the edits are textual; enabling an already-present annotation
    # or disabling an absent one is treated as an error rather than a no-op.
    #
    # Arguments:
    #   annotation -- The annotation to add or remove; its leading portion (up
    #                 to any colon) names the annotation family.
    #   enable     -- A boolean; true adds the annotation, false removes it.
    #   command    -- The defining command to use, which must be proc or its
    #                 named variant.
    #   name       -- The name of the procedure to annotate.
    #   arguments  -- The argument specification for the procedure; when empty
    #                 and the procedure exists, it is recovered from the
    #                 existing definition.
    #   body       -- The procedure body; when empty and the procedure exists,
    #                 it is recovered from the existing definition.
    #
    # Results:
    #   The result of the underlying defining command after (re)defining the
    #   procedure with the annotation added or removed.  An error is raised on
    #   invalid input or when the requested add/remove is inconsistent with the
    #   procedure's current annotation state.
    # </help>

    #
    # HACK: These regular expressions were stolen and customized
    #       from the CodeBrix.Platform.TclTk._Components.Public.Value class.
    #
    set pattern(1) [appendArgs {#\s+<<(?:} $annotation {)>>\s+}]

    if {[set index [string first : $annotation]] != -1} then {
      set annotationName [string range $annotation 0 [expr {$index - 1}]]
    } else {
      set annotationName $annotation
    }

    set pattern(2) [appendArgs \
          {#\s+<<(?:} $annotationName {):(?:\w+(?: \w+)*)>>\s+}]

    set pattern(3) {^(?:\w+)(?::(?:\w+(?: \w+)*))?$}

    if {[isTclTk]} then {
      if {[string is not boolean $enable]} then {
        error [appendArgs "invalid enable flag: " $enable]
      }

      if {[string is not annotation $annotation]} then {
        error [appendArgs "invalid annotation: " $annotation]
      }
    } else {
      if {![string is boolean $enable]} then {
        error [appendArgs "invalid enable flag: " $enable]
      }

      if {![regexp -- $pattern(3) $annotation]} then {
        error [appendArgs "invalid annotation: " $annotation]
      }
    }

    set commands [list proc nproc]
    set command [string trimleft $command :]

    if {$command ni $commands} then {
      error [appendArgs "second word must be one of: " $commands]
    }

    if {[llength [info [appendArgs $command s] $name]] > 0} then {
      if {[string length $arguments] == 0 || \
          [string length $body] == 0} then {
        if {[string length [namespace qualifiers $name]] > 0} then {
          set qualifiedName $name
        } else {
          set qualifiedName [appendArgs [namespace current] :: $name]
        }

        if {[string length $arguments] == 0} then {
          set arguments [getProcedureArguments $qualifiedName]
        }

        if {[string length $body] == 0} then {
          set body [info body $qualifiedName]
        }
      }
    }

    if {[regexp -- $pattern(1) $body] || \
        [regexp -- $pattern(2) $body]} then {
      if {$enable} then {
        error [appendArgs \
            "procedure \"" $name "\" already annotated with \"" \
            $annotation \"]
      } else {
        if {[regsub -all -- $pattern(1) $body " " body] == 0 && \
            [regsub -all -- $pattern(2) $body " " body] == 0} then {
          error [appendArgs \
              "failed to remove annotation(s) \"" $annotation \
              "\" from procedure \"" $name \"]
        }
      }
    } else {
      if {$enable} then {
        set tag [appendArgs "# " << $annotation >>]
        set body [appendArgs $tag \n\n $body]
      } else {
        error [appendArgs \
            "procedure \"" $name "\" already lacks annotation \"" \
            $annotation \"]
      }
    }

    return [$command $name $arguments $body]
  }

  proc createPairs { dictionary } {
    # <help>
    # This procedure converts a flat dictionary into a list of name-and-value
    # pairs, where each pair is itself a two-element list.  It exists as the
    # inverse companion to the pair-flattening helper, giving callers a nested
    # representation of dictionary entries that is convenient to iterate over
    # one entry at a time.
    #
    # How it works: it first verifies that the argument is a valid dictionary,
    # raising an error if not.  It then walks the dictionary two elements at a
    # time, grouping each name with its value into a two-element sub-list and
    # appending that sub-list to the result.
    #
    # Tricky details: the input must be a well-formed dictionary, i.e. have an
    # even number of elements; the strict dictionary test enforces this before
    # any work is done.
    #
    # Arguments:
    #   dictionary -- The dictionary to convert into name-and-value pairs.
    #
    # Results:
    #   A list of two-element sub-lists, one per dictionary entry, each holding
    #   a name and its value.  An empty dictionary yields the empty list.  An
    #   error is raised when the argument is not a valid dictionary.
    # </help>

    if {![string is dict -strict $dictionary]} then {
      error "argument value must be dictionary"
    }

    set result [list]

    foreach {name value} $dictionary {
      lappend result [list $name $value]
    }

    return $result
  }

  proc flattenPairs { pairs } {
    # <help>
    # This procedure converts a list of two-element name-and-value pairs back
    # into a single flat dictionary-style list.  It exists as the inverse of
    # the pair-creating helper, recombining a nested pair representation into a
    # flat sequence of alternating names and values.
    #
    # How it works: it verifies that the argument is a valid list, then walks
    # each pair, counting as it goes.  Each pair must itself be a valid list of
    # exactly two elements; a non-list pair or one of the wrong length raises an
    # error that identifies the offending pair by its position.  For each valid
    # pair the name and value are appended to the result as two separate
    # elements.
    #
    # Tricky details: the validation is strict and per-pair, and error messages
    # report the one-based position of the bad pair, which aids diagnosis when
    # the input is malformed.
    #
    # Arguments:
    #   pairs -- A list of two-element sub-lists, each holding a name and its
    #            value.
    #
    # Results:
    #   A flat list of alternating names and values suitable for use as a
    #   dictionary.  An empty input yields the empty list.  An error is raised
    #   when the input is not a list or any pair is not a two-element list.
    # </help>

    if {![string is list -strict $pairs]} then {
      error "argument value must be list"
    }

    set result [list]
    set count 0

    foreach pair $pairs {
      incr count

      if {![string is list -strict $pair]} then {
        error [appendArgs "pair #" $count " must be list"]
      }

      set length [llength $pair]

      if {$length != 2} then {
        error [appendArgs "wrong pair #" $count " length " $length]
      }

      lappend result [lindex $pair 0] [lindex $pair 1]
    }

    return $result
  }

  proc tclLogForTester { string } {
    # <help>
    # This procedure emits a diagnostic message on behalf of the test harness,
    # preferring the standard logging command when it is available and falling
    # back to standard error otherwise.  It exists so the tester can record
    # internal messages without assuming a particular logging facility is
    # present, and so that logging can be globally suppressed.
    #
    # How it works: it first checks a suppression flag in the global no-feature
    # array and does nothing when that flag is set.  Otherwise, if the standard
    # log command exists, it forwards the message to that command and returns
    # its result.  If the log command is not available it instead attempts to
    # write the message to standard error, ignoring any failure of that write.
    #
    # Tricky details: the fallback write is wrapped so that an inability to
    # write to standard error does not itself raise an error.  When the log
    # command is used, this procedure returns that command's result; on the
    # fallback path there is no meaningful return value.
    #
    # Arguments:
    #   string -- The message text to log.
    #
    # Results:
    #   The result of the underlying log command when it is used; otherwise no
    #   meaningful value.  Nothing is emitted when logging is suppressed.
    # </help>

    if {![info exists ::no(tclLogForTester)]} then {
      if {[llength [info commands tclLog]] > 0} then {
        return [tclLog $string]
      }

      catch {puts stderr $string}
    }
  }

  proc maybeInvokeForTester { name } {
    # <help>
    # This procedure optionally invokes a named hook command on behalf of the
    # test harness, tolerating its absence and trapping any error it raises.
    # It exists to provide extension points (hooks) that the test framework can
    # call at well-defined moments without requiring those hooks to be defined
    # and without letting a misbehaving hook disrupt the harness.
    #
    # How it works: it first checks a suppression flag in the global no-feature
    # array and does nothing when that flag is set.  Otherwise, if a general
    # maybe-invoke helper command exists, it delegates to that helper in the
    # caller's frame and returns its result.  Failing that, if a command with
    # the requested name exists, it invokes that command in the caller's frame
    # within a catch; on success it returns the command's result, and on failure
    # it logs an invoke error via the tester logging helper.  When nothing is
    # invoked, the empty string is returned.
    #
    # Tricky details: the hook is run via an uplevel into the caller's frame so
    # it sees the caller's context.  Errors from the hook are caught and logged
    # rather than propagated, so a failing hook never aborts the surrounding
    # operation.
    #
    # Arguments:
    #   name -- The name of the hook command to invoke if it exists.
    #
    # Results:
    #   The hook command's result when it is invoked successfully (directly or
    #   via the general helper); otherwise the empty string, including when the
    #   hook is absent, suppressed, or fails.
    # </help>

    if {![info exists ::no(maybeInvokeForTester)]} then {
      if {[llength [info commands maybeInvoke]] > 0} then {
        return [uplevel 1 [list maybeInvoke $name]]
      }

      if {[llength [info commands $name]] > 0} then {
        if {[catch {
          uplevel 1 [list $name]
        } result] == 0} then {
          return $result
        } else {
          tclLogForTester [appendArgs \
              "TESTER INVOKE ERROR: " $result]
        }
      }
    }

    return ""
  }

  proc haveCaches { type } {
    # <help>
    # This procedure reports whether a particular category of internal TclTk
    # caching is compiled into the running engine.  It exists to gate cache
    # reset and reporting logic so those operations are attempted only when the
    # relevant cache support actually exists, avoiding errors on builds that
    # omit it.
    #
    # How it works: under TclTk it switches on the requested category.  For the
    # instance category it returns true if any of several per-instance cache
    # compile-time constraints are present (argument, list, parse, execute,
    # type, or COM type caches).  For the to-string category it requires cache
    # statistics support together with at least one of the to-string caches.
    # For the string-builder category it requires cache statistics support.  Any
    # other category, or running under native Tcl, yields false.
    #
    # Tricky details: the determination is based on compile-time constraints,
    # so it reflects how the engine was built rather than current runtime
    # configuration.  Unknown category names simply fall through to false.
    #
    # Arguments:
    #   type -- The cache category to test, one of the recognized category
    #           names (instance, to-string, or string-builder).
    #
    # Results:
    #   True when the requested category of caching is compiled in; otherwise
    #   false (including under native Tcl or for unknown categories).
    # </help>

    if {[isTclTk]} then {
      switch -exact -- $type {
        instance {
          if {[haveConstraint compile.ARGUMENT_CACHE] || \
              [haveConstraint compile.LIST_CACHE] || \
              [haveConstraint compile.PARSE_CACHE] || \
              [haveConstraint compile.EXECUTE_CACHE] || \
              [haveConstraint compile.TYPE_CACHE] || \
              [haveConstraint compile.COM_TYPE_CACHE]} then {
            return true
          }
        }
        toString {
          if {[haveConstraint compile.CACHE_STATISTICS] && \
              ([haveConstraint compile.CACHE_ARGUMENTLIST_TOSTRING] || \
               [haveConstraint compile.CACHE_STRINGLIST_TOSTRING])} then {
            return true
          }
        }
        stringBuilder {
          if {[haveConstraint compile.CACHE_STATISTICS]} then {
            return true
          }
        }
      }
    }

    return false
  }

  proc resetCaches { {enable true} } {
    # <help>
    # This procedure resets and clears the active interpreter's internal caches
    # and either locks or unlocks them, then reports what it did.  It exists to
    # put caching into a known, stable state, typically so that test runs are
    # not influenced by cached results carried over from earlier work and so
    # high-priority runs can pin caching behavior.
    #
    # How it works: it acts only under TclTk, when instance caches are compiled
    # in, the object command is available, and a suppression flag is not set.
    # It assembles a set of cache-control flags requesting a typical reset,
    # clear, pre-setup, zeroed counts, and property setup, adding a lock or
    # unlock flag according to the enable argument.  It invokes the active
    # interpreter's cache-control operation with these flags and then re-enables
    # the typical caches, collecting any non-trivial results, and logs a summary
    # to the test channel.
    #
    # Tricky details: the enable flag controls locking, not whether caching is
    # turned off; caches are re-enabled afterward regardless.  When the guarding
    # conditions are not met the procedure does nothing at all.  Results that
    # report no change are filtered out of the summary.
    #
    # Arguments:
    #   enable -- A boolean; when true the caches are locked, when false they
    #             are unlocked.  Defaults to true.
    #
    # Results:
    #   No meaningful return value; its effect is to reset the caches and emit
    #   a log message describing the outcome.
    # </help>

    if {[isTclTk] && [haveCaches instance] && \
        [llength [info commands object]] > 0 && \
        ![info exists ::no(resetCaches)]} then {
      set cacheFlags [list \
          TypicalMask Reset Clear PreSetup \
          ZeroCounts MaybeSetProperties]

      if {$enable} then {
        lappend cacheFlags Lock
      } else {
        lappend cacheFlags Unlock
      }

      set results [list]

      set result [object invoke \
          Interpreter.GetActive ControlCaches \
          $cacheFlags $enable]

      if {$result ne "None"} then {
        lappend results $result
      }

      set result [object invoke \
          Interpreter.GetActive EnableCaches \
          TypicalMask true]

      if {$result ne "None"} then {
        lappend results $result
      }

      tputs [getTestChannelOrDefault] [appendArgs \
          "---- reset caches: " $results \n]
    }
  }

  proc reportCaches {} {
    # <help>
    # This procedure gathers status information about the active interpreter's
    # internal caches and logs it as a formatted summary to the test channel.
    # It exists to give visibility into cache behavior during testing, which is
    # useful for diagnosing performance and for confirming that caching is in
    # the expected state.
    #
    # How it works: it acts only under TclTk, when instance caches are compiled
    # in, the object command is available, and a suppression flag is not set.
    # It builds a set of detail flags, adding string-builder cache detail when
    # string-builder caching is enabled and adding configuration and memory-load
    # detail when a verbose runtime option is in effect.  It then collects the
    # host's other-cache information into a pair list, and additionally the
    # string and string-builder cache information when those cache categories
    # are available.  Each collected element with both a non-empty name and
    # value is turned into a name-and-value pair, and the assembled pairs are
    # formatted as a dictionary and logged.  Finally it invokes an after-report
    # hook so callers can extend the reporting.
    #
    # Tricky details: which detail is gathered depends on both compiled cache
    # support and runtime options, so the report adapts to the build and
    # configuration.  Empty entries are skipped so the summary stays concise.
    # The trailing hook invocation is a deliberate extension point.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   No meaningful return value; its effect is to emit a cache-status log
    #   message and invoke the after-report hook.
    # </help>

    if {[isTclTk] && [haveCaches instance] && \
        [llength [info commands object]] > 0 && \
        ![info exists ::no(reportCaches)]} then {
      set list null
      set detailFlags [list EmptyContent]

      if {[object invoke Interpreter.GetActive \
          AreCachesEnabled StringBuilder]} then {
        lappend detailFlags StringBuilderCacheInfo \
            StringBuilderFactoryInfo
      }

      if {[hasRuntimeOption verboseReportCaches]} then {
        lappend detailFlags CacheConfigurationMemoryLoad \
            CacheConfiguration
      }

      set list [object create StringPairList]

      object invoke -create -alias -flags +NonPublic \
          Interpreter.GetActive GetHostOtherCacheInfo \
          list $detailFlags false

      if {[haveCaches toString]} then {
        object invoke -create -alias -flags +NonPublic \
            Interpreter.GetActive GetHostStringCacheInfo \
            list $detailFlags
      }

      if {[haveCaches stringBuilder]} then {
        object invoke -create -alias -flags +NonPublic \
            Interpreter.GetActive GetHostStringBuilderCacheInfo \
            list $detailFlags
      }

      set pairs [list]

      object foreach -alias element $list {
        if {![isNonNullObjectHandle $element]} then {
          continue
        }

        set value [$element Y]

        if {[string length $value] == 0} then {
          continue
        }

        set name [$element X]

        if {[string length $name] == 0} then {
          continue
        }

        lappend pairs $name $value
      }

      tputs [getTestChannelOrDefault] [appendArgs "---- cache status: " \
          [formatListAsDict $pairs <none>] \n]

      maybeInvokeForTester ::afterReportCaches; # HOOK
    }
  }

  proc maybeMakeHighPriority { highPriority } {
    # <help>
    # This procedure attempts to switch the active interpreter into or out of
    # a "high-priority" mode and, when the mode actually changes, resets the
    # caches to match.  It exists so test runs that need more deterministic or
    # higher-priority execution can request that posture, while gracefully doing
    # nothing on builds or platforms where the capability is absent.
    #
    # How it works: it acts only under TclTk, when the object command is
    # available, and a suppression flag is not set.  Within a catch, it invokes
    # the interpreter's high-priority operation with the requested setting; if
    # that returns a boolean (indicating the mode is supported), it resets the
    # caches accordingly and keeps that boolean as the outcome.  It then logs an
    # appropriate message: that the mode was enabled or disabled (and locked or
    # unlocked and cleared), that it was unchanged, or that it was unavailable
    # when the operation itself failed.
    #
    # Tricky details: the underlying operation may report a non-boolean value
    # to mean "no change", which is handled distinctly from true or false.  All
    # interaction with the runtime is wrapped so that failure becomes an
    # informational log rather than a raised error.  Regardless of what happens,
    # the procedure returns false.
    #
    # Arguments:
    #   highPriority -- The requested high-priority setting (typically a boolean
    #                   selecting whether to enable the mode).
    #
    # Results:
    #   Always false; the meaningful effects are the possible mode change, cache
    #   reset, and the logged status message.
    # </help>

    if {[isTclTk] && [llength [info commands object]] > 0 && \
        ![info exists ::no(maybeMakeHighPriority)]} then {
      if {[catch {
        set maybe [object invoke -flags +NonPublic \
            Interpreter.GetActive MaybeMakeHighPriority \
            $highPriority]

        if {[string is boolean -strict $maybe]} then {
          resetCaches $highPriority
        }

        set maybe; # null / false / true
      } result] == 0} then {
        if {[string is boolean -strict $result]} then {
          tputs [getTestChannelOrDefault] [appendArgs \
              "---- high-priority mode has now been " \
              [expr {$result ? "enabled" : "disabled"}] ", " \
              [expr {$result ? "locked" : "unlocked"}] \
              ", and cleared\n"]
        } else {
          tputs [getTestChannelOrDefault] \
              "---- high-priority mode is unchanged\n"
        }
      } else {
        tputs [getTestChannelOrDefault] [appendArgs \
            "---- high-priority mode is unavailable: " \
            $result \n]
      }
    }

    return false
  }

  proc removeTemporarySubDirectories { directory } {
    # <help>
    # This procedure removes a directory and walks upward removing its empty
    # ancestor directories, but only within the bounds of the temporary
    # directory.  It exists to clean up the (possibly nested) sub-directories
    # the test harness creates beneath the temporary directory for logs and
    # date-stamped output, without ever touching directories outside that safe
    # area.
    #
    # How it works: it determines the temporary directory and, within a catch
    # so that failures are non-fatal, proceeds only if that temporary directory
    # exists and is writable.  It then loops, at each step requiring that the
    # current directory be non-empty as a name, exist as a writable directory,
    # lie strictly under the temporary directory, and not be the temporary
    # directory itself.  While those conditions hold it removes the current
    # directory (which fails, and thus stops the loop, if the directory is not
    # empty) and moves up to its parent.  It returns the directory at which it
    # stopped.
    #
    # Tricky details: the whole operation is intentionally fail-safe, guarded by
    # the temporary-directory containment checks so it cannot delete unrelated
    # directories, and wrapped so that an error simply ends the cleanup.  The
    # ascent stops at the first non-empty directory because removing it fails.
    # This logic is delicate and should not be changed without fully
    # understanding it.
    #
    # Arguments:
    #   directory -- The starting (innermost) directory to remove; cleanup
    #                ascends from here toward the temporary directory.
    #
    # Results:
    #   The directory at which the upward removal stopped (the first one not
    #   removed); the original directory when nothing could be removed.
    # </help>

    #
    # HACK: Cleanup any sub-directories underneath the log
    #       file "root" directory, e.g. TEMP, etc.  So, we
    #       should remove "logs" and "2024-07-04", beneath
    #       the TEMP directory, but only when they are now
    #       empty.  This block is designed to be basically
    #       "fail-safe" unless the user has purposely set
    #       their TEMP directory to something bad.  Please
    #       do not modify this block of code unless needed
    #       -AND- you know EXACTLY how (and why) it works.
    #
    set temporaryDirectory [getTemporaryPath]

    catch {
      if {[string length $temporaryDirectory] > 0 && \
          [file isdirectory $temporaryDirectory] && \
          [file writable $temporaryDirectory]} then {
        while {[string length $directory] > 0 && \
               [file isdirectory $directory] && \
               [file writable $directory] && \
               [file under $directory $temporaryDirectory] && \
               ![file same $directory $temporaryDirectory]} {
          file rmdir $directory; # NOTE: Throws on error.
          set directory [file dirname $directory]
        }
      }
    }

    return $directory
  }

  proc enableInteractiveCommands { {enable ""} } {
    # <help>
    # This procedure enables, disables, or toggles whether interactive commands
    # (the special commands recognized only in the interactive loop) are honored
    # by the active interpreter.  It exists so tests and tooling can control the
    # availability of interactive commands, for example to suppress them during
    # automated runs or to restore them afterward.
    #
    # How it works: when no explicit setting is given, it reads the current
    # interactive-commands-enabled state from the active interpreter and chooses
    # the opposite, producing a toggle.  It then writes the chosen setting back
    # to the active interpreter via its non-public interactive-commands-enabled
    # property.
    #
    # Tricky details: it reaches into a non-public interpreter property both to
    # read and to write the state, so it depends on the object command and that
    # internal property being available.  An empty argument is the signal to
    # toggle rather than to set a specific value.
    #
    # Arguments:
    #   enable -- The desired setting (a boolean) for interactive commands; when
    #             empty, the current state is toggled.
    #
    # Results:
    #   The result of writing the property (typically the value that was set);
    #   the side effect is the changed interactive-commands state.
    # </help>

    if {[string length $enable] == 0} then {
      set enable [expr {![object invoke -flags +NonPublic \
          Interpreter.GetActive InteractiveCommandsEnabled]}]
    }

    object invoke -flags +NonPublic Interpreter.GetActive \
        InteractiveCommandsEnabled $enable
  }

  proc getProcedureArguments { name } {
    # <help>
    # This procedure returns the full argument specification (parameter list)
    # of an existing procedure, including any default values, in the form
    # accepted by the procedure-defining commands.  It exists so other helpers
    # can faithfully recover and reuse a procedure's parameter list, for example
    # when cloning or re-annotating a procedure.
    #
    # How it works: under TclTk it asks the introspection command directly for
    # the argument list in its full (default-bearing) form.  Under native Tcl it
    # reconstructs that form by iterating the parameter names and, for each one
    # that has a default, emitting a two-element name-and-default sub-list, or
    # the bare name otherwise.
    #
    # Tricky details: the two engines arrive at the same representation through
    # different means; the native Tcl path must explicitly query each parameter
    # for a default because that information is not returned in one call there.
    #
    # Arguments:
    #   name -- The name of an existing procedure whose argument specification
    #           is wanted.
    #
    # Results:
    #   The procedure's argument specification, where parameters with defaults
    #   appear as two-element name-and-default sub-lists and others as bare
    #   names.
    # </help>

    if {[isTclTk]} then {
      set result [info args $name true]
    } else {
      set result [list]

      foreach arg [info args $name] {
        if {[info default $name $arg default]} then {
          lappend result [list $arg $default]
        } else {
          lappend result $arg
        }
      }
    }

    return $result
  }

  proc cloneProcedure { oldName newName {command ""} } {
    # <help>
    # This procedure creates a copy of an existing procedure under a new name,
    # preserving its argument specification and body.  It exists so the test
    # framework can duplicate procedures (for example, to save an original
    # before replacing it, or to provide an alias) without manually copying the
    # definition.
    #
    # How it works: it recovers the source procedure's argument specification
    # and body via the introspection helpers.  When no defining command is
    # supplied, it prefers the named procedure variant if running under TclTk,
    # that command exists, and the source was itself defined as a named
    # procedure; otherwise it uses the ordinary proc command.  It then invokes
    # the chosen defining command to create the new procedure with the recovered
    # argument list and body.
    #
    # Tricky details: the choice of defining command tries to match the source
    # procedure's own kind so that a named-procedure original is cloned as a
    # named procedure.  The body is copied verbatim, so any annotations embedded
    # in it carry over to the clone.
    #
    # Arguments:
    #   oldName -- The name of the existing procedure to clone.
    #   newName -- The name to give the cloned procedure.
    #   command -- The defining command to use, which must be proc or its named
    #              variant.  When empty, the kind is inferred from the source
    #              and the engine.
    #
    # Results:
    #   The result of the defining command after creating the clone (typically
    #   the empty string).
    # </help>

    set arguments [getProcedureArguments $oldName]
    set body [info body $oldName]

    if {[string length $command] == 0} then {
      if {[isTclTk] && \
          [llength [info commands nproc]] > 0 && \
          [llength [info nprocs $oldName]] > 0} then {
        set command nproc
      } else {
        set command proc
      }
    }

    return [$command $newName $arguments $body]
  }

  proc getTclMinimumVersion {} {
    # <help>
    # This procedure returns the minimum native Tcl version that the test
    # framework is willing to load.  It exists so the Tcl-loading logic can be
    # constrained to versions that support the features the framework relies
    # upon, while still allowing that floor to be overridden via the
    # environment.
    #
    # How it works: if the corresponding environment variable is set it returns
    # its value; otherwise it returns a built-in default version.
    #
    # Tricky details: the built-in default reflects a deliberate floor (a Tcl
    # version that supports script cancellation) and intentionally avoids the
    # 9.x line; the accompanying note explains the rationale, which should be
    # respected when adjusting the value.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   The minimum acceptable native Tcl version, taken from the environment
    #   when set or the built-in default otherwise.
    # </help>

    #
    # HACK: The minimum version that should be used here
    #       is 8.6, due to its support for TIP #285, e.g.
    #       [interp cancel], et al.  Also, do not bother
    #       using Tcl 9.x, which is "broken" by design.
    #
    if {[info exists ::env(TclMinimumVersion)]} then {
      return $::env(TclMinimumVersion)
    } else {
      return 8.6
    }
  }

  proc getTclMaximumVersion {} {
    # <help>
    # This procedure returns the maximum native Tcl version that the test
    # framework is willing to load.  It exists so the Tcl-loading logic can be
    # capped below versions known to be problematic, while still allowing that
    # ceiling to be overridden via the environment.
    #
    # How it works: if the corresponding environment variable is set it returns
    # its value; otherwise it returns a built-in default version.
    #
    # Tricky details: the built-in default deliberately stays below the 9.x
    # line; the accompanying note explains the rationale, which should be
    # respected when adjusting the value.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   The maximum acceptable native Tcl version, taken from the environment
    #   when set or the built-in default otherwise.
    # </help>

    #
    # HACK: The minimum version that should be used here
    #       is 8.6, due to its support for TIP #285, e.g.
    #       [interp cancel], et al.  Also, do not bother
    #       using Tcl 9.x, which is "broken" by design.
    #
    if {[info exists ::env(TclMaximumVersion)]} then {
      return $::env(TclMaximumVersion)
    } else {
      return 8.9
    }
  }

  proc tryToLoadZeus { {quiet false} } {
    # <help>
    # This procedure attempts to load the Zeus plugin, which is part
    # of TclTk Enterprise Edition.  It allows encrypted scripts to be
    # encrypted, decrypted, and evaluated.  Since it is a commercial
    # product, some kind of license certificate for it must be available
    # on the local computer (e.g. a trial license certificate from the
    # associated NuGet package, etc) -OR- it will fail to load.  Upon
    # success, this procedure will return non-zero.
    # </help>

    if {[catch {
      package require Zeus.Enterprise; # binary plugin
      package require Zeus.Cryptography; # script package

      uplevel 1 [list setupStateForZeus true]; # HACK: Need magic.
    } error] == 0} then {
      return true
    } else {
      if {!$quiet} then {
        set level [lindex [info level [info level]] 0]

        catch {
          tclLog [appendArgs "ERROR (" $level "): " $error]
        }
      }

      return false
    }
  }

  proc loadTetrisViaTclTk { {security ""} {path ""} {waitType Tcl} } {
    # <help>
    # This procedure attempts to load the native Tcl runtime via
    # the [tcl load] sub-command.  Then, sets up the interpreter
    # to evaluate the Tk Tetris game written by Jeffrey Hobbs.
    # Finally, it enters a native Tcl event loop until canceled.
    # </help>

    if {![isTclTk] && ![info exists ::env(TCLTK)]} then {
      error "the TCLTK environment variable is not set"
    }

    ############################################################

    if {[isTclTk] && [string length $security] > 0} then {
      #
      # NOTE: This requires the Harpy and Badge plugins to be
      #       available and loadable.
      #
      if {$security} then {
        source enableSecurity
      } else {
        source disableSecurity
      }
    }

    ############################################################

    set script(try) {
      if {![info exists ::env(NoTetris)]} then {
        if {[info exists ::argv]} then {
          set ::savedArgv $::argv
        } else {
          unset -nocomplain ::savedArgv
        }
        set ::argv [list]
        rename exit __exit
        proc exit { args } {
          set ai [after info]
          if {[llength $ai] > 0} then {
            foreach i $ai {after cancel $i}
          }
          catch {destroy .}; # can this fail?
          set ::forever 1; # exit vwait
        }
        package require Tk; # may error, no Tk?
        wm protocol . WM_DELETE_WINDOW exit
        %source%
        %vwait%
      }
    }

    ############################################################

    set script(finally) {
      if {![info exists ::env(NoTetris)]} then {
        unset -nocomplain ::forever
        rename exit ""; rename __exit exit
        if {[info exists ::savedArgv]} then {
          set ::argv $::savedArgv
        } else {
          unset -nocomplain ::argv
        }
        unset -nocomplain ::savedArgv
      }
    }

    ############################################################

    if {[isTclTk] && $waitType eq "TclTk"} then {
      #
      # NOTE: Uses a TclTk event loop, to be setup later in the
      #       procedure.
      #
      set script(try) [string map [list %vwait% ""] $script(try)]
    } else {
      #
      # NOTE: Assume using the current interpreter (thread) will
      #       require us to manually enter the Tcl event loop in
      #       order to service the native Tcl events.
      #
      set script(try) [string map [list %vwait% {
        after 0 list; vwait ::forever
      }] $script(try)]
    }

    ############################################################

    if {[isTclTk]} then {
      set script(body) [interp \
          readorgetscriptfile {} lib/Tetris1.0/tetris.tcl]

      if {[uplevel #0 [list tryToLoadZeus]] && \
          [isEncryptedScript $script(body)]} then {
        if {[info exists ::zeus(encodingName)] && \
            [info exists ::zeus(password)] && \
            [info exists ::zeus(salt)] && \
            [info exists ::zeus(iterationCount)] && \
            [info exists ::zeus(hashAlgorithmName)]} then {
          set script(body) \
              [decryptScript [eval $script(body)] \
              $::zeus(encodingName) $::zeus(password) \
              $::zeus(salt) $::zeus(iterationCount) \
              $::zeus(hashAlgorithmName)]

          set script(try) [string map \
              [list %source% [list eval $script(body)]] \
              $script(try)]
        } else {
          error "missing one or more Zeus decryption parameters"
        }
      } else {
        if {[info exists ::env(AllowTetrisWithoutZeus)]} then {
          set script(try) [string map [list %source% \
              {eval [tcltk [list interp readorgetscriptfile {} \
              lib/Tetris1.0/tetris.tcl]]}] $script(try)]
        } else {
          error "cannot load Zeus -OR- script is not encrypted"
        }
      }
    } else {
      if {[info exists ::env(AllowTetrisWithoutTclTk)]} then {
        set script(try) [string map \
            [list %source% [list source [file normalize [file \
            join $::env(TCLTK) Example Scripts tetris.tcl]]]] \
            $script(try)]
      } else {
        error "cannot evaluate script without TclTk"
      }
    }

    ############################################################

    set started [clock seconds]

    try {
      if {[isTclTk]} then {
        if {![tcl ready]} then {
          #
          # HACK: Avoid using any ActiveTcl "BaseKits" here in
          #       case they do not embed Tk correctly.  Also,
          #       make sure the Win32 SetDllDirectory API gets
          #       called prior to attempting to load the native
          #       Tcl library; otherwise, the inability of the
          #       "tcl*.dll" library to locate the "zlib1.dll"
          #       library could cause issues.
          #
          if {[string length $path] > 0} then {
            tcl load -maybetrustedonly -bridge -robustify \
                -minimumversion [getTclMinimumVersion] \
                -maximumversion [getTclMaximumVersion] -- \
                $path
          } else {
            tcl load -maybetrustedonly -bridge -robustify \
                -minimumversion [getTclMinimumVersion] \
                -maximumversion [getTclMaximumVersion] --
          }

          set loaded 1; # NOTE: We loaded Tcl, we must unload.
        }

        tcl eval [tcl primary] [list uplevel #0 $script(try)]

        if {$waitType eq "TclTk"} then {
          uplevel #0 [list vwait \
              -force -eventwaitflags +TclDoOneEvent -- forever]
        }
      } else {
        uplevel #0 $script(try)
      }
    } finally {
      if {[isTclTk]} then {
        tcl eval [tcl primary] \
            [list uplevel #0 $script(finally)]

        if {![info exists ::env(NoTclUnload)]} then {
          if {[info exists loaded] && $loaded} then {
            tcl unload
          }
        }

        unset -nocomplain loaded; # NOTE: We unloaded Tcl.
      } else {
        uplevel #0 $script(finally)
      }

      set elapsed [expr {[clock seconds] - $started}]
    }

    ############################################################

    return $elapsed; # return total time wasted...  :)
  }

  proc breakOnError { script } {
    # <help>
    # This procedure attempts to evaluate the specified script in the call
    # frame of the immediate caller.  If the script is successful, result
    # is returned to the caller verbatim.  If the script is unsuccessful,
    # the [debug break] sub-command will be invoked on the current thread,
    # thereby blocking further evaluation, until the interactive user has
    # a chance to dismiss the debugger.  The interactive user can retry a
    # failed script by successfully returning a true value from within the
    # current interactive loop (i.e. the one entered via the [debug break]
    # sub-command).  Here is an illustrative example:
    #
    #  STEP #1: Imagine a script that refers to a missing variable.
    #
    #           [1] % breakOnError {set blarg}
    #
    #  STEP #2: The script error is caught, reported, and an interactive
    #           loop is entered, waiting for user input.
    #
    #           breakOnError: can't read "blarg": no such variable
    #           [stop]
    #
    #  STEP #3: The user can now create the missing variable.
    #
    #           (debug) [2] % set blarg 1
    #           1
    #
    #  STEP #4: Then, to retry the failed operation, simply store a
    #           literal "1" integer value into the result, e.g. via
    #           the "#setr" interactive command, etc.
    #
    #           (debug) [3] % #setr
    #           result set
    #
    #  STEP #5: Finally, use the "#go" interactive command to exit an
    #           instance of the interactive loop.
    #
    #           (debug) [4] % #go
    #           [go]
    # </help>

    while {true} {
      if {[set code [catch {
        uplevel 1 $script; # NOTE: Evaluate script, capture results.
      } result]] == 0} then {
        return $result
      } else {
        set levelNumber [info level]
        set levelName [lindex [info level $levelNumber] 0]

        set errorLine \
            [object invoke Interpreter.GetActive ErrorLine]

        foreach varName [list \
            ::errorCode ::errorInfo errorLine result code] {
          set elementName [appendArgs \
              $levelName _ [string trimleft $varName :]]

          if {[info exists $varName]} then {
            set ::tcltk_debugger($elementName) [set $varName]
          }
        }

        host result Error [appendArgs \
            "==== " $levelName " (" $levelNumber \
            "): ERROR, line #" $errorLine ": " $result \n]

        if {![string is true -strict [uplevel 1 \
            [list debug emergency {now break}]]]} then {
          error $result
        }
      }
    }
  }

  proc getEnvironmentViaComSpec { includeExisting } {
    # <help>
    # This procedure attempts to extract the list of environment variables
    # from an instance of the operating system Command Processor.  If the
    # includeExisting argument is zero, any environment variables present
    # in the current process are ignored.  This procedure is designed to
    # be used by (development environment?) scripts that require the full
    # set of environment variables provided by the operating system Command
    # Processor, e.g. set via the AutoRun registry, et al.  An example of
    # its usage is:
    #
    #           apply [list [list] {
    #             foreach pair [getEnvironmentViaComSpec false] {
    #               set ::env([lindex $pair 0]) [lindex $pair 1]
    #             }
    #           }]
    # </help>

    if {![info exists ::env(ComSpec)]} then {
      error "the ComSpec environment variable must be set first."
    }

    set data [string map [list \r\n \n] [string trim \
        [exec -success Success -- $::env(ComSpec) /c SET]]]

    set lines [split $data \n]
    set result [list]

    foreach line $lines {
      set index [string first = $line]
      if {$index == -1} then {continue}

      set name [string range $line 0 [expr {$index - 1}]]
      set value [string range $line [expr {$index + 1}] end]

      if {$includeExisting || ![info exists ::env($name)]} then {
        lappend result [list $name $value]
      }
    }

    return $result
  }

  proc getNameForDebugHook { dictionary } {
    # <help>
    # This procedure attempts to extract the name from the list of arguments,
    # which is treated as a dictionary.  If there is no name, it should return
    # a suitable placeholder string.
    # </help>

    set result [getDictionaryValue $dictionary name]

    if {[string length $result] == 0} then {
      set result <unknown>
    }

    return $result
  }

  proc announceForDebugHook { message } {
    # <help>
    # This procedure attempts to announce to the user that the associated hook
    # has been hit.
    # </help>

    host result Continue [appendArgs "---- " $message \n]
    return ""
  }

  proc forceInteractiveLoopForDebugHook {} {
    # <help>
    # This procedure attempts to forcibly break into the interactive loop now.
    # It has been designed for use with the [debug hook] support procedures.
    # </help>

    debug emergency now; debug break
    return ""
  }

  proc debugBreakHook { args } {
    # <help>
    # This procedure is designed to be used with the [debug hook] sub-command.
    # It will attempt to break into the interactive loop after announcing that
    # it has been hit.  In order to use it, something like the following must
    # be executed: [debug hook -type Before basic-1.* ::debugBreakHook]
    # </help>

    set name [getNameForDebugHook $args]

    set message [appendArgs \
        "test " $name " being debugged via hook"]

    announceForDebugHook $message
    forceInteractiveLoopForDebugHook
    return -code Ok $message
  }

  proc skipTestHook { args } {
    # <help>
    # This procedure is designed to be used with the [debug hook] sub-command.
    # It will attempt to entirely skip the test after announcing it has been
    # hit.  In order to use it, something like the following must be executed:
    # [debug hook -type Before basic-1.* ::skipTestHook]
    # </help>

    set name [getNameForDebugHook $args]

    set message [appendArgs \
        "test " $name " forcibly skipped via hook"]

    announceForDebugHook $message
    return -code Break $message
  }

  proc noFailTestHook { args } {
    # <help>
    # This procedure is designed to be used with the [debug hook] sub-command.
    # It will attempt to prevent the test from failing after announcing it has
    # been hit.  In order to use it, something like the following must be
    # executed: [debug hook -type Before basic-1.* ::noFailTestHook]
    # </help>

    set name [getNameForDebugHook $args]

    set message [appendArgs \
        "test " $name " forcibly non-failed via hook"]

    announceForDebugHook $message
    return -code Continue $message
  }

  proc whatIfTestHook { args } {
    # <help>
    # This procedure is designed to be used with the [debug hook] sub-command.
    # It will attempt to enable 'what-if' mode for the test after announcing it
    # has been hit.  In order to use it, something like the following must be
    # executed: [debug hook -type Before basic-1.* ::whatIfTestHook]
    # </help>

    set name [getNameForDebugHook $args]

    set message [appendArgs \
        "test " $name " forcibly 'what-if' mode via hook"]

    announceForDebugHook $message
    return -code WhatIf $message
  }

  proc errorTestHook { args } {
    # <help>
    # This procedure is designed to be used with the [debug hook] sub-command.
    # It will attempt to force the test to error out after announcing it has
    # been hit.  In order to use it, something like the following must be
    # executed: [debug hook -type Before basic-1.* ::errorTestHook]
    # </help>

    set name [getNameForDebugHook $args]

    set message [appendArgs \
        "test " $name " forcibly errored out via hook"]

    announceForDebugHook $message
    return -code Error $message
  }

  proc failTestHook { args } {
    # <help>
    # This procedure is designed to be used with the [debug hook] sub-command.
    # It will attempt to force the test to fail after announcing it has been
    # hit.  In order to use it, something like the following must be executed:
    # [debug hook -type Before basic-1.* ::failTestHook]
    # </help>

    set name [getNameForDebugHook $args]

    set message [appendArgs \
        "test " $name " forcibly failed via hook"]

    announceForDebugHook $message
    return -code Exception $message
  }

  proc maybeGetArgv {} {
    # <help>
    # This procedure returns the global command-line argument list, or a
    # placeholder when there are no arguments.  It exists so logging and
    # diagnostic code can report the arguments safely, without having to test
    # for the variable's existence or for an empty list.
    #
    # How it works: it accesses the global argument variable and, if it exists
    # and is non-empty, returns it; otherwise it returns a fixed placeholder
    # string indicating none.
    #
    # Tricky details: an existing but empty argument list is treated the same as
    # a missing one, both yielding the placeholder, so the result is always
    # something printable.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   The global argument list when present and non-empty; otherwise a
    #   placeholder string indicating that there are no arguments.
    # </help>

    global argv

    if {[info exists argv] && [llength $argv] > 0} then {
      return $argv
    } else {
      return <none>
    }
  }

  proc addToArgv { option subValue } {
    # <help>
    # This procedure adds a sub-value to the list-valued argument that follows a
    # given option within the global command-line argument list, creating the
    # option (and its value list) if it is not already present.  It exists so
    # the test framework can programmatically augment the arguments it will
    # process, accumulating multiple sub-values under one option without
    # introducing duplicates.
    #
    # How it works: when the global argument variable exists, it scans for the
    # named option.  If found, it looks at the immediately following element as
    # the option's value: when that element exists, the sub-value is appended to
    # it (only if not already present, tested by exact search) using a list
    # update; when the option is the last element, a new single-element value
    # list is appended after it.  If the option is not found at all, the option
    # and a single-element value list are appended.  When the argument variable
    # does not yet exist, it is created holding just the option and its value
    # list.
    #
    # Tricky details: the option's value is treated as a list, and the sub-value
    # is wrapped as a list element so it is stored as one properly quoted item;
    # duplicates are avoided by an exact membership test.  The procedure mutates
    # the global argument list in place and also returns it.
    #
    # Arguments:
    #   option   -- The option name under which to record the sub-value.
    #   subValue -- The sub-value to add to that option's value list if not
    #               already present.
    #
    # Results:
    #   The updated global argument list.
    # </help>

    global argv

    if {[info exists argv]} then {
      set length [llength $argv]
      set found false

      for {set i 0} {$i < $length} {incr i} {
        set arg [lindex $argv $i]

        if {$arg eq $option} then {
          incr i

          if {$i < $length} then {
            set value [lindex $argv $i]

            if {[lsearch -exact $value $subValue] == -1} then {
              lset argv $i [concat $value [list $subValue]]
            }
          } else {
            lappend argv [list $subValue]
          }

          set found true; break
        }
      }

      if {!$found} then {
        lappend argv $option [list $subValue]
      }
    } else {
      set argv [list $option [list $subValue]]
    }

    return $argv
  }

  proc removeFromArgv { option subValue } {
    # <help>
    # This procedure removes a single sub-value from the list-valued argument
    # that follows a named option within the global "argv" command line list.
    # It exists to let the test harness retract a previously injected option
    # value (for example, a constraint name added by [addConstraintToArgv])
    # without disturbing the rest of the command line, and is the inverse of
    # the [addToArgv] helper.
    #
    # How it works: it scans "argv" for the first element equal to "option".
    # When found, it looks at the immediately following element, which is
    # treated as a list, and searches that list for an element exactly equal
    # to "subValue".  If present, that element is removed from the inner list.
    # If the inner list still has elements afterward, it is written back in
    # place; otherwise both the option and its now-empty value are removed
    # from "argv" entirely.  If the option is the very last element (it has no
    # following value), the option itself is removed.  The scan stops at the
    # first matching option.
    #
    # Tricky details: matching of both the option and the sub-value is exact,
    # not glob or regexp.  Only the first occurrence of the option is touched.
    # If "argv" does not exist, the procedure does nothing and there is no
    # error.  The numeric helper array used internally tracks the option index,
    # the value index, and the position of the sub-value within the value list.
    #
    # Arguments:
    #   option   -- The command line option name to locate within "argv", e.g.
    #               "-constraints".
    #   subValue -- The single element to remove from the list that follows the
    #               located option.
    #
    # Results:
    #   The (possibly modified) value of the global "argv" list.  If "argv"
    #   does not exist, the empty string is effectively returned because the
    #   final [return] still references the global, which will be created empty
    #   only if referenced; in practice callers ignore the result when no
    #   command line is present.
    # </help>

    global argv

    if {[info exists argv]} then {
      set length [llength $argv]

      for {set i(1) 0} {$i(1) < $length} {incr i(1)} {
        set arg [lindex $argv $i(1)]

        if {$arg eq $option} then {
          set i(0) $i(1); incr i(1); # save, advance

          if {$i(1) < $length} then {
            set value [lindex $argv $i(1)]
            set i(2) [lsearch -exact $value $subValue]

            if {$i(2) != -1} then {
              set value [lreplace $value $i(2) $i(2)]

              if {[llength $value] > 0} then {
                lset argv $i(1) $value
              } else {
                set argv [lreplace $argv $i(0) $i(1)]
              }
            }
          } else {
            set argv [lreplace $argv $i(0) $i(0)]
          }

          break
        }
      }
    }

    return $argv
  }

  proc addConstraintToArgv { subValue } {
    # <help>
    # This procedure adds a test constraint name to the command line so that it
    # will be honored by the test harness as though it had been supplied on the
    # original command line.  It is a thin, readable wrapper that exists so that
    # callers do not have to remember the exact option name used to carry
    # constraints.
    #
    # How it works: it simply delegates to [addToArgv], passing the
    # "-constraints" option name along with the supplied sub-value, which
    # appends the constraint to the list that follows that option in "argv".
    #
    # Arguments:
    #   subValue -- The constraint name to add to the "-constraints" option
    #               within the global "argv" list.
    #
    # Results:
    #   The (possibly modified) value of the global "argv" list, as returned by
    #   [addToArgv].
    # </help>

    return [addToArgv -constraints $subValue]
  }

  proc removeConstraintFromArgv { subValue } {
    # <help>
    # This procedure removes a test constraint name from the command line,
    # undoing the effect of [addConstraintToArgv].  It exists as a readable
    # wrapper so callers need not know the exact option name used to carry
    # constraints.
    #
    # How it works: it delegates to [removeFromArgv], passing the
    # "-constraints" option name along with the supplied sub-value, which
    # removes that constraint from the list following that option in "argv".
    #
    # Arguments:
    #   subValue -- The constraint name to remove from the "-constraints"
    #               option within the global "argv" list.
    #
    # Results:
    #   The (possibly modified) value of the global "argv" list, as returned by
    #   [removeFromArgv].
    # </help>

    return [removeFromArgv -constraints $subValue]
  }

  proc enableSystemAliasFlags { enable } {
    # <help>
    # This procedure turns the "System" flag on or off for newly created
    # command aliases by adjusting the interpreter's new-alias flags.  It exists
    # so that aliases created during a particular phase (notably core script
    # library initialization) can be marked as belonging to the system itself,
    # which affects how they are treated by later operations.  It is normally
    # driven by [setupSystemAliases].
    #
    # How it works: when enabling, it first captures the current new-alias flags
    # by calling [enableFlags] with no change requested, stashes that snapshot
    # in the debugger state array, and then enables the "System" flag.  When
    # disabling, it retrieves the previously stashed snapshot, removes it from
    # the debugger state array, and restores the new-alias flags to exactly that
    # saved value.  This save-and-restore approach means the original flags are
    # reinstated verbatim rather than merely clearing the "System" bit.
    #
    # Tricky details: the saved flags live in a single well-known slot of the
    # debugger state array, so nested enable/disable pairs are not supported;
    # the calls must be balanced one-to-one.  Disabling without a prior matching
    # enable will fail because the saved snapshot will not exist.
    #
    # Arguments:
    #   enable -- A boolean.  True saves the current new-alias flags and enables
    #             the "System" flag; false restores the previously saved flags.
    #
    # Results:
    #   The resulting new-alias flags value after the change, as returned by
    #   [enableFlags].
    # </help>

    if {$enable} then {
      set savedNewAliasFlags [enableFlags newAliasFlags]
      set ::tcltk_debugger(savedNewAliasFlags) $savedNewAliasFlags

      return [enableFlags newAliasFlags System true]
    } else {
      set savedNewAliasFlags $::tcltk_debugger(savedNewAliasFlags)
      unset -nocomplain ::tcltk_debugger(savedNewAliasFlags)

      return [enableFlags newAliasFlags $savedNewAliasFlags]
    }
  }

  #
  # NOTE: This procedure is designed to make this file suitable for use
  #       with the "-preFile" command line option, et al, to flag those
  #       aliases created during core script library initialization as
  #       belonging to the system itself.
  #
  proc setupSystemAliases { stage } {
    # <help>
    # This procedure flags command aliases created during a given stage as
    # belonging to the system.  It is designed to make this file suitable for
    # use with the "-preFile" command line option (and similar mechanisms) so
    # that aliases created during core script library initialization are marked
    # as system aliases rather than ordinary user aliases.  Typically the test
    # harness arranges to call it once before initialization with the "before"
    # stage and once afterward with the "after" stage.
    #
    # How it works: it switches on the stage name.  For "before" it enables the
    # system alias flag via [enableSystemAliasFlags] true; for "after" it
    # disables it via [enableSystemAliasFlags] false.  Any other stage value is
    # silently ignored because the switch has no matching branch and no default.
    #
    # Arguments:
    #   stage -- The setup stage, expected to be either "before" or "after".
    #            Any other value is a no-op.
    #
    # Results:
    #   The result of the underlying [enableSystemAliasFlags] call for a
    #   recognized stage; the empty string for an unrecognized stage.
    # </help>

    switch -exact -- $stage {
      before {
        enableSystemAliasFlags true
      }
      after {
        enableSystemAliasFlags false
      }
    }
  }

  proc reopenHost {} {
    # <help>
    # This procedure closes and immediately reopens the interpreter host.  Its
    # main use is to force a fresh console window to appear (for example, before
    # breaking into the debugger from a context that has no visible console), by
    # tearing down the current host and standing up a new one.
    #
    # How it works: it records its own procedure name (via the interpreter
    # call stack) for use in diagnostics, then runs "host close" followed by
    # "host open" inside a [catch].  If either step fails, it writes an error
    # message via [debug output], then calls "exit -force" because the harness
    # cannot safely continue without a working host; the subsequent [error] is
    # a defensive fallback in the unlikely event the forced exit does not
    # terminate the process.
    #
    # Tricky details: this is a destructive, last-resort style operation -- on
    # failure it forcibly exits the entire process rather than returning an
    # error to the caller.  Callers should expect that a failure here ends the
    # session.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   The empty string on success.  On failure it does not return normally;
    #   it forcibly exits the process.
    # </help>

    set level [lindex [info level [info level]] 0]

    if {[catch {host close; host open} error]} then {
      debug output [appendArgs \
          "ERROR " $level ": could not reopen host, error: " \
          $error \n]

      exit -force; # NOTE: Upon failure, cannot continue.
      error [appendArgs $level ": could not forcibly exit"]
    }
  }

  proc breakpoint { args } {
    # <help>
    # This procedure provides a convenient, named entry point for breaking into
    # the interactive debugger at a chosen spot in a script.  Callers insert a
    # [breakpoint] call where they want execution to pause so they can inspect
    # state interactively.
    #
    # How it works: it delegates to [testDebugBreak] with a force argument of
    # 1, which (under TclTk) requests that emergency debugger mode be enabled
    # once if it has not been enabled already before breaking into the loop.
    #
    # Tricky details: the procedure accepts and ignores any arguments, so it can
    # be used as a drop-in callback or hook where extra arguments may be passed;
    # see [debugBreakWithNewConsole] for a variant that also forces a fresh
    # console window.
    #
    # Arguments:
    #   args -- Any arguments are accepted and ignored.
    #
    # Results:
    #   The result of the underlying [testDebugBreak] call.
    # </help>

    testDebugBreak 1
  }

  proc debugBreakWithNewConsole { args } {
    # <help>
    # This procedure breaks into the interactive debugger after first forcing a
    # fresh console window to appear.  It is useful when execution reaches a
    # point where interactive inspection is needed but no usable console is
    # currently visible (for example, in a GUI or service-style host).
    #
    # How it works: it first calls [reopenHost] to close and reopen the host,
    # which forces a new console window, and then evaluates [breakpoint] with
    # any supplied arguments forwarded along, breaking into the interactive
    # loop.
    #
    # Tricky details: because it relies on [reopenHost], a failure to reopen the
    # host is fatal and will forcibly exit the process; see that procedure for
    # details.  Any arguments are forwarded verbatim to [breakpoint], which
    # ignores them.
    #
    # Arguments:
    #   args -- Any arguments; forwarded to [breakpoint], which ignores them.
    #
    # Results:
    #   The result of the forwarded [breakpoint] call.
    # </help>

    reopenHost; # NOTE: Attempt to force a new console window.
    eval breakpoint $args
  }

  #
  # NOTE: This procedure sets up the default values for all configuration
  #       parameters used by this package.  If the force argument is non-zero,
  #       any existing values will be overwritten and set back to their
  #       default values.
  #
  proc setupTestPackageVars { force {cleanup false} } {
    # <help>
    # This procedure establishes (or tears down) the namespace configuration
    # variables used by the test package, principally the base URI and the
    # various URNs and fully-derived URIs for the web requests this package may
    # make (the "what-if" endpoint and the OpenAI and Anthropic API endpoints,
    # including their proxy variants).  It exists to centralize the default
    # values for these settings so that the rest of the package can rely on them
    # being present and consistently named.
    #
    # How it works: for each configuration variable it declares the namespace
    # [variable] and then branches on the two flags.  In cleanup mode it removes
    # the variable with [unset -nocomplain].  Otherwise, when forcing or when
    # the variable does not yet exist, it assigns the default value, leaving any
    # existing user-provided value untouched when not forcing.  The base URI
    # default comes from [getAuxiliaryBaseUri] under TclTk (which requires the
    # update package) and a hard-coded fallback URL otherwise.  The derived URI
    # defaults are stored as literal, un-substituted templates that reference
    # the base URI and the corresponding URN, to be expanded later by the code
    # that actually issues requests.
    #
    # Tricky details: the derived URI defaults are deliberately stored with
    # their substitution left unevaluated so that changing the base URI or a URN
    # afterward is reflected when the template is finally expanded.  When force
    # is false, pre-existing values are preserved, which lets callers override
    # individual settings before invoking this procedure.  Cleanup takes
    # precedence over the force/existence logic.
    #
    # Arguments:
    #   force   -- A boolean.  When true, every configuration variable is reset
    #              to its default value even if it already exists.  When false,
    #              only missing variables are assigned.
    #   cleanup -- An optional boolean, default false.  When true, all of the
    #              configuration variables are unset instead of being assigned,
    #              and the force flag is ignored.
    #
    # Results:
    #   The empty string; the procedure operates entirely through its side
    #   effects on the package's namespace variables.
    # </help>

    #
    # NOTE: Using the [getAuxiliaryBaseUri] procedure requires the update
    #       package.
    #
    # NOTE: The base URI used to build the URIs for the test package web
    #       requests.
    #
    variable baseUri; # DEFAULT: [getAuxiliaryBaseUri] -OR- https://urn.to/r

    if {$cleanup} then {
      unset -nocomplain baseUri
    } elseif {$force || ![info exists baseUri]} then {
      if {[isTclTk]} then {
        set baseUri [getAuxiliaryBaseUri]
      } else {
        set baseUri https://urn.to/r
      }
    }

    #
    # NOTE: The URN, relative to the base URI, where "what-if" style
    #       web requests should be sent.
    #
    variable whatIfUrn; # DEFAULT: whatIf

    if {$cleanup} then {
      unset -nocomplain whatIfUrn
    } elseif {$force || ![info exists whatIfUrn]} then {
      set whatIfUrn whatIf
    }

    #
    # NOTE: The URI where "what-if" style web requests should be sent.
    #
    variable whatIfUri; # DEFAULT: ${baseUri}/${whatIfUrn}

    if {$cleanup} then {
      unset -nocomplain whatIfUri
    } elseif {$force || ![info exists whatIfUri]} then {
      set whatIfUri {${baseUri}/${whatIfUrn}}
    }

    #
    # NOTE: The URN, relative to the base URI, where OpenAI API web
    #       requests should be sent.
    #
    variable openAiUrn; # DEFAULT: openAI

    if {$cleanup} then {
      unset -nocomplain openAiUrn
    } elseif {$force || ![info exists openAiUrn]} then {
      set openAiUrn openAI
    }

    #
    # NOTE: The URI where OpenAI API web requests should be sent.
    #
    variable openAiUri; # DEFAULT: ${baseUri}/${openAiUrn}

    if {$cleanup} then {
      unset -nocomplain openAiUri
    } elseif {$force || ![info exists openAiUri]} then {
      set openAiUri {${baseUri}/${openAiUrn}}
    }

    #
    # NOTE: The URN, relative to the base URI, where OpenAI API proxy
    #       web requests should be sent.
    #
    variable openAiProxyUrn; # DEFAULT: openAI_proxy

    if {$cleanup} then {
      unset -nocomplain openAiProxyUrn
    } elseif {$force || ![info exists openAiProxyUrn]} then {
      set openAiProxyUrn openAI_proxy
    }

    #
    # NOTE: The URI where OpenAI API proxy web requests should be sent.
    #
    variable openAiProxyUri; # DEFAULT: ${baseUri}/${openAiProxyUrn}

    if {$cleanup} then {
      unset -nocomplain openAiProxyUri
    } elseif {$force || ![info exists openAiProxyUri]} then {
      set openAiProxyUri {${baseUri}/${openAiProxyUrn}}
    }

    #
    # NOTE: The URN, relative to the base URI, where Anthropic (Claude)
    #       API web requests should be sent.
    #
    variable anthropicUrn; # DEFAULT: anthropic

    if {$cleanup} then {
      unset -nocomplain anthropicUrn
    } elseif {$force || ![info exists anthropicUrn]} then {
      set anthropicUrn anthropic
    }

    #
    # NOTE: The URI where Anthropic (Claude) API web requests should be
    #       sent.
    #
    variable anthropicUri; # DEFAULT: ${baseUri}/${anthropicUrn}

    if {$cleanup} then {
      unset -nocomplain anthropicUri
    } elseif {$force || ![info exists anthropicUri]} then {
      set anthropicUri {${baseUri}/${anthropicUrn}}
    }

    #
    # NOTE: The URN, relative to the base URI, where Anthropic (Claude)
    #       API proxy web requests should be sent.
    #
    variable anthropicProxyUrn; # DEFAULT: anthropic_proxy

    if {$cleanup} then {
      unset -nocomplain anthropicProxyUrn
    } elseif {$force || ![info exists anthropicProxyUrn]} then {
      set anthropicProxyUrn anthropic_proxy
    }

    #
    # NOTE: The URI where Anthropic (Claude) API proxy web requests
    #       should be sent.
    #
    variable anthropicProxyUri; # DEFAULT: ${baseUri}/${anthropicProxyUrn}

    if {$cleanup} then {
      unset -nocomplain anthropicProxyUri
    } elseif {$force || ![info exists anthropicProxyUri]} then {
      set anthropicProxyUri {${baseUri}/${anthropicProxyUrn}}
    }
  }

  proc getTestRunTag {} {
    # <help>
    # This procedure builds the WebClient tag string to be used in all web
    # requests that originate from the TclTk core library, including those
    # performed by Harpy.  The returned tag embeds several pieces of contextual
    # data so that requests can later be correlated and searched in remote
    # logging systems.
    #
    # How it works: it gathers the current user name, host name, batch
    # identifier, test run identifier, and parent process identifier, falling
    # back to the literal "unknown" whenever a value is missing or empty (and
    # falling back to [info hostname] when the platform host is unavailable).
    # It then formats these values, together with the live process id, into a
    # single space-delimited tag.  Under TclTk the tag is richer, additionally
    # including the thread id and interpreter context and prefixed with "TclTk";
    # under native Tcl a shorter "Tcl"-prefixed form is produced.
    #
    # Tricky details: the run id and parent process id are obtained inside a
    # [catch] because they may not be available in every environment; any
    # failure quietly degrades to "unknown".  The batch id is read from the
    # BATCH_ID environment variable.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   A single-line string suitable for use as a WebClient tag, containing the
    #   contextual fields described above.  The exact set of fields differs
    #   between TclTk and native Tcl.
    # </help>

    if {[info exists ::tcl_platform(user)]} then {
      set user $::tcl_platform(user)
    } else {
      set user ""
    }

    if {[info exists ::tcl_platform(host)]} then {
      set host $::tcl_platform(host)
    } else {
      set host [info hostname]
    }

    if {[string length $user] == 0} then {
      set user unknown
    }

    if {[string length $host] == 0} then {
      set host unknown
    }

    if {[info exists ::env(BATCH_ID)]} then {
      set bid $::env(BATCH_ID)
    } else {
      set bid unknown
    }

    if {[catch {
      set rid [getTestRunId]
    }]} then {
      set rid ""
    }

    if {[string length $rid] == 0} then {
      set rid unknown
    }

    if {[catch {
      set ppid [info ppid]
    }]} then {
      set ppid ""
    }

    if {[string length $ppid] == 0} then {
      set ppid unknown
    }

    if {[isTclTk]} then {
      return [appendArgs \
          "TclTk BATCH-ID " $bid " TEST-RUN " $rid " user " $user \
          " host " $host " ppid " $ppid " pid " [pid] " tid " \
          [info tid] " ctx " [info context]]
    } else {
      return [appendArgs \
          "Tcl BATCH-ID " $bid " TEST-RUN " $rid " user " $user \
          " host " $host " pid " [pid]]
    }
  }

  proc setupTestRunTag { {channel stdout} {quiet false} } {
    # <help>
    # This procedure publishes the WebClient tag (produced by [getTestRunTag])
    # into the process environment so that web requests originating from the
    # TclTk core library, including those performed by Harpy, will carry it.  It
    # exists to wire the contextual tag into the well-known environment
    # variables that the request machinery consults.
    #
    # How it works: unless suppressed by the NoTestWebClientTag opt-out (checked
    # both in the global "no" array and in the environment), it computes the tag
    # and, if non-empty, stores it under environment variables named
    # "WebClientTag_" followed by, respectively, the parent process id (when
    # available), the current process id, and the current thread id.  Each slot
    # is only written when it is missing or differs from the new tag, and a
    # counter tracks how many slots were actually set or changed.  When at least
    # one slot changed and quiet mode is off, it reports the new tag to the
    # given channel.
    #
    # Tricky details: the report deliberately uses [tqputs] rather than [tputs]
    # or [tlog] to avoid unwanted recursion through the logging path.  Setting
    # the tag under multiple process/thread keyed names lets the request
    # machinery find the appropriate tag regardless of which identifier it keys
    # on.  If the tag is empty or unchanged everywhere, nothing is published.
    #
    # Arguments:
    #   channel -- The optional output channel for the informational message,
    #              defaulting to "stdout".
    #   quiet   -- An optional boolean, default false.  When true, the
    #              informational message is suppressed even when the tag changes.
    #
    # Results:
    #   True if at least one environment slot was set or updated; false if the
    #   feature was opted out of, the tag was empty, or nothing needed changing.
    # </help>

    if {![info exists ::no(NoTestWebClientTag)] && \
        ![info exists ::env(NoTestWebClientTag)]} then {
      set tag [getTestRunTag]

      if {[string length $tag] > 0} then {
        set count 0

        if {[catch {info ppid} ppid] == 0} then {
          set varName0 [appendArgs WebClientTag_ $ppid]

          if {![info exists ::env($varName0)] || \
              $::env($varName0) ne $tag} then {
            set ::env($varName0) $tag; incr count
          }
        }

        set pid [pid]
        set varName1 [appendArgs WebClientTag_ $pid]

        if {![info exists ::env($varName1)] || \
            $::env($varName1) ne $tag} then {
          set ::env($varName1) $tag; incr count
        }

        set tid [info tid]
        set varName2 [appendArgs WebClientTag_ $tid]

        if {![info exists ::env($varName2)] || \
            $::env($varName2) ne $tag} then {
          set ::env($varName2) $tag; incr count
        }

        if {$count > 0} then {
          if {!$quiet} then {
            #
            # HACK: Cannot use [tputs] / [tlog] here due to the
            #       potential for "unwanted" recursion.
            #
            tqputs $channel [appendArgs \
                "---- set or reset WebClient tag to: " $tag \n]
          }

          return true
        }
      }
    }

    return false
  }

  proc makeProcedureCommand { oldName {newName ""} {command ""} } {
    # <help>
    # This procedure constructs (but does not evaluate) the command that would
    # recreate an existing procedure, optionally under a new name and optionally
    # using a creation command other than [proc].  It is used to clone or rename
    # a procedure definition, for instance to redefine it within a different
    # interpreter or to wrap it with a custom procedure-defining command.
    #
    # How it works: it builds a four-element command list consisting of the
    # creation command, the target name, the argument specification, and the
    # body.  The creation command defaults to the fully qualified "::proc" and
    # the target name defaults to the original name.  The argument list is taken
    # from the existing procedure: under TclTk via [info args] with the flag
    # that yields the full default-aware specification, and under native Tcl by
    # walking each formal argument with [info default] to reconstruct the
    # name-and-default pairs.  The body is taken verbatim from [info body].
    #
    # Tricky details: the result is returned as a list ready to be passed to
    # [eval] or used as a command prefix; this procedure performs no definition
    # itself.  The native Tcl path carefully distinguishes arguments that have a
    # default from those that do not, so the reconstructed argument list matches
    # the original.
    #
    # Arguments:
    #   oldName -- The name of the existing procedure whose arguments and body
    #              are to be captured.
    #   newName -- An optional name for the procedure in the generated command;
    #              when empty, the original name is reused.
    #   command -- An optional creation command to use in place of "::proc";
    #              when empty, "::proc" is used.
    #
    # Results:
    #   A list whose elements are the creation command, the target name, the
    #   argument specification, and the body of the procedure.
    # </help>

    set result [list]

    if {[string length $command] > 0} then {
      lappend result $command
    } else {
      lappend result ::proc
    }

    if {[string length $newName] > 0} then {
      lappend result $newName
    } else {
      lappend result $oldName
    }

    if {[isTclTk]} then {
      lappend result [info args $oldName true]
    } else {
      set args [list]

      foreach arg [info args $oldName] {
        if {[info default $oldName $arg default]} then {
          lappend args [list $arg $default]
        } else {
          lappend args [list $arg]
        }
      }

      lappend result $args
    }

    lappend result [info body $oldName]

    return $result
  }

  proc hasInterpreterFlags { flags all } {
    # <help>
    # This procedure tests whether the active interpreter currently has a given
    # set of interpreter flags.  It is a script-level convenience over the
    # internal flag-checking helper, used by the test harness to make behavior
    # conditional on the interpreter's configured flags.
    #
    # How it works: it invokes the public HasFlags helper on the internal
    # ScriptOps class, which evaluates the requested flags against the active
    # interpreter's flags.  The empty string passed before the flags selects the
    # active interpreter as the subject.
    #
    # Arguments:
    #   flags -- The interpreter flag (or flag combination) to test for.
    #   all   -- A boolean controlling the match semantics; when true, all of
    #            the requested flags must be present, otherwise any one of them
    #            suffices.
    #
    # Results:
    #   A boolean indicating whether the active interpreter satisfies the
    #   requested flag test under the chosen "all" semantics.
    # </help>

    return [object invoke -flags +NonPublic \
        CodeBrix.Platform.TclTk._Components.Private.ScriptOps HasFlags "" $flags $all]
  }

  proc hasAllowBigIntegers {} {
    # <help>
    # This procedure reports whether arbitrary precision (big) integers are
    # available and enabled in the current interpreter.  Tests use it to decide
    # whether to exercise big-integer behavior or expect ordinary fixed-width
    # integer semantics.
    #
    # How it works: under TclTk it first checks the compile options recorded in
    # the platform array.  Big integers rely on the System.Numerics assembly,
    # which generally requires the .NET Framework 4.0 or later, so if the
    # "NET_40" compile option is absent it returns false outright.  When that
    # option is present it consults the interpreter's "AllowBigIntegers" flag
    # via [hasInterpreterFlags] (requiring all of that flag set) and returns the
    # result.  Under native Tcl, which has no way to disable big integers, it
    # always returns true.
    #
    # Tricky details: the compile-option check guards against attempting to use
    # a feature whose supporting assembly may not exist, so the flag is only
    # consulted when the build could plausibly support it.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   A boolean: true if big integers are available and enabled, false
    #   otherwise.  Always true under native Tcl.
    # </help>

    if {[isTclTk]} then {
      if {[info exists ::tcltk_platform(compileOptions)]} then {
        set options $::tcltk_platform(compileOptions)
      } else {
        set options [list]; # options missing?
      }

      if {[lsearch -exact $options NET_40] != -1} then {
        #
        # NOTE: Is the current interpreter configured to allow
        #       use of arbitrary precision integers?
        #
        return [hasInterpreterFlags AllowBigIntegers true]
      } else {
        #
        # NOTE: The System.Numerics assembly generally requires
        #       the .NET Framework 4.0 (or later).
        #
        return false
      }
    } else {
      #
      # NOTE: Native Tcl has no way to disable big integers.
      #
      return true
    }
  }

  proc saveAndResetPrecision { {precision 0} } {
    # <help>
    # This procedure saves the current floating-point output precision and then
    # sets it to a known value, so that tests producing floating-point output
    # can do so with a deterministic, controlled precision.  It is paired with
    # [restorePrecision], which puts the original value back afterward.
    #
    # How it works: if the global "tcl_precision" variable exists, it copies its
    # current value into a saved global and then assigns the requested
    # precision.  If "tcl_precision" does not exist, it does nothing, leaving no
    # saved value behind.
    #
    # Tricky details: a precision of zero (the default) selects the
    # implementation's "shortest string that round-trips" behavior rather than a
    # fixed digit count.  Because the save slot is a single global, nested or
    # repeated save/reset pairs are not supported; calls should be balanced
    # one-to-one with [restorePrecision].
    #
    # Arguments:
    #   precision -- The optional precision to install, defaulting to zero.
    #
    # Results:
    #   The empty string; the effect is the side effect on the precision globals.
    # </help>

    if {[info exists ::tcl_precision]} then {
      set ::saved_tcl_precision $::tcl_precision
      set ::tcl_precision $precision
    }
  }

  proc restorePrecision {} {
    # <help>
    # This procedure restores the floating-point output precision that was
    # captured by an earlier call to [saveAndResetPrecision].  It is the
    # clean-up half of that pair, returning "tcl_precision" to its prior value
    # once a test no longer needs the controlled precision.
    #
    # How it works: if the saved-precision global exists, it copies that value
    # back into "tcl_precision" and then unsets the saved global.  If no saved
    # value exists (because [saveAndResetPrecision] did nothing), it is a no-op.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   The empty string; the effect is the side effect of restoring and then
    #   clearing the precision globals.
    # </help>

    if {[info exists ::saved_tcl_precision]} then {
      set ::tcl_precision $::saved_tcl_precision
      unset ::saved_tcl_precision
    }
  }

  proc enableFlags {
          memberName {newFlags ""} {enable ""} {memberType Field}
          {typeName Interpreter} {objectName Interpreter.GetActive} } {
    # <help>
    # This procedure reads, sets, or adjusts one of the many "Flags" members of
    # the active interpreter (or of another specified object) using reflection.
    # It is the common engine behind the numerous "enableXxxFlags" wrappers in
    # this file, providing a single place that knows how to locate a flags
    # member by name, mutate it, and return its resulting value.  Tests use it
    # to toggle low-level engine behavior that is otherwise not exposed through
    # ordinary commands.
    #
    # How it works: it first validates that the requested member name actually
    # names a flags member of the target type.  It does so by enumerating the
    # non-public members of the named type that match the member type and a
    # regular expression requiring a capitalized name ending in "Flags" (and
    # excluding property getter/setter accessors); if the requested name is not
    # among them, it raises an error.  It then mutates the member.  For a field
    # member it can directly add or remove flags (using a "+" or "-" prefix
    # derived from the enable argument) or assign an absolute value, relying on
    # the auto-flags-enum object flag so that symbolic flag names are accepted.
    # For a non-field member (such as a property) it reads the current value,
    # combines it with the requested change via [combineFlags], and writes the
    # result back, or assigns an absolute value.  In all cases it finishes by
    # reading and returning the member's resulting value.
    #
    # Tricky details: when "enable" is supplied, "newFlags" is treated as a
    # delta to add or remove; when "enable" is empty but "newFlags" is given,
    # "newFlags" is assigned as the new absolute value; when both are empty, no
    # mutation occurs and the member is merely read.  The field and non-field
    # paths differ because fields can be mutated with the auto-flags-enum
    # mechanism directly while other members require an explicit
    # read-combine-write.  The defaults target the active interpreter's own
    # flags field, but the member type, type name, and object name arguments let
    # the same logic drive flags on hosts and other objects.
    #
    # Arguments:
    #   memberName -- The name of the flags member to operate on; it must match
    #                 a non-public flags member of the target type.
    #   newFlags   -- Optional flag value(s); a delta when "enable" is given,
    #                 otherwise an absolute value.  Empty means no change.
    #   enable     -- Optional boolean; when present, true adds and false
    #                 removes "newFlags".  Empty selects assignment or read-only
    #                 behavior instead.
    #   memberType -- The reflection member type to look up, defaulting to
    #                 "Field"; "Property" selects the read-combine-write path.
    #   typeName   -- The type that declares the member, defaulting to
    #                 "Interpreter".
    #   objectName -- The object instance to operate on, defaulting to the
    #                 active interpreter.
    #
    # Results:
    #   The resulting value of the flags member after any mutation.  An error is
    #   raised if the member name does not name a valid flags member of the type.
    # </help>

    #
    # HACK: Enforce that the "fieldName" argument must refer
    #       to an (non-public?) instance field of the active
    #       interpreter with the specified name.
    #
    set pattern {^(?<!(?:get_|set_))?[A-Z][0-9A-Z]*Flags$}

    if {$memberName ni [object members \
        -bindingflags +NonPublic -membertype $memberType \
        -mode regexp -pattern $pattern -nocase \
        -matchnameonly -nameonly $typeName]} then {
      error [appendArgs \
          "cannot find \"" $typeName "\" flags field: " \
          $memberName]
    }

    if {$memberType eq "Field"} then {
      if {[string length $enable] > 0} then {
        object invoke -flags +NonPublic \
            -objectflags +AutoFlagsEnum \
            $objectName $memberName [appendArgs \
            [expr {$enable ? "+" : "-"}] $newFlags]
      } elseif {[string length $newFlags] > 0} then {
        object invoke -flags +NonPublic \
            -objectflags +AutoFlagsEnum \
            $objectName $memberName $newFlags
      }
    } else {
      if {[string length $enable] > 0} then {
        set oldFlags [object invoke \
            -flags +NonPublic $objectName $memberName]

        object invoke -flags +NonPublic $objectName \
            $memberName [combineFlags $oldFlags [appendArgs \
            [expr {$enable ? "+" : "-"}] $newFlags]]
      } elseif {[string length $newFlags] > 0} then {
        object invoke -flags +NonPublic $objectName \
            $memberName $newFlags
      }
    }

    return [object invoke \
        -flags +NonPublic $objectName $memberName]
  }

  proc enableDataFlags { {newFlags ""} {enable ""} } {
    # <help>
    # This procedure reads or adjusts the active interpreter's "DataFlags",
    # which govern data-related engine behavior.  It is a thin wrapper over
    # [enableFlags] provided so callers can address this specific flags member
    # by a memorable name.
    #
    # How it works: it delegates to [enableFlags] for the "DataFlags" property
    # member, forwarding the requested flags and enable arguments.
    #
    # Arguments:
    #   newFlags -- Optional flag value(s); a delta when "enable" is given,
    #               otherwise an absolute value.  Empty means no change.
    #   enable   -- Optional boolean; true adds and false removes "newFlags".
    #               Empty selects assignment or read-only behavior.
    #
    # Results:
    #   The resulting value of the "DataFlags" member after any change.
    # </help>

    return [enableFlags DataFlags $newFlags $enable Property]
  }

