    proc openAI_getJson {
            prompt model options {channel stdout} {quiet false} } {
      # <help>
      # This procedure builds the JSON request body for an OpenAI chat
      # completion call, returning that JSON text.  It exists to assemble the
      # minimal payload -- the model name and a single user message containing
      # the prompt -- in one place, with optional tuning for more deterministic
      # results, and with a tester hook for overriding the whole body.
      #
      # How it works: both "model" and "prompt" are first escaped with
      # [escapeForJsonString] because the body is produced by textual [subst].
      # The ::beforeOpenAI_setJsonExtra hook fires; if it did not already define
      # an "extra" variable, then when the "options" dictionary has a true
      # "deterministic" entry an extra JSON fragment setting temperature 0,
      # top_p 1, n 1, and max_tokens 64 is added, otherwise the extra fragment
      # is empty.  After the ::afterOpenAI_setJsonExtra hook, the final JSON is
      # built via [subst] with command and backslash substitution disabled,
      # interpolating the model, the prompt, and the extra fragment.  The
      # ::beforeOpenAI_getJson and ::afterOpenAI_getJson hooks then fire; the
      # local "result" starts empty and is filled with the assembled JSON unless
      # a before-hook overrode it.  Unless "quiet" is true, an informational
      # line reports the default or overridden JSON.
      #
      # Tricky details: escaping happens before substitution so that arbitrary
      # prompt text cannot break out of its JSON string.  The deterministic
      # extras are an optional, opinionated tuning block intended for repeatable
      # testing; without that option the request uses the API defaults.
      #
      # Arguments:
      #   prompt  -- The user prompt text to embed in the request.
      #   model   -- The model name to request.
      #   options -- A dictionary of options; a true "deterministic" entry adds
      #              the deterministic tuning fragment.
      #   channel -- Channel for the informational message; defaults to
      #              "stdout".
      #   quiet   -- When true, suppresses the informational message; defaults
      #              to false.
      #
      # Results:
      #   The assembled (or overridden) JSON request body for OpenAI.
      # </help>

      #
      # NOTE: For JSON safety, escape all arguments that will [subst]
      #       in the final web request block.
      #
      set model [escapeForJsonString $model]
      set prompt [escapeForJsonString $prompt]

      #
      # NOTE: Build the final JSON payload for the request.  This is
      #       purposely minimal and could be extended to support many
      #       more options.
      #
      maybeInvokeForTester ::beforeOpenAI_setJsonExtra; # HOOK

      if {![info exists extra]} then {
        if {[string is true -strict \
            [getDictionaryValue $options deterministic]]} then {
          #
          # HACK: These parameters were "recommended" by ChatGPT when a
          #       "more deterministic" result in desired, i.e. testing,
          #       etc.
          #
          set extra {,
                "temperature" : 0,
                "top_p" : 1,
                "n" : 1,
                "max_tokens" : 64
          }
        } else {
          set extra ""
        }
      }

      maybeInvokeForTester ::afterOpenAI_setJsonExtra; # HOOK

      set result ""; set json [subst -nocommands -nobackslashes {
        {
          "model" : "${model}",
          "messages" : [
            {
              "role" : "user",
              "content" : "${prompt}"
            }
          ]${extra}
        }
      }]

      maybeInvokeForTester ::beforeOpenAI_getJson; # HOOK

      if {[string length $result] == 0} then {
        set result $json
        maybeInvokeForTester ::afterOpenAI_getJson; # HOOK

        if {!$quiet} then {
          tputs $channel [appendArgs \
              "---- default JSON for OpenAI is \"" $result \"\n]
        }
      } else {
        if {!$quiet} then {
          tputs $channel [appendArgs \
              "---- default JSON for OpenAI overridden to \"" \
              $result \"\n]
        }
      }

      return $result
    }

    proc anthropic_getJson {
            prompt model maxTokens options {channel stdout} {quiet false} } {
      # <help>
      # This procedure builds the JSON request body for an Anthropic (Claude)
      # Messages API call, returning that JSON text.  It is the Anthropic
      # counterpart of [openAI_getJson]; the chief difference is that the
      # Anthropic body requires an explicit "max_tokens" field, so this
      # procedure takes that value as an argument.
      #
      # How it works: both "model" and "prompt" are first escaped with
      # [escapeForJsonString] because the body is produced by textual [subst].
      # The ::beforeAnthropic_setJsonExtra hook fires; if it did not already
      # define an "extra" variable, then when the "options" dictionary has a
      # true "deterministic" entry an extra JSON fragment setting temperature 0
      # and top_p 1 is added, otherwise the extra fragment is empty.  After the
      # ::afterAnthropic_setJsonExtra hook, the final JSON is built via [subst]
      # with command and backslash substitution disabled, interpolating the
      # model, the max_tokens value, the prompt, and the extra fragment.  The
      # ::beforeAnthropic_getJson and ::afterAnthropic_getJson hooks then fire;
      # the local "result" starts empty and is filled with the assembled JSON
      # unless a before-hook overrode it.  Unless "quiet" is true, an
      # informational line reports the default or overridden JSON.
      #
      # Tricky details: escaping happens before substitution so that arbitrary
      # prompt text cannot break out of its JSON string.  The "maxTokens" value
      # is interpolated directly into the JSON (not quoted as a string), so it
      # must be a valid numeric literal.
      #
      # Arguments:
      #   prompt    -- The user prompt text to embed in the request.
      #   model     -- The model name to request.
      #   maxTokens -- The required maximum number of tokens for the response;
      #                emitted as a bare JSON number.
      #   options   -- A dictionary of options; a true "deterministic" entry
      #                adds the deterministic tuning fragment.
      #   channel   -- Channel for the informational message; defaults to
      #                "stdout".
      #   quiet     -- When true, suppresses the informational message; defaults
      #                to false.
      #
      # Results:
      #   The assembled (or overridden) JSON request body for Anthropic.
      # </help>

      #
      # NOTE: For JSON safety, escape all arguments that will [subst]
      #       in the final web request block.
      #
      set model [escapeForJsonString $model]
      set prompt [escapeForJsonString $prompt]

      #
      # NOTE: Build the final JSON payload for the request.  This is
      #       purposely minimal and could be extended to support many
      #       more options.  The Anthropic Messages API requires a
      #       "max_tokens" field.
      #
      maybeInvokeForTester ::beforeAnthropic_setJsonExtra; # HOOK

      if {![info exists extra]} then {
        if {[string is true -strict \
            [getDictionaryValue $options deterministic]]} then {
          #
          # HACK: These parameters produce more deterministic results,
          #       suitable for testing.
          #
          set extra {,
                "temperature" : 0,
                "top_p" : 1
          }
        } else {
          set extra ""
        }
      }

      maybeInvokeForTester ::afterAnthropic_setJsonExtra; # HOOK

      set result ""; set json [subst -nocommands -nobackslashes {
        {
          "model" : "${model}",
          "max_tokens" : ${maxTokens},
          "messages" : [
            {
              "role" : "user",
              "content" : "${prompt}"
            }
          ]${extra}
        }
      }]

      maybeInvokeForTester ::beforeAnthropic_getJson; # HOOK

      if {[string length $result] == 0} then {
        set result $json
        maybeInvokeForTester ::afterAnthropic_getJson; # HOOK

        if {!$quiet} then {
          tputs $channel [appendArgs \
              "---- default JSON for Anthropic is \"" $result \"\n]
        }
      } else {
        if {!$quiet} then {
          tputs $channel [appendArgs \
              "---- default JSON for Anthropic overridden to \"" \
              $result \"\n]
        }
      }

      return $result
    }

    proc openAI_getAnyApiKey { proxy {varName ""} } {
      # <help>
      # This procedure obtains an OpenAI API key (or a proxy credential) from
      # whatever source is available, returning the key and reporting whether a
      # proxy should be used.  It exists so the chat completion machinery can
      # authenticate without the caller having to know whether the key comes
      # from the environment, a key file, or the Harpy proxy/licensing
      # mechanism.
      #
      # How it works: when "proxy" is true, it goes straight to the Harpy path:
      # if the harpy command exists, it uses that machine's id as the key and
      # marks the proxy as in-use; otherwise it returns an empty key but still
      # marks the proxy as in-use (so a proxy is attempted anyway).  When
      # "proxy" is false, it prefers a direct key: the OPENAI_API_KEY
      # environment variable, then the contents of the file named by
      # OPENAI_API_KEY_FILE; failing both, it falls back to the same Harpy logic
      # as above, marking the proxy in-use when Harpy is present and not in-use
      # otherwise.  Various before/after/error tester hooks fire along the way.
      #
      # Tricky details: when "varName" is non-empty, that caller variable
      # receives the boolean proxy indication, which is essential because the
      # returned key may be empty yet a proxy may still be the intended path.
      # An empty returned key is therefore not by itself an error; the caller
      # must consider the proxy flag.
      #
      # Arguments:
      #   proxy   -- When true, force the Harpy/proxy credential path; when
      #              false, prefer a direct key and fall back to proxy.
      #   varName -- Optional name of a caller variable to receive the boolean
      #              "use proxy" indication; ignored when empty.
      #
      # Results:
      #   The API key string (which may be empty when only a proxy is
      #   available).
      # </help>

      if {[string length $varName] > 0} then {
        upvar 1 $varName useProxy
      }

      if {$proxy} then {
        maybeInvokeForTester ::beforeOpenAI_useHarpy; # HOOK

        if {[llength [info commands harpy]] > 0} then {
          set apiKey [getDictionaryValue [harpy machine] id]
          set useProxy true

          maybeInvokeForTester ::afterOpenAI_useHarpy; # HOOK
        } else {
          set apiKey ""; # NOTE: No API key available?
          set useProxy true; # NOTE: By default, use proxy.

          maybeInvokeForTester ::errorOpenAI_getProxyApiKey; # HOOK
        }
      } else {
        if {[info exists ::env(OPENAI_API_KEY)]} then {
          set apiKey $::env(OPENAI_API_KEY)
        } elseif {[info exists ::env(OPENAI_API_KEY_FILE)]} then {
          set apiKey [readSharedFile $::env(OPENAI_API_KEY_FILE)]
        } else {
          maybeInvokeForTester ::beforeOpenAI_useHarpy; # HOOK

          if {[llength [info commands harpy]] > 0} then {
            set apiKey [getDictionaryValue [harpy machine] id]
            set useProxy true

            maybeInvokeForTester ::afterOpenAI_useHarpy; # HOOK
          } else {
            set apiKey ""; # NOTE: No API key available?
            set useProxy false; # NOTE: By default, no proxy.

            maybeInvokeForTester ::errorOpenAI_getDirectApiKey; # HOOK
          }
        }
      }

      return $apiKey
    }

    proc anthropic_getAnyApiKey { proxy {varName ""} } {
      # <help>
      # This procedure obtains an Anthropic API key (or a proxy credential) from
      # whatever source is available, returning the key and reporting whether a
      # proxy should be used.  It is the Anthropic counterpart of
      # [openAI_getAnyApiKey]; it lets the chat completion machinery
      # authenticate without the caller knowing whether the key comes from the
      # environment, a key file, or the Harpy proxy/licensing mechanism.
      #
      # How it works: when "proxy" is true, it goes straight to the Harpy path:
      # if the harpy command exists, it uses that machine's id as the key and
      # marks the proxy as in-use; otherwise it returns an empty key but still
      # marks the proxy as in-use.  When "proxy" is false, it prefers a direct
      # key: the ANTHROPIC_API_KEY environment variable, then the contents of
      # the file named by ANTHROPIC_API_KEY_FILE; failing both, it falls back to
      # the same Harpy logic as above, marking the proxy in-use when Harpy is
      # present and not in-use otherwise.  Various before/after/error tester
      # hooks fire along the way.
      #
      # Tricky details: when "varName" is non-empty, that caller variable
      # receives the boolean proxy indication, which is essential because the
      # returned key may be empty yet a proxy may still be the intended path.
      # An empty returned key is therefore not by itself an error; the caller
      # must consider the proxy flag.
      #
      # Arguments:
      #   proxy   -- When true, force the Harpy/proxy credential path; when
      #              false, prefer a direct key and fall back to proxy.
      #   varName -- Optional name of a caller variable to receive the boolean
      #              "use proxy" indication; ignored when empty.
      #
      # Results:
      #   The API key string (which may be empty when only a proxy is
      #   available).
      # </help>

      if {[string length $varName] > 0} then {
        upvar 1 $varName useProxy
      }

      if {$proxy} then {
        maybeInvokeForTester ::beforeAnthropic_useHarpy; # HOOK

        if {[llength [info commands harpy]] > 0} then {
          set apiKey [getDictionaryValue [harpy machine] id]
          set useProxy true

          maybeInvokeForTester ::afterAnthropic_useHarpy; # HOOK
        } else {
          set apiKey ""; # NOTE: No API key available?
          set useProxy true; # NOTE: By default, use proxy.

          maybeInvokeForTester ::errorAnthropic_getProxyApiKey; # HOOK
        }
      } else {
        if {[info exists ::env(ANTHROPIC_API_KEY)]} then {
          set apiKey $::env(ANTHROPIC_API_KEY)
        } elseif {[info exists ::env(ANTHROPIC_API_KEY_FILE)]} then {
          set apiKey [readSharedFile $::env(ANTHROPIC_API_KEY_FILE)]
        } else {
          maybeInvokeForTester ::beforeAnthropic_useHarpy; # HOOK

          if {[llength [info commands harpy]] > 0} then {
            set apiKey [getDictionaryValue [harpy machine] id]
            set useProxy true

            maybeInvokeForTester ::afterAnthropic_useHarpy; # HOOK
          } else {
            set apiKey ""; # NOTE: No API key available?
            set useProxy false; # NOTE: By default, no proxy.

            maybeInvokeForTester ::errorAnthropic_getDirectApiKey; # HOOK
          }
        }
      }

      return $apiKey
    }

    #
    # NOTE: This procedure attempts to call the OpenAI API and return results
    #       of the specified prompt.  The apiKey argument may be empty if the
    #       OPENAI_API_KEY or OPENAI_API_KEY_FILE environment variables have
    #       been set.  Currently, the model argument may be an empty string or
    #       the value "gpt-3.5-turbo".  Currently, the type argument may be an
    #       empty string or the value "chat".  This procedure may raise script
    #       errors.
    #
    # <public>
    nproc openAI_chatCompletion {
            prompt {apiKey ""} {model ""} {type ""} {options ""} {proxy false}
            {whatIf true} {fake false} {channel stdout} {quiet false} } {
      setupTestPackageVars false

      variable baseUri
      variable openAiProxyUri
      variable openAiProxyUrn
      variable openAiUri
      variable openAiUrn
      variable whatIfUri
      variable whatIfUrn

      #########################################################################

      set useProxy false
      maybeInvokeForTester ::beforeOpenAI_ApiKey; # HOOK

      if {[string length $apiKey] == 0} then {
        set apiKey [openAI_getAnyApiKey $proxy useProxy]
      }

      maybeInvokeForTester ::afterOpenAI_ApiKey; # HOOK

      if {[string length $apiKey] == 0} then {
        error [appendArgs \
            "please set either the OPENAI_API_KEY or " \
            "OPENAI_API_KEY_FILE environment variables " \
            "and/or \[load\] the security plugin first"]
      }

      #########################################################################

      if {[string length $model] == 0} then {
        if {$useProxy} then {
          set model [openAI_getStandardModel $type $channel $quiet]
        } else {
          set model [openAI_getDefaultModel $type $channel $quiet]
        }
      }

      #########################################################################
      #
      # NOTE: Choose the correct URI for the endpoint.  This will
      #       either be the OpenAI chat completions endpoint -OR-
      #       the "what-if" endpoint, depending on the value of
      #       the whatIf argument.  These URIs are configurable,
      #       via overridding these script variables, which were
      #       originally created in the [::setupTestPackageVars]
      #       procedure.
      #
      if {$whatIf} then {
        set uri [subst $whatIfUri]
      } elseif {$useProxy} then {
        set uri [subst $openAiProxyUri]
      } else {
        set uri [subst $openAiUri]
      }

      #
      # HACK: Since the "Authorization" header is required by our
      #       Open API requests and the .NET Framework will strip
      #       it out following any 3xx redirects, we must manually
      #       follow the (first?) redirect instead, using "preview
      #       mode", prior to sending the request to the redirected
      #       endpoint.
      #
      set uri [maybeFullyResolveUri $uri 20 $channel $quiet]

      #########################################################################

      openAI_setupScriptWebClient true savedTestFlags $channel $quiet

      try {
        if {$useProxy} then {
          set data [list \
              nop false prompt $prompt apiKey $apiKey model $model \
              type $type options $options whatIf $whatIf fake $fake]

          maybeInvokeForTester ::beforeProxyAI; # HOOK

          if {!$quiet} then {
            if {![info exists ::no(NoShowProxyAiRequestJson)] && \
                ![info exists ::env(NoShowProxyAiRequestJson)]} then {
              set dataId [tcltk_buildDataId $data]

              set message [appendArgs \
                  "---- request \"" $dataId "\" raw data for ProxyAI: " \
                  $data \n]

              host result Ok $message

              if {![info exists ::no(NoKapokLogProxyAiRequestJson)] && \
                  ![info exists ::env(NoKapokLogProxyAiRequestJson)]} then {
                if {[llength [info commands kapok]] > 0} then {
                  catch {kapok log $message {+Highest ForceFlush}}
                }
              }

              if {![info exists ::no(NoLogProxyAiRequestJson)] && \
                  ![info exists ::env(NoLogProxyAiRequestJson)]} then {
                tputs $channel $message
              }
            }
          }

          set result [uri upload \
              -timeouttype network -inline -retries 0 \
              -data $data -- $uri]

          maybeInvokeForTester ::afterProxyAI; # HOOK
        } else {
          set json [openAI_getJson $prompt $model $options $channel $quiet]
          maybeInvokeForTester ::beforeOpenAI; # HOOK

          if {!$quiet} then {
            if {![info exists ::no(NoShowOpenAiRequestJson)] && \
                ![info exists ::env(NoShowOpenAiRequestJson)]} then {
              set dataId [tcltk_buildDataId $prompt]

              set message [appendArgs \
                  "---- request \"" $dataId "\" raw JSON for OpenAI: " \
                  $json \n]

              host result Ok $message

              if {![info exists ::no(NoKapokLogOpenAiRequestJson)] && \
                  ![info exists ::env(NoKapokLogOpenAiRequestJson)]} then {
                if {[llength [info commands kapok]] > 0} then {
                  catch {kapok log $message {+Highest ForceFlush}}
                }
              }

              if {![info exists ::no(NoLogOpenAiRequestJson)] && \
                  ![info exists ::env(NoLogOpenAiRequestJson)]} then {
                tputs $channel $message
              }
            }
          }

          set data [list [object create String $json]]; # HACK: Need object.

          if {$fake} then {; # NOTE: Simulated response?
            set dataId [tcltk_buildDataId $json]

            set fileName [file join \
                [info binary] [appendArgs fake-response- $dataId .json]]

            if {![file exists $fileName]} then {
              set fileName [file join [info binary] fake-response.json]
            }

            maybeInvokeForTester ::beforeOpenAI_fake; # HOOK

            if {[file exists $fileName]} then {
              set result [readSharedFile $fileName]
            } else {
              set result ""
              maybeInvokeForTester ::missingOpenAI_fake; # HOOK

              if {[string length $result] == 0} then {
                error [appendArgs \
                    "simulated OpenAI response \"" \
                    $dataId "\" data is missing"]
              }
            }

            maybeInvokeForTester ::afterOpenAI_fake; # HOOK
          } else {
            set result [uri upload \
                -timeouttype network -inline -raw -retries 0 \
                -data $data -- $uri]
          }

          maybeInvokeForTester ::afterOpenAI; # HOOK
        }

        return $result
      } finally {
        openAI_setupScriptWebClient false savedTestFlags $channel $quiet
      }
    }

    #
    # NOTE: This procedure attempts to call the Anthropic (Claude) API and
    #       return results of the specified prompt.  The apiKey argument may
    #       be empty if the ANTHROPIC_API_KEY or ANTHROPIC_API_KEY_FILE
    #       environment variables have been set.  Currently, the model
    #       argument may be an empty string or one of the Claude model IDs.
    #       Currently, the type argument may be an empty string or the value
    #       "messages".  This procedure may raise script errors.
    #
    # <public>
    nproc anthropic_chatCompletion {
            prompt {apiKey ""} {model ""} {type ""} {options ""}
            {maxTokens 1024} {proxy false} {whatIf true} {fake false}
            {channel stdout} {quiet false} } {
      setupTestPackageVars false

      variable baseUri
      variable anthropicProxyUri
      variable anthropicProxyUrn
      variable anthropicUri
      variable anthropicUrn
      variable whatIfUri
      variable whatIfUrn

      #########################################################################

      set useProxy false
      maybeInvokeForTester ::beforeAnthropic_ApiKey; # HOOK

      if {[string length $apiKey] == 0} then {
        set apiKey [anthropic_getAnyApiKey $proxy useProxy]
      }

      maybeInvokeForTester ::afterAnthropic_ApiKey; # HOOK

      if {[string length $apiKey] == 0} then {
        error [appendArgs \
            "please set either the ANTHROPIC_API_KEY or " \
            "ANTHROPIC_API_KEY_FILE environment variables " \
            "and/or \[load\] the security plugin first"]
      }

      #########################################################################

      if {[string length $model] == 0} then {
        if {$useProxy} then {
          set model [anthropic_getStandardModel $type $channel $quiet]
        } else {
          set model [anthropic_getDefaultModel $type $channel $quiet]
        }
      }

      #########################################################################
      #
      # NOTE: Choose the correct URI for the endpoint.  This will
      #       either be the Anthropic Messages API endpoint -OR-
      #       the "what-if" endpoint, depending on the value of
      #       the whatIf argument.  These URIs are configurable,
      #       via overridding these script variables, which were
      #       originally created in the [::setupTestPackageVars]
      #       procedure.
      #
      if {$whatIf} then {
        set uri [subst $whatIfUri]
      } elseif {$useProxy} then {
        set uri [subst $anthropicProxyUri]
      } else {
        set uri [subst $anthropicUri]
      }

      #
      # HACK: Since the "x-api-key" header is required by our
      #       Anthropic API requests and the .NET Framework will strip
      #       it out following any 3xx redirects, we must manually
      #       follow the (first?) redirect instead, using "preview
      #       mode", prior to sending the request to the redirected
      #       endpoint.
      #
      set uri [maybeFullyResolveUri $uri 20 $channel $quiet]

      #########################################################################

      anthropic_setupScriptWebClient true savedTestFlags $channel $quiet

      try {
        if {$useProxy} then {
          set data [list \
              nop false prompt $prompt apiKey $apiKey model $model \
              type $type options $options maxTokens $maxTokens \
              whatIf $whatIf fake $fake]

          maybeInvokeForTester ::beforeProxyAnthropic; # HOOK

          if {!$quiet} then {
            if {![info exists ::no(NoShowProxyAnthropicRequestJson)] && \
                ![info exists ::env(NoShowProxyAnthropicRequestJson)]} then {
              set dataId [tcltk_buildDataId $data]

              set message [appendArgs \
                  "---- request \"" $dataId \
                  "\" raw data for ProxyAnthropic: " \
                  $data \n]

              host result Ok $message

              if {![info exists \
                  ::no(NoKapokLogProxyAnthropicRequestJson)] && \
                  ![info exists \
                  ::env(NoKapokLogProxyAnthropicRequestJson)]} then {
                if {[llength [info commands kapok]] > 0} then {
                  catch {kapok log $message {+Highest ForceFlush}}
                }
              }

              if {![info exists \
                  ::no(NoLogProxyAnthropicRequestJson)] && \
                  ![info exists \
                  ::env(NoLogProxyAnthropicRequestJson)]} then {
                tputs $channel $message
              }
            }
          }

          set result [uri upload \
              -timeouttype network -inline -retries 0 \
              -data $data -- $uri]

          maybeInvokeForTester ::afterProxyAnthropic; # HOOK
        } else {
          set json [anthropic_getJson \
              $prompt $model $maxTokens $options $channel $quiet]

          maybeInvokeForTester ::beforeAnthropic; # HOOK

          if {!$quiet} then {
            if {![info exists ::no(NoShowAnthropicRequestJson)] && \
                ![info exists ::env(NoShowAnthropicRequestJson)]} then {
              set dataId [tcltk_buildDataId $prompt]

              set message [appendArgs \
                  "---- request \"" $dataId \
                  "\" raw JSON for Anthropic: " \
                  $json \n]

              host result Ok $message

              if {![info exists \
                  ::no(NoKapokLogAnthropicRequestJson)] && \
                  ![info exists \
                  ::env(NoKapokLogAnthropicRequestJson)]} then {
                if {[llength [info commands kapok]] > 0} then {
                  catch {kapok log $message {+Highest ForceFlush}}
                }
              }

              if {![info exists \
                  ::no(NoLogAnthropicRequestJson)] && \
                  ![info exists \
                  ::env(NoLogAnthropicRequestJson)]} then {
                tputs $channel $message
              }
            }
          }

          set data [list [object create String $json]]; # HACK: Need object.

          if {$fake} then {; # NOTE: Simulated response?
            set dataId [tcltk_buildDataId $json]

            set fileName [file join \
                [info binary] [appendArgs \
                fake-response-anthropic- $dataId .json]]

            if {![file exists $fileName]} then {
              set fileName [file join \
                  [info binary] fake-response-anthropic.json]
            }

            maybeInvokeForTester ::beforeAnthropic_fake; # HOOK

            if {[file exists $fileName]} then {
              set result [readSharedFile $fileName]
            } else {
              set result ""
              maybeInvokeForTester ::missingAnthropic_fake; # HOOK

              if {[string length $result] == 0} then {
                error [appendArgs \
                    "simulated Anthropic response \"" \
                    $dataId "\" data is missing"]
              }
            }

            maybeInvokeForTester ::afterAnthropic_fake; # HOOK
          } else {
            set result [uri upload \
                -timeouttype network -inline -raw -retries 0 \
                -data $data -- $uri]
          }

          maybeInvokeForTester ::afterAnthropic; # HOOK
        }

        return $result
      } finally {
        anthropic_setupScriptWebClient \
            false savedTestFlags $channel $quiet
      }
    }

    proc recursiveGetDirectories { path pattern } {
      # <help>
      # This procedure returns the list of all subdirectories beneath a starting
      # directory whose names match a glob-style pattern, searching recursively.
      # It exists as a brute-force way to locate directories (for example, test
      # data directories) anywhere within a tree, without writing a manual
      # recursive walk in script.
      #
      # How it works: it delegates to the managed System.IO.Directory.GetDirectories
      # method with the AllDirectories option so the search descends into every
      # subdirectory.  Under .NET Core the type name must be assembly-qualified
      # (System.IO.Directory, netstandard), so the procedure branches on
      # [isDotNetCore] to use the qualified or unqualified type name accordingly.
      #
      # Tricky details: the recursion and pattern matching are performed by the
      # underlying .NET method, so the pattern follows .NET search-pattern
      # semantics rather than Tcl glob semantics, and this routine is therefore
      # effectively TclTk-only (it uses the object subsystem).
      #
      # Arguments:
      #   path    -- The root directory to search beneath.
      #   pattern -- The .NET search pattern to match directory names against.
      #
      # Results:
      #   A list of the matching subdirectory paths found anywhere beneath
      #   "path".
      # </help>

      #
      # HACK: Use brute-force search of all files beneath the specified
      #       directory in order to locate the test data files we need.
      #
      if {[isDotNetCore]} then {
        #
        # HACK: Why does .NET Core require assembly qualified type name
        #       usage here?
        #
        return [object invoke \
            "System.IO.Directory, netstandard" GetDirectories $path \
            $pattern AllDirectories]
      } else {
        return [object invoke \
            System.IO.Directory GetDirectories $path $pattern \
            AllDirectories]
      }
    }

    proc recursiveGetFiles { path pattern } {
      # <help>
      # This procedure returns the list of all files beneath a starting
      # directory whose names match a glob-style pattern, searching recursively.
      # It is the file-oriented companion of [recursiveGetDirectories], used as
      # a brute-force way to locate files (for example, test data files)
      # anywhere within a tree.
      #
      # How it works: it delegates to the managed System.IO.Directory.GetFiles
      # method with the AllDirectories option so the search descends into every
      # subdirectory.  Under .NET Core the type name must be assembly-qualified
      # (System.IO.Directory, netstandard), so the procedure branches on
      # [isDotNetCore] to use the qualified or unqualified type name accordingly.
      #
      # Tricky details: the recursion and pattern matching are performed by the
      # underlying .NET method, so the pattern follows .NET search-pattern
      # semantics rather than Tcl glob semantics, and this routine is therefore
      # effectively TclTk-only (it uses the object subsystem).
      #
      # Arguments:
      #   path    -- The root directory to search beneath.
      #   pattern -- The .NET search pattern to match file names against.
      #
      # Results:
      #   A list of the matching file paths found anywhere beneath "path".
      # </help>

      #
      # HACK: Use brute-force search of all files beneath the specified
      #       directory in order to locate the test data files we need.
      #
      if {[isDotNetCore]} then {
        #
        # HACK: Why does .NET Core require assembly qualified type name
        #       usage here?
        #
        return [object invoke \
            "System.IO.Directory, netstandard" GetFiles $path $pattern \
            AllDirectories]
      } else {
        return [object invoke \
            System.IO.Directory GetFiles $path $pattern AllDirectories]
      }
    }

    proc thostresult { code result } {
      # <help>
      # This procedure writes a result value to the interactive host using a
      # specified return-code category, returning whatever [host result]
      # returns.  It is a thin convenience wrapper over the [host result]
      # command, naming the operation in test-oriented terms (the leading "t"
      # follows the convention used by other test-harness output helpers).
      #
      # How it works: it simply forwards "code" and "result" to [host result],
      # which renders the value to the host channel with formatting/coloring
      # appropriate to the given code category.
      #
      # Arguments:
      #   code   -- The return-code category passed to [host result] (for
      #             example, the values that select success, error, or other
      #             host result styling).
      #   result -- The result value/text to display.
      #
      # Results:
      #   The value returned by [host result].
      # </help>

      host result $code $result
    }

    proc tresult { code result } {
      # <help>
      # This procedure displays a result value on the interactive host and also
      # records it in the test log, in a single call.  It exists so that
      # test-harness code can both show a result to the user and capture it for
      # later inspection without two separate calls.
      #
      # How it works: it first calls [thostresult] to render the value to the
      # host with the given return-code category, then passes the same result
      # text to [tlog] to append it to the test log.
      #
      # Tricky details: only the "result" text is logged; the "code" category
      # affects the host display but is not recorded by [tlog].  The procedure's
      # own value is that of the final [tlog] call.
      #
      # Arguments:
      #   code   -- The return-code category forwarded to [thostresult] for host
      #             display styling.
      #   result -- The result value/text to both display and log.
      #
      # Results:
      #   The value returned by the [tlog] call.
      # </help>

      thostresult $code $result; tlog $result
    }

    proc getPassedPercentage {} {
      # <help>
      # This procedure computes the overall "pass percentage" for the current
      # test run, based on the running tallies kept in the global tcltk_tests
      # array.  It is used when summarizing a test run (for example, by the
      # result-count reporting helper) and when deciding whether the run met a
      # configured pass threshold.
      #
      # How it works: when the Total count is greater than zero, it returns
      # 100 times the sum of the Passed and Skipped counts divided by the Total
      # count, computed in floating point.  Note that skipped tests are counted
      # as part of the passing total here; a skipped test is deliberately not
      # treated as a failure for percentage purposes.  When no tests have been
      # run (a Total of zero), it returns zero rather than dividing by zero.
      #
      # Arguments:
      #   None.
      #
      # Results:
      #   A floating-point percentage in the range zero to one hundred, or the
      #   integer zero when no tests were run.
      # </help>

      if {$::tcltk_tests(Total) > 0} then {
        return [expr \
            {100.0 * (($::tcltk_tests(Passed) + \
            $::tcltk_tests(Skipped)) / \
            double($::tcltk_tests(Total)))}]
      }

      return 0; # no tests were run, etc.
    }

    proc getSkippedPercentage {} {
      # <help>
      # This procedure computes the percentage of tests that were skipped in
      # the current test run, based on the running tallies kept in the global
      # tcltk_tests array.  It is used when summarizing a run to report how
      # large a fraction of the suite was skipped (for example, due to unmet
      # test constraints).
      #
      # How it works: when the Total count is greater than zero, it returns
      # 100 times the Skipped count divided by the Total count, computed in
      # floating point.  When no tests have been run (a Total of zero), it
      # returns zero rather than dividing by zero.
      #
      # Arguments:
      #   None.
      #
      # Results:
      #   A floating-point percentage in the range zero to one hundred, or the
      #   integer zero when no tests were run.
      # </help>

      if {$::tcltk_tests(Total) > 0} then {
        return [expr \
            {100.0 * ($::tcltk_tests(Skipped) / \
            double($::tcltk_tests(Total)))}]
      }

      return 0; # no tests were run, etc.
    }

    proc getDisabledPercentage {} {
      # <help>
      # This procedure computes the percentage of tests that were disabled in
      # the current test run, based on the running tallies kept in the global
      # tcltk_tests array.  A disabled test is one that was deliberately turned
      # off (as opposed to merely skipped at runtime), and this helper reports
      # how large a fraction of the suite that represents when summarizing a
      # run.  It exists only for the native TclTk test harness, since the
      # Tcl-compatible tcltest counts have no separate "disabled" category.
      #
      # How it works: when the Total count is greater than zero, it returns
      # 100 times the Disabled count divided by the Total count, computed in
      # floating point.  When no tests have been run (a Total of zero), it
      # returns zero rather than dividing by zero.
      #
      # Arguments:
      #   None.
      #
      # Results:
      #   A floating-point percentage in the range zero to one hundred, or the
      #   integer zero when no tests were run.
      # </help>

      if {$::tcltk_tests(Total) > 0} then {
        return [expr \
            {100.0 * ($::tcltk_tests(Disabled) / \
            double($::tcltk_tests(Total)))}]
      }

      return 0; # no tests were run, etc.
    }

    proc testCheckOverallResult {
            channel percent haveStartSentry {varName ""} {quiet false} } {
      # <help>
      # This procedure renders the final verdict for an entire test run,
      # printing the "OVERALL RESULT" summary lines and reporting whether the
      # run is considered an overall success or failure.  It is one of the
      # central pieces of the harness: its boolean result and the exit code it
      # produces are what callers ultimately use to decide whether the suite
      # passed.  This is the native TclTk variant, which reads the per-category
      # counts from the global tcltk_tests array; a separate Tcl-compatible
      # variant reads the tcltest numTests array instead.
      #
      # The decision is governed by the optional global test_threshold pass
      # percentage.  When that variable is absent or equal to its default of
      # one hundred, the run succeeds only if every test is accounted for as
      # passed, skipped, or disabled (i.e. there are no failures and the
      # individual counts add up to the Total).  When a lower threshold has
      # been configured, the run succeeds as long as the supplied pass percent
      # meets or exceeds that threshold.  In either mode the presence of the
      # global test_suite_errors variable forces an overall failure regardless
      # of the counts, and a missing start sentry in the log forces failure
      # unless start-sentry failure checking has been disabled via the global
      # "no" array element failLogStartSentry.
      #
      # As a side effect, when varName is supplied this procedure writes a
      # symbolic exit code (Success or Failure) into that caller variable so
      # the caller can exit with the appropriate status.  Unless quiet mode is
      # requested, it also prints the test suite name, any suite error list,
      # and the SUCCESS, NONE, FAILURE, or "MISSING test counts" lines via the
      # themed [tresult] output; a run that succeeded but ran zero tests is
      # reported as NONE rather than SUCCESS.  Each terminal case also invokes
      # the corresponding tester hook (overallSuccess, overallNone, or
      # overallFailure) so external tooling can react to the outcome.
      #
      # Tricky details: a missing required count element is itself treated as a
      # failure (reported as "MISSING test counts"), since the harness cannot
      # certify a run whose tallies are incomplete.  The numbered MISSING
      # messages (1) and (2) distinguish the default-threshold path from the
      # custom-threshold path.
      #
      # Arguments:
      #   channel         -- The output channel for the summary messages.
      #   percent         -- The overall pass percentage for the run, used only
      #                      when a non-default threshold is in effect.
      #   haveStartSentry -- Non-zero if the expected start sentry was found in
      #                      the test log; when false (and start-sentry failure
      #                      checking is enabled) the run is failed.
      #   varName         -- Optional name of a caller variable to receive the
      #                      symbolic exit code (Success or Failure).  When
      #                      empty, no exit code is written.
      #   quiet           -- Optional boolean; when true, suppresses all of the
      #                      summary output (the verdict is still returned).
      #
      # Results:
      #   True if the run is considered an overall success, false otherwise.
      # </help>

      #
      # NOTE: Does the caller want to change the exit code to an appropriate
      #       value based on the overall test results?
      #
      if {[string length $varName] > 0} then {upvar 1 $varName exitCode}

      #
      # NOTE: Has the test pass threshold been set?  If so, is it set to the
      #       default value?
      #
      # HACK: If the test suite error message exists, the entire run will be
      #       considered a "failure", without regard for the pass percentage
      #       or the configured test pass threshold.
      #
      if {![info exists ::test_threshold] || $::test_threshold == 100} then {
        #
        # HACK: Check for the required elements of the global TclTk tests
        #       array.
        #
        if {[info exists ::tcltk_tests(Passed)] && \
            [info exists ::tcltk_tests(Skipped)] && \
            [info exists ::tcltk_tests(Disabled)] && \
            [info exists ::tcltk_tests(Total)]} then {
          #
          # NOTE: The test pass threshold is set to the default value (100%).
          #       Check to make sure that all tests passed and then set the
          #       exit code to success; otherwise, we set it to failure.
          #
          set passedSkippedOrDisabled [expr {
              $::tcltk_tests(Passed) + $::tcltk_tests(Skipped) + \
              $::tcltk_tests(Disabled)
          }]

          if {![info exists ::test_suite_errors] && \
              ([info exists ::no(failLogStartSentry)] || \
                  $haveStartSentry) && \
              $passedSkippedOrDisabled == $::tcltk_tests(Total)} then {
            set exitCode Success

            if {!$quiet} then {
              tresult Ok [appendArgs \
                  "OVERALL RESULT: " [getTestSuiteFullName] \n]

              if {$::tcltk_tests(Total) > 0} then {
                tresult Ok "OVERALL RESULT: SUCCESS\n"
                maybeInvokeForTester ::overallSuccess; # HOOK
              } else {
                tresult Ok "OVERALL RESULT: NONE\n"
                maybeInvokeForTester ::overallNone; # HOOK
              }
            }

            return true
          } else {
            set exitCode Failure

            if {!$quiet} then {
              tresult Error [appendArgs \
                  "OVERALL RESULT: " [getTestSuiteFullName] \n]

              if {[info exists ::test_suite_errors]} then {
                tresult Error [appendArgs "OVERALL ERRORS: " \
                    [expr {[llength $::test_suite_errors] > 0 ? \
                    $::test_suite_errors : "<empty>"}] \n]
              }

              tresult Error "OVERALL RESULT: FAILURE\n"
              maybeInvokeForTester ::overallFailure; # HOOK
            }

            return false
          }
        } else {
          set exitCode Failure

          if {!$quiet} then {
            tresult Error [appendArgs \
                "OVERALL RESULT: " [getTestSuiteFullName] \n]

            if {[info exists ::test_suite_errors]} then {
              tresult Error [appendArgs "OVERALL ERRORS: " \
                  [expr {[llength $::test_suite_errors] > 0 ? \
                  $::test_suite_errors : "<empty>"}] \n]
            }

            tresult Error "OVERALL RESULT: MISSING test counts (1)\n"
            tresult Error "OVERALL RESULT: FAILURE\n"
            maybeInvokeForTester ::overallFailure; # HOOK
          }

          return false
        }
      } else {
        #
        # NOTE: They specified a non-default test pass threshold.  Check to
        #       make sure that we meet or exceed the requirement and then
        #       set the exit code to success; otherwise, set it to failure.
        #
        if {![info exists ::test_suite_errors] && \
            ([info exists ::no(failLogStartSentry)] || \
                $haveStartSentry) && \
            $percent >= $::test_threshold} then {
          #
          # HACK: Check for the required elements of the global TclTk tests
          #       array.
          #
          if {[info exists ::tcltk_tests(Total)]} then {
            set exitCode Success

            if {!$quiet} then {
              tresult Ok [appendArgs \
                  "OVERALL RESULT: " [getTestSuiteFullName] \n]

              if {$::tcltk_tests(Total) > 0} then {
                tresult Ok [appendArgs \
                    "OVERALL RESULT: SUCCESS (" \
                    $percent "% >= " $::test_threshold %)\n]

                maybeInvokeForTester ::overallSuccess; # HOOK
              } else {
                tresult Ok [appendArgs \
                    "OVERALL RESULT: NONE (" \
                    $percent "% >= " $::test_threshold %)\n]

                maybeInvokeForTester ::overallNone; # HOOK
              }
            }

            return true
          } else {
            set exitCode Failure

            if {!$quiet} then {
              tresult Error [appendArgs \
                  "OVERALL RESULT: " [getTestSuiteFullName] \n]

              if {[info exists ::test_suite_errors]} then {
                tresult Error [appendArgs "OVERALL ERRORS: " \
                    [expr {[llength $::test_suite_errors] > 0 ? \
                    $::test_suite_errors : "<empty>"}] \n]
              }

              tresult Error "OVERALL RESULT: MISSING test counts (2)\n"
              tresult Error "OVERALL RESULT: FAILURE\n"
              maybeInvokeForTester ::overallFailure; # HOOK
            }

            return false
          }
        } else {
          set exitCode Failure

          if {!$quiet} then {
            tresult Error [appendArgs \
                "OVERALL RESULT: " [getTestSuiteFullName] \n]

            if {[info exists ::test_suite_errors]} then {
              tresult Error [appendArgs "OVERALL ERRORS: " \
                  [expr {[llength $::test_suite_errors] > 0 ? \
                  $::test_suite_errors : "<empty>"}] \n]
            }

            tresult Error [appendArgs \
                "OVERALL RESULT: FAILURE (" \
                $percent "% < " $::test_threshold %)\n]

            maybeInvokeForTester ::overallFailure; # HOOK
          }

          return false
        }
      }
    }

    proc reportTestResultCounts { channel {varName ""} } {
      # <help>
      # This procedure prints the per-category breakdown of a finished test run
      # -- the familiar PASSED, FAILED, SKIPPED, DISABLED, TOTAL, and pass /
      # skip / disabled percentage lines -- and, as a side effect, hands the
      # computed overall pass percentage back to the caller.  It is the primary
      # results-reporting helper of the harness and is normally called just
      # before the overall verdict is decided.  This is the native TclTk
      # variant, reading the counts from the global tcltk_tests array; a
      # separate Tcl-compatible variant reads the tcltest numTests array.
      #
      # How it works: each category line is emitted through the themed
      # [tresult] output only when its count is greater than zero, so a clean
      # run produces a compact summary.  Failed and skipped categories, when
      # present, are followed by the corresponding list of test names.  If this
      # TclTk build tracks "knownBug" statistics (detected by the presence of
      # the KnownBugs element), the procedure additionally reports the list of
      # known bugs and the bug-tagged passed, failed, skipped, and disabled
      # sub-counts.  Leaked tracked resources, if any have been recorded by the
      # debugger, are always reported -- as an error when the leak count is
      # non-zero -- ahead of the category counts.  Finally, when at least one
      # test ran, it computes and prints the skip percentage, disabled
      # percentage, and pass percentage; when no tests ran, the percentage is
      # simply set to zero.
      #
      # Tricky details: the leaked-names list is stored as alternating name and
      # value entries, so the leak count is half its length.  Each category
      # uses a distinct [tresult] severity (Ok, Error, Break, WhatIf, Return,
      # Continue) so the output is color-coded by meaning.  The pass percentage
      # produced here is exactly the value that the overall-result check then
      # compares against any configured threshold.
      #
      # Arguments:
      #   channel -- The output channel for the summary messages.
      #   varName -- Optional name of a caller variable to receive the computed
      #              overall pass percentage (or zero when no tests ran).  When
      #              empty, no value is written back.
      #
      # Results:
      #   An empty string.  The meaningful output is the printed summary and the
      #   percentage written back through varName.
      # </help>

      #
      # NOTE: Does the caller want to change the percent to an appropriate
      #       value based on the overall test results?
      #
      if {[string length $varName] > 0} then {
        upvar 1 $varName percent
      }

      #
      # NOTE: If any tests leaked (tracked) resources, always show that in
      #       the summary as well.
      #
      if {[info exists ::tcltk_debugger(leakedNames)]} then {
        set leakedNames $::tcltk_debugger(leakedNames)
        set leaked [expr {[llength $leakedNames] / 2}]

        tresult [expr {$leaked > 0 ? "Error" : "Ok"}] \
            [appendArgs "LEAKED: " $leaked \n]

        if {$leaked > 0} then {
          tresult Error [appendArgs \
              "LEAKED: " [formatLeakedNames $leakedNames] \n]
        }
      }

      #
      # NOTE: Check if this build (i.e. of TclTk) has support for tracking
      #       statistics of tests that contain the "knownBug" constraint.
      #
      set trackBugs false

      if {[info exists ::tcltk_tests(KnownBugs)]} then {
        set trackBugs true

        if {[llength $::tcltk_tests(KnownBugs)] > 0} then {
          tresult Continue [appendArgs \
              "KNOWN BUGS: " $::tcltk_tests(KnownBugs) \n]
        }
      }

      if {$::tcltk_tests(Passed) > 0} then {
        tresult Ok [appendArgs \
            "PASSED: " $::tcltk_tests(Passed) \n]
      }

      if {$trackBugs && $::tcltk_tests(PassedBug) > 0} then {
        tresult Ok [appendArgs \
            "PASSED (BUG): " $::tcltk_tests(PassedBug) \n]
      }

      if {$::tcltk_tests(Failed) > 0} then {
        tresult Error [appendArgs \
            "FAILED: " $::tcltk_tests(Failed) \n]

        if {[llength $::tcltk_tests(FailedNames)] > 0} then {
          tresult Error [appendArgs \
              "FAILED: " $::tcltk_tests(FailedNames) \n]
        }
      }

      if {$trackBugs && $::tcltk_tests(FailedBug) > 0} then {
        tresult Error [appendArgs \
            "FAILED (BUG): " $::tcltk_tests(FailedBug) \n]
      }

      if {$::tcltk_tests(Skipped) > 0} then {
        tresult Break [appendArgs \
            "SKIPPED: " $::tcltk_tests(Skipped) \n]

        if {[llength $::tcltk_tests(SkippedNames)] > 0} then {
          tresult Break [appendArgs \
              "SKIPPED: " $::tcltk_tests(SkippedNames) \n]
        }
      }

      if {$trackBugs && $::tcltk_tests(SkippedBug) > 0} then {
        tresult Break [appendArgs \
            "SKIPPED (BUG): " $::tcltk_tests(SkippedBug) \n]
      }

      if {$::tcltk_tests(Disabled) > 0} then {
        tresult WhatIf [appendArgs \
            "DISABLED: " $::tcltk_tests(Disabled) \n]
      }

      if {$trackBugs && $::tcltk_tests(DisabledBug) > 0} then {
        tresult WhatIf [appendArgs \
            "DISABLED (BUG): " $::tcltk_tests(DisabledBug) \n]
      }

      if {$::tcltk_tests(Total) > 0} then {
        tresult Return [appendArgs \
            "TOTAL: " $::tcltk_tests(Total) \n]

        if {$::tcltk_tests(Skipped) > 0} then {
          set percent [getSkippedPercentage]

          tresult Break [appendArgs \
              "SKIP PERCENTAGE: " [formatDecimal $percent] %\n]
        }

        if {$::tcltk_tests(Disabled) > 0} then {
          set percent [getDisabledPercentage]

          tresult WhatIf [appendArgs \
              "DISABLED PERCENTAGE: " [formatDecimal $percent] %\n]
        }

        set percent [getPassedPercentage]

        tresult Return [appendArgs \
            "PASS PERCENTAGE: " [formatDecimal $percent] %\n]
      } else {
        #
        # NOTE: No tests.
        #
        set percent 0
      }

      unset trackBugs
      return ""
    }

    proc getTestSnippets {} {
      # <help>
      # This procedure returns the list of "snippet" names currently registered
      # with the active interpreter.  Snippets are small named script fragments
      # the engine can store and recall; this helper exposes their names to the
      # test suite (for example, so tests can verify snippet management or clean
      # up snippets they created).
      #
      # How it works: it calls the active interpreter's ListSnippets method via
      # object invocation, passing a null pattern (match everything) and the
      # default matching options, and capturing the resulting name list and an
      # error object through by-reference output variables.  If the method does
      # not return Ok, the error object is converted to a string and re-raised
      # as a script error; otherwise the name list object is returned.
      #
      # Arguments:
      #   None.
      #
      # Results:
      #   An object handle for the list of registered snippet names.  Raises a
      #   script error (carrying the underlying message) if the query fails.
      # </help>

      set names null; set error null

      set code [object invoke Interpreter.GetActive \
          ListSnippets null false None None names error]

      if {$code ne "Ok"} then {
        error [getStringFromObjectHandle $error]
      }

      return $names
    }

    proc lmissing { list1 list2 } {
      # <help>
      # This procedure returns the elements of the first list that are missing
      # from the second list -- that is, the asymmetric set difference "list1
      # minus list2".  Unlike the symmetric-difference helper elsewhere in the
      # library, it reports only items present in the first list and absent from
      # the second, not the reverse.  It is used, for instance, to determine
      # which created application domains have not yet been unloaded.
      #
      # How it works: it scans the first list in order and, for each element,
      # uses [lsearch -exact] to test for membership in the second list,
      # appending the element to the result when it is not found.  Matching is
      # exact (not glob or regexp), and an element absent from the second list
      # is appended once per occurrence in the first.
      #
      # Arguments:
      #   list1 -- The list whose unique elements are sought.
      #   list2 -- The list to subtract; elements found here are excluded.
      #
      # Results:
      #   A list of the elements from list1 that do not appear in list2, in
      #   their original order.  The empty list if every element of list1 is
      #   present in list2.
      # </help>

      set result [list]

      foreach element $list1 {
        if {[lsearch -exact $list2 $element] == -1} then {
          lappend result $element
        }
      }

      return $result
    }

    proc getTestAppDomains {} {
      # <help>
      # This procedure returns the list of application domain identifiers that
      # have been created but not yet unloaded through the engine's AppDomainOps
      # subsystem.  It is used by the test suite to detect leaked application
      # domains -- domains a test created and failed to tear down.
      #
      # How it works: it invokes the private AppDomainOps GetLists method to
      # obtain two object handles, one for the identifiers of created domains
      # and one for the identifiers of unloaded domains.  Each handle, when not
      # null, is converted to its string (list) form, or treated as the empty
      # list when null.  The result is the set difference of the two lists --
      # the created identifiers with the unloaded identifiers removed --
      # computed via the [lmissing] helper.
      #
      # Tricky details: this reaches into non-public engine internals (the
      # +NonPublic flag) and therefore depends on the AppDomainOps
      # implementation; it is intended for test diagnostics, not general use.
      #
      # Arguments:
      #   None.
      #
      # Results:
      #   A list of the application domain identifiers that are currently
      #   created and not yet unloaded.  The empty list when none remain.
      # </help>

      #
      # HACK: First, grab lists of AppDomain identifiers that
      #       have been created -OR- unloaded from within the
      #       AppDomainOps subsystem.  The resulting list of
      #       AppDomain identifiers will only contain those
      #       that have been created and not (yet) unloaded.
      #
      set createList null
      set unloadList null

      object invoke -create -flags +NonPublic \
          CodeBrix.Platform.TclTk._Components.Private.AppDomainOps \
          GetLists createList unloadList

      if {[isNonNullObjectHandle $createList]} then {
        set createList [object invoke $createList ToString]
      } else {
        set createList [list]
      }

      if {[isNonNullObjectHandle $unloadList]} then {
        set unloadList [object invoke $unloadList ToString]
      } else {
        set unloadList [list]
      }

      return [lmissing $createList $unloadList]
    }

    proc testObjectMembers { args } {
      # <help>
      # This procedure returns the sorted list of members of an opaque object,
      # as a thin, test-friendly wrapper around the [object members] command.
      # It exists so that tests can obtain a deterministic, alphabetized member
      # listing (member ordering from the runtime is otherwise unspecified),
      # which makes test results stable and easy to compare.
      #
      # How it works: it requires at least one argument and otherwise raises a
      # "wrong # args" error naming the calling procedure.  It builds the
      # command [object members], appends all of the supplied arguments to it,
      # evaluates that command in the caller's context with [uplevel 1], and
      # returns the result sorted with [lsort].
      #
      # Tricky details: because evaluation happens via [uplevel 1], any options
      # and the object reference are interpreted exactly as [object members]
      # would interpret them at the call site; this procedure does not validate
      # or interpret them itself beyond requiring that at least one be present.
      #
      # Arguments:
      #   args -- One or more arguments forwarded verbatim to [object members];
      #           typically optional members-options followed by the object.
      #           Passing none is an error.
      #
      # Results:
      #   The alphabetically sorted list of the object's members.  Raises a
      #   "wrong # args" error when called with no arguments.
      # </help>

      if {[llength $args] == 0} then {
        error [appendArgs \
            "wrong # args: should be \"" \
            [lindex [info level [info level]] 0] \
            " ?options? object\""]
      }

      set command [list object members]
      eval lappend command $args

      return [lsort [uplevel 1 $command]]
    }

    proc getThreadTimeout { timeout type } {
      # <help>
      # This procedure resolves a thread timeout request into the concrete
      # millisecond value used by the threading helpers.  It accepts either an
      # explicit integer or one of several symbolic words, translating the
      # symbolic forms into the engine's effective or default timeout for the
      # given timeout type.  It exists so the various thread routines (sync,
      # join, cleanup) can accept flexible, human-friendly timeout arguments.
      #
      # How it works: if the timeout is an integer it is returned verbatim,
      # including negative values (a negative timeout means "wait forever",
      # which is acceptable to the callers).  The word "infinite" returns the
      # engine's Infinite timeout constant (a negative sentinel).  An empty
      # string or "effective" resolves to the effective timeout for the current
      # interpreter and the given type, while "default" resolves to the type's
      # default timeout with no interpreter context.  Any other value, raises
      # an error.  The chosen interpreter context and timeout sentinel are then
      # passed to the private ThreadOps GetTimeout method, which returns the
      # concrete value (the type is combined with +Infinite so an infinite
      # result is permitted).
      #
      # Arguments:
      #   timeout -- The requested timeout: an integer number of milliseconds,
      #              or one of the words "infinite", "effective", "default", or
      #              the empty string (treated as "effective").
      #   type    -- The timeout type name (for example Start or Join) used to
      #              select the relevant effective or default timeout.
      #
      # Results:
      #   An integer number of milliseconds (possibly negative to indicate an
      #   infinite wait).  Raises an error for an unrecognized timeout value.
      # </help>

      #
      # NOTE: Is the specified timeout value an integer?  If this ends
      #       up being a negative value, the caller may wait "forever"
      #       and that is fine for our purposes.
      #
      if {[string is integer -strict $timeout]} then {
        #
        # NOTE: Use the specified (integer) timeout value verbatim.
        #
        return $timeout
      }

      #
      # NOTE: Is the caller specifically wanting an infinite timeout?
      #
      if {[string tolower $timeout] in [list infinite]} then {
        return [object invoke CodeBrix.Platform.TclTk._Constants._Timeout Infinite]; # <0
      }

      #
      # NOTE: Otherwise, check for various special values that are not
      #       integers.
      #
      if {[string tolower $timeout] in [list "" effective]} then {
        #
        # NOTE: Get effective timeout for the current interpreter
        #       and the timeout type.
        #
        set timeout null; set interpreter ""
      } elseif {[string tolower $timeout] in [list default]} then {
        #
        # NOTE: Get default timeout for the timeout type (i.e. no
        #       interpreter context).
        #
        set timeout null; set interpreter null
      } else {
        #
        # NOTE: No other values, including an empty string, are valid.
        #
        error "invalid thread timeout value"
      }

      return [object invoke -flags +NonPublic \
          CodeBrix.Platform.TclTk._Components.Private.ThreadOps GetTimeout $interpreter \
          $timeout [appendArgs $type " +Infinite"]]
    }

    proc createThread { script {parameterized false} {maxStackSize ""} } {
      # <help>
      # This procedure creates a managed thread that will run the specified
      # script, returning an aliased object handle for the new thread (not yet
      # started).  It is the test suite's entry point for spinning up worker
      # threads, abstracting over two different creation mechanisms.
      #
      # How it works: when the engine supports it and the createEngineThread
      # runtime option is enabled (and not disabled via the "no" array), it
      # invokes the engine's own Engine.CreateThread, which constructs a real
      # System.Threading.Thread whose body is the supplied TclTk script.  The
      # empty string passed for the interpreter argument follows the standard
      # engine convention meaning "the current interpreter" (resolved via
      # Interpreter.GetActive), so the script runs in that same interpreter
      # when the thread starts -- no child interpreter is created.  The engine
      # path additionally wires the new thread into the engine's tracking and
      # notification machinery via an internal EngineThread wrapper, which
      # associates the OS thread with that interpreter for engine-aware
      # operations (current-thread lookup, thread-host integration, exception
      # notification).  Otherwise it falls back to constructing a raw
      # System.Threading.Thread directly around a thread-start delegate built
      # from the script, with no engine tracking.  In both paths the
      # parameterized flag selects between a plain start and a parameterized
      # start (one that accepts a single argument when the thread is later
      # started), and a non-empty maxStackSize requests a specific stack size;
      # in the engine path an empty maxStackSize becomes zero (the engine
      # default).
      #
      # Tricky details: when running on .NET Core the raw thread path uses the
      # assembly-qualified "System.Threading.Thread, mscorlib" type name, which
      # is reported to behave better there.  The returned handle is created with
      # the NoReturnReference object flag so the thread object is not implicitly
      # kept alive by a return reference.  The thread is created but NOT started
      # -- use the start helper for that.
      #
      # Arguments:
      #   script        -- The thread body.  In the engine path this is an TclTk
      #                    script; in the raw path it is used to build the
      #                    thread-start delegate.
      #   parameterized -- Optional boolean (default false) selecting a
      #                    parameterized thread start that accepts one argument.
      #   maxStackSize  -- Optional maximum stack size in bytes; empty means use
      #                    the default (zero, the engine default, in the engine
      #                    path).
      #
      # Results:
      #   An aliased object handle for the newly created, not-yet-started
      #   thread.
      # </help>

      if {![info exists ::no(createEngineThread)] && \
          [llength [info commands hasRuntimeOption]] > 0 && \
          [hasRuntimeOption createEngineThread]} then {
        if {[string length $maxStackSize] == 0} then {
          set maxStackSize 0; # NOTE: Use engine default.
        }

        if {$parameterized} then {
          return [object invoke -alias \
              -objectflags +NoReturnReference -parametertypes \
              [list CodeBrix.Platform.TclTk._Components.Public.Interpreter \
              System.Threading.ParameterizedThreadStart System.Int32 \
              System.Boolean System.Boolean System.Boolean] Engine \
              CreateThread "" $script $maxStackSize true false true]
        } else {
          return [object invoke -alias \
              -objectflags +NoReturnReference -parametertypes \
              [list CodeBrix.Platform.TclTk._Components.Public.Interpreter \
              System.Threading.ThreadStart System.Int32 \
              System.Boolean System.Boolean System.Boolean] Engine \
              CreateThread "" $script $maxStackSize true false true]
        }
      } else {
        if {[isDotNetCore]} then {
          #
          # HACK: This seems to make .NET Core happier for reasons
          #       that are not entirely clear.
          #
          set typeName "System.Threading.Thread, mscorlib"
        } else {
          set typeName System.Threading.Thread
        }

        if {$parameterized} then {
          if {[string length $maxStackSize] > 0} then {
            return [object create -alias \
                -objectflags +NoReturnReference -parametertypes \
                [list System.Threading.ParameterizedThreadStart \
                System.Int32] $typeName $script $maxStackSize]
          } else {
            return [object create -alias \
                -objectflags +NoReturnReference -parametertypes \
                [list System.Threading.ParameterizedThreadStart] \
                $typeName $script]
          }
        } else {
          if {[string length $maxStackSize] > 0} then {
            return [object create -alias \
                -objectflags +NoReturnReference -parametertypes \
                [list System.Threading.ThreadStart System.Int32] \
                $typeName $script $maxStackSize]
          } else {
            return [object create -alias \
                -objectflags +NoReturnReference -parametertypes \
                [list System.Threading.ThreadStart] $typeName \
                $script]
          }
        }
      }
    }

    proc startThread { thread {parameterized false} {parameter null} } {
      # <help>
      # This procedure starts a thread previously created by the thread-creation
      # helper, optionally passing a single argument to a parameterized thread.
      # It is a thin convenience wrapper that selects the correct Start overload.
      #
      # How it works: when parameterized is true it calls the thread's Start
      # method with the supplied parameter (which the parameterized thread body
      # receives as its argument); otherwise it calls the no-argument Start.
      #
      # Arguments:
      #   thread        -- The object handle of the thread to start (as returned
      #                    by the thread-creation helper).
      #   parameterized -- Optional boolean (default false); true if the thread
      #                    was created as parameterized and should receive an
      #                    argument.
      #   parameter     -- Optional value to pass to a parameterized thread
      #                    (default the null object).  Ignored when not
      #                    parameterized.
      #
      # Results:
      #   The result of the underlying Start invocation (normally empty).
      # </help>

      if {$parameterized} then {
        $thread Start $parameter
      } else {
        $thread Start
      }
    }

    proc syncThread { thread {timeout ""} {state WaitSleepJoin} } {
      # <help>
      # This procedure busy-waits until a thread reaches a desired thread state,
      # or until a timeout elapses, whichever comes first.  It is used by tests
      # that need to be sure a worker thread has reached a particular point (for
      # example, that it has entered a sleeping or waiting state) before
      # proceeding.
      #
      # How it works: it resolves the timeout to milliseconds (using the Start
      # timeout type), records a start time, then loops continuously comparing
      # the thread's current ThreadState to the target state.  When the state
      # matches, it logs a "sleep success" message with the elapsed time and
      # breaks.  If the resolved timeout is non-negative and the elapsed time
      # exceeds it, it logs a "sleep timeout" message and breaks instead.
      #
      # Tricky details: the loop is a tight spin with no delay, so it consumes
      # CPU while waiting; this is acceptable for short test synchronization.  A
      # negative resolved timeout (for example "infinite") disables the timeout
      # branch, so the loop waits indefinitely for the state.  Diagnostic
      # messages are sent to the default test channel.
      #
      # Arguments:
      #   thread  -- The object handle of the thread to observe.
      #   timeout -- Optional timeout (any form accepted by the thread-timeout
      #              resolver); empty resolves to the effective Start timeout.
      #   state   -- Optional target thread state name (default WaitSleepJoin).
      #
      # Results:
      #   An empty string.  Whether the state was reached or the wait timed out
      #   is reported only through the logged message.
      # </help>

      set channel [getTestChannelOrDefault]
      set timeout [getThreadTimeout $timeout Start]
      set start [clock milliseconds]

      while {1} {
        set now [clock milliseconds]
        set diff [expr {$now - $start}]

        if {[$thread ThreadState] eq $state} then {
          tputs $channel [appendArgs \
              "---- sleep success after " $diff " milliseconds\n"]

          break
        }

        if {$timeout >= 0 && $diff > $timeout} then {
          tputs $channel [appendArgs \
              "---- sleep timeout after " $diff " milliseconds\n"]

          break
        }
      }
    }

    proc joinThread { thread {timeout ""} } {
      # <help>
      # This procedure waits for a thread to finish (joins it), optionally with
      # a timeout.  It is used by tests to block until a worker thread has
      # completed before checking its effects or cleaning up.
      #
      # How it works: when an explicit timeout is supplied, it calls the
      # thread's Join overload that accepts an Int32 millisecond count, using
      # the resolved Join timeout, and returns that call's boolean result (true
      # if the thread finished within the timeout).  When no timeout is supplied
      # but the global test_join_timeout variable is set, that value is resolved
      # and used the same way.  Otherwise it calls the no-argument Join, which
      # blocks until the thread finishes, and returns true.
      #
      # Tricky details: the timeout value (explicit or from test_join_timeout)
      # is passed through the thread-timeout resolver with the Join type, so the
      # usual symbolic forms are accepted.  The parametertypes constraint forces
      # selection of the timed Join overload.
      #
      # Arguments:
      #   thread  -- The object handle of the thread to join.
      #   timeout -- Optional timeout (any form accepted by the thread-timeout
      #              resolver).  When empty, the global test_join_timeout is
      #              used if set; otherwise the join is unbounded.
      #
      # Results:
      #   True if the thread finished (or for the unbounded join); false if a
      #   timed join elapsed before the thread finished.
      # </help>

      if {[string length $timeout] > 0} then {
        return [$thread -parametertypes [list Int32] Join \
            [getThreadTimeout $timeout Join]]
      } elseif {[info exists ::test_join_timeout] && \
          [string length $::test_join_timeout] > 0} then {
        return [$thread -parametertypes [list Int32] Join \
            [getThreadTimeout $::test_join_timeout Join]]
      } else {
        $thread Join; return true
      }
    }

    proc cleanupThread { thread {timeout ""} {quiet false} } {
      # <help>
      # This procedure attempts to bring a test thread to a stop and reclaim it,
      # escalating through progressively more forceful measures and logging each
      # step.  It is the tear-down counterpart to the thread-creation helper,
      # used to ensure a worker thread does not survive past the test that
      # created it.
      #
      # How it works: it resolves the timeout to milliseconds using the Join
      # timeout type, then proceeds through a sequence of attempts, checking
      # IsAlive between each.  On .NET Core it first tries a plain timed Join,
      # because interrupting there can lose a held lock.  It then interrupts the
      # thread, joins again with the timeout, and -- if the thread is still
      # alive -- aborts it.  Each operation is wrapped in [catch] so a failure
      # is logged and tolerated rather than propagated.  As soon as any stage
      # confirms the thread is no longer alive (pre-joined, joined, interrupted,
      # or aborted), the procedure returns success.  If the thread is still
      # alive after the abort attempt, it is reported as possibly "zombied" and
      # the procedure returns failure.  A thread that was already dead on entry
      # returns success immediately.
      #
      # Tricky details: unless quiet mode is requested, every step emits a
      # diagnostic line to the default test channel; the timed Join overload is
      # selected via the Int32 parametertypes constraint and its boolean result
      # distinguishes a successful join from a timeout.  Abort is a last resort
      # and may leave shared state inconsistent, which is why the gentler steps
      # are tried first.
      #
      # Arguments:
      #   thread  -- The object handle of the thread to clean up.
      #   timeout -- Optional timeout (any form accepted by the thread-timeout
      #              resolver) applied to the join attempts.
      #   quiet   -- Optional boolean (default false); when true, suppresses all
      #              diagnostic logging.
      #
      # Results:
      #   True if the thread is no longer alive when the procedure finishes
      #   (already dead, joined, interrupted, or aborted); false if it is still
      #   alive (possibly zombied) or an unrecoverable error occurred.
      # </help>

      #
      # NOTE: First, figure out where to send diagnostic / error messages
      #       related to cleaning up the target thread, if any.
      #
      set channel [getTestChannelOrDefault]

      #
      # NOTE: Next, translate the specified timeout value, if any, into an
      #       integer value we can actually use.  Since this timeout value
      #       is used with the Thread.Join method, that is what is used for
      #       the timeout type here.  An argument could be made for using a
      #       timeout type of Interrupt or Dispose instead.
      #
      set timeout [getThreadTimeout $timeout Join]

      #
      # HACK: When running on .NET Core, it seems that using the Interrupt
      #       method can result in a held lock being lost, even when using
      #       a lock statement, which should have try / finally semantics.
      #       Therefore, in that case, attempt to wait on the thread prior
      #       to attempting to use the Interrupt method.
      #
      if {[isDotNetCore]} then {
        if {[$thread IsAlive]} then {
          if {[catch {
            $thread -parametertypes [list Int32] Join $timeout
          } error]} then {
            if {!$quiet} then {
              tputs $channel [appendArgs \
                  "---- failed to pre-join test thread \"" $thread \
                  "\": " $error \n]
            }
          } elseif {$error} then {
            if {!$quiet} then {
              tputs $channel [appendArgs \
                  "---- pre-joined test thread \"" $thread \"\n]
            }
          } else {
            if {!$quiet} then {
              tputs $channel [appendArgs \
                  "---- timeout pre-joining test thread \"" $thread \
                  " (" $timeout " milliseconds)\"\n"]
            }
          }
        }
      }

      if {[$thread IsAlive]} then {
        if {[catch {$thread Interrupt} error]} then {
          if {!$quiet} then {
            tputs $channel [appendArgs \
                "---- failed to interrupt test thread \"" $thread \
                "\": " $error \n]
          }
        } else {
          if {!$quiet} then {
            tputs $channel [appendArgs \
                "---- test thread \"" $thread "\" interrupted\n"]
          }
        }

        if {[$thread IsAlive]} then {
          if {[catch {
            $thread -parametertypes [list Int32] Join $timeout
          } error]} then {
            if {!$quiet} then {
              tputs $channel [appendArgs \
                  "---- failed to join test thread \"" $thread \
                  "\": " $error \n]
            }
          } elseif {$error} then {
            if {!$quiet} then {
              tputs $channel [appendArgs \
                  "---- joined test thread \"" $thread \"\n]
            }
          } else {
            if {!$quiet} then {
              tputs $channel [appendArgs \
                  "---- timeout joining test thread \"" $thread \
                  " (" $timeout " milliseconds)\"\n"]
            }
          }

          if {[$thread IsAlive]} then {
            if {[catch {$thread Abort} error]} then {
              if {!$quiet} then {
                tputs $channel [appendArgs \
                    "---- failed to abort test thread \"" $thread \
                    "\": " $error \n]
              }
            } else {
              if {!$quiet} then {
                tputs $channel [appendArgs \
                    "---- test thread \"" $thread "\" aborted\n"]
              }
            }

            if {[$thread IsAlive]} then {
              if {!$quiet} then {
                tputs $channel [appendArgs \
                    "---- test thread \"" $thread "\" may be zombied\n"]
              }
            } else {
              return true; # aborted?
            }
          } else {
            return true; # joined?
          }
        } else {
          return true; # interrupted?
        }
      } else {
        return true; # already dead?
      }

      return false; # still alive (or error).
    }

    proc reportTestDuplicateNames { channel } {
      # <help>
      # This procedure reports any test names that were used more than once (or
      # that have an invalid count) during the run.  Test names are required to
      # be unique, so duplicates usually indicate a copy-and-paste mistake in a
      # test file; this helper surfaces them in the summary output.
      #
      # How it works: it walks the name-and-count pairs accumulated in the
      # Counts element of the global tcltk_tests array.  For any name whose
      # count exceeds one it prints a "DUPLICATED" line including the count, and
      # for any name whose count is zero or negative it prints a "BAD COUNT"
      # line.  Names with a normal count of one produce no output.
      #
      # Tricky details: as the inline note explains, this check can produce
      # false positives if a file or the whole suite is run more than once
      # without resetting statistics or restarting TclTk, since the counts
      # accumulate across runs; this trade-off is accepted because enforcing
      # unique names is considered worth it.
      #
      # Arguments:
      #   channel -- The output channel for the duplicate/bad-count messages.
      #
      # Results:
      #   An empty string; the meaningful output is the printed report.
      # </help>

      #
      # NOTE: Check and display any duplicate test names that we
      #       found.  In theory, this checking may produce false
      #       positives if a test file (or the entire test suite)
      #       is run multiple times without resetting statistics
      #       and/or restarting TclTk; however, duplicate test
      #       names must be avoided and this is considered a good
      #       trade-off.
      #
      foreach {name count} $::tcltk_tests(Counts) {
        if {$count > 1} then {
          tputs $channel [appendArgs \
              "==== test name \"" $name "\" DUPLICATED (" \
              $count ")\n"]
        } elseif {$count <= 0} then {
          tputs $channel [appendArgs \
              "==== test name \"" $name "\" BAD COUNT (" \
              $count ")\n"]
        }
      }

      return ""
    }

    proc reportTestConstraintCounts { channel skippedNames } {
      # <help>
      # This procedure reports how many tests were skipped on account of each
      # test constraint, as a per-constraint tally.  It helps explain a run's
      # skip count by attributing skips to the specific constraints (platform,
      # feature, build option, and so on) that were not satisfied.
      #
      # How it works: it delegates the actual counting to the constraint-count
      # calculator, which fills in a maximum count and an array of per-constraint
      # counts from the supplied list of skipped test names.  When at least one
      # constraint was counted, it prints a header line followed by one line per
      # constraint, each showing the count right-justified to a field width
      # derived from the largest count (via a base-ten logarithm) and then the
      # constraint name, with a trailing blank line.  When nothing was counted,
      # it prints nothing.
      #
      # Arguments:
      #   channel      -- The output channel for the report.
      #   skippedNames -- The list of skipped test names (and associated skip
      #                   information) from which the per-constraint counts are
      #                   derived.
      #
      # Results:
      #   An empty string; the meaningful output is the printed report.
      # </help>

      #
      # NOTE: Produce the final output, which includes a single line header
      #       followed by one line per test constraint seen.
      #
      set maximum 0

      calculateTestConstraintCounts $skippedNames maximum counts

      if {$maximum > 0 && [array size counts] > 0} then {
        set places [expr {int(log10($maximum)) + 1}]

        tputs $channel "Number of tests skipped for each constraint:\n"

        foreach {name value} [reportArrayGet counts] {
          tputs $channel [appendArgs \
              \t [format [appendArgs % $places s] $value] \t $name \n]
        }

        tputs $channel \n
      }
    }

    proc purgeAndCleanup { channel name {quiet false} } {
      # <help>
      # This procedure performs a sweeping cleanup of the engine's many internal
      # caches and pools, then purges and cleans up the interpreter itself.  It
      # is used between tests (or test files) to release memory and to reduce
      # cross-test contamination from cached state, giving each test a cleaner
      # starting point and making resource-leak detection more meaningful.
      #
      # How it works: it invokes a long series of cache-clearing and cleanup
      # methods on private engine subsystems -- among them ProcessOps, EnumOps,
      # the string file-name comparer, StringOps preamble encodings, HashOps,
      # FactoryOps, ScriptOps, SyntaxOps, ConfigurationOps, TraceLimits, the
      # marshal to-string cache, CertificateOps, RuntimeOps, and the string
      # builder cache -- and conditionally clears the interactive help cache
      # (HelpOps) when the build has both shell and interactive-command support.
      # It finishes by running [debug purge] and a [debug cleanup] for the
      # default and miscellaneous categories.  Every call is wrapped in [catch]
      # and evaluated in the caller's context via [uplevel 1], so a subsystem
      # that is unavailable or fails simply has its result reported rather than
      # aborting the sweep.  Unless quiet mode is requested, the outcome of each
      # step is logged with a descriptive label.
      #
      # Tricky details: because it touches non-public internals (the +NonPublic
      # flag) across many subsystems, the exact set of cleanups reflects the
      # engine implementation and may evolve; the per-step [catch] makes the
      # routine resilient to subsystems that do not exist in a given build.  The
      # name argument is purely a label used to tag the purge and cleanup log
      # lines.
      #
      # Arguments:
      #   channel -- The output channel for the per-step result messages.
      #   name    -- A label (typically the test or file name) included in the
      #              purge and cleanup log lines for context.
      #   quiet   -- Optional boolean (default false); when true, suppresses all
      #              of the per-step logging.
      #
      # Results:
      #   An empty string; the work is performed for its side effects and any
      #   logged output.
      # </help>

      catch {uplevel 1 [list object invoke -flags +NonPublic \
          CodeBrix.Platform.TclTk._Components.Private.ProcessOps Cleanup]} result

      if {!$quiet} then {
        tputs $channel [appendArgs \
            "---- ProcessOps cleanup results: " $result \n]
      }

      catch {uplevel 1 [list object invoke -flags +NonPublic \
          CodeBrix.Platform.TclTk._Components.Private.EnumOps ClearCache]} result

      if {!$quiet} then {
        tputs $channel [appendArgs \
            "---- EnumOps cleanup results: " $result \n]
      }

      if {[info exists ::tcltk_platform(compileOptions)]} then {
        set options $::tcltk_platform(compileOptions)
      } else {
        set options [list]
      }

      if {[lsearch -exact $options SHELL] != -1 && \
          [lsearch -exact $options INTERACTIVE_COMMANDS] != -1} then {
        catch {uplevel 1 [list object invoke -flags +NonPublic \
            CodeBrix.Platform.TclTk._Components.Private.HelpOps ClearCache]} result

        if {!$quiet} then {
          tputs $channel [appendArgs \
              "---- HelpOps cleanup results: " $result \n]
        }
      }

      catch {uplevel 1 [list object invoke -flags +NonPublic \
          CodeBrix.Platform.TclTk._Components.Private.StringOps ClearPreambleEncodings]} result

      if {!$quiet} then {
        tputs $channel [appendArgs \
            "---- StringOps cleanup results: " $result \n]
      }

      catch {uplevel 1 [list object invoke -flags +NonPublic \
          CodeBrix.Platform.TclTk._Comparers.StringFileName ClearCache]} result

      if {!$quiet} then {
        tputs $channel [appendArgs \
            "---- Comparers.StringFileName cleanup results: " $result \n]
      }

      catch {uplevel 1 [list object invoke -flags +NonPublic \
          CodeBrix.Platform.TclTk._Components.Private.HashOps Cleanup]} result

      if {!$quiet} then {
        tputs $channel [appendArgs \
            "---- HashOps cleanup results: " $result \n]
      }

      catch {uplevel 1 [list object invoke -flags +NonPublic \
          CodeBrix.Platform.TclTk._Components.Private.FactoryOps Cleanup]} result

      if {!$quiet} then {
        tputs $channel [appendArgs \
            "---- FactoryOps cleanup results: " $result \n]
      }

      catch {uplevel 1 [list object invoke -flags +NonPublic \
          CodeBrix.Platform.TclTk._Components.Private.ScriptOps ClearInterpreterCache]} result

      if {!$quiet} then {
        tputs $channel [appendArgs \
            "---- ScriptOps cleanup results: " $result \n]
      }

      catch {uplevel 1 [list object invoke -flags +NonPublic \
          CodeBrix.Platform.TclTk._Components.Private.SyntaxOps ClearCache]} result

      if {!$quiet} then {
        tputs $channel [appendArgs \
            "---- SyntaxOps cleanup results: " $result \n]
      }

      catch {uplevel 1 [list object invoke -flags +NonPublic \
          CodeBrix.Platform.TclTk._Components.Private.ConfigurationOps Cleanup false]} result

      if {!$quiet} then {
        tputs $channel [appendArgs \
            "---- ConfigurationOps cleanup results: " $result \n]
      }

      catch {uplevel 1 [list object invoke -flags +NonPublic \
          CodeBrix.Platform.TclTk._Components.Private.TraceLimits Cleanup]} result

      if {!$quiet} then {
        tputs $channel [appendArgs \
            "---- TraceLimits cleanup results: " $result \n]
      }

      catch {uplevel 1 [list object invoke -flags +NonPublic \
          CodeBrix.Platform.TclTk._Components.Private.MarshalOps+ToStringCache Clear]} result

      if {!$quiet} then {
        tputs $channel [appendArgs \
            "---- ToStringCache cleanup results: " $result \n]
      }

      catch {uplevel 1 [list object invoke -flags +NonPublic \
          CodeBrix.Platform.TclTk._Components.Private.CertificateOps ClearCache]} result

      if {!$quiet} then {
        tputs $channel [appendArgs \
            "---- CertificateOps cleanup results: " $result \n]
      }

      catch {uplevel 1 [list object invoke -flags +NonPublic \
          CodeBrix.Platform.TclTk._Components.Private.RuntimeOps ClearCache]} result

      if {!$quiet} then {
        tputs $channel [appendArgs \
            "---- RuntimeOps cleanup results: " $result \n]
      }

      catch {uplevel 1 [list object invoke -flags +NonPublic \
          CodeBrix.Platform.TclTk._Components.Private.StringBuilderCache Clear]} result

      if {!$quiet} then {
        tputs $channel [appendArgs \
            "---- StringBuilderCache cleanup results: " $result \n]
      }

      catch {uplevel 1 [list debug purge]} result

      if {!$quiet} then {
        tputs $channel [appendArgs \
            "---- purge \"" $name "\" results: " $result \n]
      }

      catch {uplevel 1 [list debug cleanup {
        Default -Miscellaneous
      }]} result

      if {!$quiet} then {
        tputs $channel [appendArgs \
            "---- cleanup \"" $name "\" results: " $result \n]
      }
    }

    proc evalWithTimeout { script {milliseconds 2000} {resultVarName ""} } {
      # <help>
      # This procedure evaluates a script in the caller's context but aborts it
      # if it runs longer than a given number of milliseconds.  It is used by
      # tests that must guard against hangs -- for example, code that waits on
      # an event that might never arrive.
      #
      # How it works: it first verifies the millisecond limit is positive,
      # raising an error otherwise.  It then evaluates the script via [debug
      # secureeval] with a timeout, using [uplevel 1] so the script sees the
      # caller's variables.  The secure-eval options request that the timeout be
      # enforced through script cancellation: it stops any contained [vwait] on
      # cancellation, cancels globally, stops on error, and resets the
      # cancellation flags on completion so the enforcement mechanism does not
      # leave the interpreter in a cancelled state.  The whole evaluation is
      # wrapped in [catch], and that catch code is what the procedure returns.
      #
      # Tricky details: this returns the integer [catch] completion code, not
      # the script's own result; a timeout (which manifests as a cancellation)
      # therefore shows up as a non-zero code.  The actual script result or
      # error message is available only if the caller supplies resultVarName.
      #
      # Arguments:
      #   script        -- The script to evaluate (in the caller's context).
      #   milliseconds  -- Optional positive timeout in milliseconds (default
      #                    2000).  Must be greater than zero.
      #   resultVarName -- Optional name of a caller variable to receive the
      #                    script's result or error message.  When empty, the
      #                    result is discarded.
      #
      # Results:
      #   The integer completion code from [catch] (zero on normal success,
      #   non-zero on error, cancellation, or timeout).  Raises an error if the
      #   millisecond limit is not positive.
      # </help>

      #
      # NOTE: Verify that the number of milliseconds requested is greater than
      #       zero.
      #
      if {$milliseconds <= 0} then {
        error "number of milliseconds must be greater than zero"
      }

      #
      # NOTE: Evaluate the specified script in the context of the caller,
      #       returning the result to the caller.
      #
      if {[string length $resultVarName] > 0} then {
        upvar 1 $resultVarName result
      }

      return [catch {
        #
        # NOTE: Evaluate the script in the context of the caller, forcing
        #       any [vwait] that may be in the contained script to stop
        #       when it hits a script cancellation -AND- reset the script
        #       cancellation flags upon completion (i.e. important due to
        #       the use of script cancellation to enforce the timeout).
        #
        uplevel 1 [list \
            debug secureeval -nocancel true -globalcancel true \
            -stoponerror true -timeout $milliseconds {} $script]
      } result]
    }

    proc vwaitWithTimeout { varName {milliseconds 2000} } {
      # <help>
      # This procedure waits for a variable to be written, but gives up after a
      # given number of milliseconds instead of blocking forever.  It is the
      # bounded-wait counterpart to a bare [vwait], used by tests that wait on
      # an asynchronous event but must not hang if the event never fires.
      #
      # How it works: it verifies the millisecond limit is non-negative
      # (raising an error otherwise), links the named variable from the caller's
      # context via [upvar 1], and performs a [vwait] on it with a timeout and
      # the event-wait flags +NoBgError and StopOnError (so background errors do
      # not interfere and the wait stops on error), using -force to wait even
      # outside the normal conditions.  The wait is wrapped in [catch]: if it
      # completes the wait's result is returned; if it fails (for example, the
      # wait was cancelled or timed out) the procedure returns false.
      #
      # Tricky details: a zero timeout is permitted (a non-blocking poll); only
      # negative values are rejected.  Because a timeout surfaces as a failed
      # [catch], the caller cannot distinguish a timeout from other wait
      # failures by the return value alone -- both yield false -- and the
      # variable may or may not have been changed in that case.
      #
      # Arguments:
      #   varName      -- The name (in the caller's context) of the variable to
      #                   wait on.
      #   milliseconds -- Optional non-negative timeout in milliseconds (default
      #                   2000).  Zero polls without blocking.
      #
      # Results:
      #   The result of the completed [vwait] on success, or false if the wait
      #   failed, was cancelled, or timed out.  Raises an error if the
      #   millisecond limit is negative.
      # </help>

      #
      # NOTE: Verify that the number of milliseconds requested is positive
      #       or zero.
      #
      if {$milliseconds < 0} then {
        error "number of milliseconds cannot be negative"
      }

      if {[catch {
        #
        # NOTE: Refer to the specified variable in the context of our
        #       caller.
        #
        upvar 1 $varName variable

        #
        # NOTE: Wait for the variable to be changed -OR- for the wait
        #       to be canceled.
        #
        vwait -eventwaitflags {+NoBgError StopOnError} -force -timeout \
            $milliseconds -- variable
      } result] == 0} then {
        #
        # NOTE: The wait completed successfully, the variable may have
        #       been changed.
        #
        return $result
      } else {
        #
        # NOTE: The wait failed in some way, it may have been canceled
        #       and the variable may or may not have been changed.
        #
        return false
      }
    }

    proc tclLoadForTest { {varName ""} {findFlags ""} {loadFlags ""} } {
      # <help>
      # This procedure loads the native Tcl library so that tests exercising
      # TclTk's native Tcl integration can run.  It centralizes the load logic,
      # honors environment-based hooks, and supports a "disabled" mode in which
      # the load is faked rather than actually performed.
      #
      # How it works: if the environment variable tclPreLoad is set, it is
      # evaluated as a pre-load hook.  If varName is supplied, a "loaded" flag
      # in the caller's context is updated to record whether a load occurred.
      # When native Tcl is not already ready, the procedure checks whether
      # loading has been disabled via the "no" array element [tclLoadForTest]; if
      # not disabled, it builds and evaluates a [tcl load] command (in the
      # caller's context) optionally augmented with -findflags and/or
      # -loadflags.  It then marks loaded as one (which may be a fake when
      # disabled) and logs whether native Tcl was loaded, along with the module
      # and primary interpreter names (or angle-bracket "none" placeholders when
      # disabled).  Finally, if the environment variable tclPostLoad is set, it
      # is evaluated as a post-load hook.
      #
      # Tricky details: when disabled, the loaded flag is still set so that the
      # paired unload helper behaves consistently, but no real load happens --
      # hence the "may be faked" notes.  When native Tcl is already ready, the
      # whole body after the initial bookkeeping is skipped.
      #
      # Arguments:
      #   varName   -- Optional name of a caller variable to receive the loaded
      #                flag (one if a load was attempted/faked, zero otherwise).
      #   findFlags -- Optional flags passed as -findflags to [tcl load] to
      #                influence how the native library is located.
      #   loadFlags -- Optional flags passed as -loadflags to [tcl load] to
      #                influence how the native library is loaded.
      #
      # Results:
      #   An empty string; the load is performed (or faked) for its side
      #   effects, with status reported through varName and the test log.
      # </help>

      if {[info exists ::env(tclPreLoad)]} then {
        eval $::env(tclPreLoad); # HOOK
      }

      if {[string length $varName] > 0} then {
        upvar 1 $varName loaded
      }

      set loaded 0

      if {![tcl ready]} then {
        set disabled [expr {[info exists ::no(tclLoadForTest)]}]
        set channel [getTestChannelOrDefault]

        if {!$disabled} then {
          set command [list tcl load]

          if {[string length $findFlags] > 0} then {
            lappend command -findflags $findFlags
          }

          if {[string length $loadFlags] > 0} then {
            lappend command -loadflags $loadFlags
          }

          uplevel 1 $command
        }

        set loaded 1; # NOTE: May be faked.

        if {!$disabled} then {
          set moduleName [appendArgs \" [tcl module] \"]
          set interpName [appendArgs \" [tcl primary] \"]
        } else {
          set moduleName <none>
          set interpName <none>
        }

        tputs $channel [appendArgs \
            "---- native Tcl " [expr {$disabled ? "not " : ""}] \
            "loaded, module \"" $moduleName "\", interpreter \"" \
            $interpName \"\n]

        if {[info exists ::env(tclPostLoad)]} then {
          eval $::env(tclPostLoad); # HOOK
        }
      }
    }

    proc tclUnloadForTest { {force false} {varName ""} } {
      # <help>
      # This procedure unloads the native Tcl library, undoing the work of the
      # paired load helper.  It is normally used in test cleanup so that a test
      # that loaded native Tcl does not leave it loaded for later tests.
      #
      # How it works: if the environment variable tclPreUnload is set, it is
      # evaluated as a pre-unload hook.  Whether an unload actually happens is
      # decided by two inputs: a true force argument always requests an unload,
      # and a supplied varName whose "loaded" flag (in the caller's context) is
      # true also requests one.  When varName is supplied, the loaded flag is
      # unset afterward (note that it may have been a fake set by the load
      # helper).  When an unload is warranted, the procedure checks the "no"
      # array element [tclUnloadForTest]; if not disabled, it records the module
      # and primary interpreter names and evaluates [tcl unload] in the caller's
      # context, otherwise it uses angle-bracket "none" placeholders.  It then
      # logs whether native Tcl was (forcibly) unloaded, and finally evaluates
      # the tclPostUnload environment hook if set.
      #
      # Tricky details: the force path deliberately does not test whether native
      # Tcl is ready, because some tests rely on receiving an error from [tcl
      # unload] when it is not; forcing lets those error paths be exercised.
      #
      # Arguments:
      #   force   -- Optional boolean (default false); when true, an unload is
      #              attempted regardless of the loaded flag or readiness.
      #   varName -- Optional name of a caller variable holding the loaded flag
      #              from the load helper; a true value requests an unload and
      #              the flag is unset afterward.
      #
      # Results:
      #   An empty string; the unload is performed (or skipped) for its side
      #   effects, with status reported through the test log.
      # </help>

      if {[info exists ::env(tclPreUnload)]} then {
        eval $::env(tclPreUnload); # HOOK
      }

      set unload false

      if {$force} then {
        #
        # NOTE: This cannot check [tcl ready] as some tests actually
        #       rely upon errors from the [tcl unload] sub-command.
        #
        set unload true
      }

      if {[string length $varName] > 0} then {
        upvar 1 $varName loaded

        if {$loaded && !$unload} then {
          set unload true
        }

        unset -nocomplain loaded; # NOTE: May be faked.
      }

      if {$unload} then {
        set disabled [expr {[info exists ::no(tclUnloadForTest)]}]
        set channel [getTestChannelOrDefault]

        if {!$disabled} then {
          set moduleName [appendArgs \" [tcl module] \"]
          set interpName [appendArgs \" [tcl primary] \"]

          uplevel 1 [list tcl unload]
        } else {
          set moduleName <none>
          set interpName <none>
        }

        tputs $channel [appendArgs \
            "---- native Tcl " [expr {$disabled ? "not " : ""}] \
            [expr {$force ? "forcibly " : ""}] "unloaded, module \"" \
            $moduleName "\", interpreter \"" $interpName \"\n]

        if {[info exists ::env(tclPostUnload)]} then {
          eval $::env(tclPostUnload); # HOOK
        }
      }
    }

    proc generateUniqueId { {text ""} {length 16} } {
      # <help>
      # This procedure generates a short, reasonably unique identifier string,
      # suitable for non-cryptographic use by the test suite (for example, to
      # tag a native Tcl script and its output so they can be located together
      # in the test log).
      #
      # How it works: it hashes an input with SHA-512, lowercases the hex
      # digest, and returns the leading "length" characters.  When text is
      # supplied, that text is hashed, making the identifier a stable function
      # of the input (the same text yields the same id).  When text is empty, it
      # instead hashes a string assembled from several volatile sources -- a
      # "uniq" literal, the current context, thread id, process id, clock clicks,
      # and current time -- producing an effectively unique identifier each call.
      #
      # Tricky details: the result is only a prefix of a hash and is explicitly
      # not intended to be cryptographically strong or collision-proof; it is a
      # convenience for labeling, not a security primitive.
      #
      # Arguments:
      #   text   -- Optional input to hash.  When non-empty, the id is derived
      #             deterministically from it; when empty, a volatile id is
      #             generated instead.
      #   length -- Optional length of the returned identifier in characters
      #             (default 16).
      #
      # Results:
      #   A lowercase hexadecimal string of the requested length.
      # </help>

      #
      # HACK: This should generate a reasonably random unique identifier
      #       suitable for non-cryptographic use by the test suite.
      #
      set last [expr {$length - 1}]

      if {[string length $text] > 0} then {
        return [string range \
            [string tolower [hash normal sha512 $text]] 0 $last]
      } else {
        return [string range \
            [string tolower [hash normal sha512 [appendArgs uniq \
            [info context] [info tid] [pid] [clock clicks] [clock \
            now]]]] 0 $last]
      }
    }

    proc testExecTclScript { script {shell ""} {verbose 0} } {
      # <help>
      # This procedure runs a script through an external native Tcl shell (a
      # separate tclsh process) and returns its output.  It underlies the family
      # of "for Tcl shell" query helpers, which use it to ask a real Tcl
      # interpreter for facts such as its version, machine type, or normalized
      # file paths that cannot reliably be answered from within TclTk.
      #
      # How it works: because a native shell cannot evaluate a command-line
      # string directly, the script is written to a temporary file, and the
      # shell is then executed with that file as its argument (via the test
      # process-execution helper, expecting a Success exit).  The shell to use
      # is the one passed in, or, when none is given, the configured global
      # test_tclsh; if neither is available the procedure reports an error.  The
      # trimmed standard output of the shell is returned on success.  A try /
      # finally block guarantees the temporary file is deleted afterward (unless
      # suppressed via the "no" array element deleteTestExecTclFile).
      #
      # The verbose argument controls both logging and error handling, with
      # escalating levels: at greater than zero, failures (and cleanup failures)
      # are logged to the default test channel; at greater than one, a unique id
      # is generated and the script result is logged; at greater than two, the
      # script text itself is logged; at greater than three, the actual error
      # message (rather than the bare word "error") is returned on failure; and
      # at greater than four, failures are raised as real errors instead of
      # being returned.  Thus low verbosity yields a quiet best-effort call that
      # returns "error" on failure, while high verbosity yields a loud, strict
      # call that throws.
      #
      # Tricky details: failures come in two flavors -- a missing shell
      # configuration and a failed execution -- and both honor the same verbose
      # escalation rules.  The unique id used in the log lines ties the logged
      # script text and its result together for easier correlation.
      #
      # Arguments:
      #   script  -- The Tcl script to evaluate in the external shell.
      #   shell   -- Optional path to the Tcl shell to use; empty falls back to
      #              the configured global test_tclsh.
      #   verbose -- Optional verbosity level (default 0) controlling logging and
      #              whether failures are returned as a value or raised.
      #
      # Results:
      #   On success, the trimmed standard output of the shell.  On failure, the
      #   word "error" (or the full error message when verbose is greater than
      #   three), unless verbose is greater than four, in which case an error is
      #   raised.
      # </help>

      try {
        #
        # NOTE: Figure out where to send diagnostic messages related to
        #       evaluating the native Tcl script.
        #
        set channel [getTestChannelOrDefault]

        #
        # NOTE: Get a temporary file name for the script we are going to
        #       use to query the machine type for the native Tcl shell.
        #
        set fileName [file tempname]

        #
        # NOTE: Since the native Tcl shell cannot simply evaluate a string
        #       supplied via the command line, write the script to be
        #       evaluated to the temporary file.
        #
        writeFile $fileName $script

        #
        # NOTE: Use the specified shell, if it is valid; otherwise, use
        #       the configured Tcl shell.
        #
        if {[string length $shell] == 0} then {
          #
          # NOTE: Before attempting to use the configured Tcl shell, make
          #       sure it has actually been set.
          #
          if {[info exists ::test_tclsh] && \
              [string length $::test_tclsh] > 0} then {
            #
            # NOTE: Use the currently configured Tcl shell, which may or
            #       may not actually exist.
            #
            set shell $::test_tclsh
          } else {
            #
            # NOTE: We cannot execute the native Tcl shell because one
            #       has not been specified, nor configured.
            #
            set error "error: \"::test_tclsh\" variable is missing"

            if {$verbose > 0} then {
              tputs $channel [appendArgs \
                  "---- native Tcl script failure: " $error \n]
            }

            if {$verbose > 4} then {
              error $error
            } else {
              return [expr {$verbose > 3 ? $error : "error"}]
            }
          }
        }

        #
        # NOTE: Generate a unique identifier to make it easier to locate
        #       this script and its results in the test log file.
        #
        if {$verbose > 1} then {
          set id [generateUniqueId $script]
        }

        #
        # NOTE: When in "ultra-verbose" mode, emit native Tcl script to
        #       the log file.
        #
        if {$verbose > 2} then {
          tputs $channel [appendArgs \
              "---- native Tcl script (" $id ") text: " [string trim \
              $script] \n]
        }

        #
        # NOTE: Evaluate the script using the native Tcl shell, trim the
        #       excess whitespace from the output, and return it to the
        #       caller.
        #
        if {[catch {string trim \
            [testExec $shell [list -success Success] \
            [appendArgs \" $fileName \"]]} result] == 0} then {
          #
          # NOTE: When in "super-verbose" mode, emit native Tcl script
          #       results to the log file.
          #
          if {$verbose > 1} then {
            tputs $channel [appendArgs \
                "---- native Tcl script (" $id ") result: " $result \n]
          }

          #
          # NOTE: Success, return the result to the caller.
          #
          return $result
        } else {
          #
          # NOTE: We could not execute the native Tcl shell (perhaps one
          #       is not available?).
          #
          set error [appendArgs "error: " $result]

          if {$verbose > 0} then {
            tputs $channel [appendArgs \
                "---- native Tcl script failure: " $error \n]
          }

          if {$verbose > 4} then {
            error $error
          } else {
            return [expr {$verbose > 3 ? $error : "error"}]
          }
        }
      } finally {
        #
        # NOTE: Should we delete the temporary file we created, if any?
        #
        if {![info exists ::no(deleteTestExecTclFile)]} then {
          #
          # NOTE: Did we create a temporary file to hold the Tcl script?
          #
          if {[info exists fileName] && \
              [string length $fileName] > 0 && \
              [file exists $fileName]} then {
            #
            # NOTE: Delete temporary file we used to evaluate the script
            #       using the native Tcl shell.
            #
            if {[catch {file delete $fileName} error]} then {
              if {$verbose > 0} then {
                tputs $channel [appendArgs \
                    "---- native Tcl cleanup failure: " $error \n]
              }

              if {$verbose > 4} then {
                error $error
              }
            }
          }
        }
      }
    }

    proc getTclShellRaw {} {
      # <help>
      # This procedure returns the configured "raw" mode flag for native Tcl
      # shell evaluation, used by the shell-evaluation helper to decide how to
      # interpret and report a script's result.  It exists so callers do not
      # have to check for and validate the underlying global directly.
      #
      # How it works: if the global test_tclsh_raw variable exists and holds a
      # valid boolean, its value is returned; otherwise an empty string is
      # returned as the default.
      #
      # Arguments:
      #   None.
      #
      # Results:
      #   The boolean value of test_tclsh_raw when it is set and valid, or the
      #   empty string otherwise.
      # </help>

      if {[info exists ::test_tclsh_raw] && \
          [string is boolean -strict $::test_tclsh_raw]} then {
        return $::test_tclsh_raw
      } else {
        return ""; # TODO: Good default?
      }
    }

    proc getTclShellVerbosity {} {
      # <help>
      # This procedure returns the configured verbosity level for native Tcl
      # shell evaluation, the value passed as the verbose argument to the
      # shell-execution helper.  It exists so callers do not have to check for
      # and validate the underlying global directly.
      #
      # How it works: if the global test_tclsh_verbose variable exists and holds
      # a valid integer, its value is returned; otherwise zero (the quietest
      # level) is returned as the default.
      #
      # Arguments:
      #   None.
      #
      # Results:
      #   The integer value of test_tclsh_verbose when it is set and valid, or
      #   zero otherwise.
      # </help>

      if {[info exists ::test_tclsh_verbose] && \
          [string is integer -strict $::test_tclsh_verbose]} then {
        return $::test_tclsh_verbose
      } else {
        return 0; # TODO: Good default?
      }
    }

    proc getTclVersionForTclShell { {shell ""} {verbose 0} } {
      # <help>
      # This procedure queries an external native Tcl shell for its Tcl version.
      # It is one of a family of small wrappers that ask a real tclsh process a
      # single question, since these facts about the native interpreter cannot
      # be obtained reliably from within TclTk.
      #
      # How it works: it runs a tiny script ([info tclversion]) through the
      # shell-execution helper, which writes the answer to standard output, and
      # returns that output.  The shell and verbose arguments are forwarded
      # unchanged to that helper.
      #
      # Arguments:
      #   shell   -- Optional path to the Tcl shell to use; empty falls back to
      #              the configured shell.
      #   verbose -- Optional verbosity level (default 0) forwarded to the
      #              shell-execution helper.
      #
      # Results:
      #   The native Tcl version string, or a failure indication per the
      #   shell-execution helper's verbosity rules.
      # </help>

      return [testExecTclScript {
        puts -nonewline stdout [info tclversion]
      } $shell $verbose]
    }

    proc getCommandsForTclShell { {shell ""} {verbose 0} } {
      # <help>
      # This procedure queries an external native Tcl shell for the list of
      # commands it defines.  It is one of a family of small wrappers that ask a
      # real tclsh process a single question that cannot be answered reliably
      # from within TclTk.
      #
      # How it works: it runs a tiny script ([info commands]) through the
      # shell-execution helper, which writes the answer to standard output, and
      # returns that output.  The shell and verbose arguments are forwarded
      # unchanged to that helper.
      #
      # Arguments:
      #   shell   -- Optional path to the Tcl shell to use; empty falls back to
      #              the configured shell.
      #   verbose -- Optional verbosity level (default 0) forwarded to the
      #              shell-execution helper.
      #
      # Results:
      #   The list of native Tcl command names, or a failure indication per the
      #   shell-execution helper's verbosity rules.
      # </help>

      return [testExecTclScript {
        puts -nonewline stdout [info commands]
      } $shell $verbose]
    }

    proc getMachineForTclShell { {shell ""} {verbose 0} } {
      # <help>
      # This procedure queries an external native Tcl shell for its machine
      # (processor architecture) type, as reported by the tcl_platform array.
      # It is one of a family of small wrappers that ask a real tclsh process a
      # single question; the machine type is used, for example, to select the
      # matching Garuda shared library.
      #
      # How it works: it runs a tiny script (reading tcl_platform(machine))
      # through the shell-execution helper, which writes the answer to standard
      # output, and returns that output.  The shell and verbose arguments are
      # forwarded unchanged to that helper.
      #
      # Arguments:
      #   shell   -- Optional path to the Tcl shell to use; empty falls back to
      #              the configured shell.
      #   verbose -- Optional verbosity level (default 0) forwarded to the
      #              shell-execution helper.
      #
      # Results:
      #   The native Tcl machine type string, or a failure indication per the
      #   shell-execution helper's verbosity rules.
      # </help>

      return [testExecTclScript {
        puts -nonewline stdout $tcl_platform(machine)
      } $shell $verbose]
    }

    proc getTclExecutableForTclShell { {shell ""} {verbose 0} } {
      # <help>
      # This procedure queries an external native Tcl shell for the full path of
      # its own executable.  It is one of a family of small wrappers that ask a
      # real tclsh process a single question that cannot be answered reliably
      # from within TclTk.
      #
      # How it works: it runs a tiny script ([info nameofexecutable]) through the
      # shell-execution helper, which writes the answer to standard output, and
      # returns that output.  The shell and verbose arguments are forwarded
      # unchanged to that helper.
      #
      # Arguments:
      #   shell   -- Optional path to the Tcl shell to use; empty falls back to
      #              the configured shell.
      #   verbose -- Optional verbosity level (default 0) forwarded to the
      #              shell-execution helper.
      #
      # Results:
      #   The path to the native Tcl shell executable, or a failure indication
      #   per the shell-execution helper's verbosity rules.
      # </help>

      return [testExecTclScript {
        puts -nonewline stdout [info nameofexecutable]; # EXEMPT
      } $shell $verbose]
    }

    proc getTkVersionForTclShell { {shell ""} {verbose 0} } {
      # <help>
      # This procedure queries an external native Tcl shell for the version of
      # Tk available to it.  It is one of a family of small wrappers that ask a
      # real tclsh process a single question that cannot be answered reliably
      # from within TclTk.
      #
      # How it works: it runs a tiny script that requires the Tk package and
      # prints the resulting version, then exits, through the shell-execution
      # helper, and returns the captured output.  The explicit [exit] is needed
      # because loading Tk may otherwise enter an event loop or open a window
      # that would prevent the shell process from terminating on its own.  The
      # shell and verbose arguments are forwarded unchanged to the helper.
      #
      # Arguments:
      #   shell   -- Optional path to the Tcl shell to use; empty falls back to
      #              the configured shell.
      #   verbose -- Optional verbosity level (default 0) forwarded to the
      #              shell-execution helper.
      #
      # Results:
      #   The Tk version string available to the native Tcl shell, or a failure
      #   indication per the shell-execution helper's verbosity rules (for
      #   example, when Tk is not present).
      # </help>

      return [testExecTclScript {
        puts -nonewline stdout [package require Tk]; exit
      } $shell $verbose]
    }

    proc fileNormalizeWithTclShell { path {shell ""} {verbose 0} } {
      # <help>
      # This procedure asks an external native Tcl shell to normalize a file
      # path with its own [file normalize] and returns the result.  It exists so
      # tests can compare TclTk's path normalization against that of a real Tcl
      # interpreter, which may differ in platform-specific ways.
      #
      # How it works: it substitutes the supplied path into a template script
      # (replacing the %path% placeholder via [string map]) so the script reads
      # the path as a brace-quoted literal, then runs that script through the
      # shell-execution helper and returns the normalized path it prints.  The
      # shell and verbose arguments are forwarded unchanged to the helper.
      #
      # Tricky details: substitution is textual, so a path containing characters
      # that are special inside a brace-quoted word could in principle disturb
      # the generated script; ordinary file paths are fine.
      #
      # Arguments:
      #   path    -- The file path to normalize in the native Tcl shell.
      #   shell   -- Optional path to the Tcl shell to use; empty falls back to
      #              the configured shell.
      #   verbose -- Optional verbosity level (default 0) forwarded to the
      #              shell-execution helper.
      #
      # Results:
      #   The native Tcl normalized form of the path, or a failure indication
      #   per the shell-execution helper's verbosity rules.
      # </help>

      return [testExecTclScript [string map [list %path% $path] {
        puts -nonewline stdout [file normalize {%path%}]
      }] $shell $verbose]
    }

    proc evalWithTclShell { script {raw ""} {shell ""} {verbose 0} } {
      # <help>
      # This procedure evaluates an arbitrary caller-supplied script in an
      # external native Tcl shell and returns its result, with a choice of three
      # result-reporting conventions selected by the raw argument.  It is the
      # general-purpose counterpart to the single-purpose query wrappers in this
      # family, letting tests run any snippet in a real tclsh and inspect the
      # outcome.
      #
      # How it works: it substitutes the caller's script and the raw flag into a
      # template (replacing the %script% and %raw% placeholders via [string
      # map]) and runs the resulting program through the shell-execution helper.
      # The template behaves in three ways: when raw is the empty string, it
      # catches the script and prints just the result on success, or a two
      # element list of the catch code and result on error; when raw is a true
      # boolean, it always catches and prints the code-and-result list (so the
      # caller can examine both regardless of success); when raw is a false
      # boolean, it evaluates the script with [eval] and prints the result
      # directly, letting any error propagate as a shell failure.  The shell and
      # verbose arguments are forwarded to the helper.
      #
      # Tricky details: substitution is textual, so the script becomes part of
      # the generated program; placeholders are chosen to be unlikely to collide
      # with ordinary script text.  The raw argument doubles as both a mode
      # selector and, when boolean, the branch condition inside the generated
      # script.
      #
      # Arguments:
      #   script  -- The Tcl script to evaluate in the external shell.
      #   raw     -- Optional mode selector: empty for "result, or code-and-result
      #              on error"; a true boolean for "always code-and-result"; a
      #              false boolean for "evaluate and print result directly".
      #   shell   -- Optional path to the Tcl shell to use; empty falls back to
      #              the configured shell.
      #   verbose -- Optional verbosity level (default 0) forwarded to the
      #              shell-execution helper.
      #
      # Results:
      #   The script's output as produced by the selected reporting convention,
      #   or a failure indication per the shell-execution helper's verbosity
      #   rules.
      # </help>

      return [testExecTclScript [string map \
          [list %script% $script %raw% $raw] {
        if {[string length {%raw%}] == 0} then {
          set code [catch {%script%} result]
          if {$code == 0} then {
            puts -nonewline stdout $result; # success
          } else {
            puts -nonewline stdout [list $code $result]; # error
          }
        } elseif {%raw%} then {
          set code [catch {%script%} result]
          puts -nonewline stdout [list $code $result]
        } else {
          puts -nonewline stdout [eval {%script%}]
        }
      }] $shell $verbose]
    }

    proc getSharedLibPrefix {} {
      # <help>
      # This procedure returns the platform-appropriate file name prefix for a
      # shared library.  It exists so that code building shared-library file
      # names (for example, the Garuda library locator) produces the right name
      # on each platform.
      #
      # How it works: on Windows it returns the empty string, since Windows
      # dynamic libraries have no name prefix; on other platforms it returns
      # "lib", matching the conventional Unix shared-object naming.
      #
      # Arguments:
      #   None.
      #
      # Results:
      #   The empty string on Windows, or "lib" on other platforms.
      # </help>

      return [expr {[isWindows] ? "" : "lib"}]
    }

    proc getGarudaDll { {machine ""} } {
      # <help>
      # This procedure computes the full path and file name of the Garuda shared
      # library that matches the native Tcl shell's platform.  Garuda is the
      # Tcl-loadable companion to TclTk; tests that exercise loading TclTk into a
      # native Tcl interpreter need to locate the correctly built variant, and
      # that is what this helper produces.
      #
      # How it works: it requires the global base_path (the root of the source
      # tree) to be set; without it, the empty string is returned, since the
      # library can currently only be located inside the source tree.  It then
      # gathers the effective test configuration (returning empty if there is
      # none), the shared-library prefix for the platform, the base library name
      # (GarudaCore on .NET Core, otherwise Garuda), and the effective test
      # suffix (which may be empty).  When no machine was supplied, it auto
      # detects one by querying the Tcl shell (unless that query is disabled via
      # the "no" array element [getMachineForTclShell]), so the chosen library
      # matches the shell's architecture.  Finally it assembles the path under
      # base_path/bin: on .NET Core for non-Windows it uses a target-framework
      # specific layout (currently assuming the netcoreapp3.0 moniker), and
      # otherwise a platform-and-configuration directory derived from the machine
      # type; the file name is the prefix plus base name plus the platform's
      # shared-library extension.
      #
      # Tricky details: the .NET Core non-Windows branch hard-codes an
      # assumption about the target framework moniker that was accurate as of
      # the date noted inline; the machine type drives the platform directory in
      # the general branch and must therefore be accurate.
      #
      # Arguments:
      #   machine -- Optional machine (architecture) type to select the library
      #              variant; when empty, it is auto-detected from the Tcl shell
      #              unless that detection has been disabled.
      #
      # Results:
      #   The full path to the matching Garuda shared library, or the empty
      #   string when the base path or test configuration is unavailable.
      # </help>

      #
      # NOTE: Get the Garuda DLL of the same platform (i.e. machine type)
      #       as the native Tcl shell.
      #
      if {[info exists ::base_path]} then {
        #
        # NOTE: Get the effective test configuration.
        #
        set configuration [getTestConfiguration]

        #
        # NOTE: If there is no effective test configuration available, we
        #       cannot continue.
        #
        if {[string length $configuration] == 0} then {
          return ""
        }

        #
        # NOTE: The shared library is built specifically for .NET Core or
        #       the .NET Framework, use the right one; also, use the "lib"
        #       prefix when not on Windows.
        #
        set prefix [getSharedLibPrefix]

        if {[isDotNetCore]} then {
          append prefix GarudaCore
        } else {
          append prefix Garuda
        }

        #
        # NOTE: Get the effective test suffix.  This is allowed to be an
        #       empty string.
        #
        set suffix [getTestSuffix]

        #
        # NOTE: If necessary, automatically detect the machine for the Tcl
        #       shell that we plan on using.
        #
        if {[string length $machine] == 0 && \
            ![info exists ::no(getMachineForTclShell)]} then {
          set machine [getMachineForTclShell "" [getTclShellVerbosity]]
        }

        #
        # NOTE: Build the full path and file name of the Garuda shared
        #       library, using the TclTk base path.  Currently, this will
        #       only work correctly if the test suite is being run from
        #       inside the source tree.
        #
        if {[isDotNetCore] && ![isWindows]} then {
          #
          # HACK: This assumes that the Garuda shared library is always
          #       being built for the "netcoreapp3.0" TFM, which is true
          #       as of this writing (2025-09-15).
          #
          return [file join $::base_path bin \
              [appendArgs $configuration $suffix] bin \
              [getDotNetCoreTargetFrameworkMoniker 3 true] \
              [appendArgs $prefix [info sharedlibextension]]]
        } else {
          return [file join $::base_path bin \
              [machineToPlatform $machine] \
              [appendArgs $configuration Dll $suffix] \
              [appendArgs $prefix [info sharedlibextension]]]
        }
      } else {
        #
        # NOTE: We are missing the base path, return nothing.
        #
        return ""
      }
    }

    proc cleanupExcel {} {
      # <help>
      # This procedure undoes the object-type declarations and namespace imports
      # that tests make when working with the Microsoft Excel COM interop
      # assembly.  It is used in test cleanup so that Excel-related type and
      # import state does not leak into subsequent tests.
      #
      # How it works: it undeclares any object types matching the
      # Microsoft.Office.Interop.Excel pattern and unimports that interop
      # namespace.
      #
      # Tricky details: as the inline note warns, the patterns are tied to a
      # particular Excel interop layout and may need updating for later Excel
      # versions.
      #
      # Arguments:
      #   None.
      #
      # Results:
      #   An empty string; the work is performed for its cleanup side effects.
      # </help>

      #
      # TODO: These may need to be changed in later Excel versions.
      #
      object undeclare -declarepattern Microsoft.Office.Interop.Excel*
      object unimport -importpattern Microsoft.Office.Interop.Excel
    }

    proc cleanupVisualBasic {} {
      # <help>
      # This procedure undoes the namespace imports that tests make when working
      # with the Microsoft.VisualBasic framework assembly.  It is used in test
      # cleanup so that Visual Basic import state does not leak into subsequent
      # tests.
      #
      # How it works: it unimports any namespace matching the
      # Microsoft.VisualBasic pattern.
      #
      # Tricky details: as the inline note warns, the pattern is tied to a
      # particular framework layout and may need updating for later framework
      # versions.
      #
      # Arguments:
      #   None.
      #
      # Results:
      #   An empty string; the work is performed for its cleanup side effects.
      # </help>

      #
      # TODO: These may need to be changed in later framework versions.
      #
      object unimport -importpattern Microsoft.VisualBasic*
    }

    proc cleanupXml {} {
      # <help>
      # This procedure undoes the namespace imports that tests make when working
      # with the System.Xml framework assembly.  It is used in test cleanup so
      # that XML import state does not leak into subsequent tests.
      #
      # How it works: it unimports any namespace matching the System.Xml pattern.
      #
      # Tricky details: as the inline note warns, the pattern is tied to a
      # particular framework layout and may need updating for later framework
      # versions.
      #
      # Arguments:
      #   None.
      #
      # Results:
      #   An empty string; the work is performed for its cleanup side effects.
      # </help>

      #
      # TODO: These may need to be changed in later framework versions.
      #
      object unimport -importpattern System.Xml*
    }

    proc cleanupWinForms {} {
      # <help>
      # This procedure undoes the namespace imports that tests make when working
      # with the System.Windows.Forms framework assembly and its related
      # namespaces.  It is used in test cleanup so that Windows Forms import
      # state does not leak into subsequent tests.
      #
      # How it works: it unimports a fixed set of namespaces -- System.Resources
      # and the family of System.Windows.Forms namespaces (including the
      # Automation, COM interop, Design, Layout, property grid, and visual
      # styles sub-namespaces).
      #
      # Tricky details: as the inline note warns, the set of namespaces is tied
      # to a particular framework layout and may need updating for later
      # framework versions.
      #
      # Arguments:
      #   None.
      #
      # Results:
      #   An empty string; the work is performed for its cleanup side effects.
      # </help>

      #
      # TODO: These may need to be changed in later framework versions.
      #
      object unimport -importpattern System.Resources
      object unimport -importpattern System.Windows.Forms
      object unimport -importpattern System.Windows.Forms.Automation

      object unimport -importpattern \
          System.Windows.Forms.ComponentModel.Com2Interop

      object unimport -importpattern System.Windows.Forms.Design
      object unimport -importpattern System.Windows.Forms.Layout
      object unimport -importpattern System.Windows.Forms.PropertyGridInternal
      object unimport -importpattern System.Windows.Forms.VisualStyles
    }

    proc getTestLibraryDirectory {} {
      # <help>
      # This procedure returns the directory containing the script library,
      # which tests use as a base for locating other library files.  It accounts
      # for the case where the script library is embedded inside the core
      # library file rather than laid out as a directory on disk.
      #
      # How it works: it queries the script library location via [info library],
      # wrapped in [catch] because that query does not work in a "safe"
      # interpreter.  If the query succeeds and the reported location is an
      # existing file (i.e. the library is embedded within the core library),
      # the file name is stripped off with [file dirname] so a directory is
      # returned.  The resulting directory is returned; if the query failed
      # (for example, in a safe interpreter), the empty string is returned.
      #
      # Arguments:
      #   None.
      #
      # Results:
      #   The script library directory path, or the empty string when the
      #   library location cannot be determined.
      # </help>

      #
      # NOTE: First, query the location of the script library.  This will
      #       not work right in a "safe" interpreter.
      #
      if {[catch {info library} result] == 0} then {
        #
        # NOTE: Next, If the script library is embedded within the core
        #       library itself (i.e. the script library location refers
        #       to a file, not a directory), strip off the file name.
        #
        if {[file exists $result] && [file isfile $result]} then {
          set result [file dirname $result]
        }

        #
        # NOTE: Finally, return the resulting script library directory.
        #
        return $result
      }

      return ""
    }

    #
    # NOTE: Check for the test path in the various well-known locations
    #       and set the associated variable.
    #
    if {![info exists ::no(checkForAndSetTestPath)]} then {
      checkForAndSetTestPath false [expr {![isTestSuiteRunning]}]
    }

    #
    # NOTE: Fake loading and configuring the "tcltest" package unless we
    #       are prevented.
    #
    if {![info exists ::no(configureTcltest)]} then {
      configureTcltest "" [list] [list] [list] [list] false
    }

    #
    # NOTE: If needed, enable seamless shell integration via [::unknown]
    #       handler.
    #
    if {[hasRuntimeOption shellUnknown]} then {
      tcltk_enableShellUnknown true
    }

    ###########################################################################
    ############################# END TclTk ONLY ##############################
    ###########################################################################
  } else {
    ###########################################################################
    ############################# BEGIN Tcl ONLY ##############################
    ###########################################################################

    proc getPassedPercentage {} {
      # <help>
      # This procedure computes the overall "pass percentage" for the current
      # test run.  This is the Tcl-compatible variant, used when the harness is
      # running under native Tcl; it reads its tallies from the standard tcltest
      # numTests array rather than from the native TclTk tcltk_tests array used
      # by the TclTk variant.  It is used when summarizing a run and when
      # deciding whether the run met a configured pass threshold.
      #
      # How it works: when the Total count is greater than zero, it returns
      # 100 times the sum of the Passed and Skipped counts divided by the Total
      # count, computed in floating point; skipped tests are counted as part of
      # the passing total.  When no tests have been run (a Total of zero), it
      # returns zero rather than dividing by zero.
      #
      # Arguments:
      #   None.
      #
      # Results:
      #   A floating-point percentage in the range zero to one hundred, or the
      #   integer zero when no tests were run.
      # </help>

      if {$::tcltest::numTests(Total) > 0} then {
        return [expr \
            {100.0 * (($::tcltest::numTests(Passed) + \
            $::tcltest::numTests(Skipped)) / \
            double($::tcltest::numTests(Total)))}]
      }

      return 0; # no tests were run, etc.
    }

    proc getSkippedPercentage {} {
      # <help>
      # This procedure computes the percentage of tests that were skipped in the
      # current test run.  This is the Tcl-compatible variant, used when the
      # harness is running under native Tcl; it reads its tallies from the
      # standard tcltest numTests array rather than from the native TclTk
      # tcltk_tests array used by the TclTk variant.
      #
      # How it works: when the Total count is greater than zero, it returns
      # 100 times the Skipped count divided by the Total count, computed in
      # floating point.  When no tests have been run (a Total of zero), it
      # returns zero rather than dividing by zero.
      #
      # Arguments:
      #   None.
      #
      # Results:
      #   A floating-point percentage in the range zero to one hundred, or the
      #   integer zero when no tests were run.
      # </help>

      if {$::tcltest::numTests(Total) > 0} then {
        return [expr \
            {100.0 * ($::tcltest::numTests(Skipped) / \
            double($::tcltest::numTests(Total)))}]
      }

      return 0; # no tests were run, etc.
    }

    proc testCheckOverallResult {
            channel percent haveStartSentry {varName ""} {quiet false} } {
      # <help>
      # This procedure renders the final verdict for an entire test run,
      # printing the "OVERALL RESULT" summary lines and reporting whether the
      # run is considered an overall success or failure.  This is the
      # Tcl-compatible variant, used when the harness runs under native Tcl: it
      # reads the per-category counts from the standard tcltest numTests array
      # (which has no separate "disabled" category) and writes a numeric exit
      # code (zero for success, one for failure) rather than the symbolic codes
      # used by the TclTk variant.  Its boolean result and the exit code it
      # produces are what callers use to decide whether the suite passed.
      #
      # The decision is governed by the optional global test_threshold pass
      # percentage.  When that variable is absent or equal to its default of
      # one hundred, the run succeeds only if every test is accounted for as
      # passed or skipped (i.e. no failures and the counts add up to the Total).
      # When a lower threshold has been configured, the run succeeds as long as
      # the supplied pass percent meets or exceeds that threshold.  In either
      # mode the presence of the global test_suite_errors variable forces an
      # overall failure regardless of the counts, and a missing start sentry in
      # the log forces failure unless start-sentry failure checking has been
      # disabled via the "no" array element failLogStartSentry.
      #
      # As a side effect, when varName is supplied this procedure writes the
      # numeric exit code into that caller variable.  Unless quiet mode is
      # requested, it also prints (via [tputs]) the test suite name, any suite
      # error list, and the SUCCESS, NONE, FAILURE, or "MISSING test counts"
      # lines; a run that succeeded but ran zero tests is reported as NONE.
      # Each terminal case also invokes the corresponding tester hook
      # (overallSuccess, overallNone, or overallFailure).  A missing required
      # count element is itself treated as a failure (reported as "MISSING test
      # counts"); the numbered MISSING messages distinguish the default
      # threshold path from the custom-threshold path.
      #
      # Arguments:
      #   channel         -- The output channel for the summary messages.
      #   percent         -- The overall pass percentage for the run, used only
      #                      when a non-default threshold is in effect.
      #   haveStartSentry -- Non-zero if the expected start sentry was found in
      #                      the test log; when false (and start-sentry failure
      #                      checking is enabled) the run is failed.
      #   varName         -- Optional name of a caller variable to receive the
      #                      numeric exit code (zero for success, one for
      #                      failure).  When empty, no exit code is written.
      #   quiet           -- Optional boolean; when true, suppresses all of the
      #                      summary output (the verdict is still returned).
      #
      # Results:
      #   True if the run is considered an overall success, false otherwise.
      # </help>

      #
      # NOTE: Does the caller want to change the exit code to an appropriate
      #       value based on the overall test results?
      #
      if {[string length $varName] > 0} then {upvar 1 $varName exitCode}

      #
      # NOTE: Has the test pass threshold been set?  If so, is it set to the
      #       default value?
      #
      # HACK: If the test suite error message exists, the entire run will be
      #       considered a "failure", without regard for the pass percentage
      #       or the configured test pass threshold.
      #
      if {![info exists ::test_threshold] || $::test_threshold == 100} then {
        #
        # HACK: Check for the required elements of the global Tcl tests
        #       array.
        #
        if {[info exists ::tcltest::numTests(Passed)] && \
            [info exists ::tcltest::numTests(Skipped)] && \
            [info exists ::tcltest::numTests(Total)]} then {
          #
          # NOTE: The test pass threshold is set to the default value (100%).
          #       Check to make sure that all tests passed and then set the
          #       exit code to success; otherwise, we set it to failure.
          #
          set passedOrSkipped [expr {
              $::tcltest::numTests(Passed) + $::tcltest::numTests(Skipped)
          }]

          if {![info exists ::test_suite_errors] && \
              ([info exists ::no(failLogStartSentry)] || \
                  $haveStartSentry) && \
              $passedOrSkipped == $::tcltest::numTests(Total)} then {
            set exitCode 0; # Success.

            if {!$quiet} then {
              tputs $channel [appendArgs \
                  "OVERALL RESULT: " [getTestSuiteFullName] \n]

              if {$::tcltest::numTests(Total) > 0} then {
                tputs $channel "OVERALL RESULT: SUCCESS\n"
                maybeInvokeForTester ::overallSuccess; # HOOK
              } else {
                tputs $channel "OVERALL RESULT: NONE\n"
                maybeInvokeForTester ::overallNone; # HOOK
              }
            }

            return true
          } else {
            set exitCode 1; # Failure.

            if {!$quiet} then {
              tputs $channel [appendArgs \
                  "OVERALL RESULT: " [getTestSuiteFullName] \n]

              if {[info exists ::test_suite_errors]} then {
                tputs $channel [appendArgs "OVERALL ERRORS: " \
                    [expr {[llength $::test_suite_errors] > 0 ? \
                    $::test_suite_errors : "<empty>"}] \n]
              }

              tputs $channel "OVERALL RESULT: FAILURE\n"
              maybeInvokeForTester ::overallFailure; # HOOK
            }

            return false
          }
        } else {
          set exitCode 1; # Failure.

          if {!$quiet} then {
            tputs $channel [appendArgs \
                "OVERALL RESULT: " [getTestSuiteFullName] \n]

            if {[info exists ::test_suite_errors]} then {
              tputs $channel [appendArgs "OVERALL ERRORS: " \
                  [expr {[llength $::test_suite_errors] > 0 ? \
                  $::test_suite_errors : "<empty>"}] \n]
            }

            tputs $channel "OVERALL RESULT: MISSING test counts (1)\n"
            tputs $channel "OVERALL RESULT: FAILURE\n"
            maybeInvokeForTester ::overallFailure; # HOOK
          }

          return false
        }
      } else {
        #
        # NOTE: They specified a non-default test pass threshold.  Check to
        #       make sure that we meet or exceed the requirement and then
        #       set the exit code to success; otherwise, set it to failure.
        #
        if {![info exists ::test_suite_errors] && \
            ([info exists ::no(failLogStartSentry)] || \
                $haveStartSentry) && \
            $percent >= $::test_threshold} then {
          #
          # HACK: Check for the required elements of the global Tcl tests
          #       array.
          #
          if {[info exists ::tcltest::numTests(Total)]} then {
            set exitCode 0; # Success.

            if {!$quiet} then {
              tputs $channel [appendArgs \
                  "OVERALL RESULT: " [getTestSuiteFullName] \n]

              if {$::tcltest::numTests(Total) > 0} then {
                tputs $channel [appendArgs \
                    "OVERALL RESULT: SUCCESS (" \
                    $percent "% >= " $::test_threshold %)\n]

                maybeInvokeForTester ::overallSuccess; # HOOK
              } else {
                tputs $channel [appendArgs \
                    "OVERALL RESULT: NONE (" \
                    $percent "% >= " $::test_threshold %)\n]

                maybeInvokeForTester ::overallNone; # HOOK
              }
            }

            return true
          } else {
            set exitCode 1; # Failure.

            if {!$quiet} then {
              tputs $channel [appendArgs \
                  "OVERALL RESULT: " [getTestSuiteFullName] \n]

              if {[info exists ::test_suite_errors]} then {
                tputs $channel [appendArgs "OVERALL ERRORS: " \
                    [expr {[llength $::test_suite_errors] > 0 ? \
                    $::test_suite_errors : "<empty>"}] \n]
              }

              tputs $channel "OVERALL RESULT: MISSING test counts (2)\n"
              tputs $channel "OVERALL RESULT: FAILURE\n"
              maybeInvokeForTester ::overallFailure; # HOOK
            }

            return false
          }
        } else {
          set exitCode 1; # Failure.

          if {!$quiet} then {
            tputs $channel [appendArgs \
                "OVERALL RESULT: " [getTestSuiteFullName] \n]

            if {[info exists ::test_suite_errors]} then {
              tputs $channel [appendArgs "OVERALL ERRORS: " \
                  [expr {[llength $::test_suite_errors] > 0 ? \
                  $::test_suite_errors : "<empty>"}] \n]
            }

            tputs $channel [appendArgs \
                "OVERALL RESULT: FAILURE (" \
                $percent "% < " $::test_threshold %)\n]

            maybeInvokeForTester ::overallFailure; # HOOK
          }

          return false
        }
      }
    }

    proc reportTestResultCounts { channel {varName ""} } {
      # <help>
      # This procedure prints the per-category breakdown of a finished test run
      # -- the PASSED, FAILED, SKIPPED, TOTAL, and pass / skip percentage lines
      # -- and, as a side effect, hands the computed overall pass percentage
      # back to the caller.  This is the Tcl-compatible variant, reading its
      # counts from the standard tcltest numTests array (and failed file names
      # from tcltest failFiles), as opposed to the native TclTk variant that
      # reads the tcltk_tests array and tracks additional categories.
      #
      # How it works: each category line is emitted via [tputs] only when its
      # count is greater than zero, so a clean run yields a compact summary; a
      # non-zero failed count is followed by the list of failed file names when
      # available.  Leaked tracked resources, if any have been recorded by the
      # debugger, are reported ahead of the category counts.  When at least one
      # test ran, it computes and prints the skip percentage and pass
      # percentage; when no tests ran, the percentage is simply set to zero.
      #
      # Tricky details: the leaked-names list is stored as alternating name and
      # value entries, so the leak count is half its length.  Unlike the TclTk
      # variant, this one has no disabled, known-bug, or color-coded severity
      # categories, since tcltest does not track them.  The pass percentage
      # produced here is exactly the value the overall-result check then
      # compares against any configured threshold.
      #
      # Arguments:
      #   channel -- The output channel for the summary messages.
      #   varName -- Optional name of a caller variable to receive the computed
      #              overall pass percentage (or zero when no tests ran).  When
      #              empty, no value is written back.
      #
      # Results:
      #   An empty string.  The meaningful output is the printed summary and the
      #   percentage written back through varName.
      # </help>

      #
      # NOTE: Does the caller want to change the percent to an appropriate
      #       value based on the overall test results?
      #
      if {[string length $varName] > 0} then {
        upvar 1 $varName percent
      }

      #
      # NOTE: If any tests leaked (tracked) resources, always show that in
      #       the summary as well.
      #
      if {[info exists ::tcltk_debugger(leakedNames)]} then {
        set leakedNames $::tcltk_debugger(leakedNames)
        set leaked [expr {[llength $leakedNames] / 2}]

        tputs $channel [appendArgs "LEAKED: " $leaked \n]

        if {$leaked > 0} then {
          tputs $channel [appendArgs \
              "LEAKED: " [formatLeakedNames $leakedNames] \n]
        }
      }

      if {$::tcltest::numTests(Passed) > 0} then {
        tputs $channel [appendArgs \
            "PASSED: " $::tcltest::numTests(Passed) \n]
      }

      if {$::tcltest::numTests(Failed) > 0} then {
        tputs $channel [appendArgs \
            "FAILED: " $::tcltest::numTests(Failed) \n]

        if {[llength $::tcltest::failFiles] > 0} then {
          tputs $channel [appendArgs \
              "FAILED: " $::tcltest::failFiles \n]
        }
      }

      if {$::tcltest::numTests(Skipped) > 0} then {
        tputs $channel [appendArgs \
            "SKIPPED: " $::tcltest::numTests(Skipped) \n]
      }

      if {$::tcltest::numTests(Total) > 0} then {
        tputs $channel [appendArgs \
            "TOTAL: " $::tcltest::numTests(Total) \n]

        if {$::tcltest::numTests(Skipped) > 0} then {
          set percent [getSkippedPercentage]

          tputs $channel [appendArgs \
              "SKIP PERCENTAGE: " [formatDecimal $percent] %\n]
        }

        set percent [getPassedPercentage]

        tputs $channel [appendArgs \
            "PASS PERCENTAGE: " [formatDecimal $percent] %\n]
      } else {
        #
        # NOTE: No tests.
        #
        set percent 0
      }

      return ""
    }

    #
    # NOTE: Check for the test path in the various well-known locations
    #       and set the associated variable.
    #
    if {![info exists ::no(checkForAndSetTestPath)]} then {
      checkForAndSetTestPath false [expr {![isTestSuiteRunning]}]
    }

    #
    # NOTE: Load and configure the "tcltest" package unless we are prevented.
    #
    if {![info exists ::no(configureTcltest)]} then {
      configureTcltest "" [list] [list] [list] [list test testConstraint] false
    }

    #
    # NOTE: We need several of our test related commands in the global
    #       namespace as well.
    #
    exportAndImportPackageCommands [namespace current] [list \
        visibleCharsOnly s_proc f_proc \
        promptForAndGetTextInput addTestScripts evaluateTestScripts \
        combineTestScriptResults newPackageId getParameterFromAny \
        getIndexForDirectory maybeAddToAutoPath maybeScanAutoPath \
        haveModernNetFx getDotNetCoreRuntimeVersions \
        detectDotNetCoreRuntimeVersion getDotNetCoreTargetFrameworkMoniker \
        getDotNetCoreRuntimeConfiguration haveInfinitySymbol private \
        annotateProcedure createPairs flattenPairs tclLogForTester \
        maybeInvokeForTester haveCaches resetCaches reportCaches \
        maybeMakeHighPriority removeTemporarySubDirectories \
        enableInteractiveCommands getProcedureArguments cloneProcedure \
        getTclMinimumVersion getTclMaximumVersion tryToLoadZeus \
        loadTetrisViaTclTk breakOnError getEnvironmentViaComSpec \
        getNameForDebugHook announceForDebugHook \
        forceInteractiveLoopForDebugHook debugBreakHook skipTestHook \
        noFailTestHook whatIfTestHook errorTestHook failTestHook \
        maybeGetArgv addToArgv removeFromArgv addConstraintToArgv \
        removeConstraintFromArgv enableSystemAliasFlags setupSystemAliases \
        reopenHost breakpoint debugBreakWithNewConsole setupTestPackageVars \
        getTestRunTag setupTestRunTag makeProcedureCommand \
        saveAndResetPrecision restorePrecision enableFlags \
        hasInterpreterFlags hasAllowBigIntegers \
        enableDataFlags enableHostFlags enableInterpreterFlags \
        enableInterpreterStateFlags enablePluginFlags \
        enableSharedProcedureFlags enableContextProcedureFlags \
        enableSharedPackageFlags enableContextPackageFlags \
        enableSharedPackageIndexFlags enableContextPackageIndexFlags \
        enableSharedEngineFlags enableContextEngineFlags \
        enableDefaultInterpreterFlags enableExpressionFlags \
        enableInterpreterTestFlags enableInteractiveLoopFlags \
        enableReadyFlags enableEventWaitFlags enableQueueEventFlags \
        enableWaitEventFlags enableNewGlobalVariableFlags \
        enableNewLocalVariableFlags enableTclExitUnloadFlags whereAmI \
        dumpWhereAmI enableTracing disableTracing hideMyself \
        getEngineFlagsForTest getProcessGroup killProcessGroup \
        maybeKillProcessGroup enableFailSafeExitAfter evalPackageIndexFile \
        cleanupAfterEvents findParentDirectory enableRuntimeOptionsForTcl \
        setupEvaluateViaTemporaryFile evaluateViaTemporaryFile \
        cleanupEvaluateViaTemporaryFiles getKnownTclVariables \
        getKnownTclTkVariables getKnownTestVariables getKnownOtherVariables \
        cleanState dumpState needTestDoEvents testDoEvents trawputs \
        doesTestOutputRepeat dputs dlog toneputs tputs ttclLog \
        doesTestLogFileExist getTestLogStartSentry readTestLogStartSentry \
        extractTestRunIdFromLogStartSentry doesTestLogHaveStartSentry \
        didTestLogHaveStartSentry setTestLogStartSentry dtrace tlog \
        getSoftwareRegistryKey haveConstraint addConstraint \
        haveOrAddConstraint getConstraints getCachedConstraints \
        useCachedConstraints removeConstraint fixConstraints \
        isOfficialStableReleaseInProgress fixMemoryConstraints \
        fixTimingConstraints testDebugBreak testSortDictionary testArrayGet \
        testArrayGet2 testResultGet testValueGet getValueOrDefault \
        getFirstLineOfError calculateBogoCops calculateRelativePerformance \
        formatTimeStamp formatElapsedTime sourceIfValid makeUseOfTestDefaults \
        augmentTestArguments processTestArguments makeUseOfTestArguments \
        getTclShellFileName getTemporaryPath getTemporaryFileName \
        checkOsAndModeForPath isDirectoryReadable isFileReadable getFiles \
        getTestFiles getTestChildren getTestRunId getTestRunBucket \
        isValidGuid getNewTestRunId getDefaultTestLogSubPath \
        getDefaultTestLogPath getTestLogPath getTestLogId getDefaultTestLog \
        newTestLog getTestLog getLastTestLog getTestSuite \
        getTestSuiteFileName getTestSuiteFullName getTestSuiteVariantName \
        getTestMachine getTestPlatform getTestConfiguration getTestNamePrefix \
        getTestSuffix getTestUncountedLeaks getTestListedLeaks \
        getRuntimeAssemblyName getTestAssemblyName canTestExec testExec \
        testClrExec execTestShell isRandomOrder isBreakOnDemand isBreakOnLeak \
        isStopOnFailure isStopOnLeak isExitOnComplete returnInfoScript \
        runTestPrologue runTestEpilogue hookPuts unhookPuts getTestFile \
        getCurrentTestName getTestName runTest testShim tsource \
        getKnownTclTkVersions isStableTclTkRelease changeArrayElement \
        enableTestStatisticsLists shouldRecordTestStatistics \
        shouldReportTestStatistics maybeRecordTestStatistics \
        maybeReportTestStatistics recordTestStatistics \
        getNamesForTestStatistics reportTestStatistics formatList \
        formatListAsDict formatLeakedNames pathToRegexp \
        assemblyNameToRegexp maybeGetOption inverseLsearchGlob \
        removePathFromFileNames formatDecimal clearTestPercent \
        reportTestPercent reportArrayGet reportTestStatisticCounts \
        runAllTests isTestSuiteRunning getTestChannelOrDefault \
        tryVerifyTestPath checkForAndSetTestPath configureTcltest \
        machineToPlatform architectureForPlatform \
        isTestUncountedLeak calculateTestConstraintCounts \
        getRemoteMessageRaiseError getRemoteMessageLimit \
        getRemoteMessageRetries encodeRemoteMessage \
        getRemoteMessageDirectory getRemoteMessageFileName \
        isLogRemoteMessageOk logRemoteMessage logRemoteMessageFile \
        logRemoteMessageQueue logRemoteMessageWrapper getRemoteMessageHeader \
        getRemoteTestResults logRemoteTestResults logRemoteTestRunMessage \
        compileCanaryDyLib getPassedPercentage getSkippedPercentage \
        testCheckOverallResult reportTestResultCounts] false false

    ###########################################################################
    ############################## END Tcl ONLY ###############################
    ###########################################################################
  }

  #
  # NOTE: Provide the TclTk "test" package to the interpreter.
  #
  package provide TclTk.Test \
    [expr {[isTclTk] ? [info engine PatchLevel] : "1.0"}]
}
