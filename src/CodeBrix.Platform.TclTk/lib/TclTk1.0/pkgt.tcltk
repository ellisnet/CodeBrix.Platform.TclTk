#
# NOTE: Use our own namespace here because even though we do not directly
#       support namespaces ourselves, we do not want to pollute the global
#       namespace if this script actually ends up being evaluated in Tcl.
#
namespace eval ::TclTk {
  #
  # NOTE: This procedure sets up the default values for all configuration
  #       parameters used by this package.  If the force argument is non-zero,
  #       any existing values will be overwritten and set back to their
  #       default values.
  #
  proc setupPackageToolsetVars { force {cleanup false} } {
    # <help>
    # This procedure establishes the default values for all of the
    # configuration parameters used by the rest of this package, storing them
    # as namespace variables of the enclosing namespace.  These parameters are
    # almost entirely URIs and URN fragments that describe where the various
    # remote resources (the Package Client Toolset, native TclKit and Tcl/Tk
    # DLLs, the Security Toolset, license certificate requests, the remote
    # sandbox, example scripts, the remote package index, and the external IP
    # address service) may be obtained.  It exists so that every other
    # procedure here can simply call it and then read the variables it needs,
    # rather than hard-coding endpoints in many places; centralizing the
    # defaults also makes them easy to override or to clear.
    #
    # How it works: for each parameter it declares a namespace variable and
    # then, guided by the two arguments, either removes the variable, forcibly
    # resets it to its default, or leaves an already-set value alone.  When the
    # cleanup argument is true the variable is simply unset (via unset with the
    # no-complain behavior).  Otherwise, when force is true OR the variable does
    # not yet exist, it is assigned its default value; an existing value is
    # preserved when force is false.  This three-way pattern is repeated once
    # per parameter.
    #
    # Tricky details: several of the default values are deliberately stored as
    # literal, un-substituted strings containing dollar-sign references (for
    # example the URI templates that refer to a base URI and a URN).  Those
    # templates are expanded later, by the consuming procedures, using the
    # subst command once the URN for a particular request is known; this is why
    # they must be assigned as brace-quoted literals here and not expanded at
    # setup time.  The base URI default differs by engine: under TclTk it comes
    # from a helper that requires the update package, while under native Tcl a
    # fixed fallback URI is used.  Some parameters are lists of URN fragments
    # from which a consumer selects one at random to spread load across servers.
    #
    # Arguments:
    #   force   -- A boolean.  When true, every parameter (that is not being
    #              cleaned up) is reset to its default value, overwriting any
    #              existing value.  When false, only parameters that do not
    #              already exist are assigned their defaults.
    #   cleanup -- An optional boolean (default false).  When true, every
    #              parameter variable is unset instead of being assigned, which
    #              removes the package's configuration from the namespace; in
    #              this mode the force argument is ignored.
    #
    # Results:
    #   The empty string.  The procedure operates entirely through side effects
    #   on the namespace variables.
    # </help>

    #
    # NOTE: Using the [getAuxiliaryBaseUri] procedure requires the update
    #       package.
    #
    # NOTE: The base URI used to build the URIs for the Package Client
    #       Toolset downloads.
    #
    variable baseUri; # DEFAULT: [getAuxiliaryBaseUri] -OR- https://urn.to/r

    if {$cleanup} then {
      unset -nocomplain baseUri
    } elseif {$force || ![info exists baseUri]} then {
      if {[isTclTk]} then {
        set baseUri [getAuxiliaryBaseUri]
      } else {
        set baseUri https://urn.to/r
      }
    }

    #
    # NOTE: The URN, relative to the base URI, where the Package Client
    #       Toolset may be downloaded.
    #
    variable packageToolsetUrn; # DEFAULT: pkg_client_only

    if {$cleanup} then {
      unset -nocomplain packageToolsetUrn
    } elseif {$force || ![info exists packageToolsetUrn]} then {
      set packageToolsetUrn pkg_client_only
    }

    #
    # NOTE: The URI where the Package Client Toolset may be downloaded.
    #
    variable packageToolsetUri; # DEFAULT: ${baseUri}/${packageToolsetUrn}

    if {$cleanup} then {
      unset -nocomplain packageToolsetUri
    } elseif {$force || ![info exists packageToolsetUri]} then {
      set packageToolsetUri {${baseUri}/${packageToolsetUrn}}
    }

    #
    # NOTE: The URN, relative to the base URI, where the TclKit DLL for
    #       a particular platform may be downloaded.
    #
    variable tclKitDllUrn; # DEFAULT: tclkit_dll_${platform}

    if {$cleanup} then {
      unset -nocomplain tclKitDllUrn
    } elseif {$force || ![info exists tclKitDllUrn]} then {
      set tclKitDllUrn {tclkit_dll_${platform}}
    }

    #
    # NOTE: The URI where the TclKit DLL for a particular platform may
    #       be downloaded.
    #
    variable tclKitDllUri; # DEFAULT: ${baseUri}/${urn}

    if {$cleanup} then {
      unset -nocomplain tclKitDllUri
    } elseif {$force || ![info exists tclKitDllUri]} then {
      set tclKitDllUri {${baseUri}/${urn}}
    }

    # NOTE: The URN, relative to the base URI, where the Tcl/Tk DLLs
    #       for a particular platform may be downloaded.
    #
    variable tclTkDllUrn; # DEFAULT: tcltk_dll_${platform}

    if {$cleanup} then {
      unset -nocomplain tclTkDllUrn
    } elseif {$force || ![info exists tclTkDllUrn]} then {
      set tclTkDllUrn {tcltk_dll_${platform}}
    }

    #
    # NOTE: The URI where the Tcl/Tk DLLs for a particular platform
    #       may be downloaded.
    #
    variable tclTkDllUri; # DEFAULT: ${baseUri}/${urn}

    if {$cleanup} then {
      unset -nocomplain tclTkDllUri
    } elseif {$force || ![info exists tclTkDllUri]} then {
      set tclTkDllUri {${baseUri}/${urn}}
    }

    #
    # NOTE: The URN, relative to the base URI, where the Harpy and Badge
    #       plugins for a particular build may be downloaded.
    #
    variable securityToolsetUrn; # DEFAULT: security_toolset_${platform}

    if {$cleanup} then {
      unset -nocomplain securityToolsetUrn
    } elseif {$force || ![info exists securityToolsetUrn]} then {
      set securityToolsetUrn {security_toolset_${platform}}
    }

    #
    # NOTE: The URI where the Harpy and Badge plugins for a particular
    #       build may be downloaded.
    #
    variable securityToolsetUri; # DEFAULT: ${baseUri}/${urn}

    if {$cleanup} then {
      unset -nocomplain securityToolsetUri
    } elseif {$force || ![info exists securityToolsetUri]} then {
      set securityToolsetUri {${baseUri}/${urn}}
    }

    #
    # NOTE: The list of URNs, relative to the base URI, where license
    #       certificate requests should be sent.  One of these will be
    #       selected at random.
    #
    variable licenseUrns; # DEFAULT: get_license_01 ... get_license_NN

    if {$cleanup} then {
      unset -nocomplain licenseUrns
    } elseif {$force || ![info exists licenseUrns]} then {
      set licenseUrns [list \
          get_license_01 get_license_02 get_license_03 get_license_04 \
          get_license_05 get_license_06 get_license_07]
    }

    #
    # NOTE: The URI where license certificate requests should be sent.
    #
    variable licenseUri; # DEFAULT: ${baseUri}/${urn}

    if {$cleanup} then {
      unset -nocomplain licenseUri
    } elseif {$force || ![info exists licenseUri]} then {
      set licenseUri {${baseUri}/${urn}}
    }

    #
    # NOTE: The list of URNs, relative to the base URI, where test script
    #       evaluation requests should be submitted to the "safe" sandbox.
    #       One of these will be selected at random.
    #
    variable sandboxEvalUrns; # DEFAULT: eval_01 ... eval_NN

    if {$cleanup} then {
      unset -nocomplain sandboxEvalUrns
    } elseif {$force || ![info exists sandboxEvalUrns]} then {
      set sandboxEvalUrns [list \
          eval_01 eval_02 eval_03 eval_04 eval_05 eval_06 eval_07]
    }

    #
    # NOTE: The URI where script evaluation requests should be submitted
    #       to the "safe" sandbox.
    #
    variable sandboxEvalUri; # DEFAULT: ${baseUri}/${urn}

    if {$cleanup} then {
      unset -nocomplain sandboxEvalUri
    } elseif {$force || ![info exists sandboxEvalUri]} then {
      set sandboxEvalUri {${baseUri}/${urn}}
    }

    #
    # NOTE: The list of URNs, relative to the base URI, where the named
    #       example scripts may be obtained.  One of these will be selected
    #       at random.
    #
    variable scriptUrns; # DEFAULT: script_01 ... script_NN

    if {$cleanup} then {
      unset -nocomplain scriptUrns
    } elseif {$force || ![info exists scriptUrns]} then {
      set scriptUrns [list \
          script_01 script_02 script_03 script_04 script_05 script_06 \
          script_07]
    }

    #
    # NOTE: The URI where named example scripts may be obtained.
    #
    variable scriptUri; # DEFAULT: ${baseUri}/${urn}

    if {$cleanup} then {
      unset -nocomplain scriptUri
    } elseif {$force || ![info exists scriptUri]} then {
      set scriptUri {${baseUri}/${urn}}
    }

    #
    # NOTE: The list of URNs, relative to the base URI, where the remote
    #       package index may be obtained.  One of these will be selected
    #       at random.
    #
    variable packageIndexUrns; # DEFAULT: package_index_01 ... package_index_NN

    if {$cleanup} then {
      unset -nocomplain packageIndexUrns
    } elseif {$force || ![info exists packageIndexUrns]} then {
      set packageIndexUrns [list \
          package_index_01 package_index_02 package_index_03 package_index_04 \
          package_index_05 package_index_06 package_index_07]
    }

    #
    # NOTE: The URI where the remote package index may be obtained.
    #
    variable packageIndexUri; # DEFAULT: ${baseUri}/${urn}

    if {$cleanup} then {
      unset -nocomplain packageIndexUri
    } elseif {$force || ![info exists packageIndexUri]} then {
      set packageIndexUri {${baseUri}/${urn}}
    }

    #
    # NOTE: The URI where the current external IP address may be obtained.
    #
    variable ipUri; # DEFAULT: ${baseUri}/${urn}

    if {$cleanup} then {
      unset -nocomplain ipUri
    } elseif {$force || ![info exists ipUri]} then {
      set ipUri {${baseUri}/${urn}}
    }

    #
    # NOTE: The list of URNs, relative to the base URI, where the current
    #       external IP address may be obtained.  One of these will be
    #       selected at random.
    #
    variable ipUrns; # DEFAULT: ip_01 ... ip_NN

    if {$cleanup} then {
      unset -nocomplain ipUrns
    } elseif {$force || ![info exists ipUrns]} then {
      set ipUrns [list ip_01 ip_02 ip_03 ip_04 ip_05 ip_06 ip_07]
    }
  }

  #
  # NOTE: This procedure attempts to download and extract the Package Client
  #       Toolset.  The optional channel argument is the output channel where
  #       diagnostic information is sent.  The optional quiet argument should
  #       be non-zero to prevent diagnostic information from being emitted.
  #       This procedure may raise script errors.  The return value is the
  #       full path to the directory that should be added to the auto-path.
  #
  proc downloadAndExtractPackageClientToolset {
          {channel stdout} {quiet false} } {
    # <help>
    # This procedure downloads the Package Client Toolset archive from the
    # configured remote URI and extracts it into a per-package install
    # directory on the local file system.  It exists to bootstrap the package
    # repository client onto a machine that does not already have it, and it is
    # the natural companion of the [loadPackageClientToolset] procedure, which
    # loads what this procedure installs.
    #
    # How it works: it first ensures the configuration parameters are set up,
    # then imports the variables describing the toolset URI and URN.  It
    # requires the test and unzip support packages, computes a stable install
    # root via the package install path helper, expands the toolset URI
    # template with subst, and downloads the archive to a temporary file.
    # Under TclTk the built-in uri download command is used; under native Tcl
    # it falls back to an HTTP helper from the common tools package and writes
    # the bytes itself.  The temporary archive is then extracted, the archive
    # file is deleted, and a path pointing at the client files beneath the
    # extracted tree is returned.
    #
    # Tricky details: the returned path appends a fixed set of sub-directory
    # components (the repository directory, then client, then a version and a
    # platform-neutral component) that mirror the known layout inside the
    # archive; callers normally add this directory to the auto-path.  The
    # download may raise script errors (network failure, extraction failure,
    # and so on), which are intentionally not caught here.
    #
    # Arguments:
    #   channel -- An optional output channel (default stdout) used only by the
    #              native Tcl HTTP fallback to emit diagnostic information.
    #   quiet   -- An optional boolean (default false); when true it suppresses
    #              the diagnostic output produced by the native Tcl fallback.
    #
    # Results:
    #   The full path to the directory that should be added to the auto-path so
    #   that the package client toolset can be loaded.
    # </help>

    setupPackageToolsetVars false

    variable baseUri
    variable packageToolsetUri
    variable packageToolsetUrn

    package require TclTk.Test
    package require TclTk.Unzip

    set extractRootDirectory [getPackageInstallPath pkgd ea-pt-di]

    set uri [subst $packageToolsetUri]
    set fileName [getTemporaryFileName]

    if {[isTclTk]} then {
      uri download -timeouttype network -- $uri $fileName
    } else {
      package require TclTk.Tools.Common

      namespace import -force \
          ::TclTk::Tools::Common::getFileViaHttp \
          ::TclTk::Tools::Common::writeFile

      set data [getFileViaHttp $uri 20 $channel $quiet -binary true]

      writeFile $fileName $data
    }

    set extractDirectory [extractZipArchive \
        $fileName $extractRootDirectory true]

    file delete $fileName

    return [file join $extractDirectory pkgr_an_d client 1.0 neutral]
  }

  #
  # NOTE: This procedure builds a package name that should never exist, that
  #       should be used in order to force package indexes to be refreshed.
  #
  proc getBogusPackageName {} {
    # <help>
    # This procedure builds and returns a package name that is intended never
    # to correspond to a real package.  It exists to support forcing a re-scan
    # of the available package indexes: asking for a package that cannot
    # possibly exist causes the package subsystem to consult every package
    # index without actually loading anything.  It is used by the
    # [forceScanOfPackages] procedure.
    #
    # How it works: it concatenates a fixed prefix with the current time in
    # seconds (with any leading minus sign trimmed), yielding a name that
    # varies over time and is therefore extremely unlikely to collide with any
    # genuinely registered package.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   A string suitable for use as an almost-certainly nonexistent package
    #   name.
    # </help>

    return [appendArgs bogus_package_ [string trim [clock seconds] -]]
  }

  #
  # NOTE: This procedure attempts to forcibly trigger a re-scan of all the
  #       available package indexes.
  #
  proc forceScanOfPackages {} {
    # <help>
    # This procedure forces a re-scan of all available package index files so
    # that subsequently querying for package versions or names reflects every
    # index currently on the auto-path.  It exists because, by default, the
    # package subsystem may not have visited every index yet, which can make
    # queries about not-yet-loaded packages (for example via package versions)
    # come up empty; deliberately requesting a nonexistent package side-steps
    # that by provoking a full scan.
    #
    # How it works: it obtains an almost-certainly bogus package name from
    # [getBogusPackageName] and then attempts to resolve it.  Under TclTk it
    # directly invokes the internal package-unknown handler; under native Tcl
    # it issues an ordinary package require for the bogus name.  Either way the
    # request is expected to fail, so it is wrapped in catch to swallow the
    # resulting error.
    #
    # Tricky details: the TclTk path must run the handler in a context where
    # the special global directory variable maintained by the index-loading
    # subsystem is visible, and any package index file consulted during the
    # scan could itself raise an error; the catch protects against both the
    # expected lookup failure and any such incidental errors.
    #
    # Arguments:
    #   None.
    #
    # Results:
    #   The empty string.  The useful effect is the side effect of having
    #   scanned the package indexes.
    # </help>

    #
    # NOTE: Build an obviously (?) bogus package name that will be used
    #       in order to force the package indexes to be refreshed.
    #
    set packageName [getBogusPackageName]

    if {[isTclTk]} then {
      #
      # NOTE: Force TclTk to find *ALL* available package index files.
      #       This must be done in the global scope so that the special
      #       global variable 'dir' set by the package index loading
      #       subsystem can be accessed.  Use [catch] here just in case
      #       a package index file raises a script error.
      #
      catch {::tclPkgUnknown $packageName}
    } else {
      #
      # HACK: Force Tcl to find *ALL* available package index files.
      #       Without this, checking for the available versions of a
      #       package using [package versions] likely will not succeed
      #       unless the package is already loaded.  Use [catch] here
      #       just in case a package index file raises a script error.
      #
      catch {package require $packageName}
    }
  }

  #
  # NOTE: This procedure attempts to load (via [package require]) the package
  #       client toolset.  It is designed to be used in conjunction with the
  #       [downloadAndExtractPackageClientToolset] procedure, above.  Support
  #       is included for specifying an extra auto-path directory and API key
  #       to use.  By default, the [package unknown] handler is hooked to add
  #       the remote package repository lookup functionality.  TclTk supports
  #       extra script security via signed script certificates, which will be
  #       enabled by default, unless it is unavailable.
  #
  proc loadPackageClientToolset {
          {directory auto} {apiKeys ""} {hookUnknown true} {enableSecurity true}
          {isolateSecurity false} {strictSecurity false} {fetchKeyRing false}
          {debug false} } {
    # <help>
    # This procedure loads the package repository client (via package require)
    # and configures the surrounding environment so that remote package lookups
    # work.  It is the companion to [downloadAndExtractPackageClientToolset]: that
    # procedure installs the toolset, while this one makes it usable in the
    # current interpreter.  It handles locating the client directory, optionally
    # adding it to the auto-path, registering API keys, enabling TclTk's signed
    # script security, optionally fetching a keyring, and arranging for the
    # remote package-unknown handler to be active.
    #
    # How it works: if the directory argument is the literal auto, it first
    # forces a package index re-scan and checks whether the repository client
    # package is already known; if not, it searches the temporary install tree
    # for a matching directory and selects the first match, appending the known
    # client sub-directory components.  If a directory is then in hand it is
    # appended to the global auto-path, but only when not already present, to
    # avoid triggering redundant auto-path rescans.  When the debug argument is
    # set, several debug-related environment variables are set.  Any supplied
    # API keys are appended to the client's global API key list.  Under TclTk,
    # when security is requested it sources the security-enable script, and when
    # a keyring is requested it runs the keyring debug command; either of these
    # can optionally be performed with the security plugin temporarily forced
    # into isolated mode, with the prior plugin flags restored afterward in a
    # finally clause.  Finally it requires the repository client package.
    #
    # Tricky details: the security and keyring steps are wrapped in catch and a
    # failure is only re-raised when strict security is requested; otherwise
    # failures are tolerated so the client can still load where security is
    # unavailable.  When hooking the unknown handler under TclTk, an
    # interpreter flag that suppresses package-unknown handling must be
    # disabled first.  The security-enable source and the keyring command are
    # both evaluated in the caller's frame so they affect the caller's
    # interpreter state.  When directory discovery finds nothing the directory
    # is cleared, which simply skips the auto-path modification.
    #
    # Arguments:
    #   directory       -- The directory containing the client files, or the
    #                       literal auto (the default) to request automatic
    #                       discovery; the empty string skips auto-path changes.
    #   apiKeys         -- An optional list of API keys (default empty) to add
    #                       to the client's configured API key list.
    #   hookUnknown     -- An optional boolean (default true); when true the
    #                       remote package-unknown handler is enabled (under
    #                       TclTk this also disables a suppressing flag).
    #   enableSecurity  -- An optional boolean (default true); when true and
    #                       running under TclTk, signed script security is
    #                       enabled.
    #   isolateSecurity -- An optional boolean (default false); when true the
    #                       security and keyring operations run with the plugin
    #                       temporarily flagged as isolated.
    #   strictSecurity  -- An optional boolean (default false); when true a
    #                       failure of the security or keyring step is fatal
    #                       rather than tolerated.
    #   fetchKeyRing    -- An optional boolean (default false); when true and
    #                       running under TclTk, an official keyring is fetched.
    #   debug           -- An optional boolean (default false); when true,
    #                       diagnostic environment variables are set.
    #
    # Results:
    #   The result of requiring the repository client package (typically its
    #   version).  Script errors may be raised, most commonly when the client
    #   package cannot be found or loaded.
    # </help>

    #
    # NOTE: When running in TclTk, namespace support must be available and
    #       enabled.
    #
    if {[isTclTk] && ![namespace enable]} then {
      error "namespace support must be enabled"
    }

    #
    # NOTE: Does the caller want automatic discovery of the directory that
    #       contains the (downloaded?) package client toolset?  Currently,
    #       this only works on Windows and searches the temporary download
    #       location, which normally obtains its value from the environment
    #       variable TEMP.
    #
    if {$directory eq "auto"} then {
      #
      # NOTE: First, before doing anything else, see if the package client
      #       toolset is already installed somewhere it can be loaded from.
      #
      set needDirectory true

      #
      # NOTE: Force re-scan of all available package indexes, just-in-case
      #       that is required.
      #
      forceScanOfPackages

      #
      # NOTE: Check and see if the package repository client is a known
      #       package now.  If so, there is no need to search directories
      #       for it.
      #
      if {[llength [package versions TclTk.Package.Repository]] > 0} then {
        set needDirectory false
      }

      #
      # NOTE: Is searching for temporary download directories required at
      #       this point?
      #
      if {$needDirectory} then {
        set extractRootDirectory [getPackageInstallPath]

        foreach directory [findDirectoriesRecursive \
            [file join $extractRootDirectory pkgr_an_d]] {
          #
          # NOTE: Reset directory we just found to include the necessary
          #       sub-directory components for the actual client files
          #       and then stop, thereby selecting the first match.
          #
          set directory [file join $directory client 1.0 neutral]; break
        }
      }

      #
      # NOTE: If no directory was found, just clear the directory name,
      #       which will cause auto-path modification(s) to be skipped.
      #
      if {$directory eq "auto"} then {
        set directory ""
      }
    }

    #
    # NOTE: If there is a directory specified by the caller -OR- found
    #       via automatic directory discovery, add it to the auto-path
    #       now.
    #
    if {[string length $directory] > 0} then {
      #
      # NOTE: Only modify the auto-path if the directory is not already
      #       present.  This prevents needless variable trace execution
      #       that rescans the various auto-path directories.
      #
      if {![info exists ::auto_path] || \
          [lsearch -exact $::auto_path $directory] == -1} then {
        lappend ::auto_path $directory
      }
    }

    #
    # NOTE: If the caller wants to enable extra diagnostic information,
    #       set the appropriate environment variables now.
    #
    if {$debug} then {
      set ::env(DEBUG_PKGR) 1
      set ::env(DEBUG_PKGD) 1
      set ::env(DEBUG_PKGU) 1
    }

    #
    # NOTE: If the caller specified API keys, add them to the configured
    #       list of API keys for the package repository client now.  This
    #       uses a special global variable.
    #
    if {[llength $apiKeys] > 0} then {
      eval lappend ::pkgr_api_keys $apiKeys
    }

    #
    # NOTE: If the caller wants to enable the extra TclTk script security,
    #       attempt to do that now.  Only treat a failure here as fatal if
    #       the caller said so.
    #
    if {[isTclTk] && $enableSecurity} then {
      if {[catch {
        try {
          if {$isolateSecurity} then {
            package require TclTk.Test

            set savedPluginFlags [enablePluginFlags]
            enablePluginFlags Isolated true
          }

          uplevel 1 [list source enableSecurity]
        } finally {
          if {$isolateSecurity && \
              [info exists savedPluginFlags]} then {
            enablePluginFlags $savedPluginFlags
            unset -nocomplain savedPluginFlags
          }
        }
      } error] && $strictSecurity} then {
        error $error
      }
    }

    #
    # NOTE: If the caller wants to fetch an official keyring from remote
    #       URI (i.e. within Harpy), attempt to do that now.  Only treat
    #       a failure here as fatal if the caller said so.
    #
    if {[isTclTk] && $fetchKeyRing} then {
      if {[catch {
        try {
          if {$isolateSecurity} then {
            package require TclTk.Test

            set savedPluginFlags [enablePluginFlags]
            enablePluginFlags Isolated true
          }

          uplevel 1 [list debug keyring]
        } finally {
          if {$isolateSecurity && \
              [info exists savedPluginFlags]} then {
            enablePluginFlags $savedPluginFlags
            unset -nocomplain savedPluginFlags
          }
        }
      } error] && $strictSecurity} then {
        error $error
      }
    }

    #
    # NOTE: In TclTk, to actually enable make use of the [package unknown]
    #       handler, an interpreter flag must be disabled.  If necessary,
    #       do that now.
    #
    if {[isTclTk] && $hookUnknown} then {
      package require TclTk.Test

      enableInterpreterFlags NoPackageUnknown false
    }

    #
    # NOTE: Finally, attempt to actually load the package repository client.
    #       This may fail for a number of reasons.  The most likely failure
    #       case is when the directory containing the package is not found;
    #       however, there are other possible failure modes.
    #
    package require TclTk.Package.Repository
  }

  #
  # NOTE: This procedure attempts to download and extract a native TclKit DLL
  #       for the current platform.  The optional channel argument is the
  #       output channel where diagnostic information is sent.  The optional
  #       quiet argument should be non-zero to prevent diagnostic information
  #       from being emitted.  This procedure may raise script errors.  The
  #       return value is the full path to the native TclKit DLL file.
  #
  proc downloadAndExtractNativeTclKitDll {
          {channel stdout} {quiet false} } {
    # <help>
    # This procedure downloads a native TclKit DLL appropriate for the current
    # platform and extracts it into a per-platform install directory, returning
    # the path to the extracted shared library.  It exists to obtain the native
    # TclKit runtime needed when hosting Tcl from TclTk (or otherwise) without
    # requiring the user to locate and install it manually.
    #
    # How it works: it ensures the configuration parameters are set up, imports
    # the TclKit URI and URN variables, and requires the test and unzip support
    # packages.  It determines a platform token from the machine architecture,
    # builds a platform-specific install root, and expands the URN and URI
    # templates with subst.  The archive is downloaded to a temporary file
    # (using the built-in uri download under TclTk, or an HTTP helper plus a
    # file write under native Tcl), extracted, and the temporary archive
    # deleted.  Finally it globs for the shared library beneath the extracted
    # library directory and returns the first match.
    #
    # Tricky details: the shared library extension is obtained dynamically so
    # the same code works across operating systems.  The download may raise
    # script errors, which are not caught here.  If extraction produces no
    # matching library the returned value is the empty string.
    #
    # Arguments:
    #   channel -- An optional output channel (default stdout) used only by the
    #              native Tcl HTTP fallback for diagnostic information.
    #   quiet   -- An optional boolean (default false); when true it suppresses
    #              the native Tcl fallback's diagnostic output.
    #
    # Results:
    #   The full path to the extracted native TclKit DLL file.
    # </help>

    setupPackageToolsetVars false

    variable baseUri
    variable tclKitDllUri
    variable tclKitDllUrn

    package require TclTk.Test
    package require TclTk.Unzip

    set platform [machineToPlatform $::tcl_platform(machine) true]

    set extractRootDirectory [getPackageInstallPath \
        [appendArgs KitDll_ $platform] ea-td-di]

    set urn [subst $tclKitDllUrn]; set uri [subst $tclKitDllUri]
    set fileName [getTemporaryFileName]

    if {[isTclTk]} then {
      uri download -timeouttype network -- $uri $fileName
    } else {
      package require TclTk.Tools.Common

      namespace import -force \
          ::TclTk::Tools::Common::getFileViaHttp \
          ::TclTk::Tools::Common::writeFile

      set data [getFileViaHttp $uri 20 $channel $quiet -binary true]

      writeFile $fileName $data
    }

    set extractDirectory [extractZipArchive \
        $fileName $extractRootDirectory true]

    file delete $fileName

    return [lindex [glob -nocomplain \
        [file join $extractDirectory lib [appendArgs * \
        [info sharedlibextension]]]] 0]
  }

  #
  # NOTE: This procedure attempts to download and extract a set of native
  #       Tcl/Tk DLLs for the current platform.  The optional channel
  #       argument is the output channel where diagnostic information is
  #       sent.  The optional quiet argument should be non-zero to prevent
  #       diagnostic information from being emitted.  This procedure may
  #       raise script errors.  The return value is the full path to the
  #       native Tcl/Tk DLL files.
  #
  proc downloadAndExtractNativeTclTkDlls {
          {channel stdout} {quiet false} } {
    # <help>
    # This procedure downloads a set of native Tcl/Tk DLLs appropriate for the
    # current platform and extracts them into a per-platform install directory,
    # returning the path to one of the extracted shared libraries.  It exists to
    # obtain a complete native Tcl/Tk runtime without manual installation, and
    # it closely parallels [downloadAndExtractNativeTclKitDll], differing only in
    # which configured URI and URN it uses and where the libraries land inside
    # the archive.
    #
    # How it works: it ensures the configuration parameters are set up, imports
    # the Tcl/Tk URI and URN variables, requires the test and unzip support
    # packages, determines a platform token from the machine architecture, and
    # builds a platform-specific install root.  After expanding the URN and URI
    # templates with subst, it downloads the archive to a temporary file (the
    # built-in uri download under TclTk, or an HTTP helper plus a file write
    # under native Tcl), extracts it, and deletes the temporary archive.  It
    # then globs for a shared library beneath the extracted IronTcl binary
    # directory and returns the first match.
    #
    # Tricky details: the shared library extension is obtained dynamically for
    # cross-platform behavior.  Although a full set of DLLs is extracted, only a
    # single representative library path is returned; callers typically use its
    # containing directory.  The download may raise script errors, which are not
    # caught here, and the result is the empty string if no library matches.
    #
    # Arguments:
    #   channel -- An optional output channel (default stdout) used only by the
    #              native Tcl HTTP fallback for diagnostic information.
    #   quiet   -- An optional boolean (default false); when true it suppresses
    #              the native Tcl fallback's diagnostic output.
    #
    # Results:
    #   The full path to one of the extracted native Tcl/Tk DLL files.
    # </help>

    setupPackageToolsetVars false

    variable baseUri
    variable tclTkDllUri
    variable tclTkDllUrn

    package require TclTk.Test
    package require TclTk.Unzip

    set platform [machineToPlatform $::tcl_platform(machine) true]

    set extractRootDirectory [getPackageInstallPath \
        [appendArgs TclTkDll_ $platform] ea-ta-di]

    set urn [subst $tclTkDllUrn]; set uri [subst $tclTkDllUri]
    set fileName [getTemporaryFileName]

    if {[isTclTk]} then {
      uri download -timeouttype network -- $uri $fileName
    } else {
      package require TclTk.Tools.Common

      namespace import -force \
          ::TclTk::Tools::Common::getFileViaHttp \
          ::TclTk::Tools::Common::writeFile

      set data [getFileViaHttp $uri 20 $channel $quiet -binary true]

      writeFile $fileName $data
    }

    set extractDirectory [extractZipArchive \
        $fileName $extractRootDirectory true]

    file delete $fileName

    return [lindex [glob -nocomplain [file join \
        $extractDirectory IronTcl bin [appendArgs * \
        [info sharedlibextension]]]] 0]
  }

  #
  # NOTE: This procedure attempts to download and extract the Security Toolset,
  #       which includes the Harpy and Badge plugins.  The optional channel
  #       argument is the output channel where diagnostic information is sent.
  #       The optional quiet argument should be non-zero to prevent diagnostic
  #       information from being emitted.  This procedure may raise script
  #       errors.  The return value is the full path to a directory that should
  #       contain the "Harpy1.0" and "Badge1.0" plugin directories.
  #
  proc downloadAndExtractSecurityToolset {
          {channel stdout} {quiet false} } {
    # <help>
    # This procedure downloads and extracts the Security Toolset, which contains
    # the Harpy and Badge plugins used for TclTk's signed script security, and
    # returns the directory that should contain those plugins' version-specific
    # sub-directories.  It exists to install the security plugins for the build
    # flavor matching the running interpreter.
    #
    # How it works: it ensures the configuration parameters are set up, imports
    # the security toolset URI and URN variables, and requires the test and
    # unzip support packages.  It determines a platform token from the TclTk
    # platform text (falling back to a default flavor when that information is
    # unavailable), builds a per-platform install root, derives a build
    # sub-directory name by mapping the framework token to a shorter form, and
    # expands the URN and URI templates with subst.  The archive is downloaded
    # to a temporary file (the built-in uri download under TclTk, or an HTTP
    # helper plus a file write under native Tcl), extracted, and the temporary
    # archive deleted.  It then returns the library directory under the
    # build-specific path within the extracted tree.
    #
    # Tricky details: the platform token is lower-cased, and the build
    # sub-directory is computed by removing a fixed substring from that token
    # (for example turning a dot-net-framework token into a shorter net token);
    # this mapping is performed with string map.  The default platform used when
    # no TclTk platform text is present is a deliberate best-guess fallback.
    # The download may raise script errors, which are not caught here.
    #
    # Arguments:
    #   channel -- An optional output channel (default stdout) used only by the
    #              native Tcl HTTP fallback for diagnostic information.
    #   quiet   -- An optional boolean (default false); when true it suppresses
    #              the native Tcl fallback's diagnostic output.
    #
    # Results:
    #   The full path to a directory that should contain the version-specific
    #   Harpy and Badge plugin directories.
    # </help>

    setupPackageToolsetVars false

    variable baseUri
    variable securityToolsetUri
    variable securityToolsetUrn

    package require TclTk.Test
    package require TclTk.Unzip

    if {[info exists ::tcltk_platform(text)] && \
        [string length $::tcltk_platform(text)] > 0} then {
      set platform [string tolower $::tcltk_platform(text)]
    } else {
      set platform [string tolower netFx20]; # TODO: Good default?
    }

    set extractRootDirectory [getPackageInstallPath \
        [appendArgs eee_ $platform] ea-st-di]

    set dir [string map [list fx ""] $platform]; # netfx20 -> net20
    set urn [subst $securityToolsetUrn]; set uri [subst $securityToolsetUri]
    set fileName [getTemporaryFileName]

    if {[isTclTk]} then {
      uri download -timeouttype network -- $uri $fileName
    } else {
      package require TclTk.Tools.Common

      namespace import -force \
          ::TclTk::Tools::Common::getFileViaHttp \
          ::TclTk::Tools::Common::writeFile

      set data [getFileViaHttp $uri 20 $channel $quiet -binary true]

      writeFile $fileName $data
    }

    set extractDirectory [extractZipArchive \
        $fileName $extractRootDirectory true]

    file delete $fileName

    return [file join $extractDirectory build $dir lib]
  }

  #
  # NOTE: This procedure attempts to request a license certificate for TclTk,
  #       which includes the Harpy and Badge plugins.  The optional channel
  #       argument is the output channel where diagnostic information is sent.
  #       The optional quiet argument should be non-zero to prevent diagnostic
  #       information from being emitted.  This procedure may raise script
  #       errors.  The return value is the fully qualified file name for the
  #       resulting license certificate.
  #
  # WARNING: This procedure will send the short name and display name of the
  #          currently logged on user to the TclTk license server as they are
  #          required for a new license certificate to be issued.  Abuse of
  #          this service may result in a permanent ban from the service and
  #          revocation of any previously issued license certificates.
  #
  proc requestLicenseCertificate {
          {channel stdout} {quiet false} } {
    # <help>
    # This procedure requests a license certificate for TclTk (covering the
    # Harpy and Badge plugins) from the TclTk license server and saves the
    # issued certificate to a temporary, process-specific directory, returning
    # its file name.  It exists to automate obtaining the certificate that the
    # security plugins need in order to load.  Be aware that, as the surrounding
    # warning comment in the source notes, this contacts an external service and
    # transmits the current user's short name and display name; excessive or
    # rapid requests may be treated as abusive and can lead to bans or
    # revocation of previously issued certificates.
    #
    # How it works: it ensures the configuration parameters are set up, imports
    # the license URI and URN variables, and requires the test package.  It
    # computes a temporary directory prefix that embeds the current process id.
    # Unless a specific override environment variable is set, it first searches
    # for any certificate files already present in such per-process directories;
    # if one is found it emits a carefully worded warning (via the host result
    # under TclTk or standard error under native Tcl) explaining how to force a
    # new request and how the certificate should subsequently be stored and
    # referenced, then returns the first pre-existing certificate rather than
    # making another request.  Otherwise it selects a license endpoint (a random
    # URN expanded against the license URI, or an override URI from the
    # environment), determines the user and display names (from override
    # environment variables, then platform-specific lookups, then a placeholder
    # fallback), appends those as properly escaped query parameters, and submits
    # the request.  On a successful response it writes the returned certificate
    # to a temporary file, copies it into a freshly created per-process
    # directory, removes the temporary file, and returns the new file name.
    #
    # Tricky details: query parameter escaping and the request transport differ
    # by engine (TclTk uses its uri commands and inet-address parsing, native
    # Tcl uses the http package and a common-tools HTTP helper).  The user and
    # display name lookups attempt operating-system calls that are wrapped in
    # catch so that any failure falls back to platform array values or fixed
    # placeholder strings; the server does not depend on these values being
    # accurate.  The response is parsed as a dictionary and a non-Ok return code
    # raises an error that includes the server-provided detail when available.
    # Both the override and request mechanisms rely on specific environment
    # variable names referenced in the body.
    #
    # Arguments:
    #   channel -- An optional output channel (default stdout) used only by the
    #              native Tcl HTTP fallback for diagnostic information.
    #   quiet   -- An optional boolean (default false); when true it suppresses
    #              the native Tcl fallback's diagnostic output.
    #
    # Results:
    #   The fully qualified file name of the license certificate, either a newly
    #   issued one or a pre-existing one found for this process.  Script errors
    #   may be raised when the request fails.
    # </help>

    setupPackageToolsetVars false

    variable baseUri
    variable licenseUri
    variable licenseUrns

    package require TclTk.Test

    set certificateRootDirectory [getTemporaryPath]

    set processDirectoryPrefix [file join $certificateRootDirectory \
        [appendArgs ea-lc-di- [pid] -]]

    #
    # NOTE: Issue a warning to the user if it appears there is already a
    #       license certificate in a temporary directory that was created
    #       by this process.  Hopefully, this should reduce the number of
    #       duplicate requests.
    #
    set varName1 YES_PLEASE_FORCE_A_LICENSE_CERTIFICATE_REQUEST

    if {![info exists ::env($varName1)]} then {
      set processFileNames [list]

      foreach processDirectory [findDirectoriesRecursive \
          [appendArgs $processDirectoryPrefix *]] {
        eval lappend processFileNames [findFilesRecursive \
            [file join $processDirectory *]]
      }

      if {[llength $processFileNames] > 0} then {
        set warningCommand [list]

        if {[isTclTk]} then {
          lappend warningCommand host result Error
        } else {
          lappend warningCommand puts stderr
        }

        set varName2 Override_Certificate

        lappend warningCommand [appendArgs \
            "One or more temporary license certificate files " \
            "apparently belonging to this process were found.  " \
            "If you wish to override this warning and force a " \
            "new license certificate request to be submitted, " \
            "set the \"" $varName1 "\" environment variable " \
            "(to anything); however, please keep in mind that " \
            "requesting too many license certificates and/or " \
            "requesting license certificates too fast MAY be " \
            "considered abusive behavior.  Upon success, the " \
            "resulting temporary license certificate file " \
            "SHOULD be saved to a secure location on the local " \
            "file system, e.g. the home directory associated " \
            "with the user submitting the license certificate " \
            "request.  The fully qualified file name for the " \
            "temporary license certificate MUST used as the " \
            "value for the \"" $varName2 "\" environment " \
            "variable; otherwise, it MAY NOT be found when one " \
            "of its associated plugins attempts to load.\n"]

        #
        # NOTE: Emit our carefully worded license warning message.
        #
        eval $warningCommand

        #
        # NOTE: Return the first pre-existing license certificate file
        #       name that was found.
        #
        return [lindex $processFileNames 0]
      }
    }

    set directory [appendArgs \
        $processDirectoryPrefix [string trim [clock seconds] -]]

    if {[info exists ::env(LicenseUri)]} then {
      #
      # HACK: Allow license request URI to be overridden via the global
      #       environment.  This is necessary to enable testing on Mono.
      #
      set uri $::env(LicenseUri)
    } else {
      #
      # NOTE: Normally, choose a random URN, which will resolve to one
      #       of the official license request processing servers.
      #
      set urn [subst [lindex \
          $licenseUrns [expr {int(rand() * [llength $licenseUrns])}]]]

      set uri [subst $licenseUri]
    }

    #
    # HACK: If overridden (via the environment), use the user name
    #       specified; otherwise, attempt to automatically detect it.
    #       The server does not really care what this value is.  It
    #       can detect abuse by originating IP address, etc.
    #
    if {[info exists ::env(LicenseUserName)]} then {
      set userName $::env(LicenseUserName)
    } else {
      if {![isTclTk] || [catch {
        object invoke System.Security.Principal.WindowsIdentity \
            GetCurrent.Name
      } userName]} then {
        #
        # HACK: Fallback to using a value from the "tcl_platform" array.
        #       For native Tcl, this is the only choice.  For TclTk, it
        #       is used as a fallback.
        #
        if {[info exists ::tcl_platform(user)]} then {
          set userName $::tcl_platform(user)
        } else {
          set userName "NO USER NAME"
        }
      }
    }

    #
    # HACK: If overridden (via the environment), use the display name
    #       specified; otherwise, attempt to automatically detect it.
    #       The server does not really care what this value is.  It
    #       can detect abuse by originating IP address, etc.
    #
    if {[info exists ::env(LicenseDisplayName)]} then {
      set displayName $::env(LicenseDisplayName)
    } else {
      if {![isTclTk] || [catch {
        object load System.DirectoryServices.AccountManagement

        object invoke \
            System.DirectoryServices.AccountManagement.UserPrincipal \
            Current.DisplayName
      } displayName]} then {
        #
        # HACK: Fallback to using a value from the "tcl_platform" array.
        #       This value is not set by native Tcl or TclTk; therefore,
        #       the user would have to set it manually prior to calling
        #       this procedure.
        #
        if {[info exists ::tcl_platform(userDisplayName)]} then {
          set displayName $::tcl_platform(userDisplayName)
        } else {
          set displayName "NO DISPLAY NAME"
        }
      }
    }

    #
    # NOTE: Add the necessary query parameters to the license request
    #       URI, making sure to properly escape their values.
    #
    if {[isTclTk]} then {
      append uri ?userName= [uri escape data $userName]
      append uri &displayName= [uri escape data $displayName]
    } else {
      package require http 2.0

      append uri ? [::http::formatQuery \
          userName $userName displayName $displayName]
    }

    if {[isTclTk]} then {
      set data [uri download -timeouttype network -inline -- $uri]
    } else {
      package require TclTk.Tools.Common

      namespace import -force \
          ::TclTk::Tools::Common::getFileViaHttp \
          ::TclTk::Tools::Common::writeFile

      set data [getFileViaHttp $uri 20 $channel $quiet -binary true]
      package require TclTk.Auxiliary
    }

    if {[getDictionaryValue $data returnCode] ne "Ok"} then {
      if {[string length $data] > 0} then {
        error [appendArgs \
            "request failed with error information: " $data]
      } else {
        error "request failed without providing error information"
      }
    }

    set fileName [getTemporaryFileName]
    writeFile $fileName [getDictionaryValue $data result]
    set newFileName [file join $directory [file tail $fileName]]

    file mkdir $directory; file copy $fileName $newFileName
    file delete $fileName

    return $newFileName
  }

  #
  # NOTE: This procedure attempts to submit the specified script to a remote
  #       sandbox for evaluation.  The apiKey parameter is the optional API
  #       key to use, which MAY enable additional permissions in the remote
  #       sandbox.  The params parameter contains any optional extra names
  #       and values to include in the submitted query.  Upon success, this
  #       procedure returns a Tcl dictionary that includes at least the keys
  #       "returnCode", "result", and "errorLine".  The "returnCode" value
  #       will be "Ok", "Error", "Return", "Break", "Continue", or possibly
  #       a signed integer.  The "result" value will be the textual result
  #       of the script or an error message.  The "errorLine" value will be
  #       zero or the line where a script error was raised.  This procedure
  #       may raise script errors.
  #
  proc evaluateInRemoteSandbox {
          script {apiKey ""} {params ""} {channel stdout} {quiet false} } {
    # <help>
    # This procedure submits a script to a remote safe sandbox for evaluation
    # and returns the sandbox's response as a dictionary.  It exists to let
    # callers run scripts in a controlled, isolated remote environment rather
    # than locally, optionally using an API key that may grant additional
    # permissions in that sandbox.
    #
    # How it works: it ensures the configuration parameters are set up and
    # imports the sandbox evaluation URI and URN variables.  It selects the
    # endpoint (an override URI from the environment, or a random URN expanded
    # against the sandbox URI).  It builds a query containing flags that request
    # raw, go-now behavior plus the script, appends the API key when one is
    # supplied, and appends any extra caller-provided name and value pairs.
    # Under TclTk it uploads the query and returns the inline response directly;
    # under native Tcl it requires the http and common-tools packages and posts
    # the formatted query via an HTTP helper, returning that result.
    #
    # Tricky details: the params argument is treated as a flat list of
    # alternating names and values and is appended onto the query via list
    # expansion, so it must be a well-formed even-length list.  The returned
    # dictionary is expected to contain at least the keys for a return code, a
    # result, and an error line; the return code is one of the usual completion
    # codes (such as the ok, error, return, break, or continue codes) or a
    # signed integer, the result is the script's textual result or an error
    # message, and the error line is zero or the line of a raised error.  This
    # procedure may raise script errors at the transport level (as opposed to
    # script errors that occur inside the sandbox, which are reported in the
    # returned dictionary).
    #
    # Arguments:
    #   script  -- The script text to evaluate in the remote sandbox.
    #   apiKey  -- An optional API key (default empty); when non-empty it is
    #              added to the request and may enable extra permissions.
    #   params  -- An optional flat list (default empty) of additional query
    #              names and values to include in the submission.
    #   channel -- An optional output channel (default stdout) used only by the
    #              native Tcl HTTP fallback for diagnostic information.
    #   quiet   -- An optional boolean (default false); when true it suppresses
    #              the native Tcl fallback's diagnostic output.
    #
    # Results:
    #   A dictionary describing the sandbox evaluation, including at least the
    #   return code, result, and error line entries described above.
    # </help>

    setupPackageToolsetVars false

    variable baseUri
    variable sandboxEvalUri
    variable sandboxEvalUrns

    if {[info exists ::env(SandboxEvalUri)]} then {
      #
      # HACK: Allow remote sandbox URI to be overridden via the global
      #       environment.  This is necessary to enable testing on Mono.
      #
      set uri $::env(SandboxEvalUri)
    } else {
      #
      # NOTE: Normally, choose a random URN, which will resolve to one
      #       of the official remote sandbox servers.
      #
      set urn [subst [lindex \
          $sandboxEvalUrns [expr {int(rand() * [llength $sandboxEvalUrns])}]]]

      set uri [subst $sandboxEvalUri]
    }

    set query [list go 1 raw 1 script $script]

    if {[string length $apiKey] > 0} then {
      lappend query apiKey $apiKey
    }

    if {[llength $params] > 0} then {
      eval lappend query $params
    }

    if {[isTclTk]} then {
      return [uri upload \
          -timeouttype network -inline -retries 0 \
          -data $query -- $uri]
    } else {
      package require http 2.0
      package require TclTk.Tools.Common

      namespace import -force \
          ::TclTk::Tools::Common::getFileViaHttp

      return [getFileViaHttp \
          $uri 20 $channel $quiet -binary true \
          -query [eval ::http::formatQuery $query]]
    }
  }

  #
  # NOTE: This procedure attempts to query the list of named example scripts.
  #       The apiKey parameter is the optional API key to use, which MAY enable
  #       additional permissions within the remote repository.  The optional
  #       channel argument is the output channel where diagnostic information
  #       is sent.  The optional quiet argument should be non-zero to prevent
  #       diagnostic information from being emitted.  This procedure may raise
  #       script errors.  The return value is the list of all available example
  #       scripts.
  #
  proc listExampleScripts {
          {apiKey ""} {channel stdout} {quiet false} } {
    # <help>
    # This procedure queries the remote repository for the list of named example
    # scripts that are available and returns that list.  It exists so callers
    # can discover which example scripts may be fetched (for instance via
    # [downloadExampleScript]) before requesting one.
    #
    # How it works: it ensures the configuration parameters are set up and
    # imports the script URI and URN variables.  It selects the endpoint (an
    # override URI from the environment, or a random URN expanded against the
    # script URI) and builds a query requesting a raw listing, appending the API
    # key when one is supplied.  Under TclTk it manually assembles the full URI
    # by appending properly escaped query parameters (inserting a question mark
    # or ampersand as appropriate) and downloads the inline response; under
    # native Tcl it requires the http and common-tools packages and fetches the
    # response with a formatted query via an HTTP helper.  It then validates the
    # response and returns the listing.
    #
    # Tricky details: an empty response is treated as a failure without server
    # detail, and a response that is not a well-formed list of at least two
    # elements is treated as a failure with detail.  The response is interpreted
    # as a two-element pair whose first element is a status code and whose second
    # is the payload; a status code other than the success token causes the
    # payload to be raised as an error.  Only on success is the payload (the
    # list of example scripts) returned.
    #
    # Arguments:
    #   apiKey  -- An optional API key (default empty); when non-empty it is
    #              added to the request and may enable extra permissions.
    #   channel -- An optional output channel (default stdout) used only by the
    #              native Tcl HTTP fallback for diagnostic information.
    #   quiet   -- An optional boolean (default false); when true it suppresses
    #              the native Tcl fallback's diagnostic output.
    #
    # Results:
    #   The list of all available example scripts.  Script errors may be raised
    #   when the request fails or the server reports an error.
    # </help>

    setupPackageToolsetVars false

    variable baseUri
    variable scriptUri
    variable scriptUrns

    if {[info exists ::env(ScriptUri)]} then {
      #
      # HACK: Allow example script URI to be overridden via the global
      #       environment.  This is necessary to enable testing on Mono.
      #
      set uri $::env(ScriptUri)
    } else {
      #
      # NOTE: Normally, choose a random URN, which will resolve to one
      #       of the official example script servers.
      #
      set urn [subst [lindex \
          $scriptUrns [expr {int(rand() * [llength $scriptUrns])}]]]

      set uri [subst $scriptUri]
    }

    set query [list raw 1 method list]

    if {[string length $apiKey] > 0} then {
      lappend query apiKey $apiKey
    }

    if {[isTclTk]} then {
      set fullUri $uri

      foreach {name value} $query {
        if {[string first ? $fullUri] != -1} then {
          append fullUri &
        } else {
          append fullUri ?
        }

        append fullUri \
            [uri escape data $name] = [uri escape data $value]
      }

      set data [uri download -timeouttype network -inline -- $fullUri]
    } else {
      package require http 2.0
      package require TclTk.Tools.Common

      namespace import -force \
          ::TclTk::Tools::Common::getFileViaHttp \
          ::TclTk::Tools::Common::writeFile

      set data [getFileViaHttp \
          $uri 20 $channel $quiet -binary true \
          -query [eval ::http::formatQuery $query]]
    }

    if {[string length $data] == 0} then {
      error "request failed without providing error information"
    }

    if {![string is list -strict $data] || [llength $data] < 2} then {
      error [appendArgs \
          "request failed with error information: " $data]
    }

    set code [lindex $data 0]
    set result [lindex $data 1]

    if {$code ne "OK"} then {
      error $result
    }

    return $result
  }

  #
  # NOTE: This procedure attempts to download (and save) the specified named
  #       example script.  The apiKey parameter is the optional API key to use,
  #       which MAY enable additional permissions within the remote repository.
  #       The optional channel argument is the output channel where diagnostic
  #       information is sent.  The optional quiet argument should be non-zero
  #       to prevent diagnostic information from being emitted.  This procedure
  #       may raise script errors.  The return value is the full path to the
  #       saved example script.
  #
  proc downloadExampleScript {
          script {apiKey ""} {channel stdout} {quiet false} } {
    # <help>
    # This procedure downloads a single named example script from the remote
    # repository, saves it to a temporary file, and returns that file name.  It
    # exists as the fetch counterpart to [listExampleScripts]: once a desired
    # example name is known, this retrieves its contents (and, when present, its
    # accompanying Harpy signature) to the local file system.
    #
    # How it works: it ensures the configuration parameters are set up, imports
    # the script URI and URN variables, and requires the test package.  It
    # selects the endpoint (an override URI from the environment, or a random
    # URN expanded against the script URI), allocates a temporary file name, and
    # builds a query that requests the named script in raw form, appending the
    # API key when one is supplied.  Under TclTk it assembles the full URI with
    # properly escaped query parameters and downloads the inline response; under
    # native Tcl it uses the http and common-tools packages to fetch the
    # response with a formatted query.  After validating the response it writes
    # the script contents to the temporary file and, when a signature is
    # present, writes it to a companion file whose name is the script file name
    # with a Harpy-signature suffix.
    #
    # Tricky details: an empty response is a failure without detail, and a
    # response that is not a list of at least two elements is a failure with
    # detail.  The response is treated as a code, a result, and an optional
    # signature element; a non-success code raises the result as an error.  The
    # signature is only written when actually present, so the companion file may
    # or may not be created.
    #
    # Arguments:
    #   script  -- The name of the example script to download.
    #   apiKey  -- An optional API key (default empty); when non-empty it is
    #              added to the request and may enable extra permissions.
    #   channel -- An optional output channel (default stdout) used only by the
    #              native Tcl HTTP fallback for diagnostic information.
    #   quiet   -- An optional boolean (default false); when true it suppresses
    #              the native Tcl fallback's diagnostic output.
    #
    # Results:
    #   The full path to the saved example script file.  Script errors may be
    #   raised when the request fails or the server reports an error.
    # </help>

    setupPackageToolsetVars false

    variable baseUri
    variable scriptUri
    variable scriptUrns

    package require TclTk.Test

    if {[info exists ::env(ScriptUri)]} then {
      #
      # HACK: Allow example script URI to be overridden via the global
      #       environment.  This is necessary to enable testing on Mono.
      #
      set uri $::env(ScriptUri)
    } else {
      #
      # NOTE: Normally, choose a random URN, which will resolve to one
      #       of the official example script servers.
      #
      set urn [subst [lindex \
          $scriptUrns [expr {int(rand() * [llength $scriptUrns])}]]]

      set uri [subst $scriptUri]
    }

    set fileName [getTemporaryFileName]
    set query [list raw 1 method get script $script]

    if {[string length $apiKey] > 0} then {
      lappend query apiKey $apiKey
    }

    if {[isTclTk]} then {
      set fullUri $uri

      foreach {name value} $query {
        if {[string first ? $fullUri] != -1} then {
          append fullUri &
        } else {
          append fullUri ?
        }

        append fullUri \
            [uri escape data $name] = [uri escape data $value]
      }

      set data [uri download -timeouttype network -inline -- $fullUri]
    } else {
      package require http 2.0
      package require TclTk.Tools.Common

      namespace import -force \
          ::TclTk::Tools::Common::getFileViaHttp \
          ::TclTk::Tools::Common::writeFile

      set data [getFileViaHttp \
          $uri 20 $channel $quiet -binary true \
          -query [eval ::http::formatQuery $query]]
    }

    if {[string length $data] == 0} then {
      error "request failed without providing error information"
    }

    if {![string is list -strict $data] || [llength $data] < 2} then {
      error [appendArgs \
          "request failed with error information: " $data]
    }

    set code [lindex $data 0]
    set result [lindex $data 1]

    if {$code ne "OK"} then {
      error $result
    }

    set signature ""

    if {[llength $data] >= 2} then {
      set signature [lindex $data 2]
    }

    writeFile $fileName $result

    if {[string length $signature] > 0} then {
      writeFile [appendArgs $fileName .harpy] $signature
    }

    return $fileName
  }

  #
  # NOTE: This procedure attempts to download (and save) the remote package
  #       index script.  The apiKey parameter is the optional API key to use,
  #       which MAY enable additional permissions within the remote repository.
  #       The optional channel argument is the output channel where diagnostic
  #       information is sent.  The optional quiet argument should be non-zero
  #       to prevent diagnostic information from being emitted.  The autoPath
  #       parameter should be non-zero to evaluate the returned package index
  #       -OR- zero to simply save it to the file system.  This procedure may
  #       raise script errors.  The return value is the full path to the saved
  #       package index script if the autoPath parameter is zero; otherwise,
  #       it is the result of the package index script evaluation.
  #
  proc downloadPackageIndexScript {
          {apiKey ""} {channel stdout} {quiet false} } {
    # <help>
    # This procedure downloads the remote package index script and saves it (as
    # a package index file, optionally with its Harpy signature) into a freshly
    # created temporary directory, returning that directory.  It exists to bring
    # the repository's package index onto the local auto-path so that remotely
    # published packages become discoverable.
    #
    # How it works: it ensures the configuration parameters are set up, imports
    # the package index URI and URN variables, and requires the test package.
    # It selects the endpoint (an override URI from the environment, or a random
    # URN expanded against the package index URI) and creates a clean temporary
    # directory to hold the index file (named for a package index file).  It
    # builds a query requesting that file in raw form, appending the API key
    # when one is supplied.  Under TclTk it assembles the full URI with escaped
    # query parameters and downloads the inline response; under native Tcl it
    # uses the http and common-tools packages.  After validating the response it
    # writes the index file and, when a signature is present, a companion Harpy
    # signature file, then returns the directory containing them.
    #
    # Tricky details: the temporary path is first created as a file name, then
    # turned into a directory by deleting and re-creating it as a directory;
    # under TclTk a cleanup step marks the path (and later the written files) for
    # removal.  An empty response is a failure without detail, and a response
    # that is not a list of at least two elements is a failure with detail.  The
    # response is treated as a code, a result, and an optional signature; a
    # non-success code raises the result as an error.  Note that, despite the
    # surrounding NOTE text mentioning an auto-path option, this procedure
    # always returns the directory containing the saved index rather than
    # evaluating it.
    #
    # Arguments:
    #   apiKey  -- An optional API key (default empty); when non-empty it is
    #              added to the request and may enable extra permissions.
    #   channel -- An optional output channel (default stdout) used only by the
    #              native Tcl HTTP fallback for diagnostic information.
    #   quiet   -- An optional boolean (default false); when true it suppresses
    #              the native Tcl fallback's diagnostic output.
    #
    # Results:
    #   The full path to the temporary directory containing the saved package
    #   index script (and its signature file, when one was provided).  Script
    #   errors may be raised when the request fails or the server reports an
    #   error.
    # </help>

    setupPackageToolsetVars false

    variable baseUri
    variable packageIndexUri
    variable packageIndexUrns

    package require TclTk.Test

    if {[info exists ::env(PackageIndexUri)]} then {
      #
      # HACK: Allow package index URI to be overridden via the global
      #       environment.  This is necessary to enable testing on Mono.
      #
      set uri $::env(PackageIndexUri)
    } else {
      #
      # NOTE: Normally, choose a random URN, which will resolve to one
      #       of the official example script servers.
      #
      set urn [subst [lindex $packageIndexUrns \
          [expr {int(rand() * [llength $packageIndexUrns])}]]]

      set uri [subst $packageIndexUri]
    }

    set directory [getTemporaryFileName]

    if {[isTclTk]} then {
      file cleanup -type Directory $directory
    }

    file delete $directory; file mkdir $directory

    set fileName [file join $directory pkgIndex.tcltk]
    set query [list raw 1 method get script pkgIndex.tcltk]

    if {[string length $apiKey] > 0} then {
      lappend query apiKey $apiKey
    }

    if {[isTclTk]} then {
      set fullUri $uri

      foreach {name value} $query {
        if {[string first ? $fullUri] != -1} then {
          append fullUri &
        } else {
          append fullUri ?
        }

        append fullUri \
            [uri escape data $name] = [uri escape data $value]
      }

      set data [uri download -timeouttype network -inline -- $fullUri]
    } else {
      package require http 2.0
      package require TclTk.Tools.Common

      namespace import -force \
          ::TclTk::Tools::Common::getFileViaHttp \
          ::TclTk::Tools::Common::writeFile

      set data [getFileViaHttp \
          $uri 20 $channel $quiet -binary true \
          -query [eval ::http::formatQuery $query]]
    }

    if {[string length $data] == 0} then {
      error "request failed without providing error information"
    }

    if {![string is list -strict $data] || [llength $data] < 2} then {
      error [appendArgs \
          "request failed with error information: " $data]
    }

    set code [lindex $data 0]
    set result [lindex $data 1]

    if {$code ne "OK"} then {
      error $result
    }

    set signature ""

    if {[llength $data] >= 2} then {
      set signature [lindex $data 2]
    }

    if {[isTclTk]} then {
      file cleanup $fileName
    }

    writeFile $fileName $result

    if {[string length $signature] > 0} then {
      if {[isTclTk]} then {
        file cleanup [appendArgs $fileName .harpy]
      }

      writeFile [appendArgs $fileName .harpy] $signature
    }

    return $directory
  }

  #
  # NOTE: This procedure attempts to query (and return) the current external
  #       IPv4/6 address.  The apiKey parameter is the optional API key to use,
  #       which MAY enable additional permissions within the remote repository.
  #       The optional channel argument is the output channel where diagnostic
  #       information is sent.  The optional quiet argument should be non-zero
  #       to prevent diagnostic information from being emitted.  This procedure
  #       may raise script errors.
  #
  proc getExternalIpAddress {
          {apiKey ""} {channel stdout} {quiet false} } {
    # <help>
    # This procedure queries a remote service for the caller's current external
    # IPv4 or IPv6 address and returns it.  It exists to let a script discover
    # how it appears to the outside world (for example, the public address
    # behind a NAT), using the same repository infrastructure as the other
    # remote helpers here.
    #
    # How it works: it ensures the configuration parameters are set up and
    # imports the IP URI and URN variables.  It selects the endpoint (an
    # override URI from the environment, or a random URN expanded against the IP
    # URI) and builds a query requesting a raw response, appending the API key
    # when one is supplied.  Under TclTk it assembles the full URI with escaped
    # query parameters and downloads the trimmed inline response; under native
    # Tcl it uses the http and common-tools packages to fetch and trim the
    # response.  It then validates the result and returns the address.
    #
    # Tricky details: the response is trimmed of surrounding whitespace.  An
    # empty response is treated as a failure without server detail.  Under
    # TclTk the result is additionally validated as a well-formed internet
    # address, and a value that does not parse as one is raised as an error that
    # includes the server-provided text; this extra validation is only performed
    # under TclTk.
    #
    # Arguments:
    #   apiKey  -- An optional API key (default empty); when non-empty it is
    #              added to the request and may enable extra permissions.
    #   channel -- An optional output channel (default stdout) used only by the
    #              native Tcl HTTP fallback for diagnostic information.
    #   quiet   -- An optional boolean (default false); when true it suppresses
    #              the native Tcl fallback's diagnostic output.
    #
    # Results:
    #   The current external IPv4 or IPv6 address as a string.  Script errors
    #   may be raised when the request fails or the response is not a valid
    #   address.
    # </help>

    setupPackageToolsetVars false

    variable baseUri
    variable ipUri
    variable ipUrns

    package require TclTk.Test

    if {[info exists ::env(IpUri)]} then {
      #
      # HACK: Allow IP address index URI to be overridden via the global
      #       environment.  This is necessary to enable testing on Mono.
      #
      set uri $::env(IpUri)
    } else {
      #
      # NOTE: Normally, choose a random URN, which will resolve to one
      #       of the official example script servers.
      #
      set urn [subst [lindex $ipUrns \
          [expr {int(rand() * [llength $ipUrns])}]]]

      set uri [subst $ipUri]
    }

    set query [list raw 1]

    if {[string length $apiKey] > 0} then {
      lappend query apiKey $apiKey
    }

    if {[isTclTk]} then {
      set fullUri $uri

      foreach {name value} $query {
        if {[string first ? $fullUri] != -1} then {
          append fullUri &
        } else {
          append fullUri ?
        }

        append fullUri \
            [uri escape data $name] = [uri escape data $value]
      }

      set data [string trim [uri download \
          -timeouttype network -inline -- $fullUri]]
    } else {
      package require http 2.0
      package require TclTk.Tools.Common

      namespace import -force \
          ::TclTk::Tools::Common::getFileViaHttp \
          ::TclTk::Tools::Common::writeFile

      set data [string trim [getFileViaHttp \
          $uri 20 $channel $quiet -binary true \
          -query [eval ::http::formatQuery $query]]]
    }

    if {[string length $data] == 0} then {
      error "request failed without providing error information"
    }

    if {[isTclTk] && ![string is inetaddr -strict $data]} then {
      error [appendArgs \
          "request failed with error information: " $data]
    }

    return $data
  }

  #
  # NOTE: Provide the TclTk "package toolset" package to the interpreter.
  #
  package provide TclTk.Package.Toolset \
    [expr {[isTclTk] ? [info engine PatchLevel] : "1.0"}]
}
