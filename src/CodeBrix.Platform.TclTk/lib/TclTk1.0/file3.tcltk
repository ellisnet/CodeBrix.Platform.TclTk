#
# NOTE: Use our own namespace here because even though we do not directly
#       support namespaces ourselves, we do not want to pollute the global
#       namespace if this script actually ends up being evaluated in Tcl.
#
namespace eval ::TclTk {
  #
  # NOTE: This procedure attempts to emit a Tcl log message based on the
  #       calling procedure currently being invoked.  This procedure is
  #       explicitly designed to allow overriding via external scripts.
  #
  proc tclLogForCommand { {command ""} } {
    # <help>
    # This procedure emits a diagnostic log message that describes the
    # procedure that called it, optionally annotated with a command that is
    # being performed on its behalf.  It exists as a lightweight tracing hook
    # for the file-finder procedures in this file: several of them consult a
    # runtime option and, when it is enabled, call this procedure so that the
    # underlying [glob] or external "dir" command can be observed.  Because it
    # is intended to be customizable, it is explicitly designed so that
    # external scripts may override it with a compatible implementation.
    #
    # How it works: it uses [info level] to discover its own call frame and
    # the immediately enclosing one, recording its own name from the former and
    # the full argument list that invoked the caller from the latter.  The
    # depth of the calling frame is also used to build a small visual indentation
    # (runs of equals signs and dashes) so that nested calls are easier to
    # read in the log.  If a non-empty command argument is supplied, it is
    # appended to the message; in addition, if the caller has a variable named
    # "error" or "result" in scope (queried and read via [uplevel] in the
    # caller's frame), its value is appended as well, with "error" taking
    # precedence over "result".  The fully assembled message is then passed to
    # [tclLog] inside a [catch] so that a failure to log can never disrupt the
    # operation being traced.
    #
    # Tricky details: the message text intentionally wraps the calling
    # argument list, command, error, and result values in literal brace
    # characters for readability, which are produced by escaped brace
    # characters in the source; do not confuse those with list grouping.  The
    # caller's "error"/"result" variables are inspected only by name in the
    # parent frame, so this procedure is most useful when called from contexts
    # that follow that naming convention.
    #
    # Arguments:
    #   command -- Optional.  A textual description (typically a command list)
    #              of the operation being performed on the caller's behalf.
    #              When omitted or empty, only the calling procedure and its
    #              arguments are logged, with no command, error, or result
    #              suffix.
    #
    # Results:
    #   An empty string is returned; this procedure is invoked purely for the
    #   side effect of emitting a log message.
    # </help>

    set level [info level]; # current procedure
    set procName [lindex [info level $level] 0]
    incr level -1; # calling procedure

    if {[string length $command] > 0} then {
      set equals [string repeat = $level]

      set suffix [appendArgs \
          " " $equals "> command \{" $command \}]

      if {[uplevel 1 [list info exists error]]} then {
        set error [uplevel 1 [list set error]]

        if {[string length $error] > 0} then {
          append suffix " " $equals "> error \{" $error \}
        }
      } elseif {[uplevel 1 [list info exists result]]} then {
        set result [uplevel 1 [list set result]]

        if {[string length $result] > 0} then {
          append suffix " " $equals "> result \{" $result \}
        }
      }
    } else {
      set suffix ""
    }

    catch {
      tclLog [string trim [appendArgs \
          $procName " (level " [format %03d $level] ") " \
          [string repeat - $level] "> \{" [info level \
          $level] \} $suffix]]
    }
  }

  #
  # NOTE: This procedure figures out extra option values for use with the
  #       "dir" command of the Windows command shell based on which types
  #       of paths are being saught.  This procedure is not explicitly
  #       designed to allow overriding via external scripts; however, it
  #       can be overridden if some care is taken to maintain compatible
  #       semantics.
  #
  proc populateTypesForComSpecDir { dirVarName fileVarName } {
    # <help>
    # This procedure populates two caller-supplied arrays with the option
    # flags that must be passed to the Windows command shell "dir" command in
    # order to list visible versus hidden directories and files.  It exists to
    # centralize the mapping between the abstract notions of "visible" and
    # "hidden" items and the concrete attribute switches the "dir" command
    # understands, so that the [findViaComSpecDir] procedure does not have to
    # embed those switches inline.  It is not explicitly designed for
    # overriding by external scripts, but it can be overridden as long as
    # compatible semantics are maintained.
    #
    # How it works: the two argument names are linked to local array variables
    # via [upvar] so that the assignments made here are visible to the caller.
    # The directory array is given a "visible" element selecting directories
    # and a "hidden" element selecting hidden directories; the file array is
    # given analogous elements that additionally exclude directories.  The
    # values are the literal attribute switches understood by the "dir"
    # command (for example, the switch that selects directories, the switch
    # that selects hidden directories, and the corresponding switches that
    # select non-directory items).
    #
    # Arguments:
    #   dirVarName  -- The name, in the caller's frame, of an array variable
    #                  to be populated with "visible" and "hidden" elements
    #                  containing the "dir" switches for directories.
    #   fileVarName -- The name, in the caller's frame, of an array variable
    #                  to be populated with "visible" and "hidden" elements
    #                  containing the "dir" switches for files.
    #
    # Results:
    #   The result is unspecified; this procedure is invoked for the side
    #   effect of populating the two caller arrays.
    # </help>

    upvar 1 $dirVarName dirTypes
    upvar 1 $fileVarName fileTypes

    set dirTypes(visible) {/ad}
    set dirTypes(hidden) {/ahd}

    set fileTypes(visible) {/a-d}
    set fileTypes(hidden) {/ah-d}
  }

  #
  # NOTE: This procedure figures out what the -types option values should
  #       be to locate both visible and hidden directories and/or files.
  #       This procedure is not explicitly designed to allow overriding
  #       via external scripts; however, it can be overridden if some care
  #       is taken to maintain compatible semantics.
  #
  proc populateTypesForGlob { dirVarName fileVarName } {
    # <help>
    # This procedure populates two caller-supplied arrays with the values that
    # must be passed via the -types option of the [glob] command in order to
    # locate visible versus hidden directories and files.  It is the [glob]
    # counterpart to [populateTypesForComSpecDir] and exists so that the
    # finder procedures can request a particular category of item without
    # hard-coding the relevant type keywords at every call site.  It is not
    # explicitly designed for overriding by external scripts, but it can be
    # overridden as long as compatible semantics are maintained.
    #
    # How it works: the two argument names are linked to local array variables
    # via [upvar].  The "visible" elements are set to the simple type keywords
    # that select directories and files, respectively.  The "hidden" elements
    # differ between engines: under TclTk, the hidden selectors additionally
    # request system and hidden items and use a keyword that restricts the
    # match to hidden-only items, whereas under Tcl the hidden selectors use
    # the plain hidden keyword.
    #
    # Tricky details: the TclTk "hidden-only" type keyword requires a
    # sufficiently recent engine release, as noted in the inline comment; on
    # older engines the behavior would differ.  The engine is detected with
    # [isTclTk], so the same source produces appropriate type lists under both
    # TclTk and Tcl.
    #
    # Arguments:
    #   dirVarName  -- The name, in the caller's frame, of an array variable
    #                  to be populated with "visible" and "hidden" elements
    #                  containing the [glob] -types values for directories.
    #   fileVarName -- The name, in the caller's frame, of an array variable
    #                  to be populated with "visible" and "hidden" elements
    #                  containing the [glob] -types values for files.
    #
    # Results:
    #   The result is unspecified; this procedure is invoked for the side
    #   effect of populating the two caller arrays.
    # </help>

    upvar 1 $dirVarName dirTypes
    upvar 1 $fileVarName fileTypes

    set dirTypes(visible) {d}
    set fileTypes(visible) {f}

    if {[isTclTk]} then {
      #
      # HACK: Using "hiddenonly" requires release Beta 51 or later.
      #
      set dirTypes(hidden) {d system hidden hiddenonly}
      set fileTypes(hidden) {f system hidden hiddenonly}
    } else {
      set dirTypes(hidden) {d hidden}
      set fileTypes(hidden) {f hidden}
    }
  }

  #
  # NOTE: This procedure returns a list of paths (presumably from [glob])
  #       that have been filtered to remove those that are unwanted, e.g.
  #       the "." and ".." directories, etc.  This procedure is explicitly
  #       designed to allow overriding via external scripts.
  #
  proc filterForGlob { paths } {
    # <help>
    # This procedure removes unwanted entries from a list of paths, returning
    # the filtered list.  In practice the unwanted entries are the special
    # current-directory and parent-directory names (a single dot and two
    # dots), which various directory listings may include but which callers of
    # the file-finder procedures almost never want.  It exists to provide a
    # single, overridable place to apply that filtering so that the rest of
    # the finder code can simply route its raw [glob] results through here.
    # It is explicitly designed to allow overriding via external scripts, for
    # callers that wish to exclude additional entries.
    #
    # How it works: it iterates over the supplied paths, skipping any entry
    # that exactly matches the current-directory or parent-directory name, and
    # appends every other entry to the result in its original order.
    #
    # Tricky details: membership is tested with [lsearch -exact] against a
    # two-element list rather than with the [expr] "in" operator, specifically
    # so that the procedure continues to work on older Tcl versions where that
    # operator is unavailable, as noted in the inline comment.
    #
    # Arguments:
    #   paths -- A list of path strings to be filtered, typically produced by
    #            [glob] or an external directory listing.
    #
    # Results:
    #   A new list containing the input paths in their original order, with the
    #   current-directory and parent-directory entries removed.
    # </help>

    set result [list]

    foreach path $paths {
      #
      # HACK: The "in" operator for [expr] cannot be used here if we want
      #       to support Tcl 8.4.
      #
      if {[lsearch -exact [list . ..] $path] != -1} then {
        continue
      }

      lappend result $path
    }

    return $result
  }

  #
  # NOTE: This procedure returns non-zero if file and directory searches
  #       are able to use the "dir" command of the Windows command shell.
  #       This procedure is not explicitly designed to allow overriding
  #       via external scripts; however, it can be overridden if some
  #       care is taken to maintain compatible semantics.
  #
  proc canUseComSpecDir { pattern } {
    # <help>
    # This procedure decides whether the file-finder procedures are permitted
    # to satisfy a search by shelling out to the "dir" command of the Windows
    # command shell instead of using [glob].  It exists because the
    # command-shell approach is only viable in particular circumstances, and
    # the several finder procedures need a single, consistent test they can
    # consult before choosing that path.  It is not explicitly designed for
    # overriding by external scripts, but it can be overridden as long as
    # compatible semantics are maintained.
    #
    # How it works: it returns false unless all of the enabling conditions
    # hold.  Specifically, it refuses when a global opt-out flag has been set
    # (an element of the global "no" array named for this procedure), when the
    # current platform is not Windows, or when the environment variable that
    # names the command processor is not present.  When none of those
    # disqualifying conditions apply, it returns true.
    #
    # Arguments:
    #   pattern -- The search pattern that would be used.  It is accepted so
    #              that an overriding implementation may base its decision on
    #              the pattern; the built-in implementation does not otherwise
    #              examine it.
    #
    # Results:
    #   Non-zero (true) if the command-shell "dir" approach may be used for the
    #   search; otherwise zero (false).
    # </help>

    if {[info exists ::no(canUseComSpecDir)]} then {
      return false
    }

    if {![isWindows]} then {
      return false
    }

    if {![info exists ::env(ComSpec)]} then {
      return false
    }

    return true
  }

  #
  # NOTE: This procedure returns the current directory value that should be
  #       used when converting relative paths to absolute paths from within
  #       the [getDirResultPath] procedure.  This procedure is explicitly
  #       designed to allow overriding via external scripts.
  #
  proc pwdForDirResultPath { pattern path } {
    # <help>
    # This procedure returns the directory that should be treated as the
    # current working directory when [getDirResultPath] needs to convert a
    # relative path produced by the command-shell "dir" command into an
    # absolute path.  It exists as a small, explicitly overridable seam: by
    # default it simply reports the process current directory, but an external
    # script can replace it to anchor relative results against some other base
    # directory (for example, the directory the search was actually rooted
    # at).  It is explicitly designed to allow overriding via external
    # scripts.
    #
    # How it works: the built-in implementation ignores both arguments and
    # returns the value of [pwd].
    #
    # Arguments:
    #   pattern -- The search pattern associated with the result being
    #              resolved.  Unused by the built-in implementation; available
    #              to overrides.
    #   path    -- The (possibly relative) path being resolved.  Unused by the
    #              built-in implementation; available to overrides.
    #
    # Results:
    #   The absolute path of the directory to use as the base for resolving
    #   relative results; by default, the current working directory.
    # </help>

    return [pwd]
  }

  #
  # NOTE: This procedure uses the type of the specified path to figure out
  #       the (possibly normalized) path to add to the finder results.
  #       This procedure is not explicitly designed to allow overriding via
  #       external scripts; however, it can be overridden if some care is
  #       taken to maintain compatible semantics.
  #
  proc getDirResultPath { pattern path } {
    # <help>
    # This procedure converts a single path returned by the command-shell
    # "dir" command into the (possibly normalized) path that should actually
    # be added to the finder results.  It exists to paper over a fundamental
    # limitation of that command: when invoked without the recurse-into-
    # subdirectories flag, "dir /b" reports only bare file or directory names,
    # not enough relative-path information to reconstruct where each item
    # lives.  This procedure does the best it can to recover a usable path.
    # It is not explicitly designed for overriding by external scripts, but it
    # can be overridden as long as compatible semantics are maintained.
    #
    # How it works: if the incoming path is already absolute it is simply
    # normalized and returned.  Otherwise the procedure attempts, when a
    # corresponding runtime option is enabled, to reconstruct an absolute path
    # by joining pieces together and checking whether the result exists.  When
    # the search pattern itself looks like a usable path or path component, it
    # is resolved (normalizing it directly if it is absolute, or joining it
    # against the base directory from [pwdForDirResultPath] otherwise); if that
    # candidate does not exist, the bare result path is then joined onto it as
    # a final attempt.  When the pattern is not a usable path, the result path
    # is instead joined directly onto the base directory.  If any of these
    # reconstructions yields a path that actually exists, that path is
    # returned.  Should reconstruction fail and a second runtime option be
    # enabled, the procedure raises a script error describing the relative path
    # and pattern it could not handle.  As a last resort, the original relative
    # path is returned unchanged.
    #
    # Tricky details: the path-versus-component tests use TclTk string-class
    # checks and are skipped under Tcl (where the engine check short-circuits
    # them), so the reconstruction logic adapts to the running engine.  The
    # two runtime options behave independently: the first enables the
    # join-and-probe reconstruction, while the second turns an unresolved
    # relative path into a hard error instead of a passthrough.  Existence
    # checks rely on the relevant items still being present on disk at the
    # time this runs.
    #
    # Arguments:
    #   pattern -- The original search pattern that produced this result; used
    #              to help reconstruct directory context for relative results.
    #   path    -- A single path entry as reported by the "dir" command, which
    #              may be absolute or merely a bare name.
    #
    # Results:
    #   For an absolute input, its normalized form.  For a relative input, a
    #   reconstructed absolute path when one could be found to exist; otherwise
    #   either the original relative path (passthrough) or, if the error
    #   runtime option is enabled, a raised script error.
    # </help>

    if {[file pathtype $path] eq "absolute"} then {
      return [file normalize $path]
    } else {
      #
      # BUGBUG: There is not much we can do here that would be correct in
      #         all situations.  The problem is that the Windows command
      #         shell "dir" command does not return enough relative path
      #         information when invoked without the sub-directories flag.
      #
      if {[hasRuntimeOption getDirResultJoinPath]} then {
        if {![isTclTk] || \
            [string is path -strict $pattern] || \
            [string is component -strict $pattern]} then {
          if {[file pathtype $pattern] eq "absolute"} then {
            set newPath [file normalize $pattern]
          } else {
            set newPath [file normalize [file join \
                [pwdForDirResultPath $pattern $path] $pattern]]
          }

          if {![file exists $newPath]} then {
            set newPath [file normalize [file join $newPath $path]]
          }
        } else {
          set newPath [file normalize [file join \
              [pwdForDirResultPath $pattern $path] $path]]
        }

        if {[file exists $newPath]} then {
          return $newPath
        }
      }

      if {[hasRuntimeOption getDirResultErrorPath]} then {
        error [appendArgs \
            "could not handle relative path \"" $path \
            "\" resulting from pattern \"" $pattern \"]
      }

      return $path
    }
  }

  #
  # NOTE: This procedure attempts to normalize the specified path in a way
  #       that (ideally) should not raise a script error.  This procedure
  #       is explicitly designed to allow overriding via external scripts.
  #
  proc fileNormalizeForGlob { path } {
    # <help>
    # This procedure normalizes a path for use with [glob] while trying very
    # hard not to raise a script error in the process.  It exists because path
    # normalization can, under some engines and for some inputs, throw; the
    # finder procedures want a normalized path but cannot tolerate an
    # exception simply because a pattern is unusual.  It is explicitly designed
    # to allow overriding via external scripts.
    #
    # How it works: under TclTk it inspects the path to decide whether legacy
    # path resolution should be engaged.  If the path looks like a well-formed
    # path or path component (per TclTk string-class checks), it normalizes
    # with legacy resolution enabled; otherwise it normalizes with legacy
    # resolution disabled, which avoids triggering the error-prone legacy
    # behavior on inputs that are really glob patterns rather than literal
    # paths.  Under Tcl, where that fine-grained control is unavailable, it
    # falls back to a plain [file normalize].
    #
    # Tricky details: the inline comments flag this as not yet robust against
    # every corner case under TclTk, and openly question whether the Tcl
    # fallback can truly avoid raising an error in all cases.  Callers should
    # therefore treat a non-error return as best-effort normalization rather
    # than a guarantee.
    #
    # Arguments:
    #   path -- The path or glob pattern to normalize.
    #
    # Results:
    #   The normalized path, suitable for passing to [glob].
    # </help>

    if {[isTclTk]} then {
      #
      # HACK: Possibly disable the legacy path resolution to avoid raising
      #       any script errors.
      #
      # TODO: This is (probably) not quite robust enough to handle all of
      #       the possible corner cases.
      #
      if {[string is path -strict $path] || \
          [string is component -strict $path]} then {
        return [file normalize -legacy true $path]
      } else {
        return [file normalize -legacy false $path]
      }
    } else {
      #
      # BUGBUG: Can this really not raise a script error in Tcl?
      #
      return [file normalize $path]
    }
  }

  #
  # NOTE: This procedure performs [glob] using specified types, directory,
  #       and pattern.  This procedure is not explicitly designed to allow
  #       overriding via external scripts; however, it can be overridden
  #       if some care is taken to maintain compatible semantics.
  #
  proc performGlob { types directory pattern } {
    # <help>
    # This procedure performs a single [glob] operation against a directory
    # and pattern, restricted to the specified item types, and returns the
    # filtered list of matches.  It exists to consolidate the three steps that
    # every glob-based search in this file needs -- joining the directory and
    # pattern into one normalized path, invoking [glob] in a non-complaining
    # mode with the requested types, and stripping the unwanted dot entries --
    # so those steps do not have to be repeated at each call site.  It is not
    # explicitly designed for overriding by external scripts, but it can be
    # overridden as long as compatible semantics are maintained.
    #
    # How it works: if the corresponding trace runtime option is enabled, it
    # first logs the call via [tclLogForCommand].  It then joins the directory
    # and pattern with [file join], normalizes the result through
    # [fileNormalizeForGlob], invokes [glob] with the non-complaining flag and
    # the supplied -types value, and finally passes the matches through
    # [filterForGlob] before returning them.
    #
    # Tricky details: the non-complaining glob flag ensures that a pattern
    # matching nothing yields an empty list rather than an error, and the
    # normalization step is what keeps unusual patterns from throwing.  The
    # "types" argument is forwarded verbatim to [glob], so it must already be
    # in the form that command expects (such as the values produced by
    # [populateTypesForGlob]).
    #
    # Arguments:
    #   types     -- The value to pass to the [glob] -types option, selecting
    #                which kinds of items (for example, directories or files,
    #                visible or hidden) should match.
    #   directory -- The directory in which to search.
    #   pattern   -- The glob pattern to match within that directory.
    #
    # Results:
    #   A list of matching paths with the current-directory and parent-
    #   directory entries removed; the empty list if nothing matched.
    # </help>

    if {[hasRuntimeOption tracePerformGlob]} then {
      tclLogForCommand
    }

    return [filterForGlob [glob -nocomplain -types \
        $types [fileNormalizeForGlob [file join $directory \
        $pattern]]]]
  }

  #
  # NOTE: This procedure works around the lack of the -nocase option to the
  #       native Tcl interpreter for versions before 8.5.  It should not be
  #       used by external callers.  This procedure is not explicitly
  #       designed to allow overriding via external scripts; however, it
  #       can be overridden if some care is taken to maintain compatible
  #       semantics.
  #
  proc maybeAppendPathResult { listVarName element } {
    # <help>
    # This procedure appends a path element to a caller-supplied list, but only
    # if an equivalent path (compared case-insensitively) is not already
    # present.  It exists to deduplicate the results gathered by
    # [findViaComSpecDir], where the same path could otherwise be added more
    # than once, and it is written to work even on older Tcl interpreters that
    # lack the case-insensitive option to [lsearch].  It is intended for
    # internal use and should not be called by external callers; it is not
    # explicitly designed for overriding, though it can be overridden as long
    # as compatible semantics are maintained.
    #
    # How it works: the list-variable name is linked to a local variable via
    # [upvar].  Under TclTk, it uses [lsearch] with the by-variable, exact, and
    # case-insensitive options to check for an existing match before appending.
    # Under Tcl 8.5 or newer, it uses [lsearch] with the exact and case-
    # insensitive options (also guarding against the list variable not yet
    # existing).  Under older Tcl, where the case-insensitive option is
    # unavailable, it falls back to comparing lower-cased forms of the whole
    # list and the element.  In every case the element is appended only when no
    # case-insensitive match is found.
    #
    # Tricky details: the case-insensitive comparison means that paths
    # differing only in letter case are treated as duplicates, which is
    # appropriate for the case-insensitive Windows file system this code
    # targets.  The various engine and version branches exist solely to obtain
    # that comparison portably, as the inline comment about the missing
    # -nocase option explains.
    #
    # Arguments:
    #   listVarName -- The name, in the caller's frame, of the list variable to
    #                  which the element may be appended.
    #   element     -- The path string to append if it is not already present
    #                  (case-insensitively) in the list.
    #
    # Results:
    #   An empty string is returned; the procedure is invoked for the side
    #   effect of possibly appending to the caller's list.
    # </help>

    upvar 1 $listVarName list

    if {[isTclTk]} then {
      if {[lsearch -variable -exact -nocase list $element] == -1} then {
        lappend list $element
      }
    } else {
      if {[info exists ::tcl_version] && $::tcl_version >= 8.5} then {
        if {![info exists list] || \
            [lsearch -exact -nocase $list $element] == -1} then {
          lappend list $element
        }
      } else {
        if {![info exists list] || [lsearch -exact [string \
            tolower $list] [string tolower $element]] == -1} then {
          lappend list $element
        }
      }
    }

    return ""
  }

  #
  # NOTE: This procedure attempts to find files and directories within a
  #       specific parent directory.  It can optionally use recursion to
  #       traverse into sub-directories matching a specific pattern.  It
  #       can find visible items, hidden items, or both.  To find both,
  #       an empty string should be passed for the "hidden" argument.
  #
  proc findViaGlob {
          directory traversePattern wantPattern wantDirs wantFiles hidden
          recursive allowEmpty allowFiltered {callback ""} } {
    # <help>
    # This procedure finds files and/or directories beneath a parent directory
    # using [glob], optionally recursing into matching sub-directories, and
    # returns the list of matches.  It is the [glob]-based engine that backs
    # the public finder procedures in this file and is the portable
    # alternative to the command-shell approach in [findViaComSpecDir].  It can
    # locate visible items, hidden items, or both, and supports an optional
    # caller callback that can inspect and accept or reject each candidate.
    #
    # How it works: it first decides whether there is anything worth searching
    # for, honoring the allow-empty and allow-filtered flags so that an empty
    # want-pattern or a want-pattern consisting only of the special dot entries
    # can be short-circuited.  It then obtains the visible and hidden glob type
    # selectors via [populateTypesForGlob] and iterates over the visible and
    # hidden categories.  For each category it consults the hidden argument to
    # decide whether that category is wanted.  When recursion is enabled and a
    # non-empty traversal pattern is supplied, it globs for matching sub-
    # directories of the requested visibility and then calls itself on each one
    # with the same parameters, accumulating their results.  Within the current
    # directory it then globs for the want-pattern: when directories are wanted
    # it gathers matching directories, and when files are wanted it gathers
    # matching files.  If no callback is supplied, matches are appended
    # directly; if a callback is supplied, it is invoked for each match and
    # only those it approves are appended.
    #
    # Tricky details: each glob is wrapped in [catch] so that a failure to list
    # one directory does not abort the whole search.  The recursion uses the
    # traversal pattern to choose which sub-directories to descend into, which
    # is independent of the want-pattern used to select the items ultimately
    # returned.  The hidden argument is overloaded: an empty string means "both
    # visible and hidden", whereas a boolean-like string restricts the search
    # to one category (matched against the per-category flag using a string-
    # class check).  The callback is invoked with itself as its own first
    # argument, followed by the category, the kind (directory or file), and the
    # element; it must return a boolean-like value indicating acceptance.
    # Results are simply concatenated as the recursion unwinds, so ordering
    # follows the traversal and no global de-duplication is performed.
    #
    # Arguments:
    #   directory       -- The parent directory to search within.
    #   traversePattern -- The pattern used to select sub-directories to
    #                      recurse into; only consulted when recursion is
    #                      enabled, and ignored when empty.
    #   wantPattern     -- The pattern used to select the items to return.  An
    #                      empty pattern selects nothing unless allowEmpty
    #                      permits the search to proceed.
    #   wantDirs        -- Boolean-like; when true, matching directories are
    #                      included in the results.
    #   wantFiles       -- Boolean-like; when true, matching files are included
    #                      in the results.
    #   hidden          -- Empty string to include both visible and hidden
    #                      items; otherwise a boolean-like value selecting only
    #                      hidden (true) or only visible (false) items.
    #   recursive       -- Boolean-like; when true, the search descends into
    #                      sub-directories matching the traversal pattern.
    #   allowEmpty      -- Boolean-like; when true, the search proceeds even if
    #                      the want-pattern is empty.
    #   allowFiltered   -- Boolean-like; when true, the search proceeds even if
    #                      the want-pattern would be entirely removed by the
    #                      dot-entry filtering.
    #   callback        -- Optional.  A command prefix invoked for each
    #                      candidate (with itself, the category, the kind, and
    #                      the element appended) that must return a boolean-like
    #                      acceptance value.  When empty, every match is
    #                      accepted.
    #
    # Results:
    #   A list of the matching paths (directories and/or files as requested,
    #   across the requested visibility categories and any recursion); the
    #   empty list if nothing matched or the search was short-circuited.
    # </help>

    set result [list]

    if {($allowEmpty || [string length $wantPattern] > 0) && \
        ($allowFiltered || [llength [filterForGlob [list \
        $wantPattern]]] > 0)} then {
      populateTypesForGlob dirTypes fileTypes

      foreach type [list visible hidden] {
        set wantHidden [expr {
          $type eq "hidden" ? "true" : "false"
        }]

        if {[string length $hidden] == 0 || \
            [string is $wantHidden -strict $hidden]} then {
          if {$recursive && \
              [string length $traversePattern] > 0 && \
              [info exists dirTypes($type)]} then {
            if {[catch {
              performGlob $dirTypes($type) $directory \
                  $traversePattern
            } list] == 0} then {
              foreach subDirectory $list {
                eval lappend result [findViaGlob \
                    $subDirectory $traversePattern \
                    $wantPattern $wantDirs $wantFiles \
                    $hidden $recursive $allowEmpty \
                    $allowFiltered $callback]
              }
            }
          }

          if {[string length $wantPattern] > 0} then {
            if {$wantDirs && \
                [info exists dirTypes($type)]} then {
              if {[catch {
                performGlob $dirTypes($type) $directory \
                    $wantPattern
              } list] == 0} then {
                if {[string length $callback] == 0} then {
                  eval lappend result $list
                } else {
                  foreach element $list {
                    if {[$callback $callback \
                        $type directory $element]} then {
                      lappend result $element
                    }
                  }
                }
              }
            }

            if {$wantFiles && \
                [info exists fileTypes($type)]} then {
              if {[catch {
                performGlob $fileTypes($type) $directory \
                    $wantPattern
              } list] == 0} then {
                if {[string length $callback] == 0} then {
                  eval lappend result $list
                } else {
                  foreach element $list {
                    if {[$callback $callback \
                        $type file $element]} then {
                      lappend result $element
                    }
                  }
                }
              }
            }
          }
        }
      }
    }

    return $result
  }

  #
  # NOTE: This procedure attempts to find files and directories within a
  #       specific parent directory.  It can optionally use recursion to
  #       traverse into sub-directories matching a specific pattern.  It
  #       can find visible items, hidden items, or both.  To find both,
  #       an empty string should be passed for the "hidden" argument.
  #
  proc findViaComSpecDir {
          directory pattern wantDirs wantFiles hidden recursive
          allowEmpty allowFiltered } {
    # <help>
    # This procedure finds files and/or directories beneath a parent directory
    # by shelling out to the "dir" command of the Windows command shell, and
    # returns the list of matches.  It is the command-shell counterpart to
    # [findViaGlob] and exists because, on Windows, driving "dir" can be faster
    # or more capable for certain large or deep searches than repeated [glob]
    # calls.  Like its sibling it can locate visible items, hidden items, or
    # both, and it can optionally recurse into sub-directories.
    #
    # How it works: it first verifies via [canUseComSpecDir] that the command-
    # shell approach is permitted, and applies the same allow-empty and allow-
    # filtered short-circuit checks used elsewhere.  It builds the set of
    # visibility categories to search from the hidden argument (an empty string
    # meaning both, a boolean-like value selecting one), and the set of item
    # kinds from the wantDirs and wantFiles flags.  It obtains the "dir"
    # attribute switches from [populateTypesForComSpecDir], then for each
    # combination of category and kind it assembles an [exec] command that
    # invokes the command processor named by the environment.  That command
    # changes into the target directory when one is given, runs "dir" in bare
    # mode with the appropriate attribute switch (adding the recurse switch when
    # recursion is requested) and the pattern, and captures the output.  Each
    # non-empty output line is trimmed, passed through [getDirResultPath] to
    # resolve it, and appended via [maybeAppendPathResult] so duplicates are
    # avoided.
    #
    # Tricky details: under TclTk the command is built with options that
    # request Unicode handling (both for [exec] itself and via a command-
    # processor switch) and directory and pattern arguments are wrapped in
    # quote characters and converted to native form; under Tcl the native forms
    # are passed unquoted.  The directory change is skipped when the directory
    # is empty or is one of the special dot entries.  The whole command is run
    # under [catch], so a failure of any one invocation is tolerated and simply
    # yields no additions for that combination.  When the trace runtime option
    # is enabled the assembled command is logged via [tclLogForCommand].  Under
    # TclTk the result and path variables are marked for fast access as a
    # performance optimization.  Because results are merged with
    # [maybeAppendPathResult], the final list is de-duplicated case-
    # insensitively, unlike the output of [findViaGlob].
    #
    # Arguments:
    #   directory     -- The parent directory to search within; when empty or a
    #                    dot entry, no directory change is performed.
    #   pattern       -- The pattern passed to the "dir" command to select
    #                    matching items.
    #   wantDirs      -- Boolean-like; when true, directories are searched for.
    #   wantFiles     -- Boolean-like; when true, files are searched for.
    #   hidden        -- Empty string to include both visible and hidden items;
    #                    otherwise a boolean-like value selecting only hidden
    #                    (true) or only visible (false) items.
    #   recursive     -- Boolean-like; when true, the "dir" command is told to
    #                    recurse into sub-directories.
    #   allowEmpty    -- Boolean-like; when true, the search proceeds even if
    #                    the pattern is empty.
    #   allowFiltered -- Boolean-like; when true, the search proceeds even if
    #                    the pattern would be entirely removed by the dot-entry
    #                    filtering.
    #
    # Results:
    #   A case-insensitively de-duplicated list of the matching paths; the
    #   empty list if nothing matched, the command-shell approach was not
    #   permitted, or the search was short-circuited.
    # </help>

    set result [list]

    if {[canUseComSpecDir $pattern] && ($allowEmpty || [string length \
        $pattern] > 0) && ($allowFiltered || [llength [filterForGlob \
        [list $pattern]]] > 0)} then {
      set path ""

      if {[isTclTk]} then {
        makeVariableFast result true; makeVariableFast path true
      }

      set types [list]

      if {[string length $hidden] > 0} then {
        if {[string is false -strict $hidden]} then {
          lappend types visible
        }

        if {[string is true -strict $hidden]} then {
          lappend types hidden
        }
      } else {
        lappend types visible hidden
      }

      set subTypes [list]

      if {$wantDirs} then {lappend subTypes directory}
      if {$wantFiles} then {lappend subTypes file}

      populateTypesForComSpecDir dirTypes fileTypes

      foreach type $types {
        foreach subType $subTypes {
          set wantVarName [expr {
            $subType eq "directory" ? \
                [appendArgs dirTypes( $type )] : \
                [appendArgs fileTypes( $type )]
          }]

          if {[info exists $wantVarName]} then {
            set command [list exec]

            if {[isTclTk]} then {lappend command -unicode}

            lappend command $::env(ComSpec)
            if {[isTclTk]} then {lappend command /u}
            lappend command /c

            if {[string length $directory] > 0 && \
                [lsearch -exact [list . ..] $directory] == -1} then {
              lappend command cd

              if {[isTclTk]} then {
                lappend command [appendArgs \
                    \" [file nativename $directory] \"]
              } else {
                lappend command [file nativename $directory]
              }

              lappend command &&
            }

            lappend command dir /b
            if {$recursive} then {lappend command /s}
            lappend command [set $wantVarName]

            if {[string length $pattern] > 0} then {
              if {[isTclTk]} then {
                lappend command [appendArgs \
                    \" [file nativename $pattern] \"]
              } else {
                lappend command [file nativename $pattern]
              }
            }

            if {[hasRuntimeOption traceFindViaComSpecDir]} then {
              tclLogForCommand $command
            }

            if {[catch $command exec] == 0} then {
              foreach path [split $exec \n] {
                set path [string trim $path]

                if {[string length $path] > 0} then {
                  set path [getDirResultPath $pattern $path]
                  maybeAppendPathResult result $path
                }
              }
            }
          }
        }
      }
    }

    return $result
  }

  #
  # NOTE: This procedure may return directory name information that may be
  #       present in the specified pattern.  If the directory name does not
  #       represent an absolute path, an empty string is returned instead.
  #       This procedure is explicitly designed to allow overriding via
  #       external scripts.
  #
  proc fileDirNameForFind { pattern } {
    # <help>
    # This procedure extracts the directory-name portion of a search pattern,
    # but only when that portion denotes an absolute path; otherwise it returns
    # the empty string.  It exists so that the public finder procedures can
    # split a caller-supplied pattern into a directory to search in and a tail
    # to match, while refusing to commit to a relative directory whose meaning
    # would be ambiguous.  It is explicitly designed to allow overriding via
    # external scripts.
    #
    # How it works: it takes the directory name of the pattern with [file
    # dirname].  If that result is non-empty and its path type is absolute, it
    # is returned; otherwise the empty string is returned.
    #
    # Arguments:
    #   pattern -- The search pattern, possibly including a leading directory
    #              component.
    #
    # Results:
    #   The absolute directory-name portion of the pattern, or the empty string
    #   if the pattern has no directory component or that component is not
    #   absolute.
    # </help>

    set result [file dirname $pattern]

    if {[string length $result] > 0 && \
        [file pathtype $result] eq "absolute"} then {
      return $result
    }

    return ""
  }

  #
  # NOTE: This procedure returns the file name portion that may be present
  #       in the specified pattern.  This procedure is explicitly designed
  #       to allow overriding via external scripts.
  #
  proc fileTailForFind { pattern } {
    # <help>
    # This procedure returns the file-name (tail) portion of a search pattern.
    # It is the companion to [fileDirNameForFind]: where that procedure yields
    # the absolute directory to search in, this one yields the pattern to match
    # within it.  It exists so the public finder procedures can separate a
    # caller-supplied pattern into its directory and tail parts consistently.
    # It is explicitly designed to allow overriding via external scripts.
    #
    # How it works: only when the pattern is non-empty and its path type is
    # absolute does it strip the leading directory and return just the tail via
    # [file tail].  In every other case it returns the pattern unchanged, on
    # the assumption that a relative or directory-less pattern is already the
    # tail to match.
    #
    # Tricky details: the absolute-versus-other handling here mirrors that of
    # [fileDirNameForFind]; together they ensure that splitting an absolute
    # pattern produces a directory plus a tail, while a relative pattern is
    # treated wholly as the tail with an empty directory.
    #
    # Arguments:
    #   pattern -- The search pattern, possibly including a leading directory
    #              component.
    #
    # Results:
    #   The tail (file-name) portion of an absolute pattern, or the pattern
    #   itself when it is empty or not absolute.
    # </help>

    if {[string length $pattern] > 0 && \
        [file pathtype $pattern] eq "absolute"} then {
      return [file tail $pattern]
    }

    return $pattern
  }

  #
  # NOTE: This procedure returns a list of directories matching the pattern
  #       specified.  It does not recurse into sub-directories.
  #
  proc findDirectories { pattern } {
    # <help>
    # This procedure returns the list of directories that match the specified
    # pattern, without recursing into sub-directories.  It is one of the public
    # entry points of the file-finder package and exists to give callers a
    # simple, engine-independent way to enumerate directories, while internally
    # choosing the most appropriate search mechanism.
    #
    # How it works: it selects among three strategies.  When running under
    # TclTk and neither the general nor the directory-specific opt-out flag is
    # set, it uses [findViaComSpecDir] when the command-shell approach is
    # available and the glob-based finder has not been explicitly requested via
    # a runtime option, and otherwise (or when that option is set) it uses
    # [findViaGlob]; in either case the pattern is split into a directory and
    # tail using [fileDirNameForFind] and [fileTailForFind].
    # Otherwise (under Tcl, or when the TclTk finders are opted out) it uses
    # [findViaComSpecDir] only if the command shell is available and that
    # runtime option is set, and as a final fallback performs the search
    # directly with [glob]: it obtains the visible and hidden directory type
    # selectors via [populateTypesForGlob], globs for each, filters each result
    # through [filterForGlob], and concatenates them.
    #
    # Tricky details: the recursion-free behavior is what distinguishes this
    # from [findDirectoriesRecursive]; the underlying finders are invoked with
    # their recursion flag disabled and an asterisk traversal pattern that is
    # not actually descended into.  The various opt-out flags (global "no"
    # array elements) and runtime options let callers steer which mechanism is
    # used without changing this procedure.
    #
    # Arguments:
    #   pattern -- The pattern (optionally including an absolute directory
    #              component) identifying the directories to match.
    #
    # Results:
    #   A list of matching directory paths; the empty list if none match.
    # </help>

    if {![info exists ::no(findForTclTk)] && \
        ![info exists ::no(findDirectoriesForTclTk)] && \
        [isTclTk]} then {
      if {![canUseComSpecDir $pattern] || \
          [hasRuntimeOption findViaGlob]} then {
        return [findViaGlob \
            [fileDirNameForFind $pattern] * \
            [fileTailForFind $pattern] \
            true false "" false false false]
      } else {
        return [findViaComSpecDir \
            [fileDirNameForFind $pattern] \
            $pattern true false "" false \
            false false]
      }
    } else {
      if {[canUseComSpecDir $pattern] && \
          [hasRuntimeOption findViaComSpecDir]} then {
        return [findViaComSpecDir \
            [fileDirNameForFind $pattern] \
            $pattern true false "" false \
            false false]
      } else {
        populateTypesForGlob dirTypes fileTypes

        set result [list]

        eval lappend result [filterForGlob [glob -nocomplain \
            -types $dirTypes(visible) [fileNormalizeForGlob \
            $pattern]]]

        eval lappend result [filterForGlob [glob -nocomplain \
            -types $dirTypes(hidden) [fileNormalizeForGlob \
            $pattern]]]

        return $result
      }
    }
  }

  #
  # NOTE: This procedure returns a list of directories matching the pattern
  #       specified.  It recurses into sub-directories.
  #
  proc findDirectoriesRecursive { pattern } {
    # <help>
    # This procedure returns the list of directories that match the specified
    # pattern, recursing into sub-directories.  It is the recursive counterpart
    # to [findDirectories] and exists to enumerate an entire directory subtree
    # in one call.
    #
    # How it works: it chooses between the two finder engines based on
    # availability and runtime options.  If the command-shell approach is
    # unavailable for the pattern, or the glob-based finder has been explicitly
    # requested, it calls [findViaGlob] with recursion enabled, splitting the
    # pattern via [fileDirNameForFind] and [fileTailForFind] and passing an
    # asterisk as the traversal pattern so that all sub-directories are
    # descended into.  Otherwise it calls [findViaComSpecDir] with recursion
    # enabled.
    #
    # Tricky details: the only meaningful difference from [findDirectories] is
    # that the recursion flag is enabled here, which is also why the glob path
    # supplies a real traversal pattern; the directory and file selection
    # arguments still request directories only.
    #
    # Arguments:
    #   pattern -- The pattern (optionally including an absolute directory
    #              component) identifying the directories to match throughout
    #              the subtree.
    #
    # Results:
    #   A list of matching directory paths found anywhere within the searched
    #   subtree; the empty list if none match.
    # </help>

    if {![canUseComSpecDir $pattern] || \
        [hasRuntimeOption findViaGlob]} then {
      return [findViaGlob \
          [fileDirNameForFind $pattern] * \
          [fileTailForFind $pattern] \
          true false "" true false false]
    } else {
      return [findViaComSpecDir \
          [fileDirNameForFind $pattern] \
          $pattern true false "" true \
          false false]
    }
  }

  #
  # NOTE: This procedure returns a list of files matching the pattern
  #       specified.  It does not recurse into sub-directories.
  #
  proc findFiles { pattern } {
    # <help>
    # This procedure returns the list of files that match the specified
    # pattern, without recursing into sub-directories.  It is the file-oriented
    # public entry point of the finder package and the direct analogue of
    # [findDirectories], differing only in that it selects files rather than
    # directories.
    #
    # How it works: the strategy selection mirrors [findDirectories].  Under
    # TclTk, absent the general and the file-specific opt-out flags, it uses
    # [findViaComSpecDir] when the command shell is available and the
    # glob-based finder has not been explicitly requested via a runtime option,
    # and otherwise (or when that option is set) it uses [findViaGlob]; the
    # pattern is split with [fileDirNameForFind] and [fileTailForFind].
    # Otherwise it uses [findViaComSpecDir] when the command shell is available
    # and requested, and as a final fallback searches directly with [glob],
    # obtaining the visible and hidden file type selectors from
    # [populateTypesForGlob], globbing for each, filtering each result through
    # [filterForGlob], and concatenating them.
    #
    # Tricky details: as with [findDirectories], the recursion flag is disabled
    # here; the underlying finders receive want-directory false and want-file
    # true so that only files are returned.  The opt-out flags and runtime
    # options control which mechanism is used.
    #
    # Arguments:
    #   pattern -- The pattern (optionally including an absolute directory
    #              component) identifying the files to match.
    #
    # Results:
    #   A list of matching file paths; the empty list if none match.
    # </help>

    if {![info exists ::no(findForTclTk)] && \
        ![info exists ::no(findFilesForTclTk)] && \
        [isTclTk]} then {
      if {![canUseComSpecDir $pattern] || \
          [hasRuntimeOption findViaGlob]} then {
        return [findViaGlob \
            [fileDirNameForFind $pattern] * \
            [fileTailForFind $pattern] false \
            true "" false false false]
      } else {
        return [findViaComSpecDir \
            [fileDirNameForFind $pattern] \
            $pattern false true "" false \
            false false]
      }
    } else {
      if {[canUseComSpecDir $pattern] && \
          [hasRuntimeOption findViaComSpecDir]} then {
        return [findViaComSpecDir \
            [fileDirNameForFind $pattern] \
            $pattern false true "" false \
            false false]
      } else {
        populateTypesForGlob dirTypes fileTypes

        set result [list]

        eval lappend result [filterForGlob [glob -nocomplain \
            -types $fileTypes(visible) [fileNormalizeForGlob \
            $pattern]]]

        eval lappend result [filterForGlob [glob -nocomplain \
            -types $fileTypes(hidden) [fileNormalizeForGlob \
            $pattern]]]

        return $result
      }
    }
  }

  #
  # NOTE: This procedure returns a list of files matching the pattern
  #       specified.  It recurses into sub-directories.
  #
  proc findFilesRecursive { pattern } {
    # <help>
    # This procedure returns the list of files that match the specified
    # pattern, recursing into sub-directories.  It is the recursive counterpart
    # to [findFiles] and the file-oriented analogue of
    # [findDirectoriesRecursive], used to enumerate matching files throughout a
    # directory subtree in one call.
    #
    # How it works: if the command-shell approach is unavailable for the
    # pattern, or the glob-based finder has been explicitly requested, it calls
    # [findViaGlob] with recursion enabled, splitting the pattern via
    # [fileDirNameForFind] and [fileTailForFind] and passing an asterisk as the
    # traversal pattern so that every sub-directory is descended into while only
    # files are selected.  Otherwise it calls [findViaComSpecDir] with recursion
    # enabled.
    #
    # Tricky details: the want-directory false and want-file true selection
    # combined with the enabled recursion flag is what makes this find files
    # anywhere in the subtree; the traversal pattern controls descent, separate
    # from the pattern used to match the files themselves.
    #
    # Arguments:
    #   pattern -- The pattern (optionally including an absolute directory
    #              component) identifying the files to match throughout the
    #              subtree.
    #
    # Results:
    #   A list of matching file paths found anywhere within the searched
    #   subtree; the empty list if none match.
    # </help>

    if {![canUseComSpecDir $pattern] || \
        [hasRuntimeOption findViaGlob]} then {
      return [findViaGlob \
          [fileDirNameForFind $pattern] * \
          [fileTailForFind $pattern] false \
          true "" true false false]
    } else {
      return [findViaComSpecDir \
          [fileDirNameForFind $pattern] \
          $pattern false true "" true \
          false false]
    }
  }

  #
  # NOTE: This procedure attempts to copy all files matching the specified
  #       source directory and patterns to the destination directory.  This
  #       procedure may raise script errors.
  #
  proc copyFilesRecursive {
          sourceDirectory targetDirectory {patterns ""} {options ""} } {
    # <help>
    # This procedure recursively copies files matching one or more patterns
    # from a source directory tree to a target directory tree, driving the
    # Windows Robocopy utility to do the actual work.  It exists to give TclTk
    # and Tcl scripts a robust, restartable bulk-copy facility (with retry,
    # metadata, and logging controls) without having to assemble Robocopy
    # command lines by hand.  Because it relies on Robocopy, it is Windows
    # specific.  It may raise script errors.
    #
    # How it works: it first refuses to run on non-Windows platforms.  It then
    # assembles an [exec] command that invokes Robocopy, capturing the exit
    # code on TclTk.  The native forms of the source and target directories are
    # added as the always-required first two arguments (quoted under TclTk).
    # Any supplied file patterns are appended; when none are given Robocopy's
    # own default (all files) applies.  Unless suppressed, a standard set of
    # options is added: copy subdirectories including empty ones, use
    # restartable mode (and, when running as administrator under TclTk, backup
    # mode plus copy-all metadata), and preserve directory timestamps.  The
    # per-file retry count can be overridden through an option of the form that
    # embeds a non-negative integer; an explicit retry option leaves Robocopy's
    # default in place, while otherwise retries are disabled by setting the
    # count to zero.  By default file-system junctions are excluded to prevent
    # infinite traversal loops, the target is not purged, and verbose logging
    # to a temporary file is disabled; each of these defaults can be toggled by
    # an option.  When the trace runtime option is enabled the assembled
    # command is logged via [tclLogForCommand].  Finally the command is
    # executed and its success is judged by the Robocopy exit code: Robocopy
    # reports success for codes between zero and seven and failure for eight or
    # greater, so on success the captured output (the copy summary or the log
    # file name) is returned, and on failure a script error is raised that
    # includes the command and the captured output.
    #
    # Tricky details: the meaning of the Robocopy exit code is the crux of the
    # success determination -- codes up to seven indicate informational results
    # rather than errors, which is why they are accepted.  Under TclTk the exit
    # code is obtained directly from the captured exit-code variable and matched
    # against an accepted set; under Tcl the command is run inside [catch] and,
    # on a caught failure, the exit code is recovered from the global error-code
    # information via [maybeGetExitCode] and compared against the failure
    # threshold.  The retry option value is validated with a regular expression
    # and a non-negative-integer check, and an invalid value raises an error
    # rather than being silently ignored.  Junction exclusion is on by default
    # specifically because junctions make it trivial to build directory trees
    # that loop back on themselves.  Enabling logging pulls in the TclTk test
    # package to obtain a temporary file name.  Native path conversion and
    # quoting differ between TclTk and Tcl throughout.
    #
    # Arguments:
    #   sourceDirectory -- The directory tree to copy files from.  Required.
    #   targetDirectory -- The directory tree to copy files into.  Required.
    #   patterns        -- Optional.  A list of file-name patterns selecting
    #                      which files to copy; when empty, Robocopy copies all
    #                      files by default.
    #   options         -- Optional.  A list of behavior flags.  Recognized
    #                      flags suppress the default copy options, suppress
    #                      subdirectory copying, override or retain the retry
    #                      count (including a colon-prefixed form carrying an
    #                      integer count), include junctions, purge extra files
    #                      from the target, and enable verbose logging to a
    #                      temporary file.
    #
    # Results:
    #   On success (a Robocopy exit code in the accepted range), the captured
    #   Robocopy output -- typically the copy summary and details, or the log
    #   file name when logging is enabled.  On failure, a script error is
    #   raised; this procedure is also an error if invoked on a non-Windows
    #   platform or with an invalid retry count.
    # </help>

    #
    # NOTE: Block non-Windows platforms since this is Windows specific.
    #
    if {![isWindows]} then {
      error "not supported on this operating system"
    }

    #
    # NOTE: Start out with the [exec] command and the necessary options
    #       to the command.
    #
    if {[isTclTk]} then {
      set command [list exec -exitcode exitCode -- robocopy]
    } else {
      set command [list exec -- robocopy]
    }

    #
    # NOTE: Add the source and target directory names.  These are always
    #       required.
    #
    if {[isTclTk]} then {
      lappend command [appendArgs \" [file nativename $sourceDirectory] \"]
      lappend command [appendArgs \" [file nativename $targetDirectory] \"]
    } else {
      lappend command [file nativename $sourceDirectory]
      lappend command [file nativename $targetDirectory]
    }

    #
    # NOTE: If there are patterns specified, add them now.  By default,
    #       all files are copied (i.e. "*.*").
    #
    if {[llength $patterns] > 0} then {
      eval lappend command $patterns
    }

    #
    # NOTE: Should the default Robocopy options be excluded?  Generally,
    #       these options should not be excluded.  All matching files
    #       are copied, using restartable mode, and using extra options
    #       when running as administrator to enable copying more files
    #       and metadata, e.g. using backup mode and copying the extra
    #       file security information.
    #
    if {[lsearch -exact $options -nocopyopts] == -1} then {
      if {[lsearch -exact $options -nosubdirs] == -1} then {
        lappend command /E
      }

      if {[isTclTk] && [isAdministrator]} then {
        lappend command /ZB /COPYALL
      } else {
        lappend command /Z
      }

      lappend command /DCOPY:T
    }

    #
    # NOTE: Should we override the default number of retries per file?
    #       If no retry related option is found, the Robocopy default
    #       behavior will be used (i.e. 1 million retries per file).
    #
    if {[set index [lsearch -glob $options -retries:*]] != -1} then {
      #
      # NOTE: Grab the retry option name/value from the list of options
      #       and attempt to extract the integer number of retries from
      #       it.
      #
      set value [lindex $options $index]

      if {[regexp -- {^-retries:(\d+)$} $value dummy retries] && \
          [string is integer -strict $retries] && $retries >= 0} then {
        #
        # NOTE: Use the specified number of retries.  This value will
        #       be greater than or equal to zero and within the range
        #       of a 32-bit integer.
        #
        lappend command [appendArgs /R: $retries]
      } else {
        #
        # NOTE: The specified number of retries is somehow invalid.
        #
        error "number of retries must be a positive integer"
      }
    } elseif {[lsearch -exact $options -retry] == -1} then {
      #
      # NOTE: Fallback to setting retry count to zero, which is used
      #       to disable per-file retries.
      #
      lappend command /R:0
    }

    #
    # NOTE: By default, do not process file system junctions.  This
    #       is used to avoid the possibility of infinite loops when
    #       traversing the file system (i.e. because it is trivial
    #       to utilize file system junctions in order to construct
    #       directory trees that loop back upon themselves).
    #
    if {[lsearch -exact $options -junctions] == -1} then {
      lappend command /XJ
    }

    #
    # NOTE: By default, do not purge any files that happen to be in
    #       the target directory.
    #
    if {[lsearch -exact $options -purge] != -1} then {
      lappend command /PURGE
    }

    #
    # NOTE: By default, do not produce a verbose log files in the
    #       temporary directory.
    #
    if {[lsearch -exact $options -logging] != -1} then {
      lappend command /X /V /FP /NP

      package require TclTk.Test
      set logFileName [getTemporaryFileName]

      if {[isTclTk]} then {
        lappend command [appendArgs \
            \"/LOG: [file nativename $logFileName] \"]
      } else {
        lappend command [appendArgs \
            /LOG: [file nativename $logFileName]]
      }
    }

    #
    # NOTE: Optionally emit trace to log all our command arguments.
    #
    if {[hasRuntimeOption traceCopyFilesRecursive]} then {
      tclLogForCommand $command
    }

    #
    # NOTE: Upon success, the exit code from Robocopy will be between
    #       zero and seven.  If the exit code is eight or greater, it
    #       has somehow failed and that error must be reported to the
    #       caller via raising a script error.
    #
    if {[isTclTk]} then {
      #
      # NOTE: Execute the resulting [exec] command in our context and
      #       capture the results.
      #
      set result [eval $command]

      if {[info exists exitCode] && $exitCode in \
          [list Success Failure Exception 0 1 2 3 4 5 6 7]} then {
        #
        # NOTE: Return the captured output from the Robocopy command,
        #       whatever it was.  Generally, this will either be the
        #       summary and details of the files copied -OR- the log
        #       file name.
        #
        return $result
      } else {
        #
        # NOTE: Raise a script error, using the captured errors from
        #       the Robocopy command, whatever it was.
        #
        error [appendArgs \
            "command \"" $command "\" error: " $result]
      }
    } else {
      #
      # NOTE: Execute the resulting [exec] command in our context and
      #       capture the results.
      #
      if {[catch $command result] == 0 || ([info exists ::errorCode] && \
          [maybeGetExitCode $::errorCode 8] < 8)} then {
        #
        # NOTE: Return the captured output from the Robocopy command,
        #       whatever it was.  Generally, this will either be the
        #       summary and details of the files copied -OR- the log
        #       file name.
        #
        return $result
      } else {
        #
        # NOTE: Raise a script error, using the captured errors from
        #       the Robocopy command, whatever it was.
        #
        error [appendArgs \
            "command \"" $command "\" error: " $result]
      }
    }
  }

  #
  # NOTE: Provide the TclTk "file finder" package to the interpreter.
  #
  package provide TclTk.File.Finder \
    [expr {[isTclTk] ? [info engine PatchLevel] : "1.0"}]
}
