#
# NOTE: Use our own namespace here because even though we do not directly
#       support namespaces ourselves, we do not want to pollute the global
#       namespace if this script actually ends up being evaluated in Tcl.
#
namespace eval ::TclTk {
  #
  # NOTE: This procedure locks the specified variable in the call frame of
  #       the caller while it evaluates the specified script, also in the
  #       context of the caller.
  #
  proc vwaitLocked { varName isArray script } {
    # <help>
    # This procedure evaluates a script in the caller's context while holding
    # an exclusive lock on a specified variable, so that the script may read
    # and modify that variable without interference from other threads.  It
    # exists because TclTk variables can be shared across threads, and code
    # that performs a read-modify-write on a shared variable (such as the test
    # log queue) needs to do so atomically.  Under native Tcl, where this
    # cross-thread locking does not apply, it degrades gracefully to simply
    # evaluating the script.
    #
    # How it works: in TclTk, it uses [vwait] with the -force and -locked
    # options to acquire a lock on the named variable and run the script while
    # that lock is held.  There is a complication, however: when the variable
    # is currently locked by another thread, [info exists] may report that it
    # does not exist.  To keep [vwait -locked] from waiting forever for a
    # variable that will never appear, the procedure first attempts to create
    # the variable (as an empty array when isArray is true, or as an empty
    # scalar otherwise) when it appears not to exist.  That creation is wrapped
    # in [catch] because it will legitimately fail if another thread holds the
    # lock; either outcome is acceptable.  Under native Tcl, none of this
    # applies and the script is simply evaluated directly.  In all cases the
    # script and the helper operations run in the immediate caller's frame via
    # [uplevel 1].
    #
    # Arguments:
    #   varName -- The name of the variable to lock (and, in TclTk, to wait
    #              on) while the script runs.  It is resolved in the caller's
    #              context.
    #   isArray -- A boolean-like value indicating whether the variable is an
    #              array; this governs how the variable is pre-created when it
    #              appears not to exist.  An empty string suppresses the
    #              pre-creation step.
    #   script  -- The script to evaluate in the caller's context while the
    #              variable is locked.
    #
    # Results:
    #   The result of evaluating the script in the caller's context.
    # </help>

    if {[isTclTk]} then {
      #
      # HACK: The [info exists] sub-command may return false even if the
      #       variable exists, *IF* that variable is currently locked by
      #       another thread.
      #
      if {[string length $isArray] > 0 && \
          ![uplevel 1 [list info exists $varName]]} then {
        #
        # BUGFIX: If another thread has the variable locked, this could
        #         fail.  That would be bad because the caller wishes to
        #         block until the variable is available.
        #
        if {$isArray} then {
          catch {
            #
            # HACK: This will either create the array variable without
            #       elements -OR- fail because the variable has been
            #       locked by another thread; either way, that's fine.
            #
            uplevel 1 [list array set $varName [list]]
          }
        } else {
          catch {
            #
            # HACK: This will either create the scalar variable with an
            #       empty value -OR- fail because the variable has been
            #       locked by another thread; either way, that's fine.
            #
            uplevel 1 [list set $varName ""]
          }
        }
      }

      uplevel 1 [list vwait -force -locked $script -- $varName]
    } else {
      uplevel 1 $script
    }
  }

  #
  # NOTE: This procedure emits a message to the specified channel and adds
  #       it to the test log queue.
  #
  proc tqputs { channel string } {
    # <help>
    # This procedure emits a string to an output channel and simultaneously
    # adds that same string to the test log queue.  It is a convenience used
    # by the test harness so that a single call both shows a message (for
    # example, on the console) and records it for eventual inclusion in the
    # test log file.  The channel is optional: passing an empty string
    # suppresses the immediate output while still queueing the message.
    #
    # How it works: if the channel argument is a non-empty string, the message
    # is written to it with [puts -nonewline] (so the caller controls any line
    # breaks).  Regardless of whether anything was written to the channel, the
    # message is then passed to [tqlog], which appends it to the in-memory test
    # log queue for later flushing to the test log file.
    #
    # Arguments:
    #   channel -- The output channel to write the message to, or an empty
    #              string to skip the immediate output and only queue the
    #              message.
    #   string  -- The message to emit and queue.
    #
    # Results:
    #   The result of the [tqlog] call (an empty string).
    # </help>

    #
    # NOTE: If an output channel was provided, use it; otherwise, ignore
    #       the message.
    #
    if {[string length $channel] > 0} then {
      puts -nonewline $channel $string
    }

    tqlog $string
  }

  #
  # NOTE: This procedure adds a message to the test log queue.  It will be
  #       written to the test log file the next time the [tlog] procedure
  #       is called.  If the [tlog] procedure is never called, then it will
  #       never be written to the test log file.
  #
  proc tqlog { string } {
    # <help>
    # This procedure appends a message to the in-memory test log queue.  The
    # queued messages are not written to the test log file immediately;
    # instead, they accumulate until the next time the [tlog] procedure (from
    # the test package) is called, at which point [tlog] flushes them into the
    # test log file ahead of its own output.  Consequently, if [tlog] is never
    # called, queued messages are never written to the file.  This deferred
    # mechanism lets library code record diagnostic context that should appear
    # in the log without itself needing access to (or knowledge of) the log
    # file.
    #
    # How it works: an empty message is ignored outright.  Otherwise the
    # special global array "test_log_queue" is updated under a lock (via
    # [vwaitLocked], since this array is shared across threads).  The next
    # available integer entry index is computed -- one past the current array
    # size when the array already exists, or one for the first entry -- and the
    # message is stored at that index.  The "test_log_queue" array is the
    # agreed-upon hand-off point: this procedure's sole job is to populate it
    # for later consumption by the test package.
    #
    # Tricky details: as of beta 47, the use of the "test_log_queue" global is
    # thread-safe by virtue of the [vwaitLocked] wrapper, which serializes the
    # read-modify-write of the array across threads.
    #
    # Arguments:
    #   string -- The message to enqueue.  An empty string is silently
    #             ignored and nothing is queued.
    #
    # Results:
    #   Always an empty string.
    # </help>

    #
    # NOTE: If an empty string is supplied by the caller, do nothing.
    #
    if {[string length $string] > 0} then {
      #
      # NOTE: *SPECIAL* The special global variable "test_log_queue" is used
      #       by the [tlog] script library procedure from the test package to
      #       enable it to emit "queued" data into the test log file prior to
      #       emitting the string requested by its caller.  The only job for
      #       this procedure is to populate the "test_log_queue" variable for
      #       later use by the test package.
      #
      # BUGFIX: As of beta 47, use of the "test_log_queue" global variable is
      #         thread-safe.
      #
      vwaitLocked ::test_log_queue true {
        if {[info exists ::test_log_queue]} then {
          #
          # NOTE: Use the next queued test log entry.
          #
          set entry [expr {[array size ::test_log_queue] + 1}]
        } else {
          #
          # NOTE: Use the first queued test log entry.
          #
          set entry 1
        }

        #
        # NOTE: Add the new entry to the test log queue.  All entries will
        #       be sent to the actual test log file the very next time the
        #       [tlog] command from the test package is executed.
        #
        set ::test_log_queue($entry) $string
      }
    }

    return ""
  }

  #
  # NOTE: Provide the TclTk "test log" package to the interpreter.
  #
  package provide TclTk.Test.Log \
    [expr {[isTclTk] ? [info engine PatchLevel] : "1.0"}]
}
